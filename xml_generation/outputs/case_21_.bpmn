<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_gp_pool" name="General Practitioner" processRef="Process_gp_pool"/>
    <bpmn:participant id="actor_hospital_pool" name="Hospital" processRef="Process_hospital_pool"/>
    <bpmn:messageFlow id="mf1" name="Referral Request" sourceRef="submit_referral" targetRef="start_admissions"/>
    <bpmn:messageFlow id="mf2" name="Incomplete Notice" sourceRef="throw_incomplete" targetRef="catch_incomplete_gp"/>
    <bpmn:messageFlow id="mf3" name="Rejection Notice" sourceRef="throw_rejection" targetRef="catch_rejection_gp"/>
    <bpmn:messageFlow id="mf4" name="Treatment Approval" sourceRef="throw_approval" targetRef="catch_approval_gp"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_gp_pool" name="General Practitioner" isExecutable="false">
    <bpmn:laneSet id="LaneSet_gp_pool">
      <bpmn:lane id="gp" name="General Practitioner">
        <bpmn:flowNodeRef>start_gp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_incomplete_gp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_gp_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_rejection_gp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_gp_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_approval_gp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_gp_approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_referral</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_gp" name="Start"/>
    <bpmn:intermediateCatchEvent id="catch_incomplete_gp" name="Incomplete Notice Received">
      <bpmn:messageEventDefinition id="catch_incomplete_gp_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_gp_incomplete" name="Ended: Incomplete Docs"/>
    <bpmn:intermediateCatchEvent id="catch_rejection_gp" name="Rejection Notice Received">
      <bpmn:messageEventDefinition id="catch_rejection_gp_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_gp_rejected" name="Ended: Referral Rejected"/>
    <bpmn:intermediateCatchEvent id="catch_approval_gp" name="Approval Received">
      <bpmn:messageEventDefinition id="catch_approval_gp_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_gp_approved" name="Ended: Referral Approved"/>
    <bpmn:task id="submit_referral" name="Submit Referral Request"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_gp" targetRef="submit_referral"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="catch_incomplete_gp" targetRef="end_gp_incomplete"/>
    <bpmn:sequenceFlow id="sf22" sourceRef="catch_rejection_gp" targetRef="end_gp_rejected"/>
    <bpmn:sequenceFlow id="sf23" sourceRef="catch_approval_gp" targetRef="end_gp_approved"/>
  </bpmn:process>
  <bpmn:process id="Process_hospital_pool" name="Hospital" isExecutable="false">
    <bpmn:laneSet id="LaneSet_hospital_pool">
      <bpmn:lane id="admissions" name="Admissions Office">
        <bpmn:flowNodeRef>start_admissions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_admissions_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_approval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_admissions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_referral</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="specialist" name="Specialist Department">
        <bpmn:flowNodeRef>medical_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_medical</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="insurance" name="Insurance Office">
        <bpmn:flowNodeRef>verify_coverage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_coverage</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_admissions" name="Referral Received">
      <bpmn:messageEventDefinition id="start_admissions_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateThrowEvent id="throw_incomplete" name="Notify GP of Missing Documents">
      <bpmn:messageEventDefinition id="throw_incomplete_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_admissions_incomplete" name="Incomplete Docs"/>
    <bpmn:intermediateThrowEvent id="throw_rejection" name="Send Rejection Notice">
      <bpmn:messageEventDefinition id="throw_rejection_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_approval" name="Send Treatment Approval">
      <bpmn:messageEventDefinition id="throw_approval_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_admissions" name="Process Complete"/>
    <bpmn:task id="register_referral" name="Register Referral"/>
    <bpmn:task id="check_docs" name="Check Medical Documentation"/>
    <bpmn:task id="review_outcomes" name="Review Combined Verdicts"/>
    <bpmn:task id="medical_assessment" name="Conduct Medical Assessment"/>
    <bpmn:task id="record_medical" name="Record Medical Verdict"/>
    <bpmn:task id="verify_coverage" name="Verify Insurance Coverage"/>
    <bpmn:task id="record_coverage" name="Record Coverage Verdict"/>
    <bpmn:exclusiveGateway id="split_complete" name="Documentation Complete?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward for Review" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Both Verdicts Positive?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_outcome" name="Merge Outcome Paths" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="start_admissions" targetRef="register_referral"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_referral" targetRef="check_docs"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="check_docs" targetRef="split_complete"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="split_complete" targetRef="throw_incomplete" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_complete" targetRef="split_parallel" name="Complete">
      <bpmn:conditionExpression>Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="throw_incomplete" targetRef="end_admissions_incomplete"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="split_parallel" targetRef="medical_assessment"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="split_parallel" targetRef="verify_coverage"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="medical_assessment" targetRef="record_medical"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="record_medical" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="verify_coverage" targetRef="record_coverage"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="record_coverage" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="split_outcome" targetRef="throw_rejection" name="One or more verdicts negative">
      <bpmn:conditionExpression>One or more verdicts negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf17" sourceRef="split_outcome" targetRef="throw_approval" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf18" sourceRef="throw_rejection" targetRef="join_outcome"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="throw_approval" targetRef="join_outcome"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="join_outcome" targetRef="end_admissions"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_gp_pool_di" bpmnElement="actor_gp_pool" isHorizontal="true">
