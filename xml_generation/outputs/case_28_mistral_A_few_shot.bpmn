<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:process id="Process_Zarkan_Industries" name="Zarkan Industries" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Zarkan_Industries">
      <bpmn:lane id="csr" name="CSR">
        <bpmn:flowNodeRef>start_csr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_csr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>analyze_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>consult_departments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>resolve_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>archive_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>close_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_complaint_type</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_complaint_analysis</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_csr" name="Start"/>
    <bpmn:endEvent id="end_csr" name="End"/>
    <bpmn:task id="register_complaint" name="Register Complaint"/>
    <bpmn:task id="analyze_complaint" name="Analyze Complaint"/>
    <bpmn:task id="consult_departments" name="Consult Departments"/>
    <bpmn:task id="resolve_complaint" name="Resolve Complaint"/>
    <bpmn:task id="archive_complaint" name="Archive Complaint"/>
    <bpmn:task id="close_complaint" name="Close Complaint"/>
    <bpmn:exclusiveGateway id="gateway_complaint_type" name="Complaint Type" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_complaint_analysis" name="Analysis Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_csr" targetRef="register_complaint"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="register_complaint" targetRef="gateway_complaint_type"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="gateway_complaint_type" targetRef="analyze_complaint"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="analyze_complaint" targetRef="consult_departments"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="consult_departments" targetRef="gateway_complaint_analysis"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="gateway_complaint_analysis" targetRef="resolve_complaint"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="resolve_complaint" targetRef="archive_complaint"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="archive_complaint" targetRef="close_complaint"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="close_complaint" targetRef="end_csr"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
