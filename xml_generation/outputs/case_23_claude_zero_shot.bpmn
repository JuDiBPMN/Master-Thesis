<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_pool_client" name="Client" processRef="Process_pool_client"/>
    <bpmn:participant id="actor_pool_brightwave" name="BrightWave Energy" processRef="Process_pool_brightwave"/>
    <bpmn:messageFlow id="mf01" name="Complaint email" sourceRef="throw_client_complaint" targetRef="start_cs"/>
    <bpmn:messageFlow id="mf02" name="Explanation email" sourceRef="throw_cs_explanation" targetRef="catch_client_outcome"/>
    <bpmn:messageFlow id="mf03" name="Ticket assignment" sourceRef="throw_cs_ticket" targetRef="catch_invoicing_ticket"/>
    <bpmn:messageFlow id="mf04" name="Corrected invoice" sourceRef="throw_invoicing_invoice" targetRef="catch_client_outcome"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_pool_client" name="Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_pool_client">
      <bpmn:lane id="lane_client" name="Client">
        <bpmn:flowNodeRef>start_client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_client_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_client_outcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_write_complaint</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_client" name="Monthly bill received"/>
    <bpmn:intermediateThrowEvent id="throw_client_complaint" name="Send complaint email">
      <bpmn:messageEventDefinition id="throw_client_complaint_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_client_outcome" name="Receive response from BrightWave">
      <bpmn:messageEventDefinition id="catch_client_outcome_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_client" name="End"/>
    <bpmn:userTask id="task_write_complaint" name="Write complaint email"/>
    <bpmn:sequenceFlow id="sf01" sourceRef="start_client" targetRef="task_write_complaint"/>
    <bpmn:sequenceFlow id="sf02" sourceRef="task_write_complaint" targetRef="throw_client_complaint"/>
    <bpmn:sequenceFlow id="sf03" sourceRef="catch_client_outcome" targetRef="end_client"/>
  </bpmn:process>
  <bpmn:process id="Process_pool_brightwave" name="BrightWave Energy" isExecutable="false">
    <bpmn:laneSet id="LaneSet_pool_brightwave">
      <bpmn:lane id="lane_cs" name="Customer Service">
        <bpmn:flowNodeRef>start_cs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_cs_explanation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_cs_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_cs_no_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_cs_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_lookup_billing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_review_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_write_explanation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_create_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_assign_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_mistake_split</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_invoicing" name="Invoicing Department">
        <bpmn:flowNodeRef>catch_invoicing_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_invoicing_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_invoicing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_investigate_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_make_correction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_generate_invoice</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_cs" name="Receive complaint email">
      <bpmn:messageEventDefinition id="start_cs_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateThrowEvent id="throw_cs_explanation" name="Send explanation email">
      <bpmn:messageEventDefinition id="throw_cs_explanation_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_cs_ticket" name="Notify invoicing of ticket">
      <bpmn:messageEventDefinition id="throw_cs_ticket_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_cs_no_mistake" name="End – no mistake found"/>
    <bpmn:endEvent id="end_cs_mistake" name="End – correction initiated"/>
    <bpmn:intermediateCatchEvent id="catch_invoicing_ticket" name="Receive ticket assignment">
      <bpmn:messageEventDefinition id="catch_invoicing_ticket_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_invoicing_invoice" name="Send new invoice to client">
      <bpmn:messageEventDefinition id="throw_invoicing_invoice_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_invoicing" name="End"/>
    <bpmn:userTask id="task_lookup_billing" name="Look up billing information"/>
    <bpmn:userTask id="task_review_invoice" name="Review invoice"/>
    <bpmn:userTask id="task_write_explanation" name="Write explanation email"/>
    <bpmn:userTask id="task_create_ticket" name="Create ticket in internal system"/>
    <bpmn:userTask id="task_assign_ticket" name="Assign ticket to invoicing"/>
    <bpmn:userTask id="task_investigate_mistake" name="Investigate invoicing mistake"/>
    <bpmn:userTask id="task_make_correction" name="Make necessary correction"/>
    <bpmn:userTask id="task_generate_invoice" name="Generate new invoice"/>
    <bpmn:exclusiveGateway id="gw_mistake_split" name="Mistake found?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf04" sourceRef="start_cs" targetRef="task_lookup_billing"/>
    <bpmn:sequenceFlow id="sf05" sourceRef="task_lookup_billing" targetRef="task_review_invoice"/>
    <bpmn:sequenceFlow id="sf06" sourceRef="task_review_invoice" targetRef="gw_mistake_split"/>
    <bpmn:sequenceFlow id="sf07" sourceRef="gw_mistake_split" targetRef="task_write_explanation" name="No mistake found">
      <bpmn:conditionExpression>No mistake found</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf08" sourceRef="task_write_explanation" targetRef="throw_cs_explanation"/>
    <bpmn:sequenceFlow id="sf09" sourceRef="throw_cs_explanation" targetRef="end_cs_no_mistake"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="gw_mistake_split" targetRef="task_create_ticket" name="Mistake found">
      <bpmn:conditionExpression>Mistake found</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf11" sourceRef="task_create_ticket" targetRef="task_assign_ticket"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="task_assign_ticket" targetRef="throw_cs_ticket"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="throw_cs_ticket" targetRef="end_cs_mistake"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="catch_invoicing_ticket" targetRef="task_investigate_mistake"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="task_investigate_mistake" targetRef="task_make_correction"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="task_make_correction" targetRef="task_generate_invoice"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="task_generate_invoice" targetRef="throw_invoicing_invoice"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="throw_invoicing_invoice" targetRef="end_invoicing"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
