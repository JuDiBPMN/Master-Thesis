<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Company" name="Company" processRef="Process_Company"/>
    <bpmn:participant id="actor_Candidate" name="Candidate" processRef="Process_Candidate"/>
    <bpmn:messageFlow id="mf1" name="Vacancy Request" sourceRef="Hiring_Manager" targetRef="HR_Recruiter"/>
    <bpmn:messageFlow id="mf2" name="Job Advertisement" sourceRef="HR_Recruiter" targetRef="Candidate"/>
    <bpmn:messageFlow id="mf3" name="Application" sourceRef="Candidate" targetRef="HR_Recruiter"/>
    <bpmn:messageFlow id="mf4" name="Technical Interview Invitation" sourceRef="HR_Recruiter" targetRef="Candidate"/>
    <bpmn:messageFlow id="mf5" name="Personality Assessment" sourceRef="HR_Recruiter" targetRef="Candidate"/>
    <bpmn:messageFlow id="mf6" name="Personality Assessment Response" sourceRef="Candidate" targetRef="HR_Recruiter"/>
    <bpmn:messageFlow id="mf7" name="Rejection Email" sourceRef="HR_Recruiter" targetRef="Candidate"/>
    <bpmn:messageFlow id="mf8" name="Job Offer" sourceRef="HR_Recruiter" targetRef="Candidate"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="split_candidates" targetRef="complete_personality_assessment"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="complete_personality_assessment" targetRef="score_assessment"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="join_candidates" targetRef="review_combined_outcomes"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="review_combined_outcomes" targetRef="join_parallel"/>
    <bpmn:messageFlow id="MsgFlow_p4" name="" sourceRef="send_rejection_email" targetRef="end_Candidate"/>
    <bpmn:messageFlow id="MsgFlow_p5" name="" sourceRef="join_parallel" targetRef="end_Candidate"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Company" name="Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="Hiring_Manager" name="Hiring Manager">
        <bpmn:flowNodeRef>start_Company</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_vacancy_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>conduct_technical_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="HR_Recruiter" name="HR Recruiter">
        <bpmn:flowNodeRef>register_vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>post_job_advertisement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>screen_applications</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>schedule_technical_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>score_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>draft_job_offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_candidates</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_candidates</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_Company" name="Start"/>
    <bpmn:task id="submit_vacancy_request" name="Submit Vacancy Request"/>
    <bpmn:task id="register_vacancy" name="Register Vacancy"/>
    <bpmn:task id="post_job_advertisement" name="Post Job Advertisement"/>
    <bpmn:task id="screen_applications" name="Screen Applications"/>
    <bpmn:task id="schedule_technical_interview" name="Schedule Technical Interview"/>
    <bpmn:task id="conduct_technical_interview" name="Conduct Technical Interview"/>
    <bpmn:task id="record_verdict" name="Record Verdict"/>
    <bpmn:task id="score_assessment" name="Score Assessment"/>
    <bpmn:task id="draft_job_offer" name="Draft Job Offer"/>
    <bpmn:task id="send_rejection_email" name="Send Rejection Email"/>
    <bpmn:parallelGateway id="split_parallel" name="Start Parallel Activities" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Activities Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_candidates" name="Shortlist Candidates" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_candidates" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_Company" targetRef="submit_vacancy_request"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="submit_vacancy_request" targetRef="register_vacancy"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_vacancy" targetRef="post_job_advertisement"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="post_job_advertisement" targetRef="split_parallel"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="split_parallel" targetRef="screen_applications"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_parallel" targetRef="schedule_technical_interview"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="screen_applications" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="schedule_technical_interview" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="join_parallel" targetRef="join_candidates"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="join_candidates" targetRef="split_candidates"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="split_candidates" targetRef="conduct_technical_interview"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="conduct_technical_interview" targetRef="record_verdict"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="score_assessment" targetRef="join_candidates"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="record_verdict" targetRef="join_candidates"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="join_parallel" targetRef="draft_job_offer"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="draft_job_offer" targetRef="send_rejection_email"/>
  </bpmn:process>
  <bpmn:process id="Process_Candidate" name="Candidate" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Candidate">
      <bpmn:lane id="Candidate" name="Candidate"/>
    </bpmn:laneSet>
    <bpmn:endEvent id="end_Candidate" name="End"/>
    <bpmn:task id="complete_personality_assessment" name="Complete Personality Assessment"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Company_di" bpmnElement="actor_Company" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="3100" height="500"/>
