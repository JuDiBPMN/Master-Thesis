        <bpmn:flowNodeRef>ParallelGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ParallelJoinGateway</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Warehouse" name="Warehouse">
        <bpmn:flowNodeRef>InspectProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecordWarehouseVerdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Finance" name="Finance">
        <bpmn:flowNodeRef>CheckPaymentEligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecordFinanceVerdict</bpmn:flowNodeRef>
      </bpmn:lane>
