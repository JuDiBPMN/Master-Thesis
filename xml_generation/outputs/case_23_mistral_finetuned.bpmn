<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_client_pool" name="Client of BrightWave Energy" processRef="Process_client_pool"/>
    <bpmn:participant id="actor_cs_pool" name="Customer Service" processRef="Process_cs_pool"/>
    <bpmn:participant id="actor_invoicing_pool" name="Invoicing Department" processRef="Process_invoicing_pool"/>
    <bpmn:messageFlow id="mf1" name="Complaint Email" sourceRef="write_complaint_email" targetRef="start_cs"/>
    <bpmn:messageFlow id="mf2" name="Ticket" sourceRef="create_ticket" targetRef="start_invoicing"/>
    <bpmn:messageFlow id="mf3" name="New Invoice Email" sourceRef="generate_new_invoice" targetRef="end_cs_mistake"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="write_complaint_email" targetRef="start_cs"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="gateway_mistake_split" targetRef="investigate_mistake"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="investigate_mistake" targetRef="gateway_mistake_join"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="gateway_mistake_join" targetRef="correct_invoice"/>
    <bpmn:messageFlow id="MsgFlow_p4" name="" sourceRef="generate_new_invoice" targetRef="end_cs_mistake"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_client_pool" name="Client of BrightWave Energy" isExecutable="false">
    <bpmn:laneSet id="LaneSet_client_pool">
      <bpmn:lane id="client" name="Client">
        <bpmn:flowNodeRef>start_client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_client_no_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_client_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>write_complaint_email</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_client" name="Receive Monthly Bill"/>
    <bpmn:endEvent id="end_client_no_mistake" name="Receive Explanation"/>
    <bpmn:endEvent id="end_client_mistake" name="Receive New Invoice"/>
    <bpmn:task id="write_complaint_email" name="Write Complaint Email"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_client" targetRef="write_complaint_email"/>
  </bpmn:process>
  <bpmn:process id="Process_cs_pool" name="Customer Service" isExecutable="false">
    <bpmn:laneSet id="LaneSet_cs_pool">
      <bpmn:lane id="cs_employee" name="CS Employee">
        <bpmn:flowNodeRef>start_cs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_cs_no_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_cs_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>determine_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>write_explanation_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>create_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_mistake_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_mistake_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_cs" name="Receive Complaint">
      <bpmn:messageEventDefinition id="start_cs_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_cs_no_mistake" name="Send Explanation"/>
    <bpmn:endEvent id="end_cs_mistake" name="Invoice Sent"/>
    <bpmn:task id="review_invoice" name="Review Invoice"/>
    <bpmn:task id="determine_mistake" name="Determine Mistake?"/>
    <bpmn:task id="write_explanation_email" name="Write Explanation Email"/>
    <bpmn:task id="create_ticket" name="Create Ticket"/>
    <bpmn:parallelGateway id="gateway_parallel_split" name="" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_join" name="" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_mistake_split" name="Mistake Found?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_mistake_join" name="" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="start_cs" targetRef="gateway_parallel_split"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="gateway_parallel_split" targetRef="review_invoice"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="gateway_parallel_split" targetRef="determine_mistake"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="review_invoice" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="determine_mistake" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="gateway_parallel_join" targetRef="write_explanation_email"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="write_explanation_email" targetRef="end_cs_no_mistake"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="gateway_mistake_split" targetRef="create_ticket"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="create_ticket" targetRef="gateway_mistake_join"/>
  </bpmn:process>
  <bpmn:process id="Process_invoicing_pool" name="Invoicing Department" isExecutable="false">
    <bpmn:laneSet id="LaneSet_invoicing_pool">
      <bpmn:lane id="invoicing_employee" name="Invoicing Employee">
        <bpmn:flowNodeRef>start_invoicing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>investigate_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>correct_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>generate_new_invoice</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_invoicing" name="Receive Ticket">
      <bpmn:messageEventDefinition id="start_invoicing_def"/>
    </bpmn:startEvent>
    <bpmn:task id="investigate_mistake" name="Investigate Invoicing Mistake"/>
    <bpmn:task id="correct_invoice" name="Correct Invoice"/>
    <bpmn:task id="generate_new_invoice" name="Generate New Invoice"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="correct_invoice" targetRef="generate_new_invoice"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_client_pool_di" bpmnElement="actor_client_pool" isHorizontal="true">
