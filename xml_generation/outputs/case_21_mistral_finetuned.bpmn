<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_retailer" name="Retailer" processRef="Process_retailer"/>
    <bpmn:participant id="actor_customer" name="Customer" processRef="Process_customer"/>
    <bpmn:messageFlow id="mf1" name="Return Request" sourceRef="submit_return_request" targetRef="register_return_request"/>
    <bpmn:messageFlow id="mf2" name="Rejection Notice" sourceRef="notify_customer" targetRef="start_customer"/>
    <bpmn:messageFlow id="mf3" name="Rejection Notice" sourceRef="send_rejection" targetRef="start_customer"/>
    <bpmn:messageFlow id="mf4" name="Confirmation" sourceRef="send_confirmation" targetRef="start_customer"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_retailer" name="Retailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_retailer">
      <bpmn:lane id="customer_service_lane" name="Customer Service">
        <bpmn:flowNodeRef>start_retailer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_retailer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_return_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_info_completeness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_customer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>approve_return</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>process_refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_confirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_outcome_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_outcome_join</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="warehouse_lane" name="Warehouse">
        <bpmn:flowNodeRef>inspect_product</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance_lane" name="Finance">
        <bpmn:flowNodeRef>check_payment_eligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_finance_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_retailer" name="Start"/>
    <bpmn:endEvent id="end_retailer" name="End"/>
    <bpmn:task id="register_return_request" name="Register Return Request"/>
    <bpmn:task id="check_info_completeness" name="Check Information Completeness"/>
    <bpmn:task id="notify_customer" name="Notify Customer of Missing Information"/>
    <bpmn:task id="inspect_product" name="Inspect Returned Product"/>
    <bpmn:task id="record_verdict" name="Record Verdict"/>
    <bpmn:task id="check_payment_eligibility" name="Check Payment Eligibility"/>
    <bpmn:task id="record_finance_verdict" name="Record Finance Verdict"/>
    <bpmn:task id="review_outcomes" name="Review Combined Outcomes"/>
    <bpmn:task id="send_rejection" name="Send Return Rejection Notice"/>
    <bpmn:task id="approve_return" name="Approve Return"/>
    <bpmn:task id="process_refund" name="Process Refund"/>
    <bpmn:task id="send_confirmation" name="Send Refund Confirmation"/>
    <bpmn:parallelGateway id="gateway_parallel_split" name="Forward Return Request" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_join" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_outcome_split" name="Verdicts Outcome?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_outcome_join" name="Both Verdicts Positive?" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="start_retailer" targetRef="register_return_request"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="register_return_request" targetRef="check_info_completeness"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="check_info_completeness" targetRef="gateway_outcome_split"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="gateway_outcome_split" targetRef="notify_customer" name="Incomplete information">
      <bpmn:conditionExpression>Incomplete information</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="gateway_outcome_split" targetRef="gateway_parallel_split" name="Information complete">
      <bpmn:conditionExpression>Information complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf8" sourceRef="notify_customer" targetRef="end_retailer"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="gateway_parallel_split" targetRef="inspect_product"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="gateway_parallel_split" targetRef="check_payment_eligibility"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="inspect_product" targetRef="record_verdict"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="check_payment_eligibility" targetRef="record_finance_verdict"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="record_verdict" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="record_finance_verdict" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="gateway_parallel_join" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="review_outcomes" targetRef="gateway_outcome_join"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="gateway_outcome_join" targetRef="send_rejection" name="At least one verdict negative">
      <bpmn:conditionExpression>At least one verdict negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf18" sourceRef="gateway_outcome_join" targetRef="approve_return" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf19" sourceRef="send_rejection" targetRef="end_retailer"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="approve_return" targetRef="process_refund"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="process_refund" targetRef="send_confirmation"/>
    <bpmn:sequenceFlow id="sf22" sourceRef="send_confirmation" targetRef="end_retailer"/>
  </bpmn:process>
  <bpmn:process id="Process_customer" name="Customer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_customer">
      <bpmn:lane id="customer_lane" name="Customer">
        <bpmn:flowNodeRef>start_customer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_customer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_return_request</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_customer" name="Start"/>
    <bpmn:endEvent id="end_customer" name="End"/>
    <bpmn:task id="submit_return_request" name="Submit Return Request"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_customer" targetRef="submit_return_request"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="submit_return_request" targetRef="end_customer"/>
  </bpmn:process>
