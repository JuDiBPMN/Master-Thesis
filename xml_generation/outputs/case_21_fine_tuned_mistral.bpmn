<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_GP" name="General Practitioner" processRef="Process_GP"/>
    <bpmn:participant id="actor_admissions_office" name="Admissions Office" processRef="Process_admissions_office"/>
    <bpmn:participant id="actor_specialist_department" name="Specialist Department" processRef="Process_specialist_department"/>
    <bpmn:participant id="actor_insurance_office" name="Insurance Office" processRef="Process_insurance_office"/>
    <bpmn:messageFlow id="MsgFlow_0" name="Referral Request" sourceRef="submit_referral" targetRef="start_admissions"/>
    <bpmn:messageFlow id="MsgFlow_1" name="Incomplete Documentation Notice" sourceRef="notify_incomplete" targetRef="submit_referral"/>
    <bpmn:messageFlow id="MsgFlow_2" name="Referral for Assessment" sourceRef="join_parallel" targetRef="specialist_department"/>
    <bpmn:messageFlow id="MsgFlow_3" name="Referral for Coverage Verification" sourceRef="join_parallel" targetRef="insurance_office"/>
    <bpmn:messageFlow id="MsgFlow_4" name="Specialist Verdict" sourceRef="record_verdict" targetRef="admissions_office"/>
    <bpmn:messageFlow id="MsgFlow_5" name="Coverage Verdict" sourceRef="record_coverage_verdict" targetRef="admissions_office"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="split_parallel" targetRef="assess_referral"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="split_parallel" targetRef="verify_coverage"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="record_verdict" targetRef="join_parallel"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="record_coverage_verdict" targetRef="join_parallel"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_GP" name="General Practitioner" isExecutable="false">
    <bpmn:startEvent id="start_GP" name="Referral Received"/>
    <bpmn:endEvent id="end_GP_rejected" name="Rejection Received"/>
    <bpmn:endEvent id="end_GP_approved" name="Treatment Approved"/>
    <bpmn:task id="submit_referral" name="Submit Referral Request"/>
    <bpmn:sequenceFlow id="Flow_0" sourceRef="start_GP" targetRef="submit_referral"/>
  </bpmn:process>
  <bpmn:process id="Process_admissions_office" name="Admissions Office" isExecutable="false">
    <bpmn:startEvent id="start_admissions" name="Referral Received">
      <bpmn:messageEventDefinition id="start_admissions_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_admissions_rejected" name="Rejection Sent"/>
    <bpmn:endEvent id="end_admissions_approved" name="Approval Sent"/>
    <bpmn:task id="register_referral" name="Register Referral"/>
    <bpmn:task id="check_documentation" name="Check Documentation"/>
    <bpmn:task id="notify_incomplete" name="Notify GP of Missing Documents"/>
    <bpmn:task id="review_outcomes" name="Review Combined Outcomes"/>
    <bpmn:task id="send_rejection" name="Send Rejection Notice to GP"/>
    <bpmn:task id="send_approval" name="Send Treatment Approval to GP"/>
    <bpmn:exclusiveGateway id="split_documentation" name="Documentation Complete?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward for Assessment and Verification" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Outcome?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="start_admissions" targetRef="register_referral"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="register_referral" targetRef="check_documentation"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="check_documentation" targetRef="split_documentation"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="split_documentation" targetRef="notify_incomplete" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="split_documentation" targetRef="join_parallel" name="Complete">
      <bpmn:conditionExpression>Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="notify_incomplete" targetRef="split_documentation"/>
    <bpmn:sequenceFlow id="Flow_7" sourceRef="join_parallel" targetRef="split_parallel"/>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="Flow_12" sourceRef="split_outcome" targetRef="send_rejection" name="Negative">
      <bpmn:conditionExpression>Negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_13" sourceRef="split_outcome" targetRef="send_approval" name="Positive">
      <bpmn:conditionExpression>Positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_16" sourceRef="send_rejection" targetRef="end_admissions_rejected"/>
    <bpmn:sequenceFlow id="Flow_17" sourceRef="send_approval" targetRef="end_admissions_approved"/>
  </bpmn:process>
  <bpmn:process id="Process_specialist_department" name="Specialist Department" isExecutable="false">
    <bpmn:startEvent id="start_specialist" name="Referral Forwarded">
      <bpmn:messageEventDefinition id="start_specialist_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_specialist" name="Verdict Recorded"/>
    <bpmn:task id="assess_referral" name="Conduct Medical Assessment"/>
    <bpmn:task id="record_verdict" name="Record Verdict"/>
    <bpmn:sequenceFlow id="Flow_8" sourceRef="assess_referral" targetRef="record_verdict"/>
    <bpmn:sequenceFlow id="Flow_14" sourceRef="start_specialist" targetRef="assess_referral"/>
  </bpmn:process>
  <bpmn:process id="Process_insurance_office" name="Insurance Office" isExecutable="false">
    <bpmn:startEvent id="start_insurance" name="Referral Forwarded">
      <bpmn:messageEventDefinition id="start_insurance_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_insurance" name="Verdict Recorded"/>
    <bpmn:task id="verify_coverage" name="Verify Patient Coverage"/>
    <bpmn:task id="record_coverage_verdict" name="Record Coverage Verdict"/>
    <bpmn:sequenceFlow id="Flow_9" sourceRef="verify_coverage" targetRef="record_coverage_verdict"/>
    <bpmn:sequenceFlow id="Flow_15" sourceRef="start_insurance" targetRef="verify_coverage"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_GP_di" bpmnElement="actor_GP" isHorizontal="true">
