<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Zarkan_Industries" name="Zarkan Industries" processRef="Process_Zarkan_Industries"/>
    <bpmn:participant id="actor_Customer" name="Customer" processRef="Process_Customer"/>
    <bpmn:messageFlow id="mf1" name="Send Complaint Details" sourceRef="complaint_received" targetRef="customer_complaint"/>
    <bpmn:messageFlow id="mf2" name="Receive Analysis" sourceRef="customer_complaint" targetRef="complaint_analyzed"/>
    <bpmn:messageFlow id="mf3" name="Send Resolution" sourceRef="complaint_resolved" targetRef="customer_complaint"/>
    <bpmn:messageFlow id="mf4" name="Receive Confirmation" sourceRef="customer_complaint" targetRef="complaint_archived"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Zarkan_Industries" name="Zarkan Industries" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Zarkan_Industries">
      <bpmn:lane id="CSR" name="Customer Service Representative">
        <bpmn:flowNodeRef>start_event</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>complaint_received</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>complaint_analyzed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>complaint_resolved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>complaint_archived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_event</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>receive_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_call_details</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>document_concerns</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>note_receipt_date</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>analyze_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>consult_departments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>resolve_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>archive_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>close_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>decision_gateway</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_event" name="Start"/>
    <bpmn:intermediateCatchEvent id="complaint_received" name="Complaint Received">
      <bpmn:messageEventDefinition id="complaint_received_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="complaint_analyzed" name="Complaint Analyzed">
      <bpmn:messageEventDefinition id="complaint_analyzed_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="complaint_resolved" name="Complaint Resolved">
      <bpmn:messageEventDefinition id="complaint_resolved_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="complaint_archived" name="Complaint Archived">
      <bpmn:messageEventDefinition id="complaint_archived_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_event" name="End"/>
    <bpmn:task id="receive_complaint" name="Receive Complaint"/>
    <bpmn:task id="record_call_details" name="Record Call Details"/>
    <bpmn:task id="document_concerns" name="Document Concerns"/>
    <bpmn:task id="note_receipt_date" name="Note Receipt Date"/>
    <bpmn:task id="analyze_complaint" name="Analyze Complaint"/>
    <bpmn:task id="consult_departments" name="Consult Other Departments"/>
    <bpmn:task id="resolve_complaint" name="Resolve Complaint"/>
    <bpmn:task id="archive_complaint" name="Archive Complaint Details"/>
    <bpmn:task id="close_complaint" name="Close Complaint"/>
    <bpmn:exclusiveGateway id="decision_gateway" name="Decision Gateway" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_event" targetRef="receive_complaint"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="receive_complaint" targetRef="decision_gateway"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="decision_gateway" targetRef="record_call_details"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="decision_gateway" targetRef="document_concerns"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="decision_gateway" targetRef="note_receipt_date"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="record_call_details" targetRef="complaint_received"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="document_concerns" targetRef="complaint_received"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="note_receipt_date" targetRef="complaint_received"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="complaint_received" targetRef="analyze_complaint"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="analyze_complaint" targetRef="consult_departments"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="consult_departments" targetRef="complaint_analyzed"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="complaint_analyzed" targetRef="resolve_complaint"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="resolve_complaint" targetRef="complaint_resolved"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="complaint_resolved" targetRef="archive_complaint"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="archive_complaint" targetRef="complaint_archived"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="complaint_archived" targetRef="close_complaint"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="close_complaint" targetRef="end_event"/>
  </bpmn:process>
  <bpmn:process id="Process_Customer" name="Customer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Customer">
      <bpmn:lane id="Customer" name="Customer"/>
    </bpmn:laneSet>
    <bpmn:startEvent id="customer_complaint" name="Customer Complaint"/>
  </bpmn:process>
