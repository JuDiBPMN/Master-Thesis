    <bpmn:parallelGateway id="split_parallel" name="Start Parallel Review" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Reviews Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_verdict" name="Any Negative Verdict?" gatewayDirection="diverging"/>
