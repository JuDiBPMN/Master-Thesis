<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_hr_pool" name="HR Department" processRef="Process_hr_pool"/>
    <bpmn:participant id="actor_onboarding_pool" name="Onboarding Office" processRef="Process_onboarding_pool"/>
    <bpmn:messageFlow id="mf1" name="New Hire Request" sourceRef="submit_request" targetRef="start_onboarding"/>
    <bpmn:messageFlow id="mf2" name="Incomplete Notice" sourceRef="notify_incomplete" targetRef="collect_docs"/>
    <bpmn:messageFlow id="mf3" name="Resubmitted Documents" sourceRef="collect_docs" targetRef="join_rework"/>
    <bpmn:messageFlow id="mf4" name="Ready-to-Start Confirmation" sourceRef="send_confirmation" targetRef="end_hr_confirmed"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_hr_pool" name="HR Department" isExecutable="false">
    <bpmn:laneSet id="LaneSet_hr_pool">
      <bpmn:lane id="hr_officer" name="HR Officer">
        <bpmn:flowNodeRef>start_hr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hr_confirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>collect_docs</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hr" name="Start"/>
    <bpmn:endEvent id="end_hr_confirmed" name="Confirmation Received"/>
    <bpmn:task id="submit_request" name="Submit New Hire Request"/>
    <bpmn:task id="collect_docs" name="Collect Missing Documents"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_hr" targetRef="submit_request"/>
  </bpmn:process>
  <bpmn:process id="Process_onboarding_pool" name="Onboarding Office" isExecutable="false">
    <bpmn:laneSet id="LaneSet_onboarding_pool">
      <bpmn:lane id="coordinator" name="Onboarding Coordinator">
        <bpmn:flowNodeRef>start_onboarding</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_confirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>resolve_issue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_confirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_rework</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="it_dept" name="IT Department">
        <bpmn:flowNodeRef>setup_accounts</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_it</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="facilities" name="Facilities Department">
        <bpmn:flowNodeRef>prepare_workspace</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_facilities</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_onboarding" name="New Hire Request Received">
      <bpmn:messageEventDefinition id="start_onboarding_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_confirmed" name="Confirmation Sent"/>
    <bpmn:task id="register_request" name="Register New Hire Request"/>
    <bpmn:task id="check_docs" name="Check Documentation Completeness"/>
    <bpmn:task id="notify_incomplete" name="Notify HR of Missing Documents"/>
    <bpmn:task id="review_outcomes" name="Review Combined Completion Status"/>
    <bpmn:task id="resolve_issue" name="Resolve Flagged Issue"/>
    <bpmn:task id="send_confirmation" name="Send Ready-to-Start Confirmation"/>
    <bpmn:task id="setup_accounts" name="Set Up System Accounts"/>
    <bpmn:task id="record_it" name="Record IT Completion"/>
    <bpmn:task id="prepare_workspace" name="Prepare Workspace"/>
    <bpmn:task id="record_facilities" name="Record Facilities Completion"/>
    <bpmn:exclusiveGateway id="split_complete" name="Documentation Complete?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_rework" name="Recheck Documentation" gatewayDirection="converging"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward to Departments" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Completions Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Any Issues Flagged?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="start_onboarding" targetRef="register_request"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_request" targetRef="join_rework"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="join_rework" targetRef="check_docs"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="check_docs" targetRef="split_complete"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_complete" targetRef="notify_incomplete" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="split_complete" targetRef="split_parallel" name="Complete">
      <bpmn:conditionExpression>Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf8" sourceRef="notify_incomplete" targetRef="join_rework"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="split_parallel" targetRef="setup_accounts"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="split_parallel" targetRef="prepare_workspace"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="setup_accounts" targetRef="record_it"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="record_it" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="prepare_workspace" targetRef="record_facilities"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="record_facilities" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="split_outcome" targetRef="resolve_issue" name="One or more issues flagged">
      <bpmn:conditionExpression>One or more issues flagged</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf18" sourceRef="split_outcome" targetRef="send_confirmation" name="All completions confirmed">
      <bpmn:conditionExpression>All completions confirmed</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf19" sourceRef="resolve_issue" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="send_confirmation" targetRef="end_confirmed"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_hr_pool_di" bpmnElement="actor_hr_pool" isHorizontal="true">
