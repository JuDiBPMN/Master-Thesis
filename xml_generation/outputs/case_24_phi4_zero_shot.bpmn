    <bpmn:exclusiveGateway id="ExclusiveGateway2" name="Exclusive Gateway 2" gatewayDirection="converging"/>
    <bpmn:parallelGateway id="ParallelGateway1" name="Parallel Gateway 1" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="ParallelGateway2" name="Parallel Gateway 2" gatewayDirection="converging"/>
