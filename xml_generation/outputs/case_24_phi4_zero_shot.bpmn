    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="ResubmitDocsEvent" targetRef="CheckCompleteness"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_GovernmentAgency" name="Government Agency Grants Office" isExecutable="false">
    <bpmn:laneSet id="LaneSet_GovernmentAgency">
      <bpmn:lane id="GrantsAdmin" name="Grants Administrator">
        <bpmn:flowNodeRef>StartEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyMissingDocsEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReviewOutcomesEvent</bpmn:flowNodeRef>
