      <bpmndi:BPMNShape id="join_retry_di" bpmnElement="join_retry" isMarkerVisible="true">
        <dc:Bounds x="1455" y="755" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
