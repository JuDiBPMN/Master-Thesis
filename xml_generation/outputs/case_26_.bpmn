<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_customer_pool" name="Customer" processRef="Process_customer_pool"/>
    <bpmn:participant id="actor_retailer_pool" name="Retailer" processRef="Process_retailer_pool"/>
    <bpmn:messageFlow id="mf1" name="Return Request" sourceRef="submit_return" targetRef="start_cs"/>
    <bpmn:messageFlow id="mf2" name="Incomplete Notice" sourceRef="throw_incomplete" targetRef="catch_incomplete"/>
    <bpmn:messageFlow id="mf3" name="Return Rejection Notice" sourceRef="throw_rejection" targetRef="catch_rejection"/>
    <bpmn:messageFlow id="mf4" name="Refund Confirmation" sourceRef="throw_refund" targetRef="catch_refund"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_customer_pool" name="Customer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_customer_pool">
      <bpmn:lane id="customer" name="Customer">
        <bpmn:flowNodeRef>start_customer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_customer_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_customer_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_customer_refunded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_return</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_customer" name="Start"/>
    <bpmn:intermediateCatchEvent id="catch_incomplete" name="Incomplete Notice Received">
      <bpmn:messageEventDefinition id="catch_incomplete_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_customer_incomplete" name="Ended: Incomplete Request"/>
    <bpmn:intermediateCatchEvent id="catch_rejection" name="Rejection Notice Received">
      <bpmn:messageEventDefinition id="catch_rejection_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_customer_rejected" name="Ended: Return Rejected"/>
    <bpmn:intermediateCatchEvent id="catch_refund" name="Refund Confirmation Received">
      <bpmn:messageEventDefinition id="catch_refund_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_customer_refunded" name="Ended: Refund Approved"/>
    <bpmn:task id="submit_return" name="Submit Return Request"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_customer" targetRef="submit_return"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="catch_incomplete" targetRef="end_customer_incomplete"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="catch_rejection" targetRef="end_customer_rejected"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="catch_refund" targetRef="end_customer_refunded"/>
  </bpmn:process>
  <bpmn:process id="Process_retailer_pool" name="Retailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_retailer_pool">
      <bpmn:lane id="customer_service" name="Customer Service">
        <bpmn:flowNodeRef>start_cs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_cs_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_cs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_return</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>process_refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="warehouse" name="Warehouse Team">
        <bpmn:flowNodeRef>inspect_product</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_inspection</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance" name="Finance Department">
        <bpmn:flowNodeRef>check_eligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_eligibility</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_cs" name="Return Request Received">
      <bpmn:messageEventDefinition id="start_cs_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateThrowEvent id="throw_incomplete" name="Notify Customer of Missing Info">
      <bpmn:messageEventDefinition id="throw_incomplete_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_cs_incomplete" name="Incomplete Request"/>
    <bpmn:intermediateThrowEvent id="throw_rejection" name="Send Return Rejection Notice">
      <bpmn:messageEventDefinition id="throw_rejection_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_refund" name="Send Refund Confirmation">
      <bpmn:messageEventDefinition id="throw_refund_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_cs" name="Process Complete"/>
    <bpmn:task id="register_return" name="Register Return Request"/>
    <bpmn:task id="check_info" name="Check Request Information"/>
    <bpmn:task id="review_outcomes" name="Review Combined Verdicts"/>
    <bpmn:task id="send_rejection" name="Send Return Rejection Notice"/>
    <bpmn:task id="process_refund" name="Approve Return and Process Refund"/>
    <bpmn:task id="inspect_product" name="Inspect Returned Product"/>
    <bpmn:task id="record_inspection" name="Record Inspection Verdict"/>
    <bpmn:task id="check_eligibility" name="Check Payment Eligibility"/>
    <bpmn:task id="record_eligibility" name="Record Eligibility Verdict"/>
    <bpmn:exclusiveGateway id="split_info" name="Information Complete?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward for Review" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Both Verdicts Positive?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_outcome" name="Merge Outcome Paths" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="start_cs" targetRef="register_return"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="register_return" targetRef="check_info"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="check_info" targetRef="split_info"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="split_info" targetRef="throw_incomplete" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf9" sourceRef="split_info" targetRef="split_parallel" name="Complete">
      <bpmn:conditionExpression>Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf10" sourceRef="throw_incomplete" targetRef="end_cs_incomplete"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="split_parallel" targetRef="inspect_product"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="split_parallel" targetRef="check_eligibility"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="inspect_product" targetRef="record_inspection"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="record_inspection" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="check_eligibility" targetRef="record_eligibility"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="record_eligibility" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="split_outcome" targetRef="send_rejection" name="One or more verdicts negative">
      <bpmn:conditionExpression>One or more verdicts negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf20" sourceRef="split_outcome" targetRef="process_refund" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf21" sourceRef="send_rejection" targetRef="throw_rejection"/>
    <bpmn:sequenceFlow id="sf22" sourceRef="process_refund" targetRef="throw_refund"/>
    <bpmn:sequenceFlow id="sf23" sourceRef="throw_rejection" targetRef="join_outcome"/>
    <bpmn:sequenceFlow id="sf24" sourceRef="throw_refund" targetRef="join_outcome"/>
    <bpmn:sequenceFlow id="sf25" sourceRef="join_outcome" targetRef="end_cs"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
