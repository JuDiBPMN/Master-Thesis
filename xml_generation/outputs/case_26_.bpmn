      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="hand_to_driver_di" bpmnElement="hand_to_driver">
        <dc:Bounds x="1240" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_parallel_di" bpmnElement="split_parallel" isMarkerVisible="true">
        <dc:Bounds x="505" y="275" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="join_parallel_di" bpmnElement="join_parallel" isMarkerVisible="true">
        <dc:Bounds x="885" y="275" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="pick_pack_di" bpmnElement="pick_pack">
        <dc:Bounds x="670" y="420" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="schedule_redelivery_di" bpmnElement="schedule_redelivery">
        <dc:Bounds x="2190" y="420" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="assign_driver_di" bpmnElement="assign_driver">
        <dc:Bounds x="670" y="580" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_delivered_di" bpmnElement="end_delivered">
        <dc:Bounds x="2222" y="762" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="deliver_parcel_di" bpmnElement="deliver_parcel">
        <dc:Bounds x="1620" y="740" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="mark_delivered_di" bpmnElement="mark_delivered">
        <dc:Bounds x="2000" y="713" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="return_parcel_di" bpmnElement="return_parcel">
        <dc:Bounds x="2000" y="766" width="100" height="80"/>
