<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_retailer_pool" name="Retailer" processRef="Process_retailer_pool"/>
    <bpmn:participant id="actor_logistics_pool" name="Logistics Company" processRef="Process_logistics_pool"/>
    <bpmn:messageFlow id="mf1" name="Order Confirmation" sourceRef="confirm_order" targetRef="start_logistics"/>
    <bpmn:messageFlow id="mf2" name="Delivery Confirmation" sourceRef="mark_delivered" targetRef="end_retailer"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_retailer_pool" name="Retailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_retailer_pool">
      <bpmn:lane id="retailer" name="Retailer">
        <bpmn:flowNodeRef>start_retailer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_retailer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>confirm_order</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_retailer" name="Start"/>
    <bpmn:endEvent id="end_retailer" name="Order Shipped"/>
    <bpmn:task id="confirm_order" name="Confirm New Order"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_retailer" targetRef="confirm_order"/>
  </bpmn:process>
  <bpmn:process id="Process_logistics_pool" name="Logistics Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_logistics_pool">
      <bpmn:lane id="logistics_coord" name="Logistics Coordinator">
        <bpmn:flowNodeRef>start_logistics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_shipment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>generate_label</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>hand_to_driver</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="warehouse" name="Warehouse">
        <bpmn:flowNodeRef>pick_pack</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>schedule_redelivery</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="transport_planning" name="Transport Planning">
        <bpmn:flowNodeRef>assign_driver</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="driver" name="Driver">
        <bpmn:flowNodeRef>end_delivered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>deliver_parcel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>mark_delivered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>return_parcel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_delivery</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_retry</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_logistics" name="Order Confirmed">
      <bpmn:messageEventDefinition id="start_logistics_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_delivered" name="Shipment Delivered"/>
    <bpmn:task id="register_shipment" name="Register Shipment"/>
    <bpmn:task id="generate_label" name="Generate Shipping Label"/>
    <bpmn:task id="hand_to_driver" name="Hand Parcel to Driver"/>
    <bpmn:task id="pick_pack" name="Pick and Pack Items"/>
    <bpmn:task id="schedule_redelivery" name="Schedule Redelivery Attempt"/>
    <bpmn:task id="assign_driver" name="Assign Driver and Vehicle"/>
    <bpmn:task id="deliver_parcel" name="Deliver Parcel to Customer"/>
    <bpmn:task id="mark_delivered" name="Mark Shipment as Delivered"/>
    <bpmn:task id="return_parcel" name="Return Parcel to Warehouse"/>
    <bpmn:parallelGateway id="split_parallel" name="Start Parallel Tracks" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Tracks Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_delivery" name="Delivery Successful?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_retry" name="Delivery Retry Join" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="start_logistics" targetRef="register_shipment"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_shipment" targetRef="split_parallel"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="split_parallel" targetRef="pick_pack"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="split_parallel" targetRef="assign_driver"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="pick_pack" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="assign_driver" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="join_parallel" targetRef="generate_label"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="generate_label" targetRef="hand_to_driver"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="hand_to_driver" targetRef="join_retry"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="join_retry" targetRef="deliver_parcel"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="deliver_parcel" targetRef="split_delivery"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="split_delivery" targetRef="mark_delivered" name="Delivery successful">
      <bpmn:conditionExpression>Delivery successful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf14" sourceRef="split_delivery" targetRef="return_parcel" name="Customer unavailable">
      <bpmn:conditionExpression>Customer unavailable</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf15" sourceRef="mark_delivered" targetRef="end_delivered"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="return_parcel" targetRef="schedule_redelivery"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="schedule_redelivery" targetRef="join_retry"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_retailer_pool_di" bpmnElement="actor_retailer_pool" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="560" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_logistics_pool_di" bpmnElement="actor_logistics_pool" isHorizontal="true">
        <dc:Bounds x="10" y="220" width="2460" height="640"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="retailer_di" bpmnElement="retailer" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="530" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="logistics_coord_di" bpmnElement="logistics_coord" isHorizontal="true">
        <dc:Bounds x="40" y="220" width="2430" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="warehouse_di" bpmnElement="warehouse" isHorizontal="true">
        <dc:Bounds x="40" y="380" width="2430" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="transport_planning_di" bpmnElement="transport_planning" isHorizontal="true">
        <dc:Bounds x="40" y="540" width="2430" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="driver_di" bpmnElement="driver" isHorizontal="true">
        <dc:Bounds x="40" y="700" width="2430" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_retailer_di" bpmnElement="start_retailer">
        <dc:Bounds x="132" y="55" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_retailer_di" bpmnElement="end_retailer">
        <dc:Bounds x="132" y="108" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="confirm_order_di" bpmnElement="confirm_order">
        <dc:Bounds x="290" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_logistics_di" bpmnElement="start_logistics">
        <dc:Bounds x="132" y="282" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="register_shipment_di" bpmnElement="register_shipment">
        <dc:Bounds x="290" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="generate_label_di" bpmnElement="generate_label">
