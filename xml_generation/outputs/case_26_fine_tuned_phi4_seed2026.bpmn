<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Company" name="Company" processRef="Process_Company"/>
    <bpmn:participant id="actor_Candidate" name="Candidate" processRef="Process_Candidate"/>
    <bpmn:messageFlow id="inform_candidate_message" name="Inform Candidate" sourceRef="inform_candidate_event" targetRef="receive_inform_candidate"/>
    <bpmn:messageFlow id="assessment_message" name="Assessment" sourceRef="assessment_event" targetRef="receive_assessment"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="inform_candidate_event" targetRef="receive_inform_candidate"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="receive_inform_candidate" targetRef="assessment_event"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Company" name="Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="HR_Manager" name="HR Manager">
        <bpmn:flowNodeRef>start_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_process</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>inform_candidate_event</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>assessment_event</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>introduction_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>discuss_with_business_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>inform_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>prepare_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>close_application</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Business_Manager" name="Business Manager">
        <bpmn:flowNodeRef>successful_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>unsuccessful_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>receive_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>second_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>decision</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_interview" name="Start Interview"/>
    <bpmn:endEvent id="end_interview" name="End Interview"/>
    <bpmn:endEvent id="successful_assessment" name="Successful Assessment"/>
    <bpmn:endEvent id="unsuccessful_assessment" name="Unsuccessful Assessment"/>
    <bpmn:endEvent id="end_process" name="End Process"/>
    <bpmn:intermediateThrowEvent id="inform_candidate_event" name="Inform Candidate">
      <bpmn:messageEventDefinition id="inform_candidate_event_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="assessment_event" name="Assessment">
      <bpmn:messageEventDefinition id="assessment_event_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="receive_assessment" name="Receive Assessment">
      <bpmn:messageEventDefinition id="receive_assessment_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="introduction_interview" name="Introduction Interview"/>
    <bpmn:task id="discuss_with_business_manager" name="Discuss with Business Manager"/>
    <bpmn:task id="inform_candidate" name="Inform Candidate"/>
    <bpmn:task id="second_assessment" name="Second Assessment"/>
    <bpmn:task id="prepare_contract" name="Prepare Contract"/>
    <bpmn:task id="close_application" name="Close Application"/>
    <bpmn:exclusiveGateway id="decision" name="Decision" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="start_interview_to_interview" sourceRef="start_interview" targetRef="introduction_interview"/>
    <bpmn:sequenceFlow id="interview_to_discuss" sourceRef="introduction_interview" targetRef="discuss_with_business_manager"/>
    <bpmn:sequenceFlow id="discuss_to_inform" sourceRef="discuss_with_business_manager" targetRef="inform_candidate"/>
    <bpmn:sequenceFlow id="inform_to_inform_event" sourceRef="inform_candidate" targetRef="inform_candidate_event"/>
    <bpmn:sequenceFlow id="assessment_event_to_receive_assessment" sourceRef="assessment_event" targetRef="receive_assessment"/>
    <bpmn:sequenceFlow id="receive_assessment_to_decision" sourceRef="receive_assessment" targetRef="decision"/>
    <bpmn:sequenceFlow id="decision_to_prepare" sourceRef="decision" targetRef="prepare_contract" name="successful">
      <bpmn:conditionExpression>successful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="decision_to_close" sourceRef="decision" targetRef="close_application" name="unsuccessful">
      <bpmn:conditionExpression>unsuccessful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="prepare_to_end" sourceRef="prepare_contract" targetRef="end_process"/>
    <bpmn:sequenceFlow id="close_to_end" sourceRef="close_application" targetRef="end_process"/>
  </bpmn:process>
  <bpmn:process id="Process_Candidate" name="Candidate" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Candidate">
      <bpmn:lane id="Candidate" name="Candidate"/>
    </bpmn:laneSet>
    <bpmn:intermediateCatchEvent id="receive_inform_candidate" name="Receive Inform Candidate">
      <bpmn:messageEventDefinition id="receive_inform_candidate_def"/>
    </bpmn:intermediateCatchEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Company_di" bpmnElement="actor_Company" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="1540" height="720"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Candidate_di" bpmnElement="actor_Candidate" isHorizontal="true">
        <dc:Bounds x="10" y="800" width="1540" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="HR_Manager_di" bpmnElement="HR_Manager" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="1510" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Business_Manager_di" bpmnElement="Business_Manager" isHorizontal="true">
        <dc:Bounds x="40" y="380" width="1510" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Candidate_di" bpmnElement="Candidate" isHorizontal="true">
        <dc:Bounds x="40" y="800" width="1510" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_interview_di" bpmnElement="start_interview">
        <dc:Bounds x="172" y="116" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_interview_di" bpmnElement="end_interview">
        <dc:Bounds x="172" y="182" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="assessment_event_di" bpmnElement="assessment_event">
        <dc:Bounds x="172" y="248" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_process_di" bpmnElement="end_process">
        <dc:Bounds x="1212" y="149" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="inform_candidate_event_di" bpmnElement="inform_candidate_event">
        <dc:Bounds x="1212" y="215" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="introduction_interview_di" bpmnElement="introduction_interview">
        <dc:Bounds x="390" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="discuss_with_business_manager_di" bpmnElement="discuss_with_business_manager">
        <dc:Bounds x="650" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="inform_candidate_di" bpmnElement="inform_candidate">
        <dc:Bounds x="910" y="50" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="prepare_contract_di" bpmnElement="prepare_contract">
        <dc:Bounds x="910" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="close_application_di" bpmnElement="close_application">
        <dc:Bounds x="910" y="270" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="successful_assessment_di" bpmnElement="successful_assessment">
        <dc:Bounds x="172" y="454" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="unsuccessful_assessment_di" bpmnElement="unsuccessful_assessment">
        <dc:Bounds x="172" y="520" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="second_assessment_di" bpmnElement="second_assessment">
        <dc:Bounds x="130" y="586" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="receive_assessment_di" bpmnElement="receive_assessment">
        <dc:Bounds x="432" y="542" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="decision_di" bpmnElement="decision" isMarkerVisible="true">
        <dc:Bounds x="685" y="535" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="receive_inform_candidate_di" bpmnElement="receive_inform_candidate">
        <dc:Bounds x="1212" y="892" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="start_interview_to_interview_di" bpmnElement="start_interview_to_interview">
        <di:waypoint x="208" y="134"/>
        <di:waypoint x="299" y="134"/>
        <di:waypoint x="299" y="200"/>
        <di:waypoint x="390" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="interview_to_discuss_di" bpmnElement="interview_to_discuss">
        <di:waypoint x="510" y="200"/>
        <di:waypoint x="650" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="discuss_to_inform_di" bpmnElement="discuss_to_inform">
        <di:waypoint x="770" y="200"/>
        <di:waypoint x="840" y="200"/>
        <di:waypoint x="840" y="90"/>
        <di:waypoint x="910" y="90"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="inform_to_inform_event_di" bpmnElement="inform_to_inform_event">
        <di:waypoint x="1030" y="90"/>
        <di:waypoint x="1121" y="90"/>
        <di:waypoint x="1121" y="233"/>
        <di:waypoint x="1212" y="233"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="assessment_event_to_receive_assessment_di" bpmnElement="assessment_event_to_receive_assessment">
        <di:waypoint x="208" y="266"/>
        <di:waypoint x="320" y="266"/>
        <di:waypoint x="320" y="560"/>
        <di:waypoint x="432" y="560"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="receive_assessment_to_decision_di" bpmnElement="receive_assessment_to_decision">
        <di:waypoint x="468" y="560"/>
        <di:waypoint x="685" y="560"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="decision_to_prepare_di" bpmnElement="decision_to_prepare">
        <di:waypoint x="735" y="560"/>
        <di:waypoint x="822" y="560"/>
        <di:waypoint x="822" y="200"/>
        <di:waypoint x="910" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="decision_to_close_di" bpmnElement="decision_to_close">
        <di:waypoint x="735" y="560"/>
        <di:waypoint x="822" y="560"/>
        <di:waypoint x="822" y="310"/>
        <di:waypoint x="910" y="310"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="prepare_to_end_di" bpmnElement="prepare_to_end">
        <di:waypoint x="1030" y="200"/>
        <di:waypoint x="1121" y="200"/>
        <di:waypoint x="1121" y="167"/>
        <di:waypoint x="1212" y="167"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="close_to_end_di" bpmnElement="close_to_end">
        <di:waypoint x="1030" y="310"/>
        <di:waypoint x="1121" y="310"/>
        <di:waypoint x="1121" y="167"/>
        <di:waypoint x="1212" y="167"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="inform_candidate_message_di" bpmnElement="inform_candidate_message">
        <di:waypoint x="1230" y="251"/>
        <di:waypoint x="1230" y="892"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="assessment_message_di" bpmnElement="assessment_message">
        <di:waypoint x="190" y="248"/>
        <di:waypoint x="450" y="578"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p0_di" bpmnElement="MsgFlow_p0">
        <di:waypoint x="1230" y="251"/>
        <di:waypoint x="1230" y="892"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p1_di" bpmnElement="MsgFlow_p1">
        <di:waypoint x="1230" y="892"/>
        <di:waypoint x="190" y="284"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>