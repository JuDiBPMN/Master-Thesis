<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Library" name="Library System" processRef="Process_Library"/>
    <bpmn:participant id="actor_Requester" name="Requester" processRef="Process_Requester"/>
    <bpmn:messageFlow id="Book_Unavailable_to_Requester_Inform" name="Inform Requester of Unavailability" sourceRef="Book_Unavailable" targetRef="Requester_Inform"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="Book_Unavailable" targetRef="Requester_Inform"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Library" name="Library System" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Library">
      <bpmn:lane id="Library_Staff" name="Library Staff">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Book_Request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Book_Available</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Book_Unavailable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Check_Catalog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Inform_Requester</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Log_Book</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Retrieve_Book</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Check_Availability_Decision</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="Start"/>
    <bpmn:intermediateCatchEvent id="Book_Request" name="Book Request Received">
      <bpmn:messageEventDefinition id="Book_Request_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Book_Available" name="Book Available">
      <bpmn:messageEventDefinition id="Book_Available_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="Book_Unavailable" name="Book Unavailable">
      <bpmn:messageEventDefinition id="Book_Unavailable_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="End" name="End"/>
    <bpmn:task id="Check_Catalog" name="Check Catalog for Book Availability"/>
    <bpmn:task id="Inform_Requester" name="Inform Requester of Unavailability"/>
    <bpmn:task id="Log_Book" name="Log Book Against Requester's Account"/>
    <bpmn:task id="Retrieve_Book" name="Retrieve Book Using Automatic System"/>
    <bpmn:exclusiveGateway id="Check_Availability_Decision" name="Check Availability Decision" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="Start_to_Book_Request" sourceRef="Start" targetRef="Book_Request"/>
    <bpmn:sequenceFlow id="Book_Request_to_Check_Catalog" sourceRef="Book_Request" targetRef="Check_Catalog"/>
    <bpmn:sequenceFlow id="Check_Catalog_to_Check_Availability_Decision" sourceRef="Check_Catalog" targetRef="Check_Availability_Decision"/>
    <bpmn:sequenceFlow id="Check_Availability_Decision_to_Book_Available" sourceRef="Check_Availability_Decision" targetRef="Book_Available" name="Book is available">
      <bpmn:conditionExpression>Book is available</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Check_Availability_Decision_to_Book_Unavailable" sourceRef="Check_Availability_Decision" targetRef="Book_Unavailable" name="Book is unavailable">
      <bpmn:conditionExpression>Book is unavailable</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Book_Available_to_Log_Book" sourceRef="Book_Available" targetRef="Log_Book"/>
    <bpmn:sequenceFlow id="Book_Available_to_Retrieve_Book" sourceRef="Book_Available" targetRef="Retrieve_Book"/>
    <bpmn:sequenceFlow id="Log_Book_to_End" sourceRef="Log_Book" targetRef="End"/>
    <bpmn:sequenceFlow id="Retrieve_Book_to_End" sourceRef="Retrieve_Book" targetRef="End"/>
  </bpmn:process>
  <bpmn:process id="Process_Requester" name="Requester" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Requester">
      <bpmn:lane id="Requester" name="Requester"/>
    </bpmn:laneSet>
    <bpmn:intermediateCatchEvent id="Requester_Inform" name="Inform Requester">
      <bpmn:messageEventDefinition id="Requester_Inform_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="Requester_End" name="End"/>
    <bpmn:sequenceFlow id="Requester_Inform_to_Requester_End" sourceRef="Requester_Inform" targetRef="Requester_End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Library_di" bpmnElement="actor_Library" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="2060" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Requester_di" bpmnElement="actor_Requester" isHorizontal="true">
        <dc:Bounds x="10" y="330" width="760" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Library_Staff_di" bpmnElement="Library_Staff" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="2030" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Requester_di" bpmnElement="Requester" isHorizontal="true">
        <dc:Bounds x="40" y="330" width="730" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_di" bpmnElement="Start">
        <dc:Bounds x="172" y="72" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Inform_Requester_di" bpmnElement="Inform_Requester">
        <dc:Bounds x="130" y="138" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Book_Request_di" bpmnElement="Book_Request">
        <dc:Bounds x="432" y="127" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Book_Available_di" bpmnElement="Book_Available">
        <dc:Bounds x="1212" y="94" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Book_Unavailable_di" bpmnElement="Book_Unavailable">
        <dc:Bounds x="1212" y="160" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_di" bpmnElement="End">
        <dc:Bounds x="1732" y="127" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Check_Catalog_di" bpmnElement="Check_Catalog">
        <dc:Bounds x="650" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Log_Book_di" bpmnElement="Log_Book">
        <dc:Bounds x="1430" y="50" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Retrieve_Book_di" bpmnElement="Retrieve_Book">
        <dc:Bounds x="1430" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Check_Availability_Decision_di" bpmnElement="Check_Availability_Decision" isMarkerVisible="true">
        <dc:Bounds x="945" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Requester_Inform_di" bpmnElement="Requester_Inform">
        <dc:Bounds x="172" y="422" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Requester_End_di" bpmnElement="Requester_End">
        <dc:Bounds x="432" y="422" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Start_to_Book_Request_di" bpmnElement="Start_to_Book_Request">
        <di:waypoint x="208" y="90"/>
        <di:waypoint x="320" y="90"/>
        <di:waypoint x="320" y="145"/>
        <di:waypoint x="432" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Book_Request_to_Check_Catalog_di" bpmnElement="Book_Request_to_Check_Catalog">
        <di:waypoint x="468" y="145"/>
        <di:waypoint x="650" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Check_Catalog_to_Check_Availability_Decision_di" bpmnElement="Check_Catalog_to_Check_Availability_Decision">
        <di:waypoint x="770" y="145"/>
        <di:waypoint x="945" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Check_Availability_Decision_to_Book_Available_di" bpmnElement="Check_Availability_Decision_to_Book_Available">
        <di:waypoint x="995" y="145"/>
        <di:waypoint x="1103" y="145"/>
        <di:waypoint x="1103" y="112"/>
        <di:waypoint x="1212" y="112"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Check_Availability_Decision_to_Book_Unavailable_di" bpmnElement="Check_Availability_Decision_to_Book_Unavailable">
        <di:waypoint x="995" y="145"/>
        <di:waypoint x="1103" y="145"/>
        <di:waypoint x="1103" y="178"/>
        <di:waypoint x="1212" y="178"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Book_Available_to_Log_Book_di" bpmnElement="Book_Available_to_Log_Book">
        <di:waypoint x="1248" y="112"/>
        <di:waypoint x="1339" y="112"/>
        <di:waypoint x="1339" y="90"/>
        <di:waypoint x="1430" y="90"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Book_Available_to_Retrieve_Book_di" bpmnElement="Book_Available_to_Retrieve_Book">
        <di:waypoint x="1248" y="112"/>
        <di:waypoint x="1339" y="112"/>
        <di:waypoint x="1339" y="200"/>
        <di:waypoint x="1430" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Log_Book_to_End_di" bpmnElement="Log_Book_to_End">
        <di:waypoint x="1550" y="90"/>
        <di:waypoint x="1641" y="90"/>
        <di:waypoint x="1641" y="145"/>
        <di:waypoint x="1732" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Retrieve_Book_to_End_di" bpmnElement="Retrieve_Book_to_End">
        <di:waypoint x="1550" y="200"/>
        <di:waypoint x="1641" y="200"/>
        <di:waypoint x="1641" y="145"/>
        <di:waypoint x="1732" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Requester_Inform_to_Requester_End_di" bpmnElement="Requester_Inform_to_Requester_End">
        <di:waypoint x="208" y="440"/>
        <di:waypoint x="432" y="440"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Book_Unavailable_to_Requester_Inform_di" bpmnElement="Book_Unavailable_to_Requester_Inform">
        <di:waypoint x="1230" y="196"/>
        <di:waypoint x="190" y="422"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p0_di" bpmnElement="MsgFlow_p0">
        <di:waypoint x="1230" y="196"/>
        <di:waypoint x="190" y="422"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>