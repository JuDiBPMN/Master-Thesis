    <bpmn:sequenceFlow id="sf11" sourceRef="archive_complaint" targetRef="close_complaint"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="close_complaint" targetRef="end_csr"/>
  </bpmn:process>
