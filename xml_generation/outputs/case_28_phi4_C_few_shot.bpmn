    <bpmn:task id="archive_complaint" name="Archive Complaint Details"/>
    <bpmn:task id="close_complaint" name="Close Complaint"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_csr" targetRef="handle_complaint"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="handle_complaint" targetRef="record_call_details"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="handle_complaint" targetRef="document_concerns"/>
