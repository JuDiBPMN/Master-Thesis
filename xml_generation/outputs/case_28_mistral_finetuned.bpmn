<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_zarkan_industries" name="Zarkan Industries" processRef="Process_zarkan_industries"/>
    <bpmn:participant id="actor_csr" name="CSR" processRef="Process_csr"/>
    <bpmn:participant id="actor_other_departments" name="Other Departments" processRef="Process_other_departments"/>
    <bpmn:messageFlow id="mf1" name="Complaint Closed" sourceRef="close_complaint" targetRef="end_zarkan"/>
    <bpmn:messageFlow id="mf2" name="Complaint Received" sourceRef="start_csr" targetRef="handle_complaint"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="start_zarkan" targetRef="start_csr"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="gateway_join_analysis" targetRef="consult_other_departments"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="consult_other_departments" targetRef="resolve_complaint"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_zarkan_industries" name="Zarkan Industries" isExecutable="false">
    <bpmn:laneSet id="LaneSet_zarkan_industries">
      <bpmn:lane id="zarkan_industries" name="Zarkan Industries"/>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_zarkan" name="Start"/>
    <bpmn:endEvent id="end_zarkan" name="End"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="start_zarkan" targetRef="end_zarkan"/>
  </bpmn:process>
  <bpmn:process id="Process_csr" name="CSR" isExecutable="false">
    <bpmn:laneSet id="LaneSet_csr">
      <bpmn:lane id="csr" name="CSR"/>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_csr" name="Complaint Received">
      <bpmn:messageEventDefinition id="start_csr_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_csr" name="Complaint Closed">
      <bpmn:messageEventDefinition id="end_csr_def"/>
    </bpmn:endEvent>
    <bpmn:task id="handle_complaint" name="Handle Complaint"/>
    <bpmn:task id="record_call_details" name="Record Call Details"/>
    <bpmn:task id="document_customer_concerns" name="Document Customer Concerns"/>
    <bpmn:task id="note_letter_receipt" name="Note Letter Receipt Date"/>
    <bpmn:task id="analyze_complaint" name="Analyze Complaint"/>
    <bpmn:task id="resolve_complaint" name="Resolve Complaint"/>
    <bpmn:task id="archive_complaint" name="Archive Complaint"/>
    <bpmn:task id="close_complaint" name="Close Complaint"/>
    <bpmn:exclusiveGateway id="gateway_complaint_type" name="Complaint Type" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_complaint_resolved" name="Complaint Resolved?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_join_analysis" name="Analysis Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_join_resolution" name="Resolution Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="start_csr" targetRef="gateway_complaint_type"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="gateway_complaint_type" targetRef="record_call_details" name="Phone call">
      <bpmn:conditionExpression>Phone call</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf4" sourceRef="gateway_complaint_type" targetRef="document_customer_concerns" name="In-person complaint">
      <bpmn:conditionExpression>In-person complaint</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf5" sourceRef="gateway_complaint_type" targetRef="note_letter_receipt" name="Letter">
      <bpmn:conditionExpression>Letter</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="record_call_details" targetRef="analyze_complaint"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="document_customer_concerns" targetRef="analyze_complaint"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="note_letter_receipt" targetRef="analyze_complaint"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="analyze_complaint" targetRef="gateway_join_analysis"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="resolve_complaint" targetRef="gateway_join_resolution"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="gateway_join_resolution" targetRef="archive_complaint"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="archive_complaint" targetRef="close_complaint"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="close_complaint" targetRef="end_csr"/>
  </bpmn:process>
  <bpmn:process id="Process_other_departments" name="Other Departments" isExecutable="false">
    <bpmn:laneSet id="LaneSet_other_departments">
      <bpmn:lane id="other_departments" name="Other Departments"/>
    </bpmn:laneSet>
    <bpmn:task id="consult_other_departments" name="Consult Other Departments"/>
  </bpmn:process>
