<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Bank" name="Bank Process Flow for Mortgage Application Assessment" processRef="Process_Bank"/>
    <bpmn:participant id="actor_Client" name="Client Process Flow" processRef="Process_Client"/>
    <bpmn:messageFlow id="mf1" name="Send Mortgage File" sourceRef="send_mortgage_file" targetRef="receive_mortgage_file"/>
    <bpmn:messageFlow id="mf2" name="Send Assessment Result" sourceRef="send_assessment_result" targetRef="receive_assessment_result"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="send_mortgage_file" targetRef="receive_mortgage_file"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="receive_mortgage_file" targetRef="parallel_gateway"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="send_assessment_result" targetRef="receive_assessment_result"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Bank" name="Bank Process Flow for Mortgage Application Assessment" isExecutable="false">
    <bpmn:startEvent id="start_mortgage_assessment" name="Start Mortgage Assessment"/>
    <bpmn:endEvent id="end_mortgage_assessment" name="End Mortgage Assessment"/>
    <bpmn:intermediateCatchEvent id="receive_mortgage_application" name="Receive Mortgage Application">
      <bpmn:messageEventDefinition id="receive_mortgage_application_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="send_mortgage_file" name="Send Mortgage File">
      <bpmn:messageEventDefinition id="send_mortgage_file_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="send_assessment_result" name="Send Assessment Result">
      <bpmn:messageEventDefinition id="send_assessment_result_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:task id="create_mortgage_file" name="Create Mortgage File"/>
    <bpmn:task id="evaluate_financial_stability" name="Evaluate Client's Financial Stability"/>
    <bpmn:task id="gather_income_statements" name="Gather Income Statements"/>
    <bpmn:task id="check_other_credit_applications" name="Check for Other Credit Applications"/>
    <bpmn:task id="perform_risk_analysis" name="Perform Risk Analysis"/>
    <bpmn:task id="grant_line_of_credit" name="Grant Line of Credit"/>
    <bpmn:task id="decline_mortgage_application" name="Decline Mortgage Application"/>
    <bpmn:parallelGateway id="parallel_gateway" name="Parallel Gateway" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="parallel_gateway_join" name="Parallel Gateway Join" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="exclusive_gateway" name="Exclusive Gateway" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="exclusive_gateway_join" name="Exclusive Gateway Join" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_mortgage_assessment" targetRef="receive_mortgage_application"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="receive_mortgage_application" targetRef="create_mortgage_file"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="create_mortgage_file" targetRef="send_mortgage_file"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="parallel_gateway" targetRef="evaluate_financial_stability"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="parallel_gateway" targetRef="gather_income_statements"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="parallel_gateway" targetRef="check_other_credit_applications"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="evaluate_financial_stability" targetRef="parallel_gateway_join"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="gather_income_statements" targetRef="parallel_gateway_join"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="check_other_credit_applications" targetRef="parallel_gateway_join"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="parallel_gateway_join" targetRef="perform_risk_analysis"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="perform_risk_analysis" targetRef="exclusive_gateway"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="exclusive_gateway" targetRef="grant_line_of_credit"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="exclusive_gateway" targetRef="decline_mortgage_application"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="grant_line_of_credit" targetRef="send_assessment_result"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="decline_mortgage_application" targetRef="send_assessment_result"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="grant_line_of_credit" targetRef="end_mortgage_assessment"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="decline_mortgage_application" targetRef="end_mortgage_assessment"/>
  </bpmn:process>
  <bpmn:process id="Process_Client" name="Client Process Flow" isExecutable="false">
    <bpmn:endEvent id="end_mortgage_assessment_client" name="End Mortgage Assessment"/>
    <bpmn:intermediateCatchEvent id="receive_mortgage_file" name="Receive Mortgage File">
      <bpmn:messageEventDefinition id="receive_mortgage_file_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="receive_assessment_result" name="Receive Assessment Result">
      <bpmn:messageEventDefinition id="receive_assessment_result_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="sf19" sourceRef="receive_assessment_result" targetRef="end_mortgage_assessment_client"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
