      <bpmndi:BPMNShape id="Send_new_invoice_email_di" bpmnElement="Send_new_invoice_email">
        <dc:Bounds x="100" y="1149" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Create_ticket_event_di" bpmnElement="Create_ticket_event">
        <dc:Bounds x="662" y="907" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Determine_mistake_di" bpmnElement="Determine_mistake">
        <dc:Bounds x="360" y="885" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Investigate_invoicing_mistake_event_di" bpmnElement="Investigate_invoicing_mistake_event">
        <dc:Bounds x="142" y="1052" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Investigate_invoicing_mistake_di" bpmnElement="Investigate_invoicing_mistake">
        <dc:Bounds x="100" y="1118" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Make_correction_di" bpmnElement="Make_correction">
        <dc:Bounds x="100" y="1228" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Generate_new_invoice_di" bpmnElement="Generate_new_invoice">
        <dc:Bounds x="100" y="1338" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Make_correction_event_di" bpmnElement="Make_correction_event">
        <dc:Bounds x="402" y="1217" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Generate_new_invoice_event_di" bpmnElement="Generate_new_invoice_event">
        <dc:Bounds x="662" y="1217" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Customer_Service_to_Customer_Service_Determine_mistake_di" bpmnElement="Customer_Service_to_Customer_Service_Determine_mistake">
        <di:waypoint x="178" y="639"/>
