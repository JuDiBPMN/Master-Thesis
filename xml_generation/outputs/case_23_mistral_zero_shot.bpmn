<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Client" name="Client, external party”, " processRef="Process_Client"/>
    <bpmn:participant id="actor_BrightWave Energy" name="BrightWave Energy, organisation”, " processRef="Process_BrightWave Energy"/>
    <bpmn:participant id="actor_Customer Service" name="Customer Service, internal department, BrightWave Energy, " processRef="Process_Customer Service"/>
    <bpmn:participant id="actor_Invoicing" name="Invoicing, internal department, BrightWave Energy," processRef="Process_Invoicing"/>
    <bpmn:messageFlow id="Client_to_Customer_Service_message_flow" name="message_flow_Client_to_Customer_Service" sourceRef="Write_complaint_email" targetRef="Receive_complaint_email_event"/>
    <bpmn:messageFlow id="Customer_Service_to_Invoicing_message_flow" name="message_flow_Customer_Service_to_Invoicing" sourceRef="Create_ticket_event" targetRef="Investigate_invoicing_mistake_event"/>
    <bpmn:messageFlow id="Invoicing_to_Customer_Service_message_flow" name="message_flow_Invoicing_to_Customer_Service" sourceRef="Generate_new_invoice_event" targetRef="Send_new_invoice_email"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="Write_complaint_email" targetRef="Receive_complaint_email_event"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="Create_ticket_event" targetRef="Investigate_invoicing_mistake_event"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="Generate_new_invoice_event" targetRef="Send_new_invoice_email"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="Send_new_invoice_email" targetRef="End"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Client" name="Client, external party”, " isExecutable="false">
    <bpmn:laneSet id="LaneSet_Client">
      <bpmn:lane id="Client" name="Client"/>
    </bpmn:laneSet>
    <bpmn:task id="Write_complaint_email" name="Write complaint email"/>
  </bpmn:process>
  <bpmn:process id="Process_BrightWave Energy" name="BrightWave Energy, organisation”, " isExecutable="false">
    <bpmn:laneSet id="LaneSet_BrightWave Energy">
      <bpmn:lane id="Customer Service" name="Customer Service"/>
      <bpmn:lane id="Invoicing" name="Invoicing"/>
    </bpmn:laneSet>
  </bpmn:process>
  <bpmn:process id="Process_Customer Service" name="Customer Service, internal department, BrightWave Energy, " isExecutable="false">
    <bpmn:intermediateCatchEvent id="Receive_complaint_email_event" name="Receive complaint email event">
      <bpmn:messageEventDefinition id="Receive_complaint_email_event_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="Determine_mistake_event" name="Determine mistake event">
      <bpmn:messageEventDefinition id="Determine_mistake_event_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="Create_ticket_event" name="Create ticket event">
      <bpmn:messageEventDefinition id="Create_ticket_event_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="Send_new_invoice_email_event" name="Send new invoice email event">
      <bpmn:messageEventDefinition id="Send_new_invoice_email_event_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:task id="Receive_complaint_email" name="Receive complaint email"/>
    <bpmn:task id="Review_billing_information" name="Review billing information"/>
    <bpmn:task id="Determine_mistake" name="Determine mistake"/>
    <bpmn:task id="Create_ticket" name="Create ticket"/>
    <bpmn:task id="Send_new_invoice_email" name="Send new invoice email"/>
    <bpmn:sequenceFlow id="Customer_Service_to_Customer_Service_Determine_mistake" sourceRef="Receive_complaint_email_event" targetRef="Determine_mistake"/>
    <bpmn:sequenceFlow id="Customer_Service_to_Invoicing_Create_ticket" sourceRef="Determine_mistake" targetRef="Create_ticket_event"/>
  </bpmn:process>
  <bpmn:process id="Process_Invoicing" name="Invoicing, internal department, BrightWave Energy," isExecutable="false">
    <bpmn:intermediateCatchEvent id="Investigate_invoicing_mistake_event" name="Investigate invoicing mistake event">
      <bpmn:messageEventDefinition id="Investigate_invoicing_mistake_event_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="Make_correction_event" name="Make correction event">
      <bpmn:messageEventDefinition id="Make_correction_event_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Generate_new_invoice_event" name="Generate new invoice event">
      <bpmn:messageEventDefinition id="Generate_new_invoice_event_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Investigate_invoicing_mistake" name="Investigate invoicing mistake"/>
    <bpmn:task id="Make_correction" name="Make correction"/>
    <bpmn:task id="Generate_new_invoice" name="Generate new invoice"/>
    <bpmn:sequenceFlow id="Invoicing_to_Invoicing_Make_correction" sourceRef="Investigate_invoicing_mistake_event" targetRef="Make_correction_event"/>
    <bpmn:sequenceFlow id="Invoicing_to_Customer_Service_Generate_new_invoice" sourceRef="Make_correction_event" targetRef="Generate_new_invoice_event"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Client_di" bpmnElement="actor_Client" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="600" height="220"/>
