<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_hr_pool" name="HR Department" processRef="Process_hr_pool"/>
    <bpmn:participant id="actor_candidate_pool" name="Candidate" processRef="Process_candidate_pool"/>
    <bpmn:participant id="actor_hiring_manager_pool" name="Hiring Manager" processRef="Process_hiring_manager_pool"/>
    <bpmn:messageFlow id="mf1" name="Personality Assessment" sourceRef="send_personality_assessment" targetRef="complete_personality_assessment"/>
    <bpmn:messageFlow id="mf2" name="Rejection Email" sourceRef="send_rejection_email" targetRef="end_candidate"/>
    <bpmn:messageFlow id="mf3" name="Job Offer" sourceRef="send_job_offer" targetRef="end_candidate"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="start_hr" targetRef="submit_vacancy_request"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="submit_vacancy_request" targetRef="register_vacancy"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="post_job_advertisement" targetRef="start_candidate"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="start_candidate" targetRef="apply_for_vacancy"/>
    <bpmn:messageFlow id="MsgFlow_p4" name="" sourceRef="apply_for_vacancy" targetRef="screen_applications"/>
    <bpmn:messageFlow id="MsgFlow_p5" name="" sourceRef="gateway_parallel_split" targetRef="send_personality_assessment"/>
    <bpmn:messageFlow id="MsgFlow_p6" name="" sourceRef="schedule_technical_interview" targetRef="conduct_technical_interview"/>
    <bpmn:messageFlow id="MsgFlow_p7" name="" sourceRef="record_verdict" targetRef="gateway_parallel_join"/>
    <bpmn:messageFlow id="MsgFlow_p8" name="" sourceRef="send_personality_assessment" targetRef="complete_personality_assessment"/>
    <bpmn:messageFlow id="MsgFlow_p9" name="" sourceRef="complete_personality_assessment" targetRef="score_assessment"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_hr_pool" name="HR Department" isExecutable="false">
    <bpmn:laneSet id="LaneSet_hr_pool">
      <bpmn:lane id="hr_recruiter" name="HR Recruiter">
        <bpmn:flowNodeRef>start_hr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>post_job_advertisement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>screen_applications</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>schedule_technical_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>score_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>write_rejection_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>draft_job_offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_job_offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_outcome_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_outcome_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hr" name="Start"/>
    <bpmn:endEvent id="end_hr" name="End"/>
    <bpmn:task id="register_vacancy" name="Register Vacancy"/>
    <bpmn:task id="post_job_advertisement" name="Post Job Advertisement"/>
    <bpmn:task id="screen_applications" name="Screen Applications"/>
    <bpmn:task id="schedule_technical_interview" name="Schedule Technical Interview"/>
    <bpmn:task id="score_assessment" name="Score Assessment"/>
    <bpmn:task id="write_rejection_email" name="Write Rejection Email"/>
    <bpmn:task id="send_rejection_email" name="Send Rejection Email"/>
    <bpmn:task id="draft_job_offer" name="Draft Job Offer"/>
    <bpmn:task id="send_job_offer" name="Send Job Offer"/>
    <bpmn:parallelGateway id="gateway_parallel_split" name="Start Simultaneous Activities" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_join" name="Both Activities Completed" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_outcome_split" name="Verdicts?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_outcome_join" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_vacancy" targetRef="post_job_advertisement"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="screen_applications" targetRef="gateway_parallel_split"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="gateway_parallel_split" targetRef="schedule_technical_interview"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="score_assessment" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="gateway_parallel_join" targetRef="gateway_outcome_split"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="gateway_outcome_split" targetRef="write_rejection_email" name="at least one verdict is negative">
      <bpmn:conditionExpression>at least one verdict is negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf18" sourceRef="gateway_outcome_split" targetRef="draft_job_offer" name="both verdicts are positive">
      <bpmn:conditionExpression>both verdicts are positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf19" sourceRef="write_rejection_email" targetRef="send_rejection_email"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="send_rejection_email" targetRef="end_hr"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="draft_job_offer" targetRef="send_job_offer"/>
    <bpmn:sequenceFlow id="sf22" sourceRef="send_job_offer" targetRef="end_hr"/>
  </bpmn:process>
  <bpmn:process id="Process_candidate_pool" name="Candidate" isExecutable="false">
    <bpmn:laneSet id="LaneSet_candidate_pool">
      <bpmn:lane id="candidate" name="Candidate">
        <bpmn:flowNodeRef>start_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>complete_personality_assessment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_candidate" name="Start"/>
    <bpmn:endEvent id="end_candidate" name="End"/>
    <bpmn:task id="complete_personality_assessment" name="Complete Personality Assessment"/>
  </bpmn:process>
  <bpmn:process id="Process_hiring_manager_pool" name="Hiring Manager" isExecutable="false">
    <bpmn:laneSet id="LaneSet_hiring_manager_pool">
      <bpmn:lane id="hiring_manager" name="Hiring Manager">
        <bpmn:flowNodeRef>start_hiring_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hiring_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_vacancy_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>conduct_technical_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hiring_manager" name="Start"/>
    <bpmn:endEvent id="end_hiring_manager" name="End"/>
    <bpmn:task id="submit_vacancy_request" name="Submit Vacancy Request"/>
    <bpmn:task id="conduct_technical_interview" name="Conduct Technical Interview"/>
    <bpmn:task id="record_verdict" name="Record Verdict"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="conduct_technical_interview" targetRef="record_verdict"/>
    <bpmn:sequenceFlow id="sf23" sourceRef="start_hiring_manager" targetRef="end_hiring_manager"/>
  </bpmn:process>
