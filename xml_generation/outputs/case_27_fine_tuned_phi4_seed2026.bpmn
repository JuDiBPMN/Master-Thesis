<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Bank" name="Bank Process Flow for Mortgage Application Assessment" processRef="Process_Bank"/>
    <bpmn:participant id="actor_Client" name="Client" processRef="Process_Client"/>
    <bpmn:messageFlow id="financial_stability_message" name="Financial Stability" sourceRef="send_financial_stability" targetRef="receive_financial_stability"/>
    <bpmn:messageFlow id="income_statements_message" name="Income Statements" sourceRef="send_income_statements" targetRef="receive_income_statements"/>
    <bpmn:messageFlow id="credit_check_message" name="Credit Check" sourceRef="send_credit_check" targetRef="receive_credit_check"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="send_financial_stability" targetRef="receive_financial_stability"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="receive_financial_stability" targetRef="gather_income_statements"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="send_income_statements" targetRef="receive_income_statements"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="receive_income_statements" targetRef="check_other_credit_applications"/>
    <bpmn:messageFlow id="MsgFlow_p4" name="" sourceRef="send_credit_check" targetRef="receive_credit_check"/>
    <bpmn:messageFlow id="MsgFlow_p5" name="" sourceRef="receive_credit_check" targetRef="parallel_gateway_join"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Bank" name="Bank Process Flow for Mortgage Application Assessment" isExecutable="false">
    <bpmn:startEvent id="start_mortgage_assessment" name="Start Mortgage Assessment"/>
    <bpmn:endEvent id="end_mortgage_assessment" name="End Mortgage Assessment"/>
    <bpmn:intermediateThrowEvent id="send_financial_stability" name="Send Financial Stability">
      <bpmn:messageEventDefinition id="send_financial_stability_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="send_income_statements" name="Send Income Statements">
      <bpmn:messageEventDefinition id="send_income_statements_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="send_credit_check" name="Send Credit Check">
      <bpmn:messageEventDefinition id="send_credit_check_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:task id="create_mortgage_file" name="Create Mortgage File"/>
    <bpmn:task id="evaluate_financial_stability" name="Evaluate Client's Financial Stability"/>
    <bpmn:task id="gather_income_statements" name="Gather Income Statements"/>
    <bpmn:task id="check_other_credit_applications" name="Check for Other Credit Applications"/>
    <bpmn:task id="perform_risk_analysis" name="Perform Risk Analysis"/>
    <bpmn:task id="grant_line_of_credit" name="Grant Line of Credit"/>
    <bpmn:task id="decline_mortgage_application" name="Decline Mortgage Application"/>
    <bpmn:parallelGateway id="parallel_gateway_split" name="Parallel Gateway Split" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="parallel_gateway_join" name="Parallel Gateway Join" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="exclusive_gateway_split" name="Exclusive Gateway Split" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="exclusive_gateway_join" name="Exclusive Gateway Join" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="start_to_create" sourceRef="start_mortgage_assessment" targetRef="create_mortgage_file"/>
    <bpmn:sequenceFlow id="create_to_parallel_split" sourceRef="create_mortgage_file" targetRef="parallel_gateway_split"/>
    <bpmn:sequenceFlow id="parallel_split_to_evaluate" sourceRef="parallel_gateway_split" targetRef="evaluate_financial_stability"/>
    <bpmn:sequenceFlow id="parallel_split_to_gather" sourceRef="parallel_gateway_split" targetRef="gather_income_statements"/>
    <bpmn:sequenceFlow id="parallel_split_to_check" sourceRef="parallel_gateway_split" targetRef="check_other_credit_applications"/>
    <bpmn:sequenceFlow id="evaluate_to_send_financial" sourceRef="evaluate_financial_stability" targetRef="send_financial_stability"/>
    <bpmn:sequenceFlow id="gather_to_send_income" sourceRef="gather_income_statements" targetRef="send_income_statements"/>
    <bpmn:sequenceFlow id="check_to_send_credit" sourceRef="check_other_credit_applications" targetRef="send_credit_check"/>
    <bpmn:sequenceFlow id="parallel_join_to_risk_analysis" sourceRef="parallel_gateway_join" targetRef="perform_risk_analysis"/>
    <bpmn:sequenceFlow id="risk_analysis_to_exclusive_split" sourceRef="perform_risk_analysis" targetRef="exclusive_gateway_split"/>
    <bpmn:sequenceFlow id="exclusive_split_to_grant" sourceRef="exclusive_gateway_split" targetRef="grant_line_of_credit"/>
    <bpmn:sequenceFlow id="exclusive_split_to_decline" sourceRef="exclusive_gateway_split" targetRef="decline_mortgage_application"/>
    <bpmn:sequenceFlow id="grant_to_end" sourceRef="grant_line_of_credit" targetRef="end_mortgage_assessment"/>
    <bpmn:sequenceFlow id="decline_to_end" sourceRef="decline_mortgage_application" targetRef="end_mortgage_assessment"/>
  </bpmn:process>
  <bpmn:process id="Process_Client" name="Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Client">
      <bpmn:lane id="Client" name="Client"/>
    </bpmn:laneSet>
    <bpmn:intermediateCatchEvent id="receive_financial_stability" name="Receive Financial Stability">
      <bpmn:messageEventDefinition id="receive_financial_stability_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="receive_income_statements" name="Receive Income Statements">
      <bpmn:messageEventDefinition id="receive_income_statements_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="receive_credit_check" name="Receive Credit Check">
      <bpmn:messageEventDefinition id="receive_credit_check_def"/>
    </bpmn:intermediateCatchEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Bank_di" bpmnElement="actor_Bank" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="1510" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Client_di" bpmnElement="actor_Client" isHorizontal="true">
