      <bpmndi:BPMNShape id="parallel_gateway_split_di" bpmnElement="parallel_gateway_split" isMarkerVisible="true">
        <dc:Bounds x="655" y="80" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="exclusive_gateway_split_di" bpmnElement="exclusive_gateway_split" isMarkerVisible="true">
        <dc:Bounds x="655" y="160" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="receive_financial_stability_di" bpmnElement="receive_financial_stability">
        <dc:Bounds x="1212" y="426" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="receive_income_statements_di" bpmnElement="receive_income_statements">
        <dc:Bounds x="1212" y="492" width="36" height="36"/>
