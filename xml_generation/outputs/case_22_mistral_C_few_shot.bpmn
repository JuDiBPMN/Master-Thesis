      <bpmndi:BPMNShape id="post_job_advertisement_di" bpmnElement="post_job_advertisement">
        <dc:Bounds x="910" y="850" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="screen_applications_di" bpmnElement="screen_applications">
        <dc:Bounds x="1170" y="850" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="schedule_technical_interview_di" bpmnElement="schedule_technical_interview">
        <dc:Bounds x="1690" y="850" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="record_assessment_verdict_di" bpmnElement="record_assessment_verdict">
        <dc:Bounds x="390" y="850" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_outcomes_di" bpmnElement="review_outcomes">
        <dc:Bounds x="2730" y="850" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="write_rejection_email_di" bpmnElement="write_rejection_email">
        <dc:Bounds x="2990" y="795" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="draft_job_offer_di" bpmnElement="draft_job_offer">
        <dc:Bounds x="2990" y="905" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_shortlist_di" bpmnElement="split_shortlist" isMarkerVisible="true">
        <dc:Bounds x="1465" y="865" width="50" height="50"/>
