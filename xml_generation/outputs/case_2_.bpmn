<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:process id="Process_company" name="Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_company">
      <bpmn:lane id="employee" name="Employee">
        <bpmn:flowNodeRef>start_employee</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>initiate_idea</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_idea</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>express_value</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_request</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="manager" name="Manager">
        <bpmn:flowNodeRef>end_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>assess_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>initiate_project_plan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>lay_out_timeline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>set_up_budget</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>state_resources</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>communicate_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>start_project</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_approved_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_planning_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_planning_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_approved_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_employee" name="Start"/>
    <bpmn:endEvent id="end_manager" name="End"/>
    <bpmn:task id="initiate_idea" name="Initiate Idea for a project"/>
    <bpmn:task id="record_idea" name="Record Basic Idea in Document"/>
    <bpmn:task id="express_value" name="Express Value for company"/>
    <bpmn:task id="submit_request" name="Submit Request for Approval"/>
    <bpmn:task id="assess_request" name="Assess Request for Approval"/>
    <bpmn:task id="initiate_project_plan" name="Initiate Project Plan"/>
    <bpmn:task id="lay_out_timeline" name="Lay Out Timeline"/>
    <bpmn:task id="set_up_budget" name="Set Up Budget"/>
    <bpmn:task id="state_resources" name="State Required Resources"/>
    <bpmn:task id="communicate_rejection" name="Communicate Rejection"/>
    <bpmn:task id="start_project" name="Start Project"/>
    <bpmn:exclusiveGateway id="gateway_approved_split" name="Project Approved?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_planning_split" name="Plan in Parallel" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_planning_join" name="Planning Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_approved_join" name="Approval/Disapproval Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_employee" targetRef="initiate_idea"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="initiate_idea" targetRef="record_idea"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="record_idea" targetRef="express_value"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="express_value" targetRef="submit_request"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="submit_request" targetRef="assess_request"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="assess_request" targetRef="gateway_approved_split"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="gateway_approved_split" targetRef="initiate_project_plan" name="Approved">
      <bpmn:conditionExpression>Approved</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf8" sourceRef="gateway_approved_split" targetRef="communicate_rejection" name="Rejected">
      <bpmn:conditionExpression>Rejected</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf9" sourceRef="initiate_project_plan" targetRef="gateway_planning_split"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="gateway_planning_split" targetRef="lay_out_timeline"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="gateway_planning_split" targetRef="set_up_budget"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="gateway_planning_split" targetRef="state_resources"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="lay_out_timeline" targetRef="gateway_planning_join"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="set_up_budget" targetRef="gateway_planning_join"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="state_resources" targetRef="gateway_planning_join"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="gateway_planning_join" targetRef="start_project"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="communicate_rejection" targetRef="gateway_approved_join"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="start_project" targetRef="gateway_approved_join"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="gateway_approved_join" targetRef="end_manager"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
