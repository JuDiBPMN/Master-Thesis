<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Bank" name="Bank Process Flow" processRef="Process_Bank"/>
    <bpmn:participant id="actor_Client" name="Client Process Flow" processRef="Process_Client"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Bank" name="Bank Process Flow" isExecutable="false">
    <bpmn:startEvent id="start_event" name="Start Mortgage Assessment"/>
    <bpmn:endEvent id="end_event_positive" name="End Positive Assessment"/>
    <bpmn:endEvent id="end_event_negative" name="End Negative Assessment"/>
    <bpmn:intermediateCatchEvent id="intermediate_catch_event" name="Catch Event for Risk Analysis"/>
    <bpmn:task id="create_mortgage_file" name="Create Mortgage File"/>
    <bpmn:task id="evaluate_financial_stability" name="Evaluate Financial Stability"/>
    <bpmn:task id="gather_income_statements" name="Gather Income Statements"/>
    <bpmn:task id="check_other_credit_applications" name="Check Other Credit Applications"/>
    <bpmn:task id="perform_risk_analysis" name="Perform Risk Analysis"/>
    <bpmn:task id="grant_line_of_credit" name="Grant Line of Credit"/>
    <bpmn:task id="decline_mortgage_application" name="Decline Mortgage Application"/>
    <bpmn:parallelGateway id="parallel_gateway" name="Parallel Gateway" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="parallel_join_gateway" name="Parallel Join Gateway" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="exclusive_gateway" name="Exclusive Gateway" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="start_to_create" sourceRef="start_event" targetRef="create_mortgage_file"/>
    <bpmn:sequenceFlow id="create_to_parallel" sourceRef="create_mortgage_file" targetRef="parallel_gateway"/>
    <bpmn:sequenceFlow id="parallel_to_evaluate" sourceRef="parallel_gateway" targetRef="evaluate_financial_stability"/>
    <bpmn:sequenceFlow id="parallel_to_gather" sourceRef="parallel_gateway" targetRef="gather_income_statements"/>
    <bpmn:sequenceFlow id="parallel_to_check" sourceRef="parallel_gateway" targetRef="check_other_credit_applications"/>
    <bpmn:sequenceFlow id="parallel_join_to_risk" sourceRef="parallel_join_gateway" targetRef="perform_risk_analysis"/>
    <bpmn:sequenceFlow id="risk_to_exclusive" sourceRef="perform_risk_analysis" targetRef="exclusive_gateway"/>
    <bpmn:sequenceFlow id="exclusive_to_grant" sourceRef="exclusive_gateway" targetRef="grant_line_of_credit" name="positive">
      <bpmn:conditionExpression>positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="exclusive_to_decline" sourceRef="exclusive_gateway" targetRef="decline_mortgage_application" name="negative">
      <bpmn:conditionExpression>negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="grant_to_end_positive" sourceRef="grant_line_of_credit" targetRef="end_event_positive"/>
    <bpmn:sequenceFlow id="decline_to_end_negative" sourceRef="decline_mortgage_application" targetRef="end_event_negative"/>
  </bpmn:process>
  <bpmn:process id="Process_Client" name="Client Process Flow" isExecutable="false"/>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Bank_di" bpmnElement="actor_Bank" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="1510" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Client_di" bpmnElement="actor_Client" isHorizontal="true">
        <dc:Bounds x="10" y="330" width="400" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_event_di" bpmnElement="start_event">
        <dc:Bounds x="142" y="54" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="intermediate_catch_event_di" bpmnElement="intermediate_catch_event">
        <dc:Bounds x="142" y="120" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="parallel_join_gateway_di" bpmnElement="parallel_join_gateway" isMarkerVisible="true">
        <dc:Bounds x="135" y="186" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_event_positive_di" bpmnElement="end_event_positive">
        <dc:Bounds x="1182" y="94" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_event_negative_di" bpmnElement="end_event_negative">
        <dc:Bounds x="1182" y="160" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="create_mortgage_file_di" bpmnElement="create_mortgage_file">
        <dc:Bounds x="360" y="50" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="perform_risk_analysis_di" bpmnElement="perform_risk_analysis">
        <dc:Bounds x="360" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evaluate_financial_stability_di" bpmnElement="evaluate_financial_stability">
        <dc:Bounds x="880" y="-115" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gather_income_statements_di" bpmnElement="gather_income_statements">
        <dc:Bounds x="880" y="-5" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="check_other_credit_applications_di" bpmnElement="check_other_credit_applications">
        <dc:Bounds x="880" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="grant_line_of_credit_di" bpmnElement="grant_line_of_credit">
        <dc:Bounds x="880" y="215" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="decline_mortgage_application_di" bpmnElement="decline_mortgage_application">
        <dc:Bounds x="880" y="325" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="parallel_gateway_di" bpmnElement="parallel_gateway" isMarkerVisible="true">
        <dc:Bounds x="655" y="80" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="exclusive_gateway_di" bpmnElement="exclusive_gateway" isMarkerVisible="true">
        <dc:Bounds x="655" y="160" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="start_to_create_di" bpmnElement="start_to_create">
        <di:waypoint x="178" y="72"/>
        <di:waypoint x="269" y="72"/>
        <di:waypoint x="269" y="90"/>
        <di:waypoint x="360" y="90"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="create_to_parallel_di" bpmnElement="create_to_parallel">
        <di:waypoint x="480" y="90"/>
        <di:waypoint x="567" y="90"/>
        <di:waypoint x="567" y="105"/>
        <di:waypoint x="655" y="105"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="parallel_to_evaluate_di" bpmnElement="parallel_to_evaluate">
        <di:waypoint x="705" y="105"/>
        <di:waypoint x="792" y="105"/>
        <di:waypoint x="792" y="-75"/>
        <di:waypoint x="880" y="-75"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="parallel_to_gather_di" bpmnElement="parallel_to_gather">
        <di:waypoint x="705" y="105"/>
        <di:waypoint x="792" y="105"/>
        <di:waypoint x="792" y="35"/>
        <di:waypoint x="880" y="35"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="parallel_to_check_di" bpmnElement="parallel_to_check">
        <di:waypoint x="705" y="105"/>
        <di:waypoint x="792" y="105"/>
        <di:waypoint x="792" y="145"/>
        <di:waypoint x="880" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="parallel_join_to_risk_di" bpmnElement="parallel_join_to_risk">
        <di:waypoint x="185" y="211"/>
        <di:waypoint x="272" y="211"/>
        <di:waypoint x="272" y="200"/>
        <di:waypoint x="360" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="risk_to_exclusive_di" bpmnElement="risk_to_exclusive">
        <di:waypoint x="480" y="200"/>
        <di:waypoint x="567" y="200"/>
        <di:waypoint x="567" y="185"/>
        <di:waypoint x="655" y="185"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="exclusive_to_grant_di" bpmnElement="exclusive_to_grant">
        <di:waypoint x="705" y="185"/>
        <di:waypoint x="792" y="185"/>
        <di:waypoint x="792" y="255"/>
        <di:waypoint x="880" y="255"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="exclusive_to_decline_di" bpmnElement="exclusive_to_decline">
        <di:waypoint x="705" y="185"/>
        <di:waypoint x="792" y="185"/>
        <di:waypoint x="792" y="365"/>
        <di:waypoint x="880" y="365"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="grant_to_end_positive_di" bpmnElement="grant_to_end_positive">
        <di:waypoint x="1000" y="255"/>
        <di:waypoint x="1091" y="255"/>
        <di:waypoint x="1091" y="112"/>
        <di:waypoint x="1182" y="112"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="decline_to_end_negative_di" bpmnElement="decline_to_end_negative">
        <di:waypoint x="1000" y="365"/>
        <di:waypoint x="1091" y="365"/>
        <di:waypoint x="1091" y="178"/>
        <di:waypoint x="1182" y="178"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>