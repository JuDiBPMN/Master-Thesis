    <bpmn:sequenceFlow id="Review Outcomes Gateway to Send Rejection Notice" sourceRef="Review Outcomes Gateway" targetRef="Send Rejection Notice" name="either verdict is negative">
      <bpmn:conditionExpression>either verdict is negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Review Outcomes Gateway to Issue Grant Approval" sourceRef="Review Outcomes Gateway" targetRef="Issue Grant Approval" name="both verdicts are positive">
