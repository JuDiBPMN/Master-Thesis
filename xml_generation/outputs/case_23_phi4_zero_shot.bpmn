<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Pool_Client" name="Client" processRef="Process_Pool_Client"/>
    <bpmn:participant id="actor_Pool_BrightWave_Energy" name="BrightWave Energy" processRef="Process_Pool_BrightWave_Energy"/>
    <bpmn:messageFlow id="MessageFlow_1" name="Complaint Email" sourceRef="IntermediateThrowEvent_Send_Complaint" targetRef="IntermediateCatchEvent_Receive_Complaint"/>
    <bpmn:messageFlow id="MessageFlow_2" name="Explanation Email" sourceRef="IntermediateThrowEvent_Send_Explanation" targetRef="IntermediateCatchEvent_Receive_Explanation"/>
    <bpmn:messageFlow id="MessageFlow_3" name="New Invoice Email" sourceRef="IntermediateThrowEvent_Send_New_Invoice" targetRef="IntermediateCatchEvent_Receive_New_Invoice"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Pool_Client" name="Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Pool_Client">
      <bpmn:lane id="Lane_Client" name="Client">
        <bpmn:flowNodeRef>StartEvent_Client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateThrowEvent_Send_Complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateCatchEvent_Receive_Explanation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateCatchEvent_Receive_New_Invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Write_Complaint_Email</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Client" name="Start"/>
    <bpmn:endEvent id="EndEvent_Client" name="End"/>
    <bpmn:intermediateThrowEvent id="IntermediateThrowEvent_Send_Complaint" name="Send Complaint">
      <bpmn:messageEventDefinition id="IntermediateThrowEvent_Send_Complaint_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="IntermediateCatchEvent_Receive_Explanation" name="Receive Explanation">
      <bpmn:messageEventDefinition id="IntermediateCatchEvent_Receive_Explanation_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="IntermediateCatchEvent_Receive_New_Invoice" name="Receive New Invoice">
      <bpmn:messageEventDefinition id="IntermediateCatchEvent_Receive_New_Invoice_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="Task_Write_Complaint_Email" name="Write Complaint Email"/>
    <bpmn:sequenceFlow id="SequenceFlow_1" sourceRef="StartEvent_Client" targetRef="Task_Write_Complaint_Email"/>
    <bpmn:sequenceFlow id="SequenceFlow_2" sourceRef="Task_Write_Complaint_Email" targetRef="IntermediateThrowEvent_Send_Complaint"/>
    <bpmn:sequenceFlow id="SequenceFlow_9" sourceRef="IntermediateCatchEvent_Receive_Explanation" targetRef="EndEvent_Client"/>
    <bpmn:sequenceFlow id="SequenceFlow_16" sourceRef="IntermediateCatchEvent_Receive_New_Invoice" targetRef="EndEvent_Client"/>
  </bpmn:process>
  <bpmn:process id="Process_Pool_BrightWave_Energy" name="BrightWave Energy" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Pool_BrightWave_Energy">
      <bpmn:lane id="Lane_Customer_Service" name="Customer Service">
        <bpmn:flowNodeRef>EndEvent_BrightWave_Energy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateCatchEvent_Receive_Complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateThrowEvent_Send_Explanation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Receive_Complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Lookup_Billing_Information</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Review_Invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Write_Explanation_Email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Create_Ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Assign_Ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ExclusiveGateway_Check_Mistake</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Invoicing_Department" name="Invoicing Department">
        <bpmn:flowNodeRef>IntermediateThrowEvent_Send_New_Invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Investigate_Invoicing_Mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Make_Correction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Generate_New_Invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Send_New_Invoice_Email</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:endEvent id="EndEvent_BrightWave_Energy" name="End"/>
    <bpmn:intermediateCatchEvent id="IntermediateCatchEvent_Receive_Complaint" name="Receive Complaint">
      <bpmn:messageEventDefinition id="IntermediateCatchEvent_Receive_Complaint_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="IntermediateThrowEvent_Send_Explanation" name="Send Explanation">
      <bpmn:messageEventDefinition id="IntermediateThrowEvent_Send_Explanation_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="IntermediateThrowEvent_Send_New_Invoice" name="Send New Invoice">
      <bpmn:messageEventDefinition id="IntermediateThrowEvent_Send_New_Invoice_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:userTask id="Task_Receive_Complaint" name="Receive Complaint"/>
    <bpmn:userTask id="Task_Lookup_Billing_Information" name="Lookup Billing Information"/>
    <bpmn:userTask id="Task_Review_Invoice" name="Review Invoice"/>
    <bpmn:userTask id="Task_Write_Explanation_Email" name="Write Explanation Email"/>
    <bpmn:userTask id="Task_Create_Ticket" name="Create Ticket"/>
    <bpmn:userTask id="Task_Assign_Ticket" name="Assign Ticket"/>
    <bpmn:userTask id="Task_Investigate_Invoicing_Mistake" name="Investigate Invoicing Mistake"/>
    <bpmn:userTask id="Task_Make_Correction" name="Make Correction"/>
    <bpmn:userTask id="Task_Generate_New_Invoice" name="Generate New Invoice"/>
    <bpmn:userTask id="Task_Send_New_Invoice_Email" name="Send New Invoice Email"/>
    <bpmn:exclusiveGateway id="ExclusiveGateway_Check_Mistake" name="Check Mistake" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="SequenceFlow_3" sourceRef="IntermediateCatchEvent_Receive_Complaint" targetRef="Task_Receive_Complaint"/>
    <bpmn:sequenceFlow id="SequenceFlow_4" sourceRef="Task_Receive_Complaint" targetRef="Task_Lookup_Billing_Information"/>
    <bpmn:sequenceFlow id="SequenceFlow_5" sourceRef="Task_Lookup_Billing_Information" targetRef="Task_Review_Invoice"/>
    <bpmn:sequenceFlow id="SequenceFlow_6" sourceRef="Task_Review_Invoice" targetRef="ExclusiveGateway_Check_Mistake"/>
    <bpmn:sequenceFlow id="SequenceFlow_7" sourceRef="ExclusiveGateway_Check_Mistake" targetRef="Task_Write_Explanation_Email" name="no mistake">
      <bpmn:conditionExpression>no mistake</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SequenceFlow_8" sourceRef="Task_Write_Explanation_Email" targetRef="IntermediateThrowEvent_Send_Explanation"/>
    <bpmn:sequenceFlow id="SequenceFlow_10" sourceRef="ExclusiveGateway_Check_Mistake" targetRef="Task_Create_Ticket" name="mistake found">
      <bpmn:conditionExpression>mistake found</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SequenceFlow_11" sourceRef="Task_Create_Ticket" targetRef="Task_Assign_Ticket"/>
    <bpmn:sequenceFlow id="SequenceFlow_12" sourceRef="Task_Assign_Ticket" targetRef="Task_Investigate_Invoicing_Mistake"/>
    <bpmn:sequenceFlow id="SequenceFlow_13" sourceRef="Task_Investigate_Invoicing_Mistake" targetRef="Task_Make_Correction"/>
    <bpmn:sequenceFlow id="SequenceFlow_14" sourceRef="Task_Make_Correction" targetRef="Task_Generate_New_Invoice"/>
    <bpmn:sequenceFlow id="SequenceFlow_15" sourceRef="Task_Generate_New_Invoice" targetRef="IntermediateThrowEvent_Send_New_Invoice"/>
  </bpmn:process>
