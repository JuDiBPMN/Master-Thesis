      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="submit_return_request_di" bpmnElement="submit_return_request">
        <dc:Bounds x="390" y="215" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_retailer_di" bpmnElement="start_retailer">
        <dc:Bounds x="172" y="672" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="join_parallel_di" bpmnElement="join_parallel" isMarkerVisible="true">
        <dc:Bounds x="165" y="738" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_incomplete_di" bpmnElement="end_incomplete">
        <dc:Bounds x="1472" y="712" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="register_return_request_di" bpmnElement="register_return_request">
        <dc:Bounds x="390" y="635" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_outcomes_di" bpmnElement="review_outcomes">
        <dc:Bounds x="390" y="745" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="check_completeness_di" bpmnElement="check_completeness">
        <dc:Bounds x="650" y="650" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_outcome_di" bpmnElement="split_outcome" isMarkerVisible="true">
        <dc:Bounds x="685" y="760" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="notify_customer_di" bpmnElement="notify_customer">
        <dc:Bounds x="1170" y="595" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="process_refund_di" bpmnElement="process_refund">
        <dc:Bounds x="1170" y="705" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_parallel_di" bpmnElement="split_parallel" isMarkerVisible="true">
        <dc:Bounds x="1205" y="815" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="send_rejection_notice_di" bpmnElement="send_rejection_notice">
        <dc:Bounds x="910" y="595" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="approve_return_di" bpmnElement="approve_return">
        <dc:Bounds x="910" y="705" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_complete_di" bpmnElement="split_complete" isMarkerVisible="true">
        <dc:Bounds x="945" y="815" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
