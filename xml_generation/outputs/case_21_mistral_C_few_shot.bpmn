<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_customer" name="Customer" processRef="Process_customer"/>
    <bpmn:participant id="actor_retailer" name="Retailer" processRef="Process_retailer"/>
    <bpmn:messageFlow id="mf1" name="Return Request" sourceRef="submit_return_request" targetRef="start_retailer"/>
    <bpmn:messageFlow id="mf2" name="Refund Confirmation" sourceRef="review_outcomes" targetRef="end_customer"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="split_parallel" targetRef="inspect_product"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="split_parallel" targetRef="record_verdict"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="inspect_product" targetRef="join_parallel"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="record_verdict" targetRef="join_parallel"/>
    <bpmn:messageFlow id="MsgFlow_p4" name="" sourceRef="process_refund" targetRef="end_approved"/>
    <bpmn:messageFlow id="MsgFlow_p5" name="" sourceRef="send_rejection_notice" targetRef="end_rejected"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_customer" name="Customer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_customer">
      <bpmn:lane id="customer" name="Customer"/>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_customer" name="Start"/>
    <bpmn:endEvent id="end_customer" name="End"/>
    <bpmn:endEvent id="end_rejected" name="Return Rejected"/>
    <bpmn:endEvent id="end_approved" name="Return Approved"/>
    <bpmn:task id="submit_return_request" name="Submit Return Request"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_customer" targetRef="submit_return_request"/>
  </bpmn:process>
  <bpmn:process id="Process_retailer" name="Retailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_retailer">
      <bpmn:lane id="customer_service" name="Customer Service">
        <bpmn:flowNodeRef>start_retailer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_return_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_completeness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_customer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection_notice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>approve_return</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>process_refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_retailer" name="Return Request Received">
      <bpmn:messageEventDefinition id="start_retailer_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_incomplete" name="Customer Notified"/>
    <bpmn:task id="register_return_request" name="Register Return Request"/>
    <bpmn:task id="check_completeness" name="Check Request Completeness"/>
    <bpmn:task id="notify_customer" name="Notify Customer of Missing Info"/>
    <bpmn:task id="review_outcomes" name="Review Combined Verdicts"/>
    <bpmn:task id="send_rejection_notice" name="Send Return Rejection Notice"/>
    <bpmn:task id="approve_return" name="Approve Return"/>
    <bpmn:task id="process_refund" name="Process Refund"/>
    <bpmn:exclusiveGateway id="split_complete" name="Request Complete?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward for Inspection and Check" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Both Verdicts Positive?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="start_retailer" targetRef="register_return_request"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_return_request" targetRef="check_completeness"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="check_completeness" targetRef="split_complete"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="split_complete" targetRef="notify_customer" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_complete" targetRef="split_parallel" name="Complete">
      <bpmn:conditionExpression>Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="notify_customer" targetRef="end_incomplete"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="split_outcome" targetRef="send_rejection_notice" name="One or more verdicts negative">
      <bpmn:conditionExpression>One or more verdicts negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf15" sourceRef="split_outcome" targetRef="approve_return" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf16" sourceRef="approve_return" targetRef="process_refund"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_customer_di" bpmnElement="actor_customer" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="760" height="470"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_retailer_di" bpmnElement="actor_retailer" isHorizontal="true">
        <dc:Bounds x="10" y="550" width="1800" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="customer_di" bpmnElement="customer" isHorizontal="true">
