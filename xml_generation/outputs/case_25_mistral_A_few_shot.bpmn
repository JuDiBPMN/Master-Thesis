<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:process id="Process_Library" name="Library" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Library">
      <bpmn:lane id="library_staff" name="Library Staff">
        <bpmn:flowNodeRef>start_library_staff</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_library_staff</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_book_availability</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>inform_requester</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>log_book_against_requester</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>retrieve_book</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_book_availability</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_book_availability_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_library_staff" name="Start"/>
    <bpmn:endEvent id="end_library_staff" name="End"/>
    <bpmn:task id="check_book_availability" name="Check Book Availability"/>
    <bpmn:task id="inform_requester" name="Inform Requester"/>
    <bpmn:task id="log_book_against_requester" name="Log Book Against Requester"/>
    <bpmn:task id="retrieve_book" name="Retrieve Book"/>
    <bpmn:exclusiveGateway id="gateway_book_availability" name="Book Availability?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_book_availability_join" name="Procedure Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_library_staff" targetRef="check_book_availability"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="check_book_availability" targetRef="gateway_book_availability"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="gateway_book_availability" targetRef="inform_requester" name="book not available">
      <bpmn:conditionExpression>book not available</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf4" sourceRef="gateway_book_availability" targetRef="log_book_against_requester"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="log_book_against_requester" targetRef="retrieve_book"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="retrieve_book" targetRef="gateway_book_availability_join"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_Library">
      <bpmndi:BPMNShape id="library_staff_di" bpmnElement="library_staff" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="1770" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_library_staff_di" bpmnElement="start_library_staff">
        <dc:Bounds x="172" y="94" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_library_staff_di" bpmnElement="end_library_staff">
        <dc:Bounds x="172" y="160" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="check_book_availability_di" bpmnElement="check_book_availability">
        <dc:Bounds x="390" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="inform_requester_di" bpmnElement="inform_requester">
        <dc:Bounds x="910" y="50" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="log_book_against_requester_di" bpmnElement="log_book_against_requester">
        <dc:Bounds x="910" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="retrieve_book_di" bpmnElement="retrieve_book">
        <dc:Bounds x="1170" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_book_availability_di" bpmnElement="gateway_book_availability" isMarkerVisible="true">
        <dc:Bounds x="685" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_book_availability_join_di" bpmnElement="gateway_book_availability_join" isMarkerVisible="true">
        <dc:Bounds x="1465" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="208" y="112"/>
        <di:waypoint x="299" y="112"/>
        <di:waypoint x="299" y="145"/>
        <di:waypoint x="390" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="510" y="145"/>
        <di:waypoint x="685" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="735" y="145"/>
        <di:waypoint x="822" y="145"/>
        <di:waypoint x="822" y="90"/>
        <di:waypoint x="910" y="90"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="735" y="145"/>
        <di:waypoint x="822" y="145"/>
        <di:waypoint x="822" y="200"/>
        <di:waypoint x="910" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf5_di" bpmnElement="sf5">
        <di:waypoint x="1030" y="200"/>
        <di:waypoint x="1100" y="200"/>
        <di:waypoint x="1100" y="145"/>
        <di:waypoint x="1170" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="1290" y="145"/>
        <di:waypoint x="1465" y="145"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>