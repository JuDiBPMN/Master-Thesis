        <bpmn:flowNodeRef>SendRejectionNotice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ApproveReturn</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ProcessRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendRefundConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ExclusiveGateway_CheckInfo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ParallelGateway_Forward</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ParallelGateway_WaitForVerdicts</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ExclusiveGateway_OutcomeReview</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Warehouse" name="Warehouse">
        <bpmn:flowNodeRef>EndEvent_Warehouse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEvent_Warehouse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>InspectProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecordWarehouseVerdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Finance" name="Finance">
        <bpmn:flowNodeRef>EndEvent_Finance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CatchEvent_Finance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CheckPaymentEligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecordFinanceVerdict</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent" name="Start"/>
    <bpmn:endEvent id="EndEvent" name="End"/>
    <bpmn:endEvent id="EndEvent_Warehouse" name="End"/>
    <bpmn:endEvent id="EndEvent_Finance" name="End"/>
