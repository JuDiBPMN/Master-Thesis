    <bpmn:sequenceFlow id="OutcomeToRejection" sourceRef="ExclusiveGateway_OutcomeReview" targetRef="SendRejectionNotice"/>
    <bpmn:sequenceFlow id="RejectionToEnd" sourceRef="SendRejectionNotice" targetRef="EndEvent"/>
    <bpmn:sequenceFlow id="OutcomeToApproval" sourceRef="ExclusiveGateway_OutcomeReview" targetRef="ApproveReturn"/>
    <bpmn:sequenceFlow id="ApprovalToProcess" sourceRef="ApproveReturn" targetRef="ProcessRefund"/>
    <bpmn:sequenceFlow id="ProcessToEnd" sourceRef="ProcessRefund" targetRef="SendRefundConfirmation"/>
    <bpmn:sequenceFlow id="RefundToEnd" sourceRef="SendRefundConfirmation" targetRef="EndEvent"/>
  </bpmn:process>
