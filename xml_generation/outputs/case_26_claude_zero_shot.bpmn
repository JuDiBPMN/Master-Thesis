<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_pool_company" name="Company" processRef="Process_pool_company"/>
    <bpmn:participant id="actor_pool_candidate" name="Candidate" processRef="Process_pool_candidate"/>
    <bpmn:messageFlow id="mf01" name="Interview invitation" sourceRef="task_intro_interview" targetRef="start_candidate"/>
    <bpmn:messageFlow id="mf02" name="Candidate discussion request" sourceRef="task_discuss_candidate" targetRef="start_bm"/>
    <bpmn:messageFlow id="mf03" name="Application update" sourceRef="throw_hr_inform" targetRef="catch_candidate_info"/>
    <bpmn:messageFlow id="mf04" name="Second assessment result" sourceRef="throw_bm_assessment_done" targetRef="gw_assessment_split"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_pool_company" name="Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_pool_company">
      <bpmn:lane id="lane_hr" name="HR Manager">
        <bpmn:flowNodeRef>start_hr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_hr_inform</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hr_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hr_closed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_intro_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_discuss_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_inform_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_prepare_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_close_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_assessment_split</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_bm" name="Business Manager">
        <bpmn:flowNodeRef>start_bm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_bm_assessment_done</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_bm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_second_assessment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hr" name="Recruitment process started"/>
    <bpmn:intermediateThrowEvent id="throw_hr_inform" name="Send application update">
      <bpmn:messageEventDefinition id="throw_hr_inform_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_hr_contract" name="End – contract prepared"/>
    <bpmn:endEvent id="end_hr_closed" name="End – application closed"/>
    <bpmn:startEvent id="start_bm" name="Candidate discussion initiated">
      <bpmn:messageEventDefinition id="start_bm_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateThrowEvent id="throw_bm_assessment_done" name="Send assessment result">
      <bpmn:messageEventDefinition id="throw_bm_assessment_done_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_bm" name="End"/>
    <bpmn:userTask id="task_intro_interview" name="Perform introduction interview"/>
    <bpmn:userTask id="task_discuss_candidate" name="Discuss candidate"/>
    <bpmn:userTask id="task_inform_candidate" name="Inform candidate about application"/>
    <bpmn:userTask id="task_prepare_contract" name="Prepare contract"/>
    <bpmn:userTask id="task_close_application" name="Close application process"/>
    <bpmn:userTask id="task_second_assessment" name="Perform second assessment"/>
    <bpmn:parallelGateway id="gw_parallel_split" name="Discuss and inform simultaneously" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gw_parallel_join" name="Both actions complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gw_assessment_split" name="Second assessment successful?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf01" sourceRef="start_hr" targetRef="task_intro_interview"/>
    <bpmn:sequenceFlow id="sf02" sourceRef="task_intro_interview" targetRef="gw_parallel_split"/>
    <bpmn:sequenceFlow id="sf03" sourceRef="gw_parallel_split" targetRef="task_discuss_candidate"/>
    <bpmn:sequenceFlow id="sf04" sourceRef="task_discuss_candidate" targetRef="gw_parallel_join"/>
    <bpmn:sequenceFlow id="sf05" sourceRef="gw_parallel_split" targetRef="task_inform_candidate"/>
    <bpmn:sequenceFlow id="sf06" sourceRef="task_inform_candidate" targetRef="throw_hr_inform"/>
    <bpmn:sequenceFlow id="sf07" sourceRef="throw_hr_inform" targetRef="gw_parallel_join"/>
    <bpmn:sequenceFlow id="sf08" sourceRef="gw_parallel_join" targetRef="gw_assessment_split"/>
    <bpmn:sequenceFlow id="sf09" sourceRef="gw_assessment_split" targetRef="task_prepare_contract" name="Second assessment successful">
      <bpmn:conditionExpression>Second assessment successful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf10" sourceRef="task_prepare_contract" targetRef="end_hr_contract"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="gw_assessment_split" targetRef="task_close_application" name="Second assessment not successful">
      <bpmn:conditionExpression>Second assessment not successful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf12" sourceRef="task_close_application" targetRef="end_hr_closed"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="start_bm" targetRef="task_second_assessment"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="task_second_assessment" targetRef="throw_bm_assessment_done"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="throw_bm_assessment_done" targetRef="end_bm"/>
  </bpmn:process>
  <bpmn:process id="Process_pool_candidate" name="Candidate" isExecutable="false">
    <bpmn:laneSet id="LaneSet_pool_candidate">
      <bpmn:lane id="lane_candidate" name="Candidate">
        <bpmn:flowNodeRef>start_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_candidate_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_attend_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_receive_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_attend_assessment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_candidate" name="Interview invitation received">
      <bpmn:messageEventDefinition id="start_candidate_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="catch_candidate_info" name="Receive application update">
      <bpmn:messageEventDefinition id="catch_candidate_info_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_candidate" name="End"/>
    <bpmn:userTask id="task_attend_interview" name="Attend introduction interview"/>
    <bpmn:userTask id="task_receive_info" name="Receive application update"/>
    <bpmn:userTask id="task_attend_assessment" name="Attend second assessment"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="start_candidate" targetRef="task_attend_interview"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="task_attend_interview" targetRef="catch_candidate_info"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="catch_candidate_info" targetRef="task_receive_info"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="task_receive_info" targetRef="task_attend_assessment"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="task_attend_assessment" targetRef="end_candidate"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_pool_company_di" bpmnElement="actor_pool_company" isHorizontal="true">
