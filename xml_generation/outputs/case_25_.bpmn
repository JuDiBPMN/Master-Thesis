<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_applicant_pool" name="Applicant Organisation" processRef="Process_applicant_pool"/>
    <bpmn:participant id="actor_agency_pool" name="Government Agency" processRef="Process_agency_pool"/>
    <bpmn:messageFlow id="mf1" name="Grant Application" sourceRef="submit_application" targetRef="start_grants"/>
    <bpmn:messageFlow id="mf2" name="Missing Documents Notice" sourceRef="throw_incomplete" targetRef="catch_incomplete"/>
    <bpmn:messageFlow id="mf3" name="Resubmitted Documents" sourceRef="throw_resubmit" targetRef="catch_resubmission"/>
    <bpmn:messageFlow id="mf4" name="Rejection Notice" sourceRef="throw_rejection" targetRef="catch_rejection"/>
    <bpmn:messageFlow id="mf5" name="Grant Approval Letter" sourceRef="throw_approval" targetRef="catch_approval"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_applicant_pool" name="Applicant Organisation" isExecutable="false">
    <bpmn:laneSet id="LaneSet_applicant_pool">
      <bpmn:lane id="applicant" name="Applicant Organisation">
        <bpmn:flowNodeRef>start_applicant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_resubmit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_applicant_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_approval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_applicant_approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>collect_docs</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_applicant" name="Start"/>
    <bpmn:intermediateCatchEvent id="catch_incomplete" name="Missing Documents Notice Received">
      <bpmn:messageEventDefinition id="catch_incomplete_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_resubmit" name="Resubmit Documents">
      <bpmn:messageEventDefinition id="throw_resubmit_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_rejection" name="Rejection Notice Received">
      <bpmn:messageEventDefinition id="catch_rejection_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_applicant_rejected" name="Ended: Application Rejected"/>
    <bpmn:intermediateCatchEvent id="catch_approval" name="Approval Letter Received">
      <bpmn:messageEventDefinition id="catch_approval_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_applicant_approved" name="Ended: Grant Approved"/>
    <bpmn:task id="submit_application" name="Submit Grant Application"/>
    <bpmn:task id="collect_docs" name="Collect Missing Documents"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_applicant" targetRef="submit_application"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="catch_incomplete" targetRef="collect_docs"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="collect_docs" targetRef="throw_resubmit"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="catch_rejection" targetRef="end_applicant_rejected"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="catch_approval" targetRef="end_applicant_approved"/>
  </bpmn:process>
  <bpmn:process id="Process_agency_pool" name="Government Agency" isExecutable="false">
    <bpmn:laneSet id="LaneSet_agency_pool">
      <bpmn:lane id="grants_admin" name="Grants Administrator">
        <bpmn:flowNodeRef>start_grants</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_resubmission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_approval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_grants</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>issue_approval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_rework</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="tech_review" name="Technical Review Panel">
        <bpmn:flowNodeRef>assess_feasibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_tech</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance" name="Finance Department">
        <bpmn:flowNodeRef>review_budget</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_finance</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_grants" name="Application Received">
      <bpmn:messageEventDefinition id="start_grants_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateThrowEvent id="throw_incomplete" name="Notify Applicant of Missing Docs">
      <bpmn:messageEventDefinition id="throw_incomplete_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_resubmission" name="Receive Resubmitted Documents">
      <bpmn:messageEventDefinition id="catch_resubmission_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_rejection" name="Send Rejection Notice">
      <bpmn:messageEventDefinition id="throw_rejection_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_approval" name="Send Grant Approval Letter">
      <bpmn:messageEventDefinition id="throw_approval_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_grants" name="Process Complete"/>
    <bpmn:task id="register_application" name="Register Grant Application"/>
    <bpmn:task id="check_docs" name="Check Documentation Completeness"/>
    <bpmn:task id="review_outcomes" name="Review Combined Verdicts"/>
    <bpmn:task id="send_rejection" name="Send Rejection Notice"/>
    <bpmn:task id="issue_approval" name="Issue Grant Approval Letter"/>
    <bpmn:task id="assess_feasibility" name="Assess Project Feasibility"/>
    <bpmn:task id="record_tech" name="Record Technical Verdict"/>
    <bpmn:task id="review_budget" name="Review Proposed Budget"/>
    <bpmn:task id="record_finance" name="Record Finance Verdict"/>
    <bpmn:exclusiveGateway id="join_rework" name="Recheck Documentation" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_complete" name="Documentation Complete?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward for Review" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Both Verdicts Positive?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_outcome" name="Merge Outcome Paths" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="start_grants" targetRef="register_application"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="register_application" targetRef="join_rework"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="join_rework" targetRef="check_docs"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="check_docs" targetRef="split_complete"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="split_complete" targetRef="throw_incomplete" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf11" sourceRef="split_complete" targetRef="split_parallel" name="Complete">
      <bpmn:conditionExpression>Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf12" sourceRef="catch_resubmission" targetRef="join_rework"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="split_parallel" targetRef="assess_feasibility"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="split_parallel" targetRef="review_budget"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="assess_feasibility" targetRef="record_tech"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="record_tech" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="review_budget" targetRef="record_finance"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="record_finance" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="split_outcome" targetRef="send_rejection" name="One or more verdicts negative">
      <bpmn:conditionExpression>One or more verdicts negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf22" sourceRef="split_outcome" targetRef="issue_approval" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf23" sourceRef="send_rejection" targetRef="throw_rejection"/>
    <bpmn:sequenceFlow id="sf24" sourceRef="issue_approval" targetRef="throw_approval"/>
    <bpmn:sequenceFlow id="sf25" sourceRef="throw_rejection" targetRef="join_outcome"/>
    <bpmn:sequenceFlow id="sf26" sourceRef="throw_approval" targetRef="join_outcome"/>
    <bpmn:sequenceFlow id="sf27" sourceRef="join_outcome" targetRef="end_grants"/>
  </bpmn:process>
