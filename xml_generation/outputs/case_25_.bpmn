<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="1.0">
  <bpmn:process id="Process_publishing_house" name="Publishing House" isExecutable="false">
    <bpmn:laneSet id="LaneSet_publishing_house">
      <bpmn:lane id="editorial_manager" name="Editorial Manager">
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>assign_manuscript</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_proof</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>identify_issues</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_proof</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="editor" name="Editor">
        <bpmn:flowNodeRef>proofread_manuscript</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="layout_designer" name="Layout Designer">
        <bpmn:flowNodeRef>format_pages</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>apply_corrections</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="print_manager" name="Print Manager">
        <bpmn:flowNodeRef>end</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>proof_requested</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_to_printer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>produce_proof</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>place_print_order</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_proof_loop</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start" name="Manuscript Accepted"/>
    <bpmn:endEvent id="end" name="Print Order Placed"/>
    <bpmn:intermediateThrowEvent id="proof_requested" name="New Proof Requested"/>
    <bpmn:task id="assign_manuscript" name="Assign Manuscript"/>
    <bpmn:task id="proofread_manuscript" name="Proofread and Correct Manuscript"/>
    <bpmn:task id="format_pages" name="Format Pages and Design Cover"/>
    <bpmn:task id="send_to_printer" name="Send Files to Printer"/>
    <bpmn:task id="produce_proof" name="Produce Proof Copy"/>
    <bpmn:task id="review_proof" name="Review Proof"/>
    <bpmn:task id="place_print_order" name="Place Full Print Order"/>
    <bpmn:task id="identify_issues" name="Identify Proof Issues"/>
    <bpmn:task id="apply_corrections" name="Apply Corrections"/>
    <bpmn:parallelGateway id="split_parallel" name="Assign Parallel Tracks" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Tracks Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_proof" name="Proof Approved?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_proof_loop" name="Proof Review Loop Join" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start" targetRef="assign_manuscript"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="assign_manuscript" targetRef="split_parallel"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="split_parallel" targetRef="proofread_manuscript"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="split_parallel" targetRef="format_pages"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="proofread_manuscript" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="format_pages" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="join_parallel" targetRef="send_to_printer"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="send_to_printer" targetRef="join_proof_loop"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="join_proof_loop" targetRef="produce_proof"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="produce_proof" targetRef="review_proof"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="review_proof" targetRef="split_proof"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="split_proof" targetRef="place_print_order" name="Proof approved">
      <bpmn:conditionExpression>Proof approved</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf13" sourceRef="split_proof" targetRef="identify_issues" name="Proof rejected">
      <bpmn:conditionExpression>Proof rejected</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf14" sourceRef="identify_issues" targetRef="apply_corrections"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="apply_corrections" targetRef="proof_requested"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="proof_requested" targetRef="join_proof_loop"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="place_print_order" targetRef="end"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_publishing_house">
      <bpmndi:BPMNShape id="editorial_manager_di" bpmnElement="editorial_manager" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="1270" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="editor_di" bpmnElement="editor" isHorizontal="true">
        <dc:Bounds x="40" y="180" width="1270" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="layout_designer_di" bpmnElement="layout_designer" isHorizontal="true">
        <dc:Bounds x="40" y="340" width="1270" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="print_manager_di" bpmnElement="print_manager" isHorizontal="true">
        <dc:Bounds x="40" y="500" width="1270" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <dc:Bounds x="110" y="82" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_proof_di" bpmnElement="review_proof">
        <dc:Bounds x="270" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="assign_manuscript_di" bpmnElement="assign_manuscript">
        <dc:Bounds x="430" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_proof_di" bpmnElement="split_proof" isMarkerVisible="true">
        <dc:Bounds x="590" y="75" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_parallel_di" bpmnElement="split_parallel" isMarkerVisible="true">
        <dc:Bounds x="750" y="75" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="identify_issues_di" bpmnElement="identify_issues">
        <dc:Bounds x="910" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="proofread_manuscript_di" bpmnElement="proofread_manuscript">
        <dc:Bounds x="110" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="format_pages_di" bpmnElement="format_pages">
        <dc:Bounds x="110" y="380" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="apply_corrections_di" bpmnElement="apply_corrections">
        <dc:Bounds x="270" y="380" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="proof_requested_di" bpmnElement="proof_requested">
        <dc:Bounds x="110" y="562" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="place_print_order_di" bpmnElement="place_print_order">
        <dc:Bounds x="270" y="540" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="join_parallel_di" bpmnElement="join_parallel" isMarkerVisible="true">
        <dc:Bounds x="430" y="555" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <dc:Bounds x="590" y="562" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="send_to_printer_di" bpmnElement="send_to_printer">
        <dc:Bounds x="750" y="540" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="join_proof_loop_di" bpmnElement="join_proof_loop" isMarkerVisible="true">
        <dc:Bounds x="910" y="555" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="produce_proof_di" bpmnElement="produce_proof">
        <dc:Bounds x="1070" y="540" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="146" y="100"/>
        <di:waypoint x="430" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="530" y="100"/>
        <di:waypoint x="750" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="800" y="100"/>
        <di:waypoint x="110" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="800" y="100"/>
        <di:waypoint x="110" y="420"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf5_di" bpmnElement="sf5">
        <di:waypoint x="210" y="260"/>
        <di:waypoint x="430" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="210" y="420"/>
        <di:waypoint x="430" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
        <di:waypoint x="480" y="580"/>
        <di:waypoint x="750" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="850" y="580"/>
        <di:waypoint x="910" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="960" y="580"/>
        <di:waypoint x="1070" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf10_di" bpmnElement="sf10">
        <di:waypoint x="1170" y="580"/>
        <di:waypoint x="270" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf11_di" bpmnElement="sf11">
        <di:waypoint x="370" y="100"/>
        <di:waypoint x="590" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf12_di" bpmnElement="sf12">
        <di:waypoint x="640" y="100"/>
        <di:waypoint x="270" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf13_di" bpmnElement="sf13">
        <di:waypoint x="640" y="100"/>
        <di:waypoint x="910" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf14_di" bpmnElement="sf14">
        <di:waypoint x="1010" y="100"/>
        <di:waypoint x="270" y="420"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf15_di" bpmnElement="sf15">
        <di:waypoint x="370" y="420"/>
        <di:waypoint x="110" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf16_di" bpmnElement="sf16">
        <di:waypoint x="146" y="580"/>
        <di:waypoint x="910" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf17_di" bpmnElement="sf17">
        <di:waypoint x="370" y="580"/>
        <di:waypoint x="590" y="580"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>