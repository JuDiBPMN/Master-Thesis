      <bpmndi:BPMNShape id="Event_1jw3y5s_di" bpmnElement="Event_1jw3y5s">
        <dc:Bounds x="132" y="308" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_1q3kz12_di" bpmnElement="Event_1q3kz12">
        <dc:Bounds x="132" y="335" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="submit_thesis_di" bpmnElement="submit_thesis">
        <dc:Bounds x="290" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1j3q2vx_di" bpmnElement="Flow_1j3q2vx">
        <di:waypoint x="168" y="246"/>
        <di:waypoint x="229" y="246"/>
        <di:waypoint x="229" y="300"/>
        <di:waypoint x="290" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="200" y="148"/>
        <di:waypoint x="257" y="148"/>
        <di:waypoint x="257" y="100"/>
        <di:waypoint x="315" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="365" y="100"/>
        <di:waypoint x="480" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="mf1_di" bpmnElement="mf1">
        <di:waypoint x="340" y="260"/>
        <di:waypoint x="150" y="70"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p0_di" bpmnElement="MsgFlow_p0">
