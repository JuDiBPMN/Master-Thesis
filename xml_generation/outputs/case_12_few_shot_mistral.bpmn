      <bpmndi:BPMNShape id="administration_di" bpmnElement="administration" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="720" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="student_di" bpmnElement="student" isHorizontal="true">
        <dc:Bounds x="40" y="220" width="530" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_admin_di" bpmnElement="start_admin">
        <dc:Bounds x="132" y="34" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0xqzq3w_di" bpmnElement="Event_0xqzq3w">
        <dc:Bounds x="132" y="66" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_admin_di" bpmnElement="end_admin">
        <dc:Bounds x="132" y="98" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="check_completeness_di" bpmnElement="check_completeness">
        <dc:Bounds x="100" y="108" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="notify_missing_docs_di" bpmnElement="notify_missing_docs">
        <dc:Bounds x="480" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_completeness_di" bpmnElement="split_completeness" isMarkerVisible="true">
        <dc:Bounds x="315" y="75" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_student_di" bpmnElement="start_student">
        <dc:Bounds x="132" y="228" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0qjxq3x_di" bpmnElement="Event_0qjxq3x">
        <dc:Bounds x="132" y="255" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_student_di" bpmnElement="end_student">
        <dc:Bounds x="132" y="282" width="36" height="36"/>
