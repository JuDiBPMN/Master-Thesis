<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_university" name="University" processRef="Process_university"/>
    <bpmn:participant id="actor_student_pool" name="Student" processRef="Process_student_pool"/>
    <bpmn:messageFlow id="mf1" name="Thesis Submitted" sourceRef="submit_thesis" targetRef="start_admin"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="submit_thesis" targetRef="check_completeness"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="Complete" sourceRef="split_completeness" targetRef="evaluate_thesis"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="send_rejection_notice" targetRef="end_student"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="send_rejection_notice" targetRef="end_student"/>
    <bpmn:messageFlow id="MsgFlow_p4" name="" sourceRef="issue_grade" targetRef="Event_1jw3y5s"/>
    <bpmn:messageFlow id="MsgFlow_p5" name="" sourceRef="evaluate_thesis" targetRef="Event_0xqzq3w"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_university" name="University" isExecutable="false">
    <bpmn:laneSet id="LaneSet_university">
      <bpmn:lane id="administration" name="Administration Office">
        <bpmn:flowNodeRef>start_admin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0xqzq3w</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_admin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_completeness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_missing_docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_completeness</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_admin" name="Thesis Submitted"/>
    <bpmn:intermediateCatchEvent id="Event_0xqzq3w" name="Receive complete submission">
      <bpmn:messageEventDefinition id="Event_0xqzq3w_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_admin" name="Process Ends"/>
    <bpmn:task id="check_completeness" name="Check Submission Completeness"/>
    <bpmn:task id="notify_missing_docs" name="Notify Student of Missing Docs"/>
    <bpmn:exclusiveGateway id="split_completeness" name="Submission Completeness?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="check_completeness" targetRef="split_completeness"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="split_completeness" targetRef="notify_missing_docs" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmn:process id="Process_student_pool" name="Student" isExecutable="false">
    <bpmn:laneSet id="LaneSet_student_pool">
      <bpmn:lane id="student" name="Student">
        <bpmn:flowNodeRef>start_student</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0qjxq3x</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_student</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1jw3y5s</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1q3kz12</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_thesis</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_student" name="Start"/>
    <bpmn:intermediateCatchEvent id="Event_0qjxq3x" name="Receive missing docs notification">
      <bpmn:messageEventDefinition id="Event_0qjxq3x_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_student" name="Process Ends"/>
    <bpmn:intermediateCatchEvent id="Event_1jw3y5s" name="Receive grade">
      <bpmn:messageEventDefinition id="Event_1jw3y5s_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_1q3kz12" name="Receive rejection notice">
      <bpmn:messageEventDefinition id="Event_1q3kz12_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="submit_thesis" name="Submit Thesis"/>
    <bpmn:sequenceFlow id="Flow_1j3q2vx" sourceRef="start_student" targetRef="submit_thesis"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_university_di" bpmnElement="actor_university" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="750" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_student_pool_di" bpmnElement="actor_student_pool" isHorizontal="true">
