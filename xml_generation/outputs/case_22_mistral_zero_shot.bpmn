<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Company" name="Company, HR department and hiring managers pool”, " processRef="Process_Company"/>
    <bpmn:participant id="actor_Candidate" name="Candidate pool" processRef="Process_Candidate"/>
    <bpmn:messageFlow id="Personality_Assessment_Message_Flow" name="Personality assessment message flow" sourceRef="Technical_Interview_Scheduled" targetRef="Personality_Assessment_Received"/>
    <bpmn:messageFlow id="Verdicts_Message_Flow" name="Verdicts message flow" sourceRef="Record_Verdicts" targetRef="Parallel_Join"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Company" name="Company, HR department and hiring managers pool”, " isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="HR_Department" name="HR department">
        <bpmn:flowNodeRef>Vacancy_Request_Received</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Application_Received</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Technical_Interview_Scheduled</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Personality_Assessment_Received</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Verdicts_Recorded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Job_Offer_Drafted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Job_Offer_Sent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Rejection_Email_Sent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Register_Vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Post_Job_Advertisement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Screen_Applications</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Schedule_Technical_Interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Send_Personality_Assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Score_Personality_Assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Record_Verdicts</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Write_Rejection_Email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Draft_Job_Offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Send_Job_Offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Parallel_Split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Parallel_Join</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Hiring_Manager" name="Hiring manager">
        <bpmn:flowNodeRef>Submit_Vacancy_Request</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Vacancy_Request_Received" name="Vacancy request received"/>
    <bpmn:intermediateCatchEvent id="Application_Received" name="Application received">
      <bpmn:messageEventDefinition id="Application_Received_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="Technical_Interview_Scheduled" name="Technical interview scheduled">
      <bpmn:messageEventDefinition id="Technical_Interview_Scheduled_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Personality_Assessment_Received" name="Personality assessment received">
      <bpmn:messageEventDefinition id="Personality_Assessment_Received_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="Verdicts_Recorded" name="Verdicts recorded"/>
    <bpmn:intermediateThrowEvent id="Job_Offer_Drafted" name="Job offer drafted"/>
    <bpmn:endEvent id="Job_Offer_Sent" name="Job offer sent"/>
    <bpmn:endEvent id="Rejection_Email_Sent" name="Rejection email sent"/>
    <bpmn:task id="Submit_Vacancy_Request" name="Submit vacancy request"/>
    <bpmn:task id="Register_Vacancy" name="Register vacancy"/>
    <bpmn:task id="Post_Job_Advertisement" name="Post job advertisement"/>
    <bpmn:task id="Screen_Applications" name="Screen applications"/>
    <bpmn:task id="Schedule_Technical_Interview" name="Schedule technical interview"/>
    <bpmn:task id="Send_Personality_Assessment" name="Send personality assessment"/>
    <bpmn:task id="Score_Personality_Assessment" name="Score personality assessment"/>
    <bpmn:task id="Record_Verdicts" name="Record verdicts"/>
    <bpmn:task id="Write_Rejection_Email" name="Write rejection email"/>
    <bpmn:task id="Draft_Job_Offer" name="Draft job offer"/>
    <bpmn:task id="Send_Job_Offer" name="Send job offer"/>
    <bpmn:parallelGateway id="Parallel_Split" name="Parallel split" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="Parallel_Join" name="Parallel join" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="Vacancy_Request_Received_to_Register_Vacancy" sourceRef="Vacancy_Request_Received" targetRef="Register_Vacancy"/>
    <bpmn:sequenceFlow id="Register_Vacancy_to_Post_Job_Advertisement" sourceRef="Register_Vacancy" targetRef="Post_Job_Advertisement"/>
    <bpmn:sequenceFlow id="Post_Job_Advertisement_to_Screen_Applications" sourceRef="Post_Job_Advertisement" targetRef="Screen_Applications"/>
    <bpmn:sequenceFlow id="Screen_Applications_to_Schedule_Technical_Interview" sourceRef="Screen_Applications" targetRef="Schedule_Technical_Interview"/>
    <bpmn:sequenceFlow id="Schedule_Technical_Interview_to_Send_Personality_Assessment" sourceRef="Schedule_Technical_Interview" targetRef="Send_Personality_Assessment"/>
    <bpmn:sequenceFlow id="Send_Personality_Assessment_to_Receive_Personality_Assessment" sourceRef="Send_Personality_Assessment" targetRef="Personality_Assessment_Received"/>
    <bpmn:sequenceFlow id="Personality_Assessment_Received_to_Score_Personality_Assessment" sourceRef="Personality_Assessment_Received" targetRef="Score_Personality_Assessment"/>
    <bpmn:sequenceFlow id="Score_Personality_Assessment_to_Record_Verdicts" sourceRef="Score_Personality_Assessment" targetRef="Record_Verdicts"/>
    <bpmn:sequenceFlow id="Record_Verdicts_to_Parallel_Split" sourceRef="Record_Verdicts" targetRef="Parallel_Split"/>
    <bpmn:sequenceFlow id="Parallel_Split_to_Write_Rejection_Email" sourceRef="Parallel_Split" targetRef="Write_Rejection_Email"/>
    <bpmn:sequenceFlow id="Write_Rejection_Email_to_Rejection_Email_Sent" sourceRef="Write_Rejection_Email" targetRef="Rejection_Email_Sent"/>
    <bpmn:sequenceFlow id="Parallel_Split_to_Draft_Job_Offer" sourceRef="Parallel_Split" targetRef="Draft_Job_Offer"/>
    <bpmn:sequenceFlow id="Draft_Job_Offer_to_Send_Job_Offer" sourceRef="Draft_Job_Offer" targetRef="Send_Job_Offer"/>
    <bpmn:sequenceFlow id="Send_Job_Offer_to_Job_Offer_Sent" sourceRef="Send_Job_Offer" targetRef="Job_Offer_Sent"/>
  </bpmn:process>
  <bpmn:process id="Process_Candidate" name="Candidate pool" isExecutable="false">
