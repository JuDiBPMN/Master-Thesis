<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Government_Agency" name="Government Agency" processRef="Process_Government_Agency"/>
    <bpmn:messageFlow id="mf1" name="Application Details" sourceRef="gateway_documentation_join" targetRef="gateway_verdicts_split"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Government_Agency" name="Government Agency" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Government_Agency">
      <bpmn:lane id="grants_office" name="Grants Office">
        <bpmn:flowNodeRef>start_grants_office</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="grants_administrator" name="Grants Administrator">
        <bpmn:flowNodeRef>end_grants_administrator</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_documentation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_missing_documents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>recheck_documentation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>forward_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_documentation_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_documentation_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_verdicts_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_verdicts_join</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="applicant" name="Applicant">
        <bpmn:flowNodeRef>start_applicant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>collect_missing_documents</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="technical_review_panel" name="Technical Review Panel">
        <bpmn:flowNodeRef>end_technical_review_panel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>technical_review</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance_department" name="Finance Department">
        <bpmn:flowNodeRef>end_finance_department</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>budget_review</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_grants_office" name="Start"/>
    <bpmn:endEvent id="end_grants_administrator" name="End"/>
    <bpmn:startEvent id="start_applicant" name="Start"/>
    <bpmn:endEvent id="end_technical_review_panel" name="End"/>
    <bpmn:endEvent id="end_finance_department" name="End"/>
    <bpmn:task id="submit_application" name="Submit Application"/>
    <bpmn:task id="register_application" name="Register Application"/>
    <bpmn:task id="check_documentation" name="Check Documentation"/>
    <bpmn:task id="notify_missing_documents" name="Notify Missing Documents"/>
    <bpmn:task id="collect_missing_documents" name="Collect Missing Documents"/>
    <bpmn:task id="recheck_documentation" name="Recheck Documentation"/>
    <bpmn:task id="forward_application" name="Forward Application"/>
    <bpmn:task id="technical_review" name="Technical Review"/>
    <bpmn:task id="budget_review" name="Budget Review"/>
    <bpmn:task id="review_outcomes" name="Review Outcomes"/>
    <bpmn:exclusiveGateway id="gateway_documentation_split" name="Documentation Completeness?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_documentation_join" name="Reviews Initiated" gatewayDirection="converging"/>
    <bpmn:parallelGateway id="gateway_verdicts_split" name="Verdicts?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_verdicts_join" name="Approval/Rejection" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_grants_office" targetRef="submit_application"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="submit_application" targetRef="register_application"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_application" targetRef="check_documentation"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="check_documentation" targetRef="gateway_documentation_split"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="gateway_documentation_split" targetRef="notify_missing_documents" name="documentation is incomplete">
      <bpmn:conditionExpression>documentation is incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="gateway_documentation_split" targetRef="recheck_documentation" name="documentation is complete">
      <bpmn:conditionExpression>documentation is complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="recheck_documentation" targetRef="forward_application"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="forward_application" targetRef="gateway_verdicts_split"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="gateway_verdicts_split" targetRef="technical_review" name="technical review panel">
      <bpmn:conditionExpression>technical review panel</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf10" sourceRef="gateway_verdicts_split" targetRef="budget_review" name="finance department">
      <bpmn:conditionExpression>finance department</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf11" sourceRef="technical_review" targetRef="gateway_verdicts_join"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="budget_review" targetRef="gateway_verdicts_join"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="gateway_verdicts_join" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="review_outcomes" targetRef="end_grants_administrator"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="review_outcomes" targetRef="end_technical_review_panel"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="review_outcomes" targetRef="end_finance_department"/>
  </bpmn:process>
