<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="1.0">
  <bpmn:process id="Process_approval_committee" name="Approval Committee" isExecutable="false">
    <bpmn:laneSet id="LaneSet_approval_committee">
      <bpmn:lane id="project_manager" name="Project Manager">
        <bpmn:flowNodeRef>start_approval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_proposal</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance_department" name="Finance Department">
        <bpmn:flowNodeRef>assess_budget</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="hr_department" name="HR Department">
        <bpmn:flowNodeRef>evaluate_resources</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_approval" name="Project Approval Process Started"/>
    <bpmn:endEvent id="end_approval" name="Project Approval Process Ended"/>
    <bpmn:task id="submit_proposal" name="Submit Project Proposal"/>
    <bpmn:task id="assess_budget" name="Assess Budget Viable"/>
    <bpmn:task id="evaluate_resources" name="Evaluate Resource Availability"/>
    <bpmn:task id="review_proposal" name="Review Proposal"/>
    <bpmn:task id="approve_project" name="Approve Project"/>
    <bpmn:task id="request_revision" name="Request Proposal Revision"/>
    <bpmn:exclusiveGateway id="gateway_finance_split" name="Budget Assessment" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_hr_split" name="Resource Availability Assessment" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_approval_split" name="Approval Decision" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_join" name="Parallel Processes Converge" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_approval" targetRef="submit_proposal"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="submit_proposal" targetRef="gateway_finance_split"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="gateway_finance_split" targetRef="approve_project" name="Positive">
      <bpmn:conditionExpression>Positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf4" sourceRef="gateway_finance_split" targetRef="request_revision" name="Negative">
      <bpmn:conditionExpression>Negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf5" sourceRef="submit_proposal" targetRef="gateway_hr_split"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="gateway_hr_split" targetRef="gateway_approval_split"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="gateway_approval_split" targetRef="approve_project" name="Both Positive">
      <bpmn:conditionExpression>Both Positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf8" sourceRef="gateway_approval_split" targetRef="request_revision" name="At least One Negative">
      <bpmn:conditionExpression>At least One Negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf9" sourceRef="gateway_parallel_join" targetRef="end_approval"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_approval_committee">
      <bpmndi:BPMNShape id="project_manager_di" bpmnElement="project_manager" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="870" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="finance_department_di" bpmnElement="finance_department" isHorizontal="true">
        <dc:Bounds x="40" y="180" width="870" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="hr_department_di" bpmnElement="hr_department" isHorizontal="true">
        <dc:Bounds x="40" y="340" width="870" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_approval_di" bpmnElement="start_approval">
        <dc:Bounds x="110" y="82" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="submit_proposal_di" bpmnElement="submit_proposal">
        <dc:Bounds x="270" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="assess_budget_di" bpmnElement="assess_budget">
        <dc:Bounds x="110" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evaluate_resources_di" bpmnElement="evaluate_resources">
        <dc:Bounds x="110" y="380" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_proposal_di" bpmnElement="review_proposal">
        <dc:Bounds x="100" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_finance_split_di" bpmnElement="gateway_finance_split" isMarkerVisible="true">
        <dc:Bounds x="260" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_hr_split_di" bpmnElement="gateway_hr_split" isMarkerVisible="true">
        <dc:Bounds x="420" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_parallel_join_di" bpmnElement="gateway_parallel_join" isMarkerVisible="true">
        <dc:Bounds x="580" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_approval_split_di" bpmnElement="gateway_approval_split" isMarkerVisible="true">
        <dc:Bounds x="740" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_approval_di" bpmnElement="end_approval">
        <dc:Bounds x="900" y="242" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="approve_project_di" bpmnElement="approve_project">
        <dc:Bounds x="1060" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="request_revision_di" bpmnElement="request_revision">
        <dc:Bounds x="1220" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="146" y="100"/>
        <di:waypoint x="270" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="370" y="100"/>
        <di:waypoint x="260" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="310" y="260"/>
        <di:waypoint x="1060" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="310" y="260"/>
        <di:waypoint x="1220" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf5_di" bpmnElement="sf5">
        <di:waypoint x="370" y="100"/>
        <di:waypoint x="420" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="470" y="260"/>
        <di:waypoint x="740" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
        <di:waypoint x="790" y="260"/>
        <di:waypoint x="1060" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="790" y="260"/>
        <di:waypoint x="1220" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="630" y="260"/>
        <di:waypoint x="900" y="260"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>