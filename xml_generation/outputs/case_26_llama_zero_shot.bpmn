<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Company" name="Company" processRef="Process_Company"/>
    <bpmn:participant id="actor_Customer" name="Customer" processRef="Process_Customer"/>
    <bpmn:messageFlow id="messageFlow_1" name="Message Flow" sourceRef="intermediateThrowEvent" targetRef="intermediateCatchEvent"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Company" name="Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="HR" name="HR">
        <bpmn:flowNodeRef>intermediateThrowEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>endEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>introductionInterview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>informCandidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>prepareContract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>exclusiveGateway</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Business" name="Business">
        <bpmn:flowNodeRef>intermediateCatchEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>discussWithBusinessManager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>secondAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>parallelGateway</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Finance" name="Finance"/>
    </bpmn:laneSet>
    <bpmn:intermediateThrowEvent id="intermediateThrowEvent" name="Intermediate Throw Event">
      <bpmn:messageEventDefinition id="intermediateThrowEvent_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="intermediateCatchEvent" name="Intermediate Catch Event">
      <bpmn:messageEventDefinition id="intermediateCatchEvent_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="endEvent" name="End Event">
      <bpmn:messageEventDefinition id="endEvent_def"/>
    </bpmn:endEvent>
    <bpmn:task id="introductionInterview" name="Introduction Interview"/>
    <bpmn:task id="discussWithBusinessManager" name="Discuss with Business Manager"/>
    <bpmn:task id="informCandidate" name="Inform Candidate"/>
    <bpmn:task id="secondAssessment" name="Second Assessment"/>
    <bpmn:task id="prepareContract" name="Prepare Contract"/>
    <bpmn:exclusiveGateway id="exclusiveGateway" name="Exclusive Gateway" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="parallelGateway" name="Parallel Gateway" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sequenceFlow_1" sourceRef="introductionInterview" targetRef="discussWithBusinessManager"/>
    <bpmn:sequenceFlow id="sequenceFlow_2" sourceRef="discussWithBusinessManager" targetRef="informCandidate"/>
    <bpmn:sequenceFlow id="sequenceFlow_3" sourceRef="informCandidate" targetRef="secondAssessment"/>
    <bpmn:sequenceFlow id="sequenceFlow_4" sourceRef="secondAssessment" targetRef="prepareContract"/>
  </bpmn:process>
  <bpmn:process id="Process_Customer" name="Customer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Customer">
      <bpmn:lane id="Customer Service" name="Customer Service"/>
      <bpmn:lane id="Operations" name="Operations"/>
    </bpmn:laneSet>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Company_di" bpmnElement="actor_Company" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="1540" height="1410"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Customer_di" bpmnElement="actor_Customer" isHorizontal="true">
        <dc:Bounds x="10" y="1490" width="400" height="440"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="HR_di" bpmnElement="HR" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="1510" height="470"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Business_di" bpmnElement="Business" isHorizontal="true">
        <dc:Bounds x="40" y="490" width="1510" height="470"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Finance_di" bpmnElement="Finance" isHorizontal="true">
        <dc:Bounds x="40" y="960" width="1510" height="470"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="intermediateThrowEvent_di" bpmnElement="intermediateThrowEvent">
        <dc:Bounds x="172" y="109" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endEvent_di" bpmnElement="endEvent">
        <dc:Bounds x="172" y="175" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="introductionInterview_di" bpmnElement="introductionInterview">
        <dc:Bounds x="130" y="241" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="exclusiveGateway_di" bpmnElement="exclusiveGateway" isMarkerVisible="true">
        <dc:Bounds x="165" y="351" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="informCandidate_di" bpmnElement="informCandidate">
        <dc:Bounds x="650" y="215" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="prepareContract_di" bpmnElement="prepareContract">
        <dc:Bounds x="1170" y="215" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="intermediateCatchEvent_di" bpmnElement="intermediateCatchEvent">
        <dc:Bounds x="172" y="667" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="parallelGateway_di" bpmnElement="parallelGateway" isMarkerVisible="true">
        <dc:Bounds x="165" y="733" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="discussWithBusinessManager_di" bpmnElement="discussWithBusinessManager">
        <dc:Bounds x="390" y="685" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="secondAssessment_di" bpmnElement="secondAssessment">
        <dc:Bounds x="910" y="685" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sequenceFlow_1_di" bpmnElement="sequenceFlow_1">
        <di:waypoint x="250" y="281"/>
        <di:waypoint x="320" y="281"/>
        <di:waypoint x="320" y="725"/>
        <di:waypoint x="390" y="725"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sequenceFlow_2_di" bpmnElement="sequenceFlow_2">
        <di:waypoint x="510" y="725"/>
        <di:waypoint x="580" y="725"/>
        <di:waypoint x="580" y="255"/>
        <di:waypoint x="650" y="255"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sequenceFlow_3_di" bpmnElement="sequenceFlow_3">
        <di:waypoint x="770" y="255"/>
        <di:waypoint x="840" y="255"/>
        <di:waypoint x="840" y="725"/>
        <di:waypoint x="910" y="725"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sequenceFlow_4_di" bpmnElement="sequenceFlow_4">
        <di:waypoint x="1030" y="725"/>
        <di:waypoint x="1100" y="725"/>
        <di:waypoint x="1100" y="255"/>
        <di:waypoint x="1170" y="255"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="messageFlow_1_di" bpmnElement="messageFlow_1">
        <di:waypoint x="190" y="109"/>
        <di:waypoint x="190" y="703"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>