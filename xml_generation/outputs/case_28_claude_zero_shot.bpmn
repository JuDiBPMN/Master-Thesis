      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_create_file_di" bpmnElement="task_create_file">
        <dc:Bounds x="390" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_evaluate_stability_di" bpmnElement="task_evaluate_stability">
        <dc:Bounds x="910" y="50" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_gather_income_di" bpmnElement="task_gather_income">
        <dc:Bounds x="910" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_check_credit_di" bpmnElement="task_check_credit">
        <dc:Bounds x="910" y="270" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_risk_analysis_di" bpmnElement="task_risk_analysis">
        <dc:Bounds x="1430" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_grant_credit_di" bpmnElement="task_grant_credit">
        <dc:Bounds x="1950" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_decline_application_di" bpmnElement="task_decline_application">
        <dc:Bounds x="1950" y="215" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_parallel_split_di" bpmnElement="gw_parallel_split" isMarkerVisible="true">
        <dc:Bounds x="685" y="175" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_parallel_join_di" bpmnElement="gw_parallel_join" isMarkerVisible="true">
        <dc:Bounds x="1205" y="175" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_assessment_split_di" bpmnElement="gw_assessment_split" isMarkerVisible="true">
        <dc:Bounds x="1725" y="175" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf01_di" bpmnElement="sf01">
        <di:waypoint x="208" y="200"/>
        <di:waypoint x="390" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf02_di" bpmnElement="sf02">
        <di:waypoint x="510" y="200"/>
        <di:waypoint x="685" y="200"/>
      </bpmndi:BPMNEdge>
