<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:process id="Process_pool_zarkan" name="Zarkan Industries" isExecutable="false">
    <bpmn:laneSet id="LaneSet_pool_zarkan">
      <bpmn:lane id="lane_csr" name="Customer Service Representative">
        <bpmn:flowNodeRef>start_csr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_csr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_record_call</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_document_concerns</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_note_receipt_date</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_analyze_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_consult_departments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_resolve_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_archive_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_close_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_channel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_channel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_parallel_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_csr" name="Complaint received"/>
    <bpmn:endEvent id="end_csr" name="End – complaint closed"/>
    <bpmn:userTask id="task_record_call" name="Record call details"/>
    <bpmn:userTask id="task_document_concerns" name="Document customer concerns"/>
    <bpmn:userTask id="task_note_receipt_date" name="Note letter receipt date"/>
    <bpmn:userTask id="task_analyze_complaint" name="Analyze complaint"/>
    <bpmn:userTask id="task_consult_departments" name="Consult other departments"/>
    <bpmn:userTask id="task_resolve_complaint" name="Resolve complaint"/>
    <bpmn:userTask id="task_archive_complaint" name="Archive complaint details"/>
    <bpmn:userTask id="task_close_complaint" name="Close complaint"/>
    <bpmn:exclusiveGateway id="gw_channel_split" name="Complaint channel?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gw_channel_join" name="Registration complete" gatewayDirection="converging"/>
    <bpmn:parallelGateway id="gw_parallel_split" name="Analyze and consult simultaneously" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gw_parallel_join" name="Analysis and consultation complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf01" sourceRef="start_csr" targetRef="gw_channel_split"/>
    <bpmn:sequenceFlow id="sf02" sourceRef="gw_channel_split" targetRef="task_record_call" name="Phone call">
      <bpmn:conditionExpression>Phone call</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf03" sourceRef="gw_channel_split" targetRef="task_document_concerns" name="In-person at service desk">
      <bpmn:conditionExpression>In-person at service desk</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf04" sourceRef="gw_channel_split" targetRef="task_note_receipt_date" name="Letter">
      <bpmn:conditionExpression>Letter</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf05" sourceRef="task_record_call" targetRef="gw_channel_join"/>
    <bpmn:sequenceFlow id="sf06" sourceRef="task_document_concerns" targetRef="gw_channel_join"/>
    <bpmn:sequenceFlow id="sf07" sourceRef="task_note_receipt_date" targetRef="gw_channel_join"/>
    <bpmn:sequenceFlow id="sf08" sourceRef="gw_channel_join" targetRef="gw_parallel_split"/>
    <bpmn:sequenceFlow id="sf09" sourceRef="gw_parallel_split" targetRef="task_analyze_complaint"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="gw_parallel_split" targetRef="task_consult_departments"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="task_analyze_complaint" targetRef="gw_parallel_join"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="task_consult_departments" targetRef="gw_parallel_join"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="gw_parallel_join" targetRef="task_resolve_complaint"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="task_resolve_complaint" targetRef="task_archive_complaint"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="task_archive_complaint" targetRef="task_close_complaint"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="task_close_complaint" targetRef="end_csr"/>
  </bpmn:process>
