<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_HR_manager" name="HR Manager" processRef="Process_HR_manager"/>
    <bpmn:participant id="actor_Business_manager" name="Business Manager" processRef="Process_Business_manager"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="gateway_parallel_split" targetRef="second_assessment"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="second_assessment" targetRef="gateway_parallel_join"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_HR_manager" name="HR Manager" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HR_manager">
      <bpmn:lane id="HR_manager_lane" name="HR Manager Lane">
        <bpmn:flowNodeRef>start_HR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_HR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>introduction_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>discuss_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>inform_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>prepare_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>close_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_assessment_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_assessment_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_HR" name="Start"/>
    <bpmn:endEvent id="end_HR" name="End"/>
    <bpmn:task id="introduction_interview" name="Introduction Interview"/>
    <bpmn:task id="discuss_candidate" name="Discuss Candidate with Business Manager"/>
    <bpmn:task id="inform_candidate" name="Inform Candidate about Application"/>
    <bpmn:task id="prepare_contract" name="Prepare Contract"/>
    <bpmn:task id="close_application" name="Close Application Process"/>
    <bpmn:parallelGateway id="gateway_parallel_split" name="Start Concurrent Activities" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_join" name="Concurrent Activities Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_assessment_split" name="Assessment Successful?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_assessment_join" name="Assessment Decision Made" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_HR" targetRef="introduction_interview"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="introduction_interview" targetRef="discuss_candidate"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="discuss_candidate" targetRef="gateway_parallel_split"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="gateway_parallel_split" targetRef="inform_candidate"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="inform_candidate" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="gateway_parallel_join" targetRef="gateway_assessment_split"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="gateway_assessment_split" targetRef="prepare_contract" name="Assessment successful">
      <bpmn:conditionExpression>Assessment successful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf10" sourceRef="gateway_assessment_split" targetRef="close_application" name="Assessment not successful">
      <bpmn:conditionExpression>Assessment not successful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf11" sourceRef="prepare_contract" targetRef="gateway_assessment_join"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="close_application" targetRef="gateway_assessment_join"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="gateway_assessment_join" targetRef="end_HR"/>
  </bpmn:process>
  <bpmn:process id="Process_Business_manager" name="Business Manager" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Business_manager">
      <bpmn:lane id="Business_manager_lane" name="Business Manager Lane">
        <bpmn:flowNodeRef>start_BM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_BM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>second_assessment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_BM" name="Start"/>
    <bpmn:endEvent id="end_BM" name="End"/>
    <bpmn:task id="second_assessment" name="Second Assessment with Candidate"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="start_BM" targetRef="second_assessment"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="second_assessment" targetRef="end_BM"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_HR_manager_di" bpmnElement="actor_HR_manager" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="2840" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Business_manager_di" bpmnElement="actor_Business_manager" isHorizontal="true">
        <dc:Bounds x="10" y="330" width="1020" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="HR_manager_lane_di" bpmnElement="HR_manager_lane" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="2810" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Business_manager_lane_di" bpmnElement="Business_manager_lane" isHorizontal="true">
        <dc:Bounds x="40" y="330" width="990" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_HR_di" bpmnElement="start_HR">
        <dc:Bounds x="172" y="127" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_HR_di" bpmnElement="end_HR">
        <dc:Bounds x="2512" y="127" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="introduction_interview_di" bpmnElement="introduction_interview">
        <dc:Bounds x="390" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="discuss_candidate_di" bpmnElement="discuss_candidate">
        <dc:Bounds x="650" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="inform_candidate_di" bpmnElement="inform_candidate">
        <dc:Bounds x="1170" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="prepare_contract_di" bpmnElement="prepare_contract">
        <dc:Bounds x="1950" y="50" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="close_application_di" bpmnElement="close_application">
        <dc:Bounds x="1950" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_parallel_split_di" bpmnElement="gateway_parallel_split" isMarkerVisible="true">
        <dc:Bounds x="945" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_parallel_join_di" bpmnElement="gateway_parallel_join" isMarkerVisible="true">
        <dc:Bounds x="1465" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_assessment_split_di" bpmnElement="gateway_assessment_split" isMarkerVisible="true">
        <dc:Bounds x="1725" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_assessment_join_di" bpmnElement="gateway_assessment_join" isMarkerVisible="true">
        <dc:Bounds x="2245" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_BM_di" bpmnElement="start_BM">
        <dc:Bounds x="172" y="422" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_BM_di" bpmnElement="end_BM">
        <dc:Bounds x="692" y="422" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="second_assessment_di" bpmnElement="second_assessment">
        <dc:Bounds x="390" y="400" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="208" y="145"/>
        <di:waypoint x="390" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="510" y="145"/>
        <di:waypoint x="650" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="770" y="145"/>
        <di:waypoint x="945" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="995" y="145"/>
        <di:waypoint x="1170" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="1290" y="145"/>
        <di:waypoint x="1465" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="1515" y="145"/>
        <di:waypoint x="1725" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="1775" y="145"/>
        <di:waypoint x="1862" y="145"/>
        <di:waypoint x="1862" y="90"/>
        <di:waypoint x="1950" y="90"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf10_di" bpmnElement="sf10">
        <di:waypoint x="1775" y="145"/>
        <di:waypoint x="1862" y="145"/>
        <di:waypoint x="1862" y="200"/>
        <di:waypoint x="1950" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf11_di" bpmnElement="sf11">
        <di:waypoint x="2070" y="90"/>
        <di:waypoint x="2157" y="90"/>
        <di:waypoint x="2157" y="145"/>
        <di:waypoint x="2245" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf12_di" bpmnElement="sf12">
        <di:waypoint x="2070" y="200"/>
        <di:waypoint x="2157" y="200"/>
        <di:waypoint x="2157" y="145"/>
        <di:waypoint x="2245" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf13_di" bpmnElement="sf13">
        <di:waypoint x="2295" y="145"/>
        <di:waypoint x="2512" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf14_di" bpmnElement="sf14">
        <di:waypoint x="208" y="440"/>
        <di:waypoint x="390" y="440"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf15_di" bpmnElement="sf15">
        <di:waypoint x="510" y="440"/>
        <di:waypoint x="692" y="440"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p0_di" bpmnElement="MsgFlow_p0">
        <di:waypoint x="970" y="170"/>
        <di:waypoint x="450" y="400"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p1_di" bpmnElement="MsgFlow_p1">
        <di:waypoint x="450" y="400"/>
        <di:waypoint x="1490" y="170"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>