        <di:waypoint x="1602" y="200"/>
        <di:waypoint x="1690" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="1810" y="90"/>
        <di:waypoint x="1897" y="90"/>
        <di:waypoint x="1897" y="395"/>
        <di:waypoint x="1985" y="395"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="1810" y="200"/>
        <di:waypoint x="1897" y="200"/>
        <di:waypoint x="1897" y="395"/>
        <di:waypoint x="1985" y="395"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf10_di" bpmnElement="sf10">
        <di:waypoint x="2035" y="395"/>
        <di:waypoint x="2143" y="395"/>
        <di:waypoint x="2143" y="145"/>
        <di:waypoint x="2252" y="145"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
