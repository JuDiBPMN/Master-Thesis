<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:process id="Process_HR_and_Business_Management" name="HR and Business Management" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HR_and_Business_Management">
      <bpmn:lane id="hr_manager" name="HR Manager">
        <bpmn:flowNodeRef>start_hr_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hr_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>introduction_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>discuss_with_business_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>inform_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>prepare_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>close_application_process</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="business_manager" name="Business Manager">
        <bpmn:flowNodeRef>second_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>assessment_outcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>assessment_outcome_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hr_manager" name="Start"/>
    <bpmn:endEvent id="end_hr_manager" name="End"/>
    <bpmn:task id="introduction_interview" name="Introduction Interview"/>
    <bpmn:task id="discuss_with_business_manager" name="Discuss with Business Manager"/>
    <bpmn:task id="inform_candidate" name="Inform Candidate"/>
    <bpmn:task id="second_assessment" name="Second Assessment"/>
    <bpmn:task id="prepare_contract" name="Prepare Contract"/>
    <bpmn:task id="close_application_process" name="Close Application Process"/>
    <bpmn:exclusiveGateway id="assessment_outcome" name="Assessment Outcome" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="assessment_outcome_join" name="Assessment Outcome Join" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_hr_manager" targetRef="introduction_interview"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="introduction_interview" targetRef="discuss_with_business_manager"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="discuss_with_business_manager" targetRef="inform_candidate"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="inform_candidate" targetRef="second_assessment"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="second_assessment" targetRef="assessment_outcome"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="assessment_outcome" targetRef="prepare_contract" name="successful">
      <bpmn:conditionExpression>successful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="assessment_outcome" targetRef="close_application_process" name="not successful">
      <bpmn:conditionExpression>not successful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf8" sourceRef="prepare_contract" targetRef="assessment_outcome_join"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="close_application_process" targetRef="assessment_outcome_join"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="assessment_outcome_join" targetRef="end_hr_manager"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_HR_and_Business_Management">
      <bpmndi:BPMNShape id="hr_manager_di" bpmnElement="hr_manager" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="2550" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="business_manager_di" bpmnElement="business_manager" isHorizontal="true">
        <dc:Bounds x="40" y="270" width="2550" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_hr_manager_di" bpmnElement="start_hr_manager">
        <dc:Bounds x="172" y="127" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_hr_manager_di" bpmnElement="end_hr_manager">
        <dc:Bounds x="2252" y="127" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="introduction_interview_di" bpmnElement="introduction_interview">
        <dc:Bounds x="390" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="discuss_with_business_manager_di" bpmnElement="discuss_with_business_manager">
        <dc:Bounds x="650" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="inform_candidate_di" bpmnElement="inform_candidate">
        <dc:Bounds x="910" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="prepare_contract_di" bpmnElement="prepare_contract">
        <dc:Bounds x="1690" y="50" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="close_application_process_di" bpmnElement="close_application_process">
        <dc:Bounds x="1690" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="second_assessment_di" bpmnElement="second_assessment">
        <dc:Bounds x="1170" y="355" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="assessment_outcome_di" bpmnElement="assessment_outcome" isMarkerVisible="true">
        <dc:Bounds x="1465" y="370" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="assessment_outcome_join_di" bpmnElement="assessment_outcome_join" isMarkerVisible="true">
        <dc:Bounds x="1985" y="370" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="208" y="145"/>
        <di:waypoint x="390" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="510" y="145"/>
        <di:waypoint x="650" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="770" y="145"/>
        <di:waypoint x="910" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="1030" y="145"/>
        <di:waypoint x="1100" y="145"/>
        <di:waypoint x="1100" y="395"/>
        <di:waypoint x="1170" y="395"/>
      </bpmndi:BPMNEdge>
