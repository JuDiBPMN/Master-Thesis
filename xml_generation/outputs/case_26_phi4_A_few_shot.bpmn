      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="1515" y="395"/>
        <di:waypoint x="1602" y="395"/>
        <di:waypoint x="1602" y="90"/>
        <di:waypoint x="1690" y="90"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
        <di:waypoint x="1515" y="395"/>
