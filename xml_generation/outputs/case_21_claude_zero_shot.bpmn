<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_pool_customer" name="Customer" processRef="Process_pool_customer"/>
    <bpmn:participant id="actor_pool_retailer" name="Retailer" processRef="Process_pool_retailer"/>
    <bpmn:messageFlow id="mf01" name="Return request" sourceRef="throw_customer_request" targetRef="start_cs"/>
    <bpmn:messageFlow id="mf02" name="Inspection request" sourceRef="throw_cs_to_warehouse" targetRef="catch_wh_request"/>
    <bpmn:messageFlow id="mf03" name="Eligibility check request" sourceRef="throw_cs_to_finance" targetRef="catch_fin_request"/>
    <bpmn:messageFlow id="mf04" name="Warehouse verdict" sourceRef="throw_wh_verdict" targetRef="catch_cs_wh_verdict"/>
    <bpmn:messageFlow id="mf05" name="Finance verdict" sourceRef="throw_fin_verdict" targetRef="catch_cs_fin_verdict"/>
    <bpmn:messageFlow id="mf06" name="Return rejection notice" sourceRef="throw_cs_rejection" targetRef="catch_customer_outcome"/>
    <bpmn:messageFlow id="mf07" name="Refund confirmation" sourceRef="throw_cs_confirmation" targetRef="catch_customer_outcome"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_pool_customer" name="Customer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_pool_customer">
      <bpmn:lane id="lane_customer" name="Customer">
        <bpmn:flowNodeRef>start_customer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_customer_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_customer_outcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_customer</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_customer" name="Return request submitted"/>
    <bpmn:intermediateThrowEvent id="throw_customer_request" name="Send return request">
      <bpmn:messageEventDefinition id="throw_customer_request_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_customer_outcome" name="Receive outcome from retailer">
      <bpmn:messageEventDefinition id="catch_customer_outcome_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_customer" name="End"/>
    <bpmn:sequenceFlow id="sf01" sourceRef="start_customer" targetRef="throw_customer_request"/>
    <bpmn:sequenceFlow id="sf02" sourceRef="catch_customer_outcome" targetRef="end_customer"/>
  </bpmn:process>
  <bpmn:process id="Process_pool_retailer" name="Retailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_pool_retailer">
      <bpmn:lane id="lane_cs" name="Customer Service">
        <bpmn:flowNodeRef>start_cs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_cs_to_warehouse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_cs_to_finance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_cs_wh_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_cs_fin_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_cs_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_cs_confirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_cs_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_cs_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_cs_refunded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_register</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_check_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_notify_missing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_approve_refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_complete_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_verdicts_split</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_warehouse" name="Warehouse">
        <bpmn:flowNodeRef>catch_wh_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_wh_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_warehouse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_inspect_product</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_record_wh_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_finance" name="Finance">
        <bpmn:flowNodeRef>catch_fin_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_fin_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_finance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_check_eligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_record_fin_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_cs" name="Receive return request">
      <bpmn:messageEventDefinition id="start_cs_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateThrowEvent id="throw_cs_to_warehouse" name="Forward request to warehouse">
      <bpmn:messageEventDefinition id="throw_cs_to_warehouse_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_cs_to_finance" name="Forward request to finance">
      <bpmn:messageEventDefinition id="throw_cs_to_finance_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_cs_wh_verdict" name="Receive warehouse verdict">
      <bpmn:messageEventDefinition id="catch_cs_wh_verdict_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="catch_cs_fin_verdict" name="Receive finance verdict">
      <bpmn:messageEventDefinition id="catch_cs_fin_verdict_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_cs_rejection" name="Send return rejection notice">
      <bpmn:messageEventDefinition id="throw_cs_rejection_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_cs_confirmation" name="Send refund confirmation">
      <bpmn:messageEventDefinition id="throw_cs_confirmation_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_cs_incomplete" name="End – incomplete submission"/>
    <bpmn:endEvent id="end_cs_rejected" name="End – return rejected"/>
    <bpmn:endEvent id="end_cs_refunded" name="End – refund confirmed"/>
    <bpmn:intermediateCatchEvent id="catch_wh_request" name="Receive request for inspection">
      <bpmn:messageEventDefinition id="catch_wh_request_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_wh_verdict" name="Send warehouse verdict">
      <bpmn:messageEventDefinition id="throw_wh_verdict_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_warehouse" name="End"/>
    <bpmn:intermediateCatchEvent id="catch_fin_request" name="Receive request for eligibility check">
      <bpmn:messageEventDefinition id="catch_fin_request_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_fin_verdict" name="Send finance verdict">
      <bpmn:messageEventDefinition id="throw_fin_verdict_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_finance" name="End"/>
    <bpmn:userTask id="task_register" name="Register return request"/>
    <bpmn:userTask id="task_check_info" name="Check information completeness"/>
    <bpmn:userTask id="task_notify_missing" name="Notify customer of missing information"/>
    <bpmn:userTask id="task_review_outcomes" name="Review combined outcomes"/>
    <bpmn:userTask id="task_approve_refund" name="Approve return and process refund"/>
    <bpmn:manualTask id="task_inspect_product" name="Inspect returned product"/>
    <bpmn:userTask id="task_record_wh_verdict" name="Record warehouse verdict"/>
    <bpmn:userTask id="task_check_eligibility" name="Check refund eligibility"/>
    <bpmn:userTask id="task_record_fin_verdict" name="Record finance verdict"/>
    <bpmn:exclusiveGateway id="gw_complete_split" name="Information complete?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gw_parallel_split" name="Forward to departments" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gw_parallel_join" name="Wait for both verdicts" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gw_verdicts_split" name="Both verdicts positive?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf03" sourceRef="start_cs" targetRef="task_register"/>
    <bpmn:sequenceFlow id="sf04" sourceRef="task_register" targetRef="task_check_info"/>
    <bpmn:sequenceFlow id="sf05" sourceRef="task_check_info" targetRef="gw_complete_split"/>
    <bpmn:sequenceFlow id="sf06" sourceRef="gw_complete_split" targetRef="task_notify_missing" name="Information incomplete">
      <bpmn:conditionExpression>Information incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf07" sourceRef="task_notify_missing" targetRef="end_cs_incomplete"/>
    <bpmn:sequenceFlow id="sf08" sourceRef="gw_complete_split" targetRef="gw_parallel_split" name="Information complete">
      <bpmn:conditionExpression>Information complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf09" sourceRef="gw_parallel_split" targetRef="throw_cs_to_warehouse"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="gw_parallel_split" targetRef="throw_cs_to_finance"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="catch_cs_wh_verdict" targetRef="gw_parallel_join"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="catch_cs_fin_verdict" targetRef="gw_parallel_join"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="gw_parallel_join" targetRef="task_review_outcomes"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="task_review_outcomes" targetRef="gw_verdicts_split"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="gw_verdicts_split" targetRef="throw_cs_rejection" name="Either verdict is negative">
      <bpmn:conditionExpression>Either verdict is negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf16" sourceRef="throw_cs_rejection" targetRef="end_cs_rejected"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="gw_verdicts_split" targetRef="task_approve_refund" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf18" sourceRef="task_approve_refund" targetRef="throw_cs_confirmation"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="throw_cs_confirmation" targetRef="end_cs_refunded"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="catch_wh_request" targetRef="task_inspect_product"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="task_inspect_product" targetRef="task_record_wh_verdict"/>
    <bpmn:sequenceFlow id="sf22" sourceRef="task_record_wh_verdict" targetRef="throw_wh_verdict"/>
    <bpmn:sequenceFlow id="sf23" sourceRef="throw_wh_verdict" targetRef="end_warehouse"/>
    <bpmn:sequenceFlow id="sf24" sourceRef="catch_fin_request" targetRef="task_check_eligibility"/>
    <bpmn:sequenceFlow id="sf25" sourceRef="task_check_eligibility" targetRef="task_record_fin_verdict"/>
    <bpmn:sequenceFlow id="sf26" sourceRef="task_record_fin_verdict" targetRef="throw_fin_verdict"/>
    <bpmn:sequenceFlow id="sf27" sourceRef="throw_fin_verdict" targetRef="end_finance"/>
  </bpmn:process>
