<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_pool_company" name="Company" processRef="Process_pool_company"/>
    <bpmn:participant id="actor_pool_candidate" name="Candidate" processRef="Process_pool_candidate"/>
    <bpmn:messageFlow id="mf01" name="Vacancy request" sourceRef="throw_hm_vacancy" targetRef="start_hr"/>
    <bpmn:messageFlow id="mf02" name="Job advertisement" sourceRef="task_post_job_ad" targetRef="start_candidate"/>
    <bpmn:messageFlow id="mf03" name="Interview schedule" sourceRef="throw_hr_schedule" targetRef="catch_hm_interview_sched"/>
    <bpmn:messageFlow id="mf04" name="Personality assessment" sourceRef="throw_hr_assessment" targetRef="catch_cand_assessment"/>
    <bpmn:messageFlow id="mf05" name="Interview verdict" sourceRef="throw_hm_verdict" targetRef="catch_hr_hm_verdict"/>
    <bpmn:messageFlow id="mf06" name="Completed assessment" sourceRef="throw_cand_assessment" targetRef="catch_hr_assessment_result"/>
    <bpmn:messageFlow id="mf07" name="Rejection email" sourceRef="throw_hr_rejection" targetRef="catch_cand_outcome"/>
    <bpmn:messageFlow id="mf08" name="Job offer" sourceRef="throw_hr_job_offer" targetRef="catch_cand_outcome"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_pool_company" name="Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_pool_company">
      <bpmn:lane id="lane_hm" name="Hiring Manager">
        <bpmn:flowNodeRef>start_hm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_hm_vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_hm_interview_sched</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_hm_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_conduct_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_record_hm_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_hr" name="HR Recruiter">
        <bpmn:flowNodeRef>start_hr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_hr_schedule</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_hr_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_hr_hm_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_hr_assessment_result</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_hr_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_hr_job_offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hr_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hr_offered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_register_vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_post_job_ad</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_screen_applications</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_schedule_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_score_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_record_hr_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_write_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_draft_job_offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_verdicts_split</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hm" name="Submit vacancy request"/>
    <bpmn:intermediateThrowEvent id="throw_hm_vacancy" name="Send vacancy request to HR">
      <bpmn:messageEventDefinition id="throw_hm_vacancy_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_hm_interview_sched" name="Receive interview schedule">
      <bpmn:messageEventDefinition id="catch_hm_interview_sched_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_hm_verdict" name="Send interview verdict">
      <bpmn:messageEventDefinition id="throw_hm_verdict_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_hm" name="End"/>
    <bpmn:startEvent id="start_hr" name="Receive vacancy request">
      <bpmn:messageEventDefinition id="start_hr_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateThrowEvent id="throw_hr_schedule" name="Send interview schedule to HM">
      <bpmn:messageEventDefinition id="throw_hr_schedule_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_hr_assessment" name="Send personality assessment">
      <bpmn:messageEventDefinition id="throw_hr_assessment_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_hr_hm_verdict" name="Receive interview verdict">
      <bpmn:messageEventDefinition id="catch_hr_hm_verdict_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="catch_hr_assessment_result" name="Receive completed assessment">
      <bpmn:messageEventDefinition id="catch_hr_assessment_result_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_hr_rejection" name="Send rejection email">
      <bpmn:messageEventDefinition id="throw_hr_rejection_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_hr_job_offer" name="Send job offer">
      <bpmn:messageEventDefinition id="throw_hr_job_offer_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_hr_rejected" name="End – candidate rejected"/>
    <bpmn:endEvent id="end_hr_offered" name="End – job offer sent"/>
    <bpmn:userTask id="task_register_vacancy" name="Register vacancy"/>
    <bpmn:userTask id="task_post_job_ad" name="Post job advertisement"/>
    <bpmn:userTask id="task_screen_applications" name="Screen applications and shortlist"/>
    <bpmn:userTask id="task_schedule_interview" name="Schedule technical interview"/>
    <bpmn:userTask id="task_score_assessment" name="Score personality assessment"/>
    <bpmn:userTask id="task_record_hr_verdict" name="Record assessment verdict"/>
    <bpmn:userTask id="task_review_outcomes" name="Review combined outcomes"/>
    <bpmn:userTask id="task_write_rejection" name="Write rejection email"/>
    <bpmn:userTask id="task_draft_job_offer" name="Draft job offer"/>
    <bpmn:userTask id="task_conduct_interview" name="Conduct technical interview"/>
    <bpmn:userTask id="task_record_hm_verdict" name="Record interview verdict"/>
    <bpmn:parallelGateway id="gw_parallel_split" name="Initiate interview and assessment" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gw_parallel_join" name="Wait for both verdicts" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gw_verdicts_split" name="Both verdicts positive?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf01" sourceRef="start_hm" targetRef="throw_hm_vacancy"/>
    <bpmn:sequenceFlow id="sf02" sourceRef="catch_hm_interview_sched" targetRef="task_conduct_interview"/>
    <bpmn:sequenceFlow id="sf03" sourceRef="task_conduct_interview" targetRef="task_record_hm_verdict"/>
    <bpmn:sequenceFlow id="sf04" sourceRef="task_record_hm_verdict" targetRef="throw_hm_verdict"/>
    <bpmn:sequenceFlow id="sf05" sourceRef="throw_hm_verdict" targetRef="end_hm"/>
    <bpmn:sequenceFlow id="sf06" sourceRef="start_hr" targetRef="task_register_vacancy"/>
    <bpmn:sequenceFlow id="sf07" sourceRef="task_register_vacancy" targetRef="task_post_job_ad"/>
    <bpmn:sequenceFlow id="sf08" sourceRef="task_post_job_ad" targetRef="task_screen_applications"/>
    <bpmn:sequenceFlow id="sf09" sourceRef="task_screen_applications" targetRef="gw_parallel_split"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="gw_parallel_split" targetRef="task_schedule_interview"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="task_schedule_interview" targetRef="throw_hr_schedule"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="gw_parallel_split" targetRef="throw_hr_assessment"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="catch_hr_hm_verdict" targetRef="gw_parallel_join"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="catch_hr_assessment_result" targetRef="task_score_assessment"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="task_score_assessment" targetRef="task_record_hr_verdict"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="task_record_hr_verdict" targetRef="gw_parallel_join"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="gw_parallel_join" targetRef="task_review_outcomes"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="task_review_outcomes" targetRef="gw_verdicts_split"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="gw_verdicts_split" targetRef="task_write_rejection" name="Either verdict is negative">
      <bpmn:conditionExpression>Either verdict is negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf20" sourceRef="task_write_rejection" targetRef="throw_hr_rejection"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="throw_hr_rejection" targetRef="end_hr_rejected"/>
    <bpmn:sequenceFlow id="sf22" sourceRef="gw_verdicts_split" targetRef="task_draft_job_offer" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf23" sourceRef="task_draft_job_offer" targetRef="throw_hr_job_offer"/>
    <bpmn:sequenceFlow id="sf24" sourceRef="throw_hr_job_offer" targetRef="end_hr_offered"/>
  </bpmn:process>
  <bpmn:process id="Process_pool_candidate" name="Candidate" isExecutable="false">
    <bpmn:laneSet id="LaneSet_pool_candidate">
      <bpmn:lane id="lane_candidate" name="Candidate">
        <bpmn:flowNodeRef>start_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_cand_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_cand_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_cand_outcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_apply</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_complete_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_submit_assessment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_candidate" name="Job advertisement posted">
      <bpmn:messageEventDefinition id="start_candidate_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="catch_cand_assessment" name="Receive personality assessment">
      <bpmn:messageEventDefinition id="catch_cand_assessment_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_cand_assessment" name="Send completed assessment to HR">
      <bpmn:messageEventDefinition id="throw_cand_assessment_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_cand_outcome" name="Receive rejection or job offer">
      <bpmn:messageEventDefinition id="catch_cand_outcome_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_candidate" name="End"/>
    <bpmn:userTask id="task_apply" name="Apply for vacancy"/>
    <bpmn:userTask id="task_complete_assessment" name="Complete personality assessment"/>
    <bpmn:userTask id="task_submit_assessment" name="Submit personality assessment"/>
    <bpmn:sequenceFlow id="sf25" sourceRef="start_candidate" targetRef="task_apply"/>
    <bpmn:sequenceFlow id="sf26" sourceRef="task_apply" targetRef="catch_cand_assessment"/>
    <bpmn:sequenceFlow id="sf27" sourceRef="catch_cand_assessment" targetRef="task_complete_assessment"/>
    <bpmn:sequenceFlow id="sf28" sourceRef="task_complete_assessment" targetRef="task_submit_assessment"/>
    <bpmn:sequenceFlow id="sf29" sourceRef="task_submit_assessment" targetRef="throw_cand_assessment"/>
    <bpmn:sequenceFlow id="sf30" sourceRef="throw_cand_assessment" targetRef="catch_cand_outcome"/>
    <bpmn:sequenceFlow id="sf31" sourceRef="catch_cand_outcome" targetRef="end_candidate"/>
  </bpmn:process>
