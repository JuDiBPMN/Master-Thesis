<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_client" name="Client" processRef="Process_client"/>
    <bpmn:participant id="actor_brightwave_energy" name="BrightWave Energy" processRef="Process_brightwave_energy"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="write_complaint_email" targetRef="receive_complaint"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_client" name="Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_client">
      <bpmn:lane id="client" name="Client"/>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_client" name="Start"/>
    <bpmn:task id="write_complaint_email" name="Write Complaint Email"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_client" targetRef="write_complaint_email"/>
  </bpmn:process>
  <bpmn:process id="Process_brightwave_energy" name="BrightWave Energy" isExecutable="false">
    <bpmn:laneSet id="LaneSet_brightwave_energy">
      <bpmn:lane id="customer_service" name="Customer Service">
        <bpmn:flowNodeRef>end_process</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>receive_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>lookup_billing_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>no_mistake_found</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>write_explanation_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_explanation_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_process</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>create_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_mistake_found</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="invoicing" name="Invoicing">
        <bpmn:flowNodeRef>assign_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>investigate_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>make_correction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>generate_new_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_new_invoice</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:endEvent id="end_process" name="End"/>
    <bpmn:task id="receive_complaint" name="Receive Complaint"/>
    <bpmn:task id="lookup_billing_info" name="Look Up Billing Info"/>
    <bpmn:task id="review_invoice" name="Review Invoice"/>
    <bpmn:task id="no_mistake_found" name="No Mistake Found"/>
    <bpmn:task id="write_explanation_email" name="Write Explanation Email"/>
    <bpmn:task id="send_explanation_email" name="Send Explanation Email"/>
    <bpmn:task id="end_process" name="End Process"/>
    <bpmn:task id="create_ticket" name="Create Ticket"/>
    <bpmn:task id="assign_ticket" name="Assign Ticket"/>
    <bpmn:task id="investigate_mistake" name="Investigate Mistake"/>
    <bpmn:task id="make_correction" name="Make Correction"/>
    <bpmn:task id="generate_new_invoice" name="Generate New Invoice"/>
    <bpmn:task id="send_new_invoice" name="Send New Invoice"/>
    <bpmn:exclusiveGateway id="gateway_mistake_found" name="Mistake Found?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="receive_complaint" targetRef="lookup_billing_info"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="lookup_billing_info" targetRef="review_invoice"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="review_invoice" targetRef="gateway_mistake_found"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="gateway_mistake_found" targetRef="no_mistake_found"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="no_mistake_found" targetRef="write_explanation_email"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="write_explanation_email" targetRef="send_explanation_email"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="send_explanation_email" targetRef="end_process"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="gateway_mistake_found" targetRef="create_ticket"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="create_ticket" targetRef="assign_ticket"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="assign_ticket" targetRef="investigate_mistake"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="investigate_mistake" targetRef="make_correction"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="make_correction" targetRef="generate_new_invoice"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="generate_new_invoice" targetRef="send_new_invoice"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="send_new_invoice" targetRef="end_process"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_client_di" bpmnElement="actor_client" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="760" height="220"/>
      </bpmndi:BPMNShape>
