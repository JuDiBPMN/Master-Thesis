      <bpmndi:BPMNShape id="generate_new_invoice_di" bpmnElement="generate_new_invoice">
        <dc:Bounds x="2210" y="635" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="send_new_invoice_di" bpmnElement="send_new_invoice">
