<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Government_Agency" name="Government Agency”, " processRef="Process_Government_Agency"/>
    <bpmn:participant id="actor_Applicant_Organisation" name="Applicant Organisation" processRef="Process_Applicant_Organisation"/>
    <bpmn:messageFlow id="Missing_Documents_Notification_to_Applicant" name="Missing Documents Notification" sourceRef="Missing_Documents_Notification" targetRef="Missing_Documents_Received"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="Notify_Missing_Documents" targetRef="Resubmit_Documents"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="Resubmit_Documents" targetRef="Receive_Documents"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="Check_Documentation_Again" targetRef="Assess_Project_Feasibility"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="Assess_Project_Feasibility" targetRef="Review_Combined_Outcomes"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Government_Agency" name="Government Agency”, " isExecutable="false">
    <bpmn:laneSet id="LaneSet_Government_Agency">
      <bpmn:lane id="Grants_Office" name="Grants Office">
        <bpmn:flowNodeRef>Application_Submitted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Register_Application</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Grants_Administrator" name="Grants Administrator">
        <bpmn:flowNodeRef>Application_Rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Application_Approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Missing_Documents_Notification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Missing_Documents_Received</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Check_Documentation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Notify_Missing_Documents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Receive_Documents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Check_Documentation_Again</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Review_Combined_Outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Documentation_Check_Gateway</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Technical_Review_Panel" name="Technical Review Panel">
        <bpmn:flowNodeRef>Project_Feasibility_Assessment_Completed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Finance_Department" name="Finance Department">
        <bpmn:flowNodeRef>Budget_Adequacy_Review_Completed</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Application_Submitted" name="Application Submitted"/>
    <bpmn:endEvent id="Application_Rejected" name="Application Rejected"/>
    <bpmn:endEvent id="Application_Approved" name="Application Approved"/>
    <bpmn:intermediateThrowEvent id="Missing_Documents_Notification" name="Missing Documents Notification"/>
    <bpmn:intermediateCatchEvent id="Missing_Documents_Received" name="Missing Documents Received"/>
    <bpmn:intermediateCatchEvent id="Project_Feasibility_Assessment_Completed" name="Project Feasibility Assessment Completed"/>
    <bpmn:intermediateCatchEvent id="Budget_Adequacy_Review_Completed" name="Budget Adequacy Review Completed"/>
    <bpmn:task id="Register_Application" name="Register Application"/>
    <bpmn:task id="Check_Documentation" name="Check Documentation"/>
    <bpmn:task id="Notify_Missing_Documents" name="Notify Missing Documents"/>
    <bpmn:task id="Receive_Documents" name="Receive Documents"/>
    <bpmn:task id="Check_Documentation_Again" name="Check Documentation Again"/>
    <bpmn:task id="Review_Combined_Outcomes" name="Review Combined Outcomes"/>
    <bpmn:exclusiveGateway id="Documentation_Check_Gateway" name="Documentation Check Gateway" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="Application_Submitted_to_Grants_Office" sourceRef="Application_Submitted" targetRef="Register_Application"/>
    <bpmn:sequenceFlow id="Register_Application_to_Check_Documentation" sourceRef="Register_Application" targetRef="Check_Documentation"/>
    <bpmn:sequenceFlow id="Check_Documentation_to_Notify_Missing_Documents" sourceRef="Check_Documentation" targetRef="Notify_Missing_Documents"/>
    <bpmn:sequenceFlow id="Receive_Documents_to_Check_Documentation_Again" sourceRef="Receive_Documents" targetRef="Check_Documentation_Again"/>
    <bpmn:sequenceFlow id="Review_Combined_Outcomes_to_Application_Approved" sourceRef="Review_Combined_Outcomes" targetRef="Application_Approved"/>
    <bpmn:sequenceFlow id="Review_Combined_Outcomes_to_Application_Rejected" sourceRef="Review_Combined_Outcomes" targetRef="Application_Rejected"/>
    <bpmn:sequenceFlow id="Missing_Documents_Notification_to_Missing_Documents_Received" sourceRef="Missing_Documents_Notification" targetRef="Missing_Documents_Received"/>
    <bpmn:sequenceFlow id="Project_Feasibility_Assessment_Completed_to_Review_Combined_Outcomes" sourceRef="Project_Feasibility_Assessment_Completed" targetRef="Review_Combined_Outcomes"/>
    <bpmn:sequenceFlow id="Budget_Adequacy_Review_Completed_to_Review_Combined_Outcomes" sourceRef="Budget_Adequacy_Review_Completed" targetRef="Review_Combined_Outcomes"/>
  </bpmn:process>
  <bpmn:process id="Process_Applicant_Organisation" name="Applicant Organisation" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Applicant_Organisation">
      <bpmn:lane id="Applicant" name="Applicant">
        <bpmn:flowNodeRef>Resubmit_Documents</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:task id="Resubmit_Documents" name="Resubmit Documents"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Government_Agency_di" bpmnElement="actor_Government_Agency" isHorizontal="true">
