      <bpmndi:BPMNShape id="Check_Documentation_Again_di" bpmnElement="Check_Documentation_Again">
        <dc:Bounds x="390" y="498" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Review_Combined_Outcomes_di" bpmnElement="Review_Combined_Outcomes">
        <dc:Bounds x="390" y="608" width="120" height="80"/>
      </bpmndi:BPMNShape>
