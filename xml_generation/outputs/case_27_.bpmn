<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_contractor_pool" name="Contractor" processRef="Process_contractor_pool"/>
    <bpmn:participant id="actor_authority_pool" name="Municipal Authority" processRef="Process_authority_pool"/>
    <bpmn:messageFlow id="mf1" name="Permit Application" sourceRef="submit_application" targetRef="start_permits"/>
    <bpmn:messageFlow id="mf2" name="Missing Documents Notice" sourceRef="throw_incomplete" targetRef="catch_incomplete"/>
    <bpmn:messageFlow id="mf3" name="Resubmitted Documents" sourceRef="throw_resubmit" targetRef="catch_resubmission"/>
    <bpmn:messageFlow id="mf4" name="Permit Refusal Notice" sourceRef="throw_refusal" targetRef="catch_refusal"/>
    <bpmn:messageFlow id="mf5" name="Building Permit" sourceRef="throw_permit" targetRef="catch_permit"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_contractor_pool" name="Contractor" isExecutable="false">
    <bpmn:laneSet id="LaneSet_contractor_pool">
      <bpmn:lane id="contractor" name="Contractor">
        <bpmn:flowNodeRef>start_contractor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_resubmit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_refusal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_contractor_refused</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_permit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_contractor_approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>collect_docs</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_contractor" name="Start"/>
    <bpmn:intermediateCatchEvent id="catch_incomplete" name="Missing Documents Notice Received">
      <bpmn:messageEventDefinition id="catch_incomplete_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_resubmit" name="Resubmit Documents">
      <bpmn:messageEventDefinition id="throw_resubmit_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_refusal" name="Refusal Notice Received">
      <bpmn:messageEventDefinition id="catch_refusal_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_contractor_refused" name="Ended: Permit Refused"/>
    <bpmn:intermediateCatchEvent id="catch_permit" name="Building Permit Received">
      <bpmn:messageEventDefinition id="catch_permit_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_contractor_approved" name="Ended: Permit Issued"/>
    <bpmn:task id="submit_application" name="Submit Permit Application"/>
    <bpmn:task id="collect_docs" name="Collect Missing Documents"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_contractor" targetRef="submit_application"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="catch_incomplete" targetRef="collect_docs"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="collect_docs" targetRef="throw_resubmit"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="catch_refusal" targetRef="end_contractor_refused"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="catch_permit" targetRef="end_contractor_approved"/>
  </bpmn:process>
  <bpmn:process id="Process_authority_pool" name="Municipal Authority" isExecutable="false">
    <bpmn:laneSet id="LaneSet_authority_pool">
      <bpmn:lane id="permits_clerk" name="Permits Clerk">
        <bpmn:flowNodeRef>start_permits</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_resubmission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_refusal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_permit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_permits</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_refusal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>issue_permit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_rework</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="urban_planning" name="Urban Planning Department">
        <bpmn:flowNodeRef>zoning_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_zoning</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="building_safety" name="Building Safety Department">
        <bpmn:flowNodeRef>safety_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_safety</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_permits" name="Application Received">
      <bpmn:messageEventDefinition id="start_permits_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateThrowEvent id="throw_incomplete" name="Notify Contractor of Missing Docs">
      <bpmn:messageEventDefinition id="throw_incomplete_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_resubmission" name="Receive Resubmitted Documents">
      <bpmn:messageEventDefinition id="catch_resubmission_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_refusal" name="Send Permit Refusal Notice">
      <bpmn:messageEventDefinition id="throw_refusal_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_permit" name="Send Building Permit">
      <bpmn:messageEventDefinition id="throw_permit_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_permits" name="Process Complete"/>
    <bpmn:task id="register_application" name="Register Permit Application"/>
    <bpmn:task id="check_docs" name="Check Documentation Completeness"/>
    <bpmn:task id="review_outcomes" name="Review Combined Verdicts"/>
    <bpmn:task id="send_refusal" name="Send Permit Refusal Notice"/>
    <bpmn:task id="issue_permit" name="Issue Building Permit"/>
    <bpmn:task id="zoning_review" name="Review Zoning Compliance"/>
    <bpmn:task id="record_zoning" name="Record Zoning Verdict"/>
    <bpmn:task id="safety_assessment" name="Assess Structural Safety"/>
    <bpmn:task id="record_safety" name="Record Safety Verdict"/>
    <bpmn:exclusiveGateway id="join_rework" name="Recheck Documentation" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_complete" name="Documentation Complete?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward for Review" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Both Verdicts Positive?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_outcome" name="Merge Outcome Paths" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="start_permits" targetRef="register_application"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="register_application" targetRef="join_rework"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="join_rework" targetRef="check_docs"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="check_docs" targetRef="split_complete"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="split_complete" targetRef="throw_incomplete" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf11" sourceRef="split_complete" targetRef="split_parallel" name="Complete">
      <bpmn:conditionExpression>Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf12" sourceRef="throw_incomplete" targetRef="catch_resubmission"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="catch_resubmission" targetRef="join_rework"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="split_parallel" targetRef="zoning_review"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="split_parallel" targetRef="safety_assessment"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="zoning_review" targetRef="record_zoning"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="record_zoning" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="safety_assessment" targetRef="record_safety"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="record_safety" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf22" sourceRef="split_outcome" targetRef="send_refusal" name="One or more verdicts negative">
      <bpmn:conditionExpression>One or more verdicts negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf23" sourceRef="split_outcome" targetRef="issue_permit" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf24" sourceRef="send_refusal" targetRef="throw_refusal"/>
    <bpmn:sequenceFlow id="sf25" sourceRef="issue_permit" targetRef="throw_permit"/>
    <bpmn:sequenceFlow id="sf26" sourceRef="throw_refusal" targetRef="join_outcome"/>
    <bpmn:sequenceFlow id="sf27" sourceRef="throw_permit" targetRef="join_outcome"/>
    <bpmn:sequenceFlow id="sf28" sourceRef="join_outcome" targetRef="end_permits"/>
  </bpmn:process>
