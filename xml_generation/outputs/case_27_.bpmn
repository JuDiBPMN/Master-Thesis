<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_gp_pool" name="General Practitioner" processRef="Process_gp_pool"/>
    <bpmn:participant id="actor_hospital_pool" name="Hospital" processRef="Process_hospital_pool"/>
    <bpmn:participant id="actor_specialist_pool" name="Specialist" processRef="Process_specialist_pool"/>
    <bpmn:messageFlow id="mf1" name="Referral Request" sourceRef="send_referral" targetRef="start_hospital"/>
    <bpmn:messageFlow id="mf2" name="No Availability Notice" sourceRef="notify_no_slot" targetRef="end_gp_no_slot"/>
    <bpmn:messageFlow id="mf3" name="Referral Package" sourceRef="notify_gp_booked" targetRef="start_specialist"/>
    <bpmn:messageFlow id="mf4" name="Discharge Notice" sourceRef="notify_gp_discharge" targetRef="end_gp_discharged"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_gp_pool" name="General Practitioner" isExecutable="false">
    <bpmn:laneSet id="LaneSet_gp_pool">
      <bpmn:lane id="gp" name="General Practitioner">
        <bpmn:flowNodeRef>start_gp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_gp_no_referral</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_gp_no_slot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_gp_discharged</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>examine_patient</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>prescribe_treatment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_referral</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_referral</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_gp" name="Start"/>
    <bpmn:endEvent id="end_gp_no_referral" name="Treatment Prescribed"/>
    <bpmn:endEvent id="end_gp_no_slot" name="No Slot Available"/>
    <bpmn:endEvent id="end_gp_discharged" name="Patient Discharged"/>
    <bpmn:task id="examine_patient" name="Examine Patient"/>
    <bpmn:task id="prescribe_treatment" name="Prescribe Treatment Directly"/>
    <bpmn:task id="send_referral" name="Send Referral Request"/>
    <bpmn:exclusiveGateway id="split_referral" name="Referral Needed?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_gp" targetRef="examine_patient"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="examine_patient" targetRef="split_referral"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="split_referral" targetRef="prescribe_treatment" name="No referral needed">
      <bpmn:conditionExpression>No referral needed</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf4" sourceRef="split_referral" targetRef="send_referral" name="Referral needed">
      <bpmn:conditionExpression>Referral needed</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf5" sourceRef="prescribe_treatment" targetRef="end_gp_no_referral"/>
  </bpmn:process>
  <bpmn:process id="Process_hospital_pool" name="Hospital" isExecutable="false">
    <bpmn:laneSet id="LaneSet_hospital_pool">
      <bpmn:lane id="intake_coord" name="Intake Coordinator">
        <bpmn:flowNodeRef>start_hospital</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hospital_no_slot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hospital_booked</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_referral</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_no_slot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>book_appointment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_gp_booked</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_slot</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hospital" name="Referral Received">
      <bpmn:messageEventDefinition id="start_hospital_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_hospital_no_slot" name="GP Notified"/>
    <bpmn:endEvent id="end_hospital_booked" name="Appointment Booked"/>
    <bpmn:task id="review_referral" name="Review Referral and Check Availability"/>
    <bpmn:task id="notify_no_slot" name="Notify GP of No Availability"/>
    <bpmn:task id="book_appointment" name="Book Appointment"/>
    <bpmn:task id="notify_gp_booked" name="Notify GP of Appointment"/>
    <bpmn:exclusiveGateway id="split_slot" name="Slot Available?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="start_hospital" targetRef="review_referral"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="review_referral" targetRef="split_slot"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="split_slot" targetRef="notify_no_slot" name="No slot available">
      <bpmn:conditionExpression>No slot available</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf9" sourceRef="split_slot" targetRef="book_appointment" name="Slot available">
      <bpmn:conditionExpression>Slot available</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf10" sourceRef="notify_no_slot" targetRef="end_hospital_no_slot"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="book_appointment" targetRef="notify_gp_booked"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="notify_gp_booked" targetRef="end_hospital_booked"/>
  </bpmn:process>
  <bpmn:process id="Process_specialist_pool" name="Specialist" isExecutable="false">
    <bpmn:laneSet id="LaneSet_specialist_pool">
      <bpmn:lane id="specialist" name="Specialist">
        <bpmn:flowNodeRef>start_specialist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_specialist_treat</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_specialist_disc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>examine_specialist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_diagnosis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>schedule_treatment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>discharge_patient</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_gp_discharge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_followup</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_specialist" name="Referral Received">
      <bpmn:messageEventDefinition id="start_specialist_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_specialist_treat" name="Treatment Plan Scheduled"/>
    <bpmn:endEvent id="end_specialist_disc" name="Patient Discharged"/>
    <bpmn:task id="examine_specialist" name="Examine Patient"/>
    <bpmn:task id="record_diagnosis" name="Record Diagnosis"/>
    <bpmn:task id="schedule_treatment" name="Schedule Treatment Plan"/>
    <bpmn:task id="discharge_patient" name="Discharge Patient"/>
    <bpmn:task id="notify_gp_discharge" name="Notify GP of Discharge"/>
    <bpmn:exclusiveGateway id="split_followup" name="Follow-up Treatment Required?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="start_specialist" targetRef="examine_specialist"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="examine_specialist" targetRef="record_diagnosis"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="record_diagnosis" targetRef="split_followup"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="split_followup" targetRef="schedule_treatment" name="Follow-up required">
      <bpmn:conditionExpression>Follow-up required</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf17" sourceRef="split_followup" targetRef="discharge_patient" name="No further treatment">
      <bpmn:conditionExpression>No further treatment</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf18" sourceRef="schedule_treatment" targetRef="end_specialist_treat"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="discharge_patient" targetRef="notify_gp_discharge"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="notify_gp_discharge" targetRef="end_specialist_disc"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
