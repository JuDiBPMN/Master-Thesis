<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_government_agency" name="Government Agency" processRef="Process_government_agency"/>
    <bpmn:participant id="actor_applicant_organisation" name="Applicant Organisation" processRef="Process_applicant_organisation"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="submit_application" targetRef="register_application"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="notify_missing_documents" targetRef="collect_missing_documents"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="resubmit_documents" targetRef="check_documentation_again"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="send_rejection_notice" targetRef="end_applicant"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_government_agency" name="Government Agency" isExecutable="false">
    <bpmn:laneSet id="LaneSet_government_agency">
      <bpmn:lane id="grants_office" name="Grants Office">
        <bpmn:flowNodeRef>end_grants_office</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_documentation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_missing_documents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_documentation_again</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>forward_to_review_panels</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_combined_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection_notice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>issue_grant_approval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_documentation_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_documentation_check_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_outcome_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_outcome_review_join</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="technical_review_panel" name="Technical Review Panel">
        <bpmn:flowNodeRef>assess_project_feasibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_technical_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance_department" name="Finance Department">
        <bpmn:flowNodeRef>review_proposed_budget</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_finance_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:endEvent id="end_grants_office" name="End"/>
    <bpmn:task id="register_application" name="Register Application"/>
    <bpmn:task id="check_documentation" name="Check Documentation"/>
    <bpmn:task id="notify_missing_documents" name="Notify Missing Documents"/>
    <bpmn:task id="check_documentation_again" name="Check Documentation Again"/>
    <bpmn:task id="forward_to_review_panels" name="Forward to Review Panels"/>
    <bpmn:task id="assess_project_feasibility" name="Assess Project Feasibility"/>
    <bpmn:task id="record_technical_verdict" name="Record Technical Verdict"/>
    <bpmn:task id="review_proposed_budget" name="Review Proposed Budget"/>
    <bpmn:task id="record_finance_verdict" name="Record Finance Verdict"/>
    <bpmn:task id="review_combined_outcomes" name="Review Combined Outcomes"/>
    <bpmn:task id="send_rejection_notice" name="Send Rejection Notice"/>
    <bpmn:task id="issue_grant_approval" name="Issue Grant Approval"/>
    <bpmn:exclusiveGateway id="gateway_documentation_check" name="Documentation Complete?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_documentation_check_join" name="Documentation Check Complete" gatewayDirection="converging"/>
    <bpmn:parallelGateway id="gateway_parallel_split" name="Start Concurrent Reviews" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_join" name="Reviews Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_outcome_review" name="Review Outcomes" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_outcome_review_join" name="Outcome Review Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_application" targetRef="check_documentation"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="check_documentation" targetRef="gateway_documentation_check"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="gateway_documentation_check" targetRef="notify_missing_documents" name="documentation is incomplete">
      <bpmn:conditionExpression>documentation is incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf9" sourceRef="check_documentation_again" targetRef="gateway_documentation_check_join"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="gateway_documentation_check" targetRef="forward_to_review_panels" name="documentation is complete">
      <bpmn:conditionExpression>documentation is complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf11" sourceRef="forward_to_review_panels" targetRef="gateway_parallel_split"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="gateway_parallel_split" targetRef="assess_project_feasibility"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="gateway_parallel_split" targetRef="review_proposed_budget"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="assess_project_feasibility" targetRef="record_technical_verdict"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="review_proposed_budget" targetRef="record_finance_verdict"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="record_technical_verdict" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="record_finance_verdict" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="gateway_parallel_join" targetRef="review_combined_outcomes"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="review_combined_outcomes" targetRef="gateway_outcome_review"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="gateway_outcome_review" targetRef="send_rejection_notice" name="either verdict is negative">
      <bpmn:conditionExpression>either verdict is negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf22" sourceRef="gateway_outcome_review" targetRef="issue_grant_approval" name="both verdicts are positive">
      <bpmn:conditionExpression>both verdicts are positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf23" sourceRef="issue_grant_approval" targetRef="end_grants_office"/>
    <bpmn:sequenceFlow id="sf24" sourceRef="gateway_outcome_review" targetRef="gateway_outcome_review_join" name="either verdict is negative">
      <bpmn:conditionExpression>either verdict is negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf25" sourceRef="issue_grant_approval" targetRef="gateway_outcome_review_join"/>
    <bpmn:sequenceFlow id="sf26" sourceRef="gateway_outcome_review_join" targetRef="end_grants_office"/>
  </bpmn:process>
  <bpmn:process id="Process_applicant_organisation" name="Applicant Organisation" isExecutable="false">
    <bpmn:laneSet id="LaneSet_applicant_organisation">
      <bpmn:lane id="applicant" name="Applicant">
        <bpmn:flowNodeRef>start_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_applicant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>collect_missing_documents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>resubmit_documents</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_application" name="Start Application"/>
    <bpmn:endEvent id="end_applicant" name="End"/>
    <bpmn:task id="submit_application" name="Submit Application"/>
    <bpmn:task id="collect_missing_documents" name="Collect Missing Documents"/>
    <bpmn:task id="resubmit_documents" name="Resubmit Documents"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_application" targetRef="submit_application"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="collect_missing_documents" targetRef="resubmit_documents"/>
  </bpmn:process>
