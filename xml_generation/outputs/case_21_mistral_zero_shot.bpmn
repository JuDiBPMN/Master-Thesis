<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Retailer" name="Retailer" processRef="Process_Retailer"/>
    <bpmn:participant id="actor_Customer" name="Customer" processRef="Process_Customer"/>
    <bpmn:messageFlow id="CustomerService_Warehouse" name="Product Inspection Verdict" sourceRef="CheckReturnInformation" targetRef="ProductVerdictRecorded"/>
    <bpmn:messageFlow id="CustomerService_Finance" name="Payment Eligibility Verdict" sourceRef="CheckReturnInformation" targetRef="PaymentVerdictRecorded"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Retailer" name="Retailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Retailer">
      <bpmn:lane id="CustomerService" name="Customer Service">
        <bpmn:flowNodeRef>CustomerSubmitsReturnRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReturnRequestInformationComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReturnRequestInformationIncomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReturnApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReturnRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RegisterReturnRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CheckReturnInformation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReviewCombinedOutcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CheckReturnInformationComplete</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Warehouse" name="Warehouse">
        <bpmn:flowNodeRef>ProductVerdictRecorded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PhysicalProductInspection</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Finance" name="Finance">
        <bpmn:flowNodeRef>PaymentVerdictRecorded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PaymentEligibilityCheck</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="CustomerSubmitsReturnRequest" name="Customer Submits Return Request"/>
    <bpmn:intermediateCatchEvent id="ReturnRequestInformationComplete" name="Return Request Information Complete"/>
    <bpmn:intermediateThrowEvent id="ReturnRequestInformationIncomplete" name="Return Request Information Incomplete"/>
    <bpmn:intermediateCatchEvent id="ProductVerdictRecorded" name="Product Verdict Recorded"/>
    <bpmn:intermediateCatchEvent id="PaymentVerdictRecorded" name="Payment Verdict Recorded"/>
    <bpmn:endEvent id="ReturnApproved" name="Return Approved"/>
    <bpmn:endEvent id="ReturnRejected" name="Return Rejected"/>
    <bpmn:task id="RegisterReturnRequest" name="Register Return Request"/>
    <bpmn:task id="CheckReturnInformation" name="Check Return Information"/>
    <bpmn:task id="PhysicalProductInspection" name="Physical Product Inspection"/>
    <bpmn:task id="PaymentEligibilityCheck" name="Payment Eligibility Check"/>
    <bpmn:task id="ReviewCombinedOutcomes" name="Review Combined Outcomes"/>
    <bpmn:exclusiveGateway id="CheckReturnInformationComplete" name="Check Return Information Complete" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="CustomerSubmitsReturnRequest_RegisterReturnRequest" sourceRef="CustomerSubmitsReturnRequest" targetRef="RegisterReturnRequest"/>
    <bpmn:sequenceFlow id="RegisterReturnRequest_CheckReturnInformation" sourceRef="RegisterReturnRequest" targetRef="CheckReturnInformation"/>
    <bpmn:sequenceFlow id="CheckReturnInformation_ProductVerdictRecorded" sourceRef="CheckReturnInformation" targetRef="ProductVerdictRecorded"/>
    <bpmn:sequenceFlow id="ProductVerdictRecorded_PaymentVerdictRecorded" sourceRef="ProductVerdictRecorded" targetRef="PaymentVerdictRecorded"/>
    <bpmn:sequenceFlow id="PaymentVerdictRecorded_ReviewCombinedOutcomes" sourceRef="PaymentVerdictRecorded" targetRef="ReviewCombinedOutcomes"/>
    <bpmn:sequenceFlow id="ReviewCombinedOutcomes_ReturnApproved" sourceRef="ReviewCombinedOutcomes" targetRef="ReturnApproved"/>
    <bpmn:sequenceFlow id="ReviewCombinedOutcomes_ReturnRejected" sourceRef="ReviewCombinedOutcomes" targetRef="ReturnRejected"/>
    <bpmn:sequenceFlow id="CheckReturnInformationComplete_ProductVerdictRecorded" sourceRef="CheckReturnInformationComplete" targetRef="ProductVerdictRecorded"/>
    <bpmn:sequenceFlow id="CheckReturnInformationComplete_ReturnRejected" sourceRef="CheckReturnInformationComplete" targetRef="ReturnRejected"/>
    <bpmn:sequenceFlow id="CheckReturnInformationComplete_ReturnApproved" sourceRef="CheckReturnInformationComplete" targetRef="ReviewCombinedOutcomes"/>
  </bpmn:process>
  <bpmn:process id="Process_Customer" name="Customer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Customer">
      <bpmn:lane id="Customer" name="Customer"/>
    </bpmn:laneSet>
  </bpmn:process>
