<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_pool_applicant" name="Applicant Organisation" processRef="Process_pool_applicant"/>
    <bpmn:participant id="actor_pool_agency" name="Government Agency" processRef="Process_pool_agency"/>
    <bpmn:messageFlow id="mf01" name="Grant application" sourceRef="throw_applicant_submission" targetRef="start_grants"/>
    <bpmn:messageFlow id="mf02" name="Missing documents notice" sourceRef="throw_grants_missing" targetRef="catch_applicant_missing"/>
    <bpmn:messageFlow id="mf03" name="Resubmitted application" sourceRef="throw_applicant_resubmit" targetRef="catch_grants_resubmission"/>
    <bpmn:messageFlow id="mf04" name="Application for feasibility review" sourceRef="throw_grants_to_technical" targetRef="catch_technical_request"/>
    <bpmn:messageFlow id="mf05" name="Application for budget review" sourceRef="throw_grants_to_finance" targetRef="catch_finance_request"/>
    <bpmn:messageFlow id="mf06" name="Feasibility verdict" sourceRef="throw_technical_verdict" targetRef="catch_grants_tech_verdict"/>
    <bpmn:messageFlow id="mf07" name="Budget verdict" sourceRef="throw_finance_verdict" targetRef="catch_grants_fin_verdict"/>
    <bpmn:messageFlow id="mf08" name="Rejection notice" sourceRef="throw_grants_rejection" targetRef="catch_applicant_outcome"/>
    <bpmn:messageFlow id="mf09" name="Grant approval letter" sourceRef="throw_grants_approval" targetRef="catch_applicant_outcome"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_pool_applicant" name="Applicant Organisation" isExecutable="false">
    <bpmn:laneSet id="LaneSet_pool_applicant">
      <bpmn:lane id="lane_applicant" name="Applicant">
        <bpmn:flowNodeRef>start_applicant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_applicant_submission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_applicant_missing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_applicant_resubmit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_applicant_outcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_applicant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_submit_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_collect_documents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_resubmit</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_applicant" name="Grant application process started"/>
    <bpmn:intermediateThrowEvent id="throw_applicant_submission" name="Send grant application">
      <bpmn:messageEventDefinition id="throw_applicant_submission_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_applicant_missing" name="Receive missing documents notice">
      <bpmn:messageEventDefinition id="catch_applicant_missing_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_applicant_resubmit" name="Send resubmission">
      <bpmn:messageEventDefinition id="throw_applicant_resubmit_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_applicant_outcome" name="Receive decision from agency">
      <bpmn:messageEventDefinition id="catch_applicant_outcome_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_applicant" name="End"/>
    <bpmn:userTask id="task_submit_application" name="Submit grant application"/>
    <bpmn:userTask id="task_collect_documents" name="Collect missing documents"/>
    <bpmn:userTask id="task_resubmit" name="Resubmit application"/>
    <bpmn:sequenceFlow id="sf01" sourceRef="start_applicant" targetRef="task_submit_application"/>
    <bpmn:sequenceFlow id="sf02" sourceRef="task_submit_application" targetRef="throw_applicant_submission"/>
    <bpmn:sequenceFlow id="sf03" sourceRef="catch_applicant_missing" targetRef="task_collect_documents"/>
    <bpmn:sequenceFlow id="sf04" sourceRef="task_collect_documents" targetRef="task_resubmit"/>
    <bpmn:sequenceFlow id="sf05" sourceRef="task_resubmit" targetRef="throw_applicant_resubmit"/>
    <bpmn:sequenceFlow id="sf06" sourceRef="catch_applicant_outcome" targetRef="end_applicant"/>
  </bpmn:process>
  <bpmn:process id="Process_pool_agency" name="Government Agency" isExecutable="false">
    <bpmn:laneSet id="LaneSet_pool_agency">
      <bpmn:lane id="lane_grants" name="Grants Office">
        <bpmn:flowNodeRef>start_grants</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_grants_resubmission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_grants_missing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_grants_to_technical</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_grants_to_finance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_grants_tech_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_grants_fin_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_grants_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_grants_approval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_grants_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_grants_approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_register_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_check_completeness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_notify_missing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_complete_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_complete_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_verdicts_split</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_technical" name="Technical Review Panel">
        <bpmn:flowNodeRef>catch_technical_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_technical_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_technical</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_assess_feasibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_record_tech_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_finance" name="Finance Department">
        <bpmn:flowNodeRef>catch_finance_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_finance_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_finance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_review_budget</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_record_fin_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_grants" name="Receive grant application">
      <bpmn:messageEventDefinition id="start_grants_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="catch_grants_resubmission" name="Receive resubmission">
      <bpmn:messageEventDefinition id="catch_grants_resubmission_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_grants_missing" name="Send missing documents notice">
      <bpmn:messageEventDefinition id="throw_grants_missing_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_grants_to_technical" name="Forward application to technical panel">
      <bpmn:messageEventDefinition id="throw_grants_to_technical_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_grants_to_finance" name="Forward application to finance">
      <bpmn:messageEventDefinition id="throw_grants_to_finance_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="catch_grants_tech_verdict" name="Receive feasibility verdict">
      <bpmn:messageEventDefinition id="catch_grants_tech_verdict_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="catch_grants_fin_verdict" name="Receive budget verdict">
      <bpmn:messageEventDefinition id="catch_grants_fin_verdict_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_grants_rejection" name="Send rejection notice">
      <bpmn:messageEventDefinition id="throw_grants_rejection_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_grants_approval" name="Send grant approval letter">
      <bpmn:messageEventDefinition id="throw_grants_approval_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_grants_rejected" name="End – application rejected"/>
    <bpmn:endEvent id="end_grants_approved" name="End – grant approved"/>
    <bpmn:intermediateCatchEvent id="catch_technical_request" name="Receive application for review">
      <bpmn:messageEventDefinition id="catch_technical_request_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_technical_verdict" name="Send feasibility verdict">
      <bpmn:messageEventDefinition id="throw_technical_verdict_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_technical" name="End"/>
    <bpmn:intermediateCatchEvent id="catch_finance_request" name="Receive application for budget review">
      <bpmn:messageEventDefinition id="catch_finance_request_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_finance_verdict" name="Send budget verdict">
      <bpmn:messageEventDefinition id="throw_finance_verdict_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_finance" name="End"/>
    <bpmn:userTask id="task_register_application" name="Register application"/>
    <bpmn:userTask id="task_check_completeness" name="Check documentation completeness"/>
    <bpmn:userTask id="task_notify_missing" name="Notify applicant of missing documents"/>
    <bpmn:userTask id="task_review_outcomes" name="Review combined outcomes"/>
    <bpmn:userTask id="task_assess_feasibility" name="Assess project feasibility"/>
    <bpmn:userTask id="task_record_tech_verdict" name="Record feasibility verdict"/>
    <bpmn:userTask id="task_review_budget" name="Review proposed budget"/>
    <bpmn:userTask id="task_record_fin_verdict" name="Record budget verdict"/>
    <bpmn:exclusiveGateway id="gw_complete_split" name="Documentation complete?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gw_complete_join" name="Merge completeness check loop" gatewayDirection="converging"/>
    <bpmn:parallelGateway id="gw_parallel_split" name="Forward to reviewers" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gw_parallel_join" name="Wait for both verdicts" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gw_verdicts_split" name="Both verdicts positive?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf07" sourceRef="start_grants" targetRef="gw_complete_join"/>
    <bpmn:sequenceFlow id="sf08" sourceRef="catch_grants_resubmission" targetRef="gw_complete_join"/>
    <bpmn:sequenceFlow id="sf09" sourceRef="gw_complete_join" targetRef="task_register_application"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="task_register_application" targetRef="task_check_completeness"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="task_check_completeness" targetRef="gw_complete_split"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="gw_complete_split" targetRef="task_notify_missing" name="Documentation incomplete">
      <bpmn:conditionExpression>Documentation incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf13" sourceRef="task_notify_missing" targetRef="throw_grants_missing"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="throw_grants_missing" targetRef="gw_complete_join"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="gw_complete_split" targetRef="gw_parallel_split" name="Documentation complete">
      <bpmn:conditionExpression>Documentation complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf16" sourceRef="gw_parallel_split" targetRef="throw_grants_to_technical"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="gw_parallel_split" targetRef="throw_grants_to_finance"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="catch_grants_tech_verdict" targetRef="gw_parallel_join"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="catch_grants_fin_verdict" targetRef="gw_parallel_join"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="gw_parallel_join" targetRef="task_review_outcomes"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="task_review_outcomes" targetRef="gw_verdicts_split"/>
    <bpmn:sequenceFlow id="sf22" sourceRef="gw_verdicts_split" targetRef="throw_grants_rejection" name="Either verdict is negative">
      <bpmn:conditionExpression>Either verdict is negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf23" sourceRef="throw_grants_rejection" targetRef="end_grants_rejected"/>
    <bpmn:sequenceFlow id="sf24" sourceRef="gw_verdicts_split" targetRef="throw_grants_approval" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf25" sourceRef="throw_grants_approval" targetRef="end_grants_approved"/>
    <bpmn:sequenceFlow id="sf26" sourceRef="catch_technical_request" targetRef="task_assess_feasibility"/>
    <bpmn:sequenceFlow id="sf27" sourceRef="task_assess_feasibility" targetRef="task_record_tech_verdict"/>
    <bpmn:sequenceFlow id="sf28" sourceRef="task_record_tech_verdict" targetRef="throw_technical_verdict"/>
    <bpmn:sequenceFlow id="sf29" sourceRef="throw_technical_verdict" targetRef="end_technical"/>
    <bpmn:sequenceFlow id="sf30" sourceRef="catch_finance_request" targetRef="task_review_budget"/>
    <bpmn:sequenceFlow id="sf31" sourceRef="task_review_budget" targetRef="task_record_fin_verdict"/>
    <bpmn:sequenceFlow id="sf32" sourceRef="task_record_fin_verdict" targetRef="throw_finance_verdict"/>
    <bpmn:sequenceFlow id="sf33" sourceRef="throw_finance_verdict" targetRef="end_finance"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
