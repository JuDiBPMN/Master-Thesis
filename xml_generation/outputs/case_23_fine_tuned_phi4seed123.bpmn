<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Client" name="Client" processRef="Process_Client"/>
    <bpmn:participant id="actor_BrightWave Energy" name="BrightWave Energy" processRef="Process_BrightWave Energy"/>
    <bpmn:messageFlow id="Complaint Sent_Complaint Received" name="Complaint" sourceRef="Complaint Sent" targetRef="Complaint Received"/>
    <bpmn:messageFlow id="No Mistake Found_Explanation Sent" name="Explanation" sourceRef="No Mistake Found" targetRef="Explanation Sent"/>
    <bpmn:messageFlow id="Ticket Created_Ticket Assigned" name="Ticket" sourceRef="Ticket Created" targetRef="Ticket Assigned"/>
    <bpmn:messageFlow id="Send New Invoice_New Invoice Received" name="New Invoice" sourceRef="Send New Invoice" targetRef="New Invoice Received"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="Complaint Sent" targetRef="Complaint Received"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="No Mistake Found" targetRef="Explanation Sent"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="Send New Invoice" targetRef="New Invoice Received"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="New Invoice Received" targetRef="Mistake Resolved"/>
    <bpmn:messageFlow id="MsgFlow_p4" name="" sourceRef="Mistake Resolved" targetRef="End"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Client" name="Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Client">
      <bpmn:lane id="Client" name="Client"/>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="Start"/>
    <bpmn:intermediateThrowEvent id="Complaint Sent" name="Complaint Sent">
      <bpmn:messageEventDefinition id="Complaint Sent_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Explanation Sent" name="Explanation Sent">
      <bpmn:messageEventDefinition id="Explanation Sent_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="New Invoice Received" name="New Invoice Received">
      <bpmn:messageEventDefinition id="New Invoice Received_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="End" name="End"/>
    <bpmn:task id="Write Complaint Email" name="Write Complaint Email"/>
    <bpmn:sequenceFlow id="Start_Write Complaint Email" sourceRef="Start" targetRef="Write Complaint Email"/>
    <bpmn:sequenceFlow id="Write Complaint Email_Complaint Sent" sourceRef="Write Complaint Email" targetRef="Complaint Sent"/>
    <bpmn:sequenceFlow id="Explanation Sent_End" sourceRef="Explanation Sent" targetRef="End"/>
  </bpmn:process>
  <bpmn:process id="Process_BrightWave Energy" name="BrightWave Energy" isExecutable="false">
    <bpmn:laneSet id="LaneSet_BrightWave Energy">
      <bpmn:lane id="Customer Service" name="Customer Service">
        <bpmn:flowNodeRef>Complaint Received</bpmn:flowNodeRef>
