        <bpmn:flowNodeRef>Assign Ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Check Mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Mistake Resolved</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Invoicing" name="Invoicing">
        <bpmn:flowNodeRef>Ticket Assigned</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>New Invoice Sent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Investigate Mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Make Correction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Generate New Invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Send New Invoice</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
