    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Write Explanation Email_No Mistake Found" sourceRef="Write Explanation Email" targetRef="No Mistake Found"/>
    <bpmn:sequenceFlow id="Check Mistake_Create Ticket" sourceRef="Check Mistake" targetRef="Create Ticket" name="mistake found">
      <bpmn:conditionExpression>mistake found</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Create Ticket_Ticket Created" sourceRef="Create Ticket" targetRef="Ticket Created"/>
