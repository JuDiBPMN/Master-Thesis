    <bpmn:exclusiveGateway id="Check Mistake" name="Check Mistake" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="Mistake Resolved" name="Mistake Resolved" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="Complaint Received_Lookup Billing Information" sourceRef="Complaint Received" targetRef="Lookup Billing Information"/>
