<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:process id="Process_publishing_house" name="Publishing House" isExecutable="false">
    <bpmn:laneSet id="LaneSet_publishing_house">
      <bpmn:lane id="editorial_manager" name="Editorial Manager">
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>accept_manuscript</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>assign_editor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>assign_layout_designer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_proof</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>identify_issues</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>request_new_proof</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_simultaneous</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_join</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="editor" name="Editor">
        <bpmn:flowNodeRef>proofread_manuscript</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="layout_designer" name="Layout Designer">
        <bpmn:flowNodeRef>format_pages</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>design_cover</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>apply_corrections</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="print_manager" name="Print Manager">
        <bpmn:flowNodeRef>end_process</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>place_full_print_order</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start" name="Manuscript Accepted"/>
    <bpmn:endEvent id="end_process" name="Process Ends"/>
    <bpmn:task id="accept_manuscript" name="Accept Manuscript"/>
    <bpmn:task id="assign_editor" name="Assign Editor"/>
    <bpmn:task id="assign_layout_designer" name="Assign Layout Designer"/>
    <bpmn:task id="proofread_manuscript" name="Proofread Manuscript"/>
    <bpmn:task id="format_pages" name="Format Pages"/>
    <bpmn:task id="design_cover" name="Design Cover"/>
    <bpmn:task id="review_proof" name="Review Proof"/>
    <bpmn:task id="identify_issues" name="Identify Issues"/>
    <bpmn:task id="apply_corrections" name="Apply Corrections"/>
    <bpmn:task id="request_new_proof" name="Request New Proof"/>
    <bpmn:task id="place_full_print_order" name="Place Full Print Order"/>
    <bpmn:parallelGateway id="gateway_simultaneous" name="Simultaneous Assignment" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_approved" name="Proof Approved?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_rejected" name="Proof Rejected?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_join" name="Both Branches Join" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start" targetRef="accept_manuscript"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="accept_manuscript" targetRef="gateway_simultaneous"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="gateway_simultaneous" targetRef="proofread_manuscript"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="proofread_manuscript" targetRef="gateway_approved"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="gateway_approved" targetRef="place_full_print_order"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="gateway_approved" targetRef="end_process"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="gateway_rejected" targetRef="identify_issues"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="identify_issues" targetRef="apply_corrections"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="apply_corrections" targetRef="request_new_proof"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="request_new_proof" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="gateway_parallel_join" targetRef="proofread_manuscript"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_publishing_house">
      <bpmndi:BPMNShape id="editorial_manager_di" bpmnElement="editorial_manager" isHorizontal="true">
