      </bpmn:lane>
      <bpmn:lane id="gp" name="GP">
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gp_submits_referral</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
