    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf9" sourceRef="analyzeComplaint" targetRef="consultDepartments" name="none">
      <bpmn:conditionExpression>none</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf10" sourceRef="consultDepartments" targetRef="exclusiveGateway2" name="none">
      <bpmn:conditionExpression>none</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf11" sourceRef="exclusiveGateway2" targetRef="resolveComplaint" name="none">
      <bpmn:conditionExpression>none</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf12" sourceRef="resolveComplaint" targetRef="archiveComplaint" name="none">
      <bpmn:conditionExpression>none</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf13" sourceRef="archiveComplaint" targetRef="closeComplaint" name="none">
      <bpmn:conditionExpression>none</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf14" sourceRef="closeComplaint" targetRef="endEvent" name="none">
      <bpmn:conditionExpression>none</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
