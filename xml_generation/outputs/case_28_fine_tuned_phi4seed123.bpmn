        <bpmn:flowNodeRef>consultDepartments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>resolveComplaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>archiveComplaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>closeComplaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>exclusiveGateway1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>exclusiveGateway2</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="startEvent" name="Start"/>
    <bpmn:endEvent id="endEvent" name="End"/>
    <bpmn:intermediateCatchEvent id="complaintReceived" name="Complaint Received">
      <bpmn:messageEventDefinition id="complaintReceived_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="complaintHandled" name="Complaint Handled">
      <bpmn:messageEventDefinition id="complaintHandled_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:task id="receiveComplaint" name="Receive Complaint"/>
    <bpmn:task id="recordCallDetails" name="Record Call Details"/>
    <bpmn:task id="documentConcerns" name="Document Concerns"/>
    <bpmn:task id="noteReceiptDate" name="Note Receipt Date"/>
    <bpmn:task id="analyzeComplaint" name="Analyze Complaint"/>
    <bpmn:task id="consultDepartments" name="Consult Departments"/>
    <bpmn:task id="resolveComplaint" name="Resolve Complaint"/>
    <bpmn:task id="archiveComplaint" name="Archive Complaint"/>
    <bpmn:task id="closeComplaint" name="Close Complaint"/>
    <bpmn:exclusiveGateway id="exclusiveGateway1" name="Exclusive Gateway 1" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="exclusiveGateway2" name="Exclusive Gateway 2" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="startEvent" targetRef="exclusiveGateway1" name="none">
      <bpmn:conditionExpression>none</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf2" sourceRef="exclusiveGateway1" targetRef="recordCallDetails" name="phone call">
      <bpmn:conditionExpression>phone call</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf3" sourceRef="exclusiveGateway1" targetRef="documentConcerns" name="in-person">
      <bpmn:conditionExpression>in-person</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf4" sourceRef="exclusiveGateway1" targetRef="noteReceiptDate" name="letter">
      <bpmn:conditionExpression>letter</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf5" sourceRef="recordCallDetails" targetRef="complaintReceived" name="none">
      <bpmn:conditionExpression>none</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="documentConcerns" targetRef="complaintReceived" name="none">
      <bpmn:conditionExpression>none</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="noteReceiptDate" targetRef="complaintReceived" name="none">
