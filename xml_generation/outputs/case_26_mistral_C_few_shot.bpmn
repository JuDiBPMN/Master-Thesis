<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_HR_manager_pool" name="HR Manager" processRef="Process_HR_manager_pool"/>
    <bpmn:participant id="actor_Business_manager_pool" name="Business Manager" processRef="Process_Business_manager_pool"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="Success" sourceRef="gateway_assessment_split" targetRef="prepare_contract"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="Failure" sourceRef="gateway_assessment_split" targetRef="close_application"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="prepare_contract" targetRef="end_HR_manager"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="close_application" targetRef="end_HR_manager"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_HR_manager_pool" name="HR Manager" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HR_manager_pool">
      <bpmn:lane id="HR_manager" name="HR Manager">
        <bpmn:flowNodeRef>start_HR_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_HR_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>introduction_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>discuss_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>inform_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_assessment_split</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_HR_manager" name="Start"/>
    <bpmn:endEvent id="end_HR_manager" name="End"/>
    <bpmn:task id="introduction_interview" name="Introduction Interview"/>
    <bpmn:task id="discuss_candidate" name="Discuss Candidate with Business Manager"/>
    <bpmn:task id="inform_candidate" name="Inform Candidate about Application"/>
    <bpmn:exclusiveGateway id="gateway_assessment_split" name="Assessment Success?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_HR_manager" targetRef="introduction_interview"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="introduction_interview" targetRef="discuss_candidate"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="discuss_candidate" targetRef="inform_candidate"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="inform_candidate" targetRef="gateway_assessment_split"/>
  </bpmn:process>
  <bpmn:process id="Process_Business_manager_pool" name="Business Manager" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Business_manager_pool">
      <bpmn:lane id="Business_manager" name="Business Manager">
        <bpmn:flowNodeRef>start_Business_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_Business_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>second_assessment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_Business_manager" name="Start"/>
    <bpmn:endEvent id="end_Business_manager" name="End"/>
    <bpmn:task id="second_assessment" name="Second Assessment"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_HR_manager_pool_di" bpmnElement="actor_HR_manager_pool" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="1540" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Business_manager_pool_di" bpmnElement="actor_Business_manager_pool" isHorizontal="true">
        <dc:Bounds x="10" y="330" width="600" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="HR_manager_di" bpmnElement="HR_manager" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="1510" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Business_manager_di" bpmnElement="Business_manager" isHorizontal="true">
        <dc:Bounds x="40" y="330" width="570" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_HR_manager_di" bpmnElement="start_HR_manager">
        <dc:Bounds x="172" y="94" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_HR_manager_di" bpmnElement="end_HR_manager">
        <dc:Bounds x="172" y="160" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="introduction_interview_di" bpmnElement="introduction_interview">
        <dc:Bounds x="390" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="discuss_candidate_di" bpmnElement="discuss_candidate">
        <dc:Bounds x="650" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="inform_candidate_di" bpmnElement="inform_candidate">
        <dc:Bounds x="910" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_assessment_split_di" bpmnElement="gateway_assessment_split" isMarkerVisible="true">
        <dc:Bounds x="1205" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_Business_manager_di" bpmnElement="start_Business_manager">
        <dc:Bounds x="172" y="404" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_Business_manager_di" bpmnElement="end_Business_manager">
        <dc:Bounds x="172" y="470" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="second_assessment_di" bpmnElement="second_assessment">
        <dc:Bounds x="130" y="536" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="208" y="112"/>
        <di:waypoint x="299" y="112"/>
        <di:waypoint x="299" y="145"/>
        <di:waypoint x="390" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="510" y="145"/>
        <di:waypoint x="650" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="770" y="145"/>
        <di:waypoint x="910" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="1030" y="145"/>
        <di:waypoint x="1205" y="145"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>