    <bpmn:task id="decline_application" name="Decline Mortgage Application"/>
    <bpmn:parallelGateway id="split_parallel" name="Start Parallel Processing" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="All Tasks Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_decision" name="Assessment Positive?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="Flow_1kd72rx" sourceRef="start_mortgage_assessment" targetRef="create_mortgage_file"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="create_mortgage_file" targetRef="split_parallel"/>
