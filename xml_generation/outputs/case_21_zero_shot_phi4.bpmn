<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_AdmissionsOffice" name="Admissions Office" processRef="Process_AdmissionsOffice"/>
    <bpmn:participant id="actor_SpecialistDepartment" name="Specialist Department" processRef="Process_SpecialistDepartment"/>
    <bpmn:participant id="actor_InsuranceOffice" name="Insurance Office" processRef="Process_InsuranceOffice"/>
    <bpmn:participant id="actor_GeneralPractitioner" name="General Practitioner" processRef="Process_GeneralPractitioner"/>
    <bpmn:messageFlow id="NotifyGPMessageFlow" name="Notify GP of Missing Documents" sourceRef="AdmissionsClerk" targetRef="GP"/>
    <bpmn:messageFlow id="SendRejectionNoticeMessageFlow" name="Send Rejection Notice" sourceRef="AdmissionsClerk" targetRef="GP"/>
    <bpmn:messageFlow id="SendApprovalMessageFlow" name="Send Treatment Approval" sourceRef="AdmissionsClerk" targetRef="GP"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="StartEvent" targetRef="RegisterReferral"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="ForwardToSpecialist" targetRef="ConductAssessment"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="ForwardToInsurance" targetRef="VerifyCoverage"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="SendVerdictsToClerk" targetRef="ReviewOutcomes"/>
    <bpmn:messageFlow id="MsgFlow_p4" name="" sourceRef="SendVerdictsToClerkInsurance" targetRef="ReviewOutcomes"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_AdmissionsOffice" name="Admissions Office" isExecutable="false">
    <bpmn:laneSet id="LaneSet_AdmissionsOffice">
      <bpmn:lane id="AdmissionsClerk" name="Admissions Clerk">
        <bpmn:flowNodeRef>EndEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEventRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEventApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RegisterReferral</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CheckDocumentation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyGP</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ForwardToSpecialist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ForwardToInsurance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReviewOutcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendRejectionNotice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CheckDocumentationGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReviewOutcomesGateway</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:endEvent id="EndEvent" name="End"/>
    <bpmn:endEvent id="EndEventRejection" name="End Rejection"/>
    <bpmn:endEvent id="EndEventApproval" name="End Approval"/>
    <bpmn:manualTask id="RegisterReferral" name="Register Referral"/>
    <bpmn:manualTask id="CheckDocumentation" name="Check Documentation"/>
    <bpmn:manualTask id="NotifyGP" name="Notify GP of Missing Documents"/>
    <bpmn:manualTask id="ForwardToSpecialist" name="Forward to Specialist"/>
    <bpmn:manualTask id="ForwardToInsurance" name="Forward to Insurance"/>
    <bpmn:manualTask id="ReviewOutcomes" name="Review Combined Outcomes"/>
    <bpmn:manualTask id="SendRejectionNotice" name="Send Rejection Notice"/>
    <bpmn:manualTask id="SendApproval" name="Send Treatment Approval"/>
    <bpmn:exclusiveGateway id="CheckDocumentationGateway" name="Check Documentation" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="ReviewOutcomesGateway" name="Review Outcomes" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="RegisterToCheck" sourceRef="RegisterReferral" targetRef="CheckDocumentation"/>
    <bpmn:sequenceFlow id="CheckToNotify" sourceRef="CheckDocumentation" targetRef="NotifyGP" name="documentationIncomplete">
      <bpmn:conditionExpression>documentationIncomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="CheckToForward" sourceRef="CheckDocumentation" targetRef="ForwardToSpecialist" name="documentationComplete">
      <bpmn:conditionExpression>documentationComplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="ReviewOutcomesToRejection" sourceRef="ReviewOutcomes" targetRef="SendRejectionNotice" name="eitherVerdictNegative">
      <bpmn:conditionExpression>eitherVerdictNegative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="ReviewOutcomesToApproval" sourceRef="ReviewOutcomes" targetRef="SendApproval" name="bothVerdictsPositive">
      <bpmn:conditionExpression>bothVerdictsPositive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SendRejectionNoticeToEndEventRejection" sourceRef="SendRejectionNotice" targetRef="EndEventRejection"/>
    <bpmn:sequenceFlow id="SendApprovalToEndEventApproval" sourceRef="SendApproval" targetRef="EndEventApproval"/>
  </bpmn:process>
  <bpmn:process id="Process_SpecialistDepartment" name="Specialist Department" isExecutable="false">
    <bpmn:laneSet id="LaneSet_SpecialistDepartment">
      <bpmn:lane id="Specialist" name="Specialist">
        <bpmn:flowNodeRef>ConductAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecordSpecialistVerdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendVerdictsToClerk</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:manualTask id="ConductAssessment" name="Conduct Medical Assessment"/>
    <bpmn:manualTask id="RecordSpecialistVerdict" name="Record Specialist Verdict"/>
    <bpmn:manualTask id="SendVerdictsToClerk" name="Send Verdicts to Clerk"/>
    <bpmn:sequenceFlow id="ConductAssessmentToRecordSpecialistVerdict" sourceRef="ConductAssessment" targetRef="RecordSpecialistVerdict"/>
    <bpmn:sequenceFlow id="RecordSpecialistVerdictToSendVerdictsToClerk" sourceRef="RecordSpecialistVerdict" targetRef="SendVerdictsToClerk"/>
  </bpmn:process>
  <bpmn:process id="Process_InsuranceOffice" name="Insurance Office" isExecutable="false">
    <bpmn:laneSet id="LaneSet_InsuranceOffice">
      <bpmn:lane id="InsuranceOfficer" name="Insurance Officer">
        <bpmn:flowNodeRef>VerifyCoverage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecordInsuranceVerdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendVerdictsToClerkInsurance</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:manualTask id="VerifyCoverage" name="Verify Coverage"/>
    <bpmn:manualTask id="RecordInsuranceVerdict" name="Record Insurance Verdict"/>
    <bpmn:manualTask id="SendVerdictsToClerkInsurance" name="Send Verdicts to Clerk"/>
    <bpmn:sequenceFlow id="VerifyCoverageToRecordInsuranceVerdict" sourceRef="VerifyCoverage" targetRef="RecordInsuranceVerdict"/>
    <bpmn:sequenceFlow id="RecordInsuranceVerdictToSendVerdictsToClerkInsurance" sourceRef="RecordInsuranceVerdict" targetRef="SendVerdictsToClerkInsurance"/>
  </bpmn:process>
  <bpmn:process id="Process_GeneralPractitioner" name="General Practitioner" isExecutable="false">
    <bpmn:laneSet id="LaneSet_GeneralPractitioner">
      <bpmn:lane id="GP" name="General Practitioner">
        <bpmn:flowNodeRef>StartEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubmitReferral</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent" name="Start"/>
    <bpmn:manualTask id="SubmitReferral" name="Submit Referral"/>
  </bpmn:process>
