  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Retailer" name="Retailer Company Pool" processRef="Process_Retailer"/>
    <bpmn:participant id="actor_Customer" name="Customer Pool" processRef="Process_Customer"/>
    <bpmn:messageFlow id="MissingInfoToCustomer" name="Notify Missing Info" sourceRef="ThrowEvent_MissingInfo" targetRef="CatchEvent_MissingInfo"/>
    <bpmn:messageFlow id="WarehouseRequest" name="Warehouse Request" sourceRef="ThrowEvent_Warehouse" targetRef="CatchEvent_Warehouse"/>
    <bpmn:messageFlow id="FinanceRequest" name="Finance Request" sourceRef="ThrowEvent_Finance" targetRef="CatchEvent_Finance"/>
    <bpmn:messageFlow id="RejectionNoticeToCustomer" name="Rejection Notice" sourceRef="ThrowEvent_RejectionNotice" targetRef="CatchEvent_RejectionNotice"/>
    <bpmn:messageFlow id="RefundConfirmationToCustomer" name="Refund Confirmation" sourceRef="ThrowEvent_RefundConfirmation" targetRef="CatchEvent_RefundConfirmation"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Retailer" name="Retailer Company Pool" isExecutable="false">
