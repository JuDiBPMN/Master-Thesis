    <bpmn:parallelGateway id="ParallelGateway_Forward" name="Forward to Departments" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="ParallelGateway_WaitForVerdicts" name="Wait for Verdicts" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="ExclusiveGateway_ReviewOutcomes" name="Review Outcomes" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="StartToRegister" sourceRef="StartEvent" targetRef="RegisterReturnRequest"/>
    <bpmn:sequenceFlow id="RegisterToCheckInfo" sourceRef="RegisterReturnRequest" targetRef="CheckInformation"/>
