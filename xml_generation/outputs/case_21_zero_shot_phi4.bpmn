    <bpmn:sequenceFlow id="RejectToEnd" sourceRef="SendRejectionNotice" targetRef="EndEvent"/>
    <bpmn:sequenceFlow id="ApproveToRefund" sourceRef="ExclusiveGateway_ReviewOutcomes" targetRef="ApproveReturn"/>
    <bpmn:sequenceFlow id="RefundToEnd" sourceRef="ProcessRefund" targetRef="SendRefundConfirmation"/>
    <bpmn:sequenceFlow id="RefundToEnd_Confirm" sourceRef="SendRefundConfirmation" targetRef="EndEvent"/>
  </bpmn:process>
