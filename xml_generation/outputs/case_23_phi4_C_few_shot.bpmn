<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_client_pool" name="Client" processRef="Process_client_pool"/>
    <bpmn:participant id="actor_brightwave_energy_pool" name="BrightWave Energy" processRef="Process_brightwave_energy_pool"/>
    <bpmn:messageFlow id="mf1" name="Complaint Email" sourceRef="write_complaint_email" targetRef="start_customer_service"/>
    <bpmn:messageFlow id="mf2" name="Explanation Email" sourceRef="send_explanation_email" targetRef="end_client_explanation"/>
    <bpmn:messageFlow id="mf3" name="New Invoice Email" sourceRef="send_new_invoice" targetRef="end_client_new_invoice"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="write_complaint_email" targetRef="start_customer_service"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="send_new_invoice" targetRef="end_client_new_invoice"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_client_pool" name="Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_client_pool">
      <bpmn:lane id="client" name="Client">
        <bpmn:flowNodeRef>start_client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_client_explanation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_client_new_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>write_complaint_email</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_client" name="Start"/>
    <bpmn:endEvent id="end_client_explanation" name="Explanation Sent"/>
    <bpmn:endEvent id="end_client_new_invoice" name="New Invoice Sent"/>
    <bpmn:task id="write_complaint_email" name="Write Complaint Email"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_client" targetRef="write_complaint_email"/>
  </bpmn:process>
  <bpmn:process id="Process_brightwave_energy_pool" name="BrightWave Energy" isExecutable="false">
    <bpmn:laneSet id="LaneSet_brightwave_energy_pool">
      <bpmn:lane id="customer_service" name="Customer Service">
        <bpmn:flowNodeRef>start_customer_service</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_customer_service_explanation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_customer_service_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>receive_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>lookup_billing_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>write_explanation_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_explanation_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>create_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>assign_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_mistake_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_mistake_check_join</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="invoicing_department" name="Invoicing Department">
        <bpmn:flowNodeRef>investigate_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>correct_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>generate_new_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_new_invoice</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_customer_service" name="Complaint Received">
      <bpmn:messageEventDefinition id="start_customer_service_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_customer_service_explanation" name="Explanation Email Sent"/>
    <bpmn:endEvent id="end_customer_service_ticket" name="Ticket Created"/>
    <bpmn:task id="receive_complaint" name="Receive Complaint"/>
    <bpmn:task id="lookup_billing_info" name="Lookup Billing Information"/>
    <bpmn:task id="review_invoice" name="Review Invoice"/>
    <bpmn:task id="write_explanation_email" name="Write Explanation Email"/>
    <bpmn:task id="send_explanation_email" name="Send Explanation Email"/>
    <bpmn:task id="create_ticket" name="Create Ticket"/>
    <bpmn:task id="assign_ticket" name="Assign Ticket to Invoicing Department"/>
    <bpmn:task id="investigate_mistake" name="Investigate Invoicing Mistake"/>
    <bpmn:task id="correct_mistake" name="Correct Mistake"/>
    <bpmn:task id="generate_new_invoice" name="Generate New Invoice"/>
    <bpmn:task id="send_new_invoice" name="Send New Invoice"/>
    <bpmn:exclusiveGateway id="gateway_mistake_check" name="Mistake Found?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_mistake_check_join" name="Mistake Check Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="start_customer_service" targetRef="receive_complaint"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="receive_complaint" targetRef="lookup_billing_info"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="lookup_billing_info" targetRef="review_invoice"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="review_invoice" targetRef="gateway_mistake_check"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="gateway_mistake_check" targetRef="write_explanation_email" name="No Mistake">
      <bpmn:conditionExpression>No Mistake</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf8" sourceRef="gateway_mistake_check" targetRef="create_ticket" name="Mistake Found">
      <bpmn:conditionExpression>Mistake Found</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf9" sourceRef="write_explanation_email" targetRef="send_explanation_email"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="send_explanation_email" targetRef="end_customer_service_explanation"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="create_ticket" targetRef="assign_ticket"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="assign_ticket" targetRef="end_customer_service_ticket"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="end_customer_service_ticket" targetRef="investigate_mistake"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="investigate_mistake" targetRef="correct_mistake"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="correct_mistake" targetRef="generate_new_invoice"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="generate_new_invoice" targetRef="send_new_invoice"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="send_explanation_email" targetRef="gateway_mistake_check_join"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="send_new_invoice" targetRef="gateway_mistake_check_join"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_client_pool_di" bpmnElement="actor_client_pool" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="760" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_brightwave_energy_pool_di" bpmnElement="actor_brightwave_energy_pool" isHorizontal="true">
        <dc:Bounds x="10" y="440" width="3620" height="500"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="client_di" bpmnElement="client" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="730" height="360"/>
