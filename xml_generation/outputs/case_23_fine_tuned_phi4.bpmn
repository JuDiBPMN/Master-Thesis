      <bpmndi:BPMNShape id="determine_mistake_di" bpmnElement="determine_mistake">
        <dc:Bounds x="650" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="write_explanation_email_di" bpmnElement="write_explanation_email">
        <dc:Bounds x="1170" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_mistake_di" bpmnElement="split_mistake" isMarkerVisible="true">
        <dc:Bounds x="945" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="create_ticket_di" bpmnElement="create_ticket">
        <dc:Bounds x="1170" y="355" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="investigate_invoicing_mistake_di" bpmnElement="investigate_invoicing_mistake">
        <dc:Bounds x="1430" y="355" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="make_correction_di" bpmnElement="make_correction">
        <dc:Bounds x="1690" y="355" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="generate_new_invoice_di" bpmnElement="generate_new_invoice">
        <dc:Bounds x="1950" y="355" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="send_new_invoice_email_di" bpmnElement="send_new_invoice_email">
        <dc:Bounds x="2210" y="355" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_invoicing_di" bpmnElement="split_invoicing" isMarkerVisible="true">
        <dc:Bounds x="165" y="370" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="join_invoicing_di" bpmnElement="join_invoicing" isMarkerVisible="true">
        <dc:Bounds x="2505" y="370" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_client_di" bpmnElement="start_client">
        <dc:Bounds x="172" y="654" width="36" height="36"/>
