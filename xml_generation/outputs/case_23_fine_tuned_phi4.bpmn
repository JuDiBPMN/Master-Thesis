      <bpmndi:BPMNShape id="end_client_mistake_corrected_di" bpmnElement="end_client_mistake_corrected">
        <dc:Bounds x="172" y="720" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_client_no_mistake_di" bpmnElement="end_client_no_mistake">
