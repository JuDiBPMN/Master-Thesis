<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_BrightWave_Energy" name="BrightWave Energy" processRef="Process_BrightWave_Energy"/>
    <bpmn:participant id="actor_Client" name="Client" processRef="Process_Client"/>
    <bpmn:messageFlow id="mf1" name="Complaint Email" sourceRef="write_complaint_email" targetRef="start_bwe"/>
    <bpmn:messageFlow id="mf2" name="Explanation Email" sourceRef="write_explanation_email" targetRef="end_bwe_no_mistake"/>
    <bpmn:messageFlow id="mf3" name="New Invoice Email" sourceRef="send_new_invoice_email" targetRef="end_bwe_mistake_corrected"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_BrightWave_Energy" name="BrightWave Energy" isExecutable="false">
    <bpmn:laneSet id="LaneSet_BrightWave_Energy">
      <bpmn:lane id="Customer_Service" name="Customer Service">
        <bpmn:flowNodeRef>start_bwe</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_bwe_no_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_bwe_mistake_corrected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>determine_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>write_explanation_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_mistake</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Invoicing" name="Invoicing">
        <bpmn:flowNodeRef>create_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>investigate_invoicing_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>make_correction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>generate_new_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_new_invoice_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_invoicing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_invoicing</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_bwe" name="Receive Complaint">
      <bpmn:messageEventDefinition id="start_bwe_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_bwe_no_mistake" name="Send Explanation">
      <bpmn:messageEventDefinition id="end_bwe_no_mistake_def"/>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_bwe_mistake_corrected" name="Send New Invoice">
      <bpmn:messageEventDefinition id="end_bwe_mistake_corrected_def"/>
    </bpmn:endEvent>
    <bpmn:task id="review_invoice" name="Review Invoice"/>
    <bpmn:task id="determine_mistake" name="Determine Mistake?"/>
    <bpmn:task id="write_explanation_email" name="Write Explanation Email"/>
    <bpmn:task id="create_ticket" name="Create Ticket"/>
    <bpmn:task id="investigate_invoicing_mistake" name="Investigate Invoicing Mistake"/>
    <bpmn:task id="make_correction" name="Make Correction"/>
    <bpmn:task id="generate_new_invoice" name="Generate New Invoice"/>
    <bpmn:task id="send_new_invoice_email" name="Send New Invoice Email"/>
    <bpmn:exclusiveGateway id="split_mistake" name="Mistake Found?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_mistake" name="Join Mistake Decision" gatewayDirection="converging"/>
    <bpmn:parallelGateway id="split_invoicing" name="Split Invoicing Work" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_invoicing" name="Join Invoicing Work" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="start_bwe" targetRef="review_invoice"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="review_invoice" targetRef="determine_mistake"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="determine_mistake" targetRef="split_mistake"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_mistake" targetRef="write_explanation_email" name="No mistake">
      <bpmn:conditionExpression>No mistake</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="split_mistake" targetRef="create_ticket" name="Mistake found">
      <bpmn:conditionExpression>Mistake found</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf8" sourceRef="write_explanation_email" targetRef="end_bwe_no_mistake"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="create_ticket" targetRef="investigate_invoicing_mistake"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="investigate_invoicing_mistake" targetRef="make_correction"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="make_correction" targetRef="generate_new_invoice"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="generate_new_invoice" targetRef="send_new_invoice_email"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="send_new_invoice_email" targetRef="join_invoicing"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="join_invoicing" targetRef="end_bwe_mistake_corrected"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="join_mistake" targetRef="end_bwe_mistake_corrected"/>
  </bpmn:process>
  <bpmn:process id="Process_Client" name="Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Client">
      <bpmn:lane id="Client" name="Client"/>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_client" name="Receive Monthly Bill"/>
    <bpmn:endEvent id="end_client_no_mistake" name="Receive Explanation"/>
    <bpmn:endEvent id="end_client_mistake_corrected" name="Receive New Invoice"/>
    <bpmn:task id="write_complaint_email" name="Write Complaint Email"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_client" targetRef="write_complaint_email"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="write_complaint_email" targetRef="end_client_no_mistake"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_BrightWave_Energy_di" bpmnElement="actor_BrightWave_Energy" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="3100" height="500"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Client_di" bpmnElement="actor_Client" isHorizontal="true">
        <dc:Bounds x="10" y="580" width="1020" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Customer_Service_di" bpmnElement="Customer_Service" isHorizontal="true">
