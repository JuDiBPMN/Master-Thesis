    <bpmn:sequenceFlow id="sf22" sourceRef="send_rejection" targetRef="throw_rejection" />
    <bpmn:sequenceFlow id="sf21" name="Both verdicts positive" sourceRef="split_outcome" targetRef="send_offer">
