        <di:waypoint x="1572" y="200"/>
        <di:waypoint x="1660" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf12_di" bpmnElement="sf12">
        <di:waypoint x="1780" y="90"/>
