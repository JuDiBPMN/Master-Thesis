<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Bank" name="Bank Process Flow for Mortgage Application Assessment" processRef="Process_Bank"/>
    <bpmn:participant id="actor_Client" name="Client" processRef="Process_Client"/>
    <bpmn:messageFlow id="mf1" name="Financial Info" sourceRef="send_financial_info" targetRef="receive_financial_info"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Bank" name="Bank Process Flow for Mortgage Application Assessment" isExecutable="false">
    <bpmn:startEvent id="start_mortgage_assessment" name="Start Mortgage Assessment"/>
    <bpmn:endEvent id="end_mortgage_assessment" name="End Mortgage Assessment"/>
    <bpmn:intermediateThrowEvent id="send_financial_info" name="Send Financial Info">
      <bpmn:messageEventDefinition id="send_financial_info_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:task id="create_mortgage_file" name="Create Mortgage File"/>
    <bpmn:task id="evaluate_financial_stability" name="Evaluate Client's Financial Stability"/>
    <bpmn:task id="gather_income_statements" name="Gather Income Statements"/>
    <bpmn:task id="check_other_credit_applications" name="Check for Other Credit Applications"/>
    <bpmn:task id="perform_risk_analysis" name="Perform Risk Analysis"/>
    <bpmn:task id="grant_line_of_credit" name="Grant Line of Credit"/>
    <bpmn:task id="decline_mortgage_application" name="Decline Mortgage Application"/>
    <bpmn:parallelGateway id="parallel_split" name="Parallel Split" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="parallel_join" name="Parallel Join" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="decision_gateway" name="Decision Gateway" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="decision_join" name="Decision Join" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_mortgage_assessment" targetRef="create_mortgage_file"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="create_mortgage_file" targetRef="parallel_split"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="parallel_split" targetRef="evaluate_financial_stability"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="parallel_split" targetRef="gather_income_statements"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="parallel_split" targetRef="check_other_credit_applications"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="evaluate_financial_stability" targetRef="perform_risk_analysis"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="gather_income_statements" targetRef="perform_risk_analysis"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="check_other_credit_applications" targetRef="perform_risk_analysis"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="perform_risk_analysis" targetRef="decision_gateway"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="decision_gateway" targetRef="grant_line_of_credit"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="decision_gateway" targetRef="decline_mortgage_application"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="grant_line_of_credit" targetRef="decision_join"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="decline_mortgage_application" targetRef="decision_join"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="decision_join" targetRef="parallel_join"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="parallel_join" targetRef="end_mortgage_assessment"/>
  </bpmn:process>
  <bpmn:process id="Process_Client" name="Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Client">
      <bpmn:lane id="Client" name="Client"/>
    </bpmn:laneSet>
    <bpmn:intermediateCatchEvent id="receive_financial_info" name="Receive Financial Info">
      <bpmn:messageEventDefinition id="receive_financial_info_def"/>
    </bpmn:intermediateCatchEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Bank_di" bpmnElement="actor_Bank" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="2810" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Client_di" bpmnElement="actor_Client" isHorizontal="true">
        <dc:Bounds x="10" y="330" width="600" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Client_di" bpmnElement="Client" isHorizontal="true">
        <dc:Bounds x="40" y="330" width="570" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_mortgage_assessment_di" bpmnElement="start_mortgage_assessment">
        <dc:Bounds x="142" y="94" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="send_financial_info_di" bpmnElement="send_financial_info">
        <dc:Bounds x="142" y="160" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_mortgage_assessment_di" bpmnElement="end_mortgage_assessment">
        <dc:Bounds x="2482" y="127" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="create_mortgage_file_di" bpmnElement="create_mortgage_file">
        <dc:Bounds x="360" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evaluate_financial_stability_di" bpmnElement="evaluate_financial_stability">
        <dc:Bounds x="880" y="-5" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gather_income_statements_di" bpmnElement="gather_income_statements">
        <dc:Bounds x="880" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="check_other_credit_applications_di" bpmnElement="check_other_credit_applications">
        <dc:Bounds x="880" y="215" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="perform_risk_analysis_di" bpmnElement="perform_risk_analysis">
        <dc:Bounds x="1140" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="grant_line_of_credit_di" bpmnElement="grant_line_of_credit">
        <dc:Bounds x="1660" y="50" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="decline_mortgage_application_di" bpmnElement="decline_mortgage_application">
        <dc:Bounds x="1660" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="parallel_split_di" bpmnElement="parallel_split" isMarkerVisible="true">
        <dc:Bounds x="655" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="parallel_join_di" bpmnElement="parallel_join" isMarkerVisible="true">
        <dc:Bounds x="2215" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="decision_gateway_di" bpmnElement="decision_gateway" isMarkerVisible="true">
        <dc:Bounds x="1435" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="decision_join_di" bpmnElement="decision_join" isMarkerVisible="true">
        <dc:Bounds x="1955" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="receive_financial_info_di" bpmnElement="receive_financial_info">
        <dc:Bounds x="172" y="422" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="178" y="112"/>
        <di:waypoint x="269" y="112"/>
        <di:waypoint x="269" y="145"/>
        <di:waypoint x="360" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="480" y="145"/>
        <di:waypoint x="655" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="705" y="145"/>
        <di:waypoint x="792" y="145"/>
        <di:waypoint x="792" y="35"/>
        <di:waypoint x="880" y="35"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="705" y="145"/>
        <di:waypoint x="880" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf5_di" bpmnElement="sf5">
        <di:waypoint x="705" y="145"/>
        <di:waypoint x="792" y="145"/>
        <di:waypoint x="792" y="255"/>
        <di:waypoint x="880" y="255"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="1000" y="35"/>
        <di:waypoint x="1070" y="35"/>
        <di:waypoint x="1070" y="145"/>
        <di:waypoint x="1140" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
        <di:waypoint x="1000" y="145"/>
        <di:waypoint x="1140" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="1000" y="255"/>
        <di:waypoint x="1070" y="255"/>
        <di:waypoint x="1070" y="145"/>
        <di:waypoint x="1140" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="1260" y="145"/>
        <di:waypoint x="1435" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf10_di" bpmnElement="sf10">
        <di:waypoint x="1485" y="145"/>
        <di:waypoint x="1572" y="145"/>
        <di:waypoint x="1572" y="90"/>
        <di:waypoint x="1660" y="90"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf11_di" bpmnElement="sf11">
