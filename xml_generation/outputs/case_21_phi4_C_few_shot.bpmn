<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_customer_pool" name="Customer" processRef="Process_customer_pool"/>
    <bpmn:participant id="actor_retailer_pool" name="Retailer" processRef="Process_retailer_pool"/>
    <bpmn:messageFlow id="mf1" name="Return Request" sourceRef="submit_return_request" targetRef="start_retailer"/>
    <bpmn:messageFlow id="mf2" name="Incomplete Notice" sourceRef="notify_incomplete" targetRef="end_customer_incomplete"/>
    <bpmn:messageFlow id="mf3" name="Rejection Notice" sourceRef="send_rejection_notice" targetRef="end_customer_rejected"/>
    <bpmn:messageFlow id="mf4" name="Refund Confirmation" sourceRef="send_refund_confirmation" targetRef="end_customer_refunded"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="end_retailer_rejected" targetRef="end_customer_rejected"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="end_retailer_refunded" targetRef="end_customer_refunded"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_customer_pool" name="Customer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_customer_pool">
      <bpmn:lane id="customer" name="Customer">
        <bpmn:flowNodeRef>start_customer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_customer_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_customer_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_customer_refunded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_return_request</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_customer" name="Start"/>
    <bpmn:endEvent id="end_customer_incomplete" name="Incomplete Information"/>
    <bpmn:endEvent id="end_customer_rejected" name="Return Rejected"/>
    <bpmn:endEvent id="end_customer_refunded" name="Refund Confirmed"/>
    <bpmn:task id="submit_return_request" name="Submit Return Request"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_customer" targetRef="submit_return_request"/>
  </bpmn:process>
  <bpmn:process id="Process_retailer_pool" name="Retailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_retailer_pool">
      <bpmn:lane id="customer_service" name="Customer Service">
        <bpmn:flowNodeRef>start_retailer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_retailer_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_retailer_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_retailer_refunded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_return_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_information</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection_notice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>approve_return</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>process_refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_refund_confirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_information</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="warehouse" name="Warehouse">
        <bpmn:flowNodeRef>inspect_product</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_warehouse_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance" name="Finance">
        <bpmn:flowNodeRef>check_payment_eligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_finance_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_retailer" name="Return Request Received">
      <bpmn:messageEventDefinition id="start_retailer_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_retailer_incomplete" name="Customer Notified"/>
    <bpmn:endEvent id="end_retailer_rejected" name="Rejection Notice Sent"/>
    <bpmn:endEvent id="end_retailer_refunded" name="Refund Processed"/>
    <bpmn:task id="register_return_request" name="Register Return Request"/>
    <bpmn:task id="check_information" name="Check Request Information"/>
    <bpmn:task id="notify_incomplete" name="Notify Customer of Missing Info"/>
    <bpmn:task id="review_outcomes" name="Review Combined Verdicts"/>
    <bpmn:task id="send_rejection_notice" name="Send Return Rejection Notice"/>
    <bpmn:task id="approve_return" name="Approve Return"/>
    <bpmn:task id="process_refund" name="Process Refund"/>
    <bpmn:task id="send_refund_confirmation" name="Send Refund Confirmation"/>
    <bpmn:task id="inspect_product" name="Inspect Returned Product"/>
    <bpmn:task id="record_warehouse_verdict" name="Record Warehouse Verdict"/>
    <bpmn:task id="check_payment_eligibility" name="Check Payment Eligibility"/>
    <bpmn:task id="record_finance_verdict" name="Record Finance Verdict"/>
    <bpmn:exclusiveGateway id="split_information" name="Information Complete?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward for Review" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Both Verdicts Positive?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="start_retailer" targetRef="register_return_request"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_return_request" targetRef="check_information"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="check_information" targetRef="split_information"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="split_information" targetRef="notify_incomplete" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_information" targetRef="split_parallel" name="Complete">
      <bpmn:conditionExpression>Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="notify_incomplete" targetRef="end_retailer_incomplete"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="split_parallel" targetRef="inspect_product"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="split_parallel" targetRef="check_payment_eligibility"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="inspect_product" targetRef="record_warehouse_verdict"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="record_warehouse_verdict" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="check_payment_eligibility" targetRef="record_finance_verdict"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="record_finance_verdict" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="split_outcome" targetRef="send_rejection_notice" name="One or more verdicts negative">
      <bpmn:conditionExpression>One or more verdicts negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf17" sourceRef="split_outcome" targetRef="approve_return" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf18" sourceRef="approve_return" targetRef="process_refund"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="process_refund" targetRef="send_refund_confirmation"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="send_rejection_notice" targetRef="end_retailer_rejected"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="send_refund_confirmation" targetRef="end_retailer_refunded"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
