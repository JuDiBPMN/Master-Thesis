<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Company" name="Company Pool" processRef="Process_Company"/>
    <bpmn:participant id="actor_Candidate" name="Candidate Pool" processRef="Process_Candidate"/>
    <bpmn:messageFlow id="message_1" name="Inform Candidate" sourceRef="inform_candidate" targetRef="start_assessment"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Company" name="Company Pool" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Company">
      <bpmn:lane id="HR_Manager" name="HR Manager">
        <bpmn:flowNodeRef>start_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>start_discussion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_discussion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>start_inform</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_inform</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>start_prepare_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_prepare_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>start_close_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_close_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>introduction_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>discuss_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>inform_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>prepare_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>close_application</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Business_Manager" name="Business Manager">
        <bpmn:flowNodeRef>start_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>successful_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>unsuccessful_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>second_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>decision_assessment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_interview" name="Start Interview"/>
    <bpmn:endEvent id="end_interview" name="End Interview"/>
    <bpmn:startEvent id="start_discussion" name="Start Discussion"/>
    <bpmn:endEvent id="end_discussion" name="End Discussion"/>
    <bpmn:startEvent id="start_assessment" name="Start Assessment"/>
    <bpmn:endEvent id="end_assessment" name="End Assessment"/>
    <bpmn:endEvent id="successful_assessment" name="Successful Assessment"/>
    <bpmn:endEvent id="unsuccessful_assessment" name="Unsuccessful Assessment"/>
    <bpmn:startEvent id="start_inform" name="Start Inform"/>
    <bpmn:endEvent id="end_inform" name="End Inform"/>
    <bpmn:startEvent id="start_prepare_contract" name="Start Prepare Contract"/>
    <bpmn:endEvent id="end_prepare_contract" name="End Prepare Contract"/>
    <bpmn:startEvent id="start_close_application" name="Start Close Application"/>
    <bpmn:endEvent id="end_close_application" name="End Close Application"/>
    <bpmn:task id="introduction_interview" name="Introduction Interview"/>
    <bpmn:task id="discuss_candidate" name="Discuss Candidate"/>
    <bpmn:task id="inform_candidate" name="Inform Candidate"/>
    <bpmn:task id="second_assessment" name="Second Assessment"/>
    <bpmn:task id="prepare_contract" name="Prepare Contract"/>
    <bpmn:task id="close_application" name="Close Application"/>
    <bpmn:exclusiveGateway id="decision_assessment" name="Decision Assessment" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="flow_1" sourceRef="start_interview" targetRef="introduction_interview"/>
    <bpmn:sequenceFlow id="flow_2" sourceRef="introduction_interview" targetRef="end_interview"/>
    <bpmn:sequenceFlow id="flow_3" sourceRef="end_interview" targetRef="start_discussion"/>
    <bpmn:sequenceFlow id="flow_4" sourceRef="start_discussion" targetRef="discuss_candidate"/>
    <bpmn:sequenceFlow id="flow_5" sourceRef="discuss_candidate" targetRef="start_inform"/>
    <bpmn:sequenceFlow id="flow_6" sourceRef="start_inform" targetRef="inform_candidate"/>
    <bpmn:sequenceFlow id="flow_7" sourceRef="inform_candidate" targetRef="end_inform"/>
    <bpmn:sequenceFlow id="flow_8" sourceRef="end_inform" targetRef="end_discussion"/>
    <bpmn:sequenceFlow id="flow_9" sourceRef="end_discussion" targetRef="start_assessment"/>
    <bpmn:sequenceFlow id="flow_10" sourceRef="start_assessment" targetRef="second_assessment"/>
    <bpmn:sequenceFlow id="flow_11" sourceRef="second_assessment" targetRef="decision_assessment"/>
    <bpmn:sequenceFlow id="flow_12" sourceRef="decision_assessment" targetRef="start_prepare_contract" name="successful">
      <bpmn:conditionExpression>successful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_13" sourceRef="decision_assessment" targetRef="start_close_application" name="unsuccessful">
      <bpmn:conditionExpression>unsuccessful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_14" sourceRef="start_prepare_contract" targetRef="prepare_contract"/>
    <bpmn:sequenceFlow id="flow_15" sourceRef="prepare_contract" targetRef="end_prepare_contract"/>
    <bpmn:sequenceFlow id="flow_16" sourceRef="end_prepare_contract" targetRef="end_discussion"/>
    <bpmn:sequenceFlow id="flow_17" sourceRef="start_close_application" targetRef="close_application"/>
    <bpmn:sequenceFlow id="flow_18" sourceRef="close_application" targetRef="end_close_application"/>
  </bpmn:process>
  <bpmn:process id="Process_Candidate" name="Candidate Pool" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Candidate">
      <bpmn:lane id="Candidate" name="Candidate"/>
    </bpmn:laneSet>
  </bpmn:process>
