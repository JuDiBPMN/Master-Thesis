<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_applicant_pool" name="Applicant Organisation" processRef="Process_applicant_pool"/>
    <bpmn:participant id="actor_grants_office" name="Government Grants Office" processRef="Process_grants_office"/>
    <bpmn:messageFlow id="mf1" name="Grant Application" sourceRef="submit_application" targetRef="start_grants"/>
    <bpmn:messageFlow id="mf2" name="Rejection Notice" sourceRef="send_rejection" targetRef="applicant"/>
    <bpmn:messageFlow id="mf3" name="Grant Approval Letter" sourceRef="issue_approval" targetRef="applicant"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="Complete" sourceRef="split_documents" targetRef="collect_documents"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="collect_documents" targetRef="split_documents"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="Grant Application" sourceRef="submit_application" targetRef="start_grants"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="Rejection Notice" sourceRef="send_rejection" targetRef="applicant"/>
    <bpmn:messageFlow id="MsgFlow_p4" name="Grant Approval Letter" sourceRef="issue_approval" targetRef="applicant"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_applicant_pool" name="Applicant Organisation" isExecutable="false">
    <bpmn:laneSet id="LaneSet_applicant_pool">
      <bpmn:lane id="applicant" name="Applicant Organisation">
        <bpmn:flowNodeRef>start_applicant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_applicant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>collect_documents</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_applicant" name="Start"/>
    <bpmn:endEvent id="end_applicant" name="End"/>
    <bpmn:task id="submit_application" name="Submit Grant Application"/>
    <bpmn:task id="collect_documents" name="Collect Missing Documents"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_applicant" targetRef="submit_application"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="submit_application" targetRef="end_applicant"/>
  </bpmn:process>
  <bpmn:process id="Process_grants_office" name="Government Grants Office" isExecutable="false">
    <bpmn:laneSet id="LaneSet_grants_office">
      <bpmn:lane id="grants_admin" name="Grants Administrator">
        <bpmn:flowNodeRef>start_grants</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_grants</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_documents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>issue_approval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_documents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="technical_reviewer" name="Technical Reviewer">
        <bpmn:flowNodeRef>review_feasibility</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance_officer" name="Finance Officer">
        <bpmn:flowNodeRef>review_budget</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_grants" name="Application Received">
      <bpmn:messageEventDefinition id="start_grants_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_grants" name="Decision Sent">
      <bpmn:messageEventDefinition id="end_grants_def"/>
    </bpmn:endEvent>
    <bpmn:task id="register_application" name="Register Application"/>
    <bpmn:task id="check_documents" name="Check Documentation Completeness"/>
    <bpmn:task id="notify_incomplete" name="Notify Applicant of Missing Documents"/>
    <bpmn:task id="review_feasibility" name="Assess Project Feasibility"/>
    <bpmn:task id="review_budget" name="Review Proposed Budget"/>
    <bpmn:task id="review_outcomes" name="Review Combined Verdicts"/>
    <bpmn:task id="send_rejection" name="Send Rejection Notice to Applicant"/>
    <bpmn:task id="issue_approval" name="Issue Grant Approval Letter"/>
    <bpmn:exclusiveGateway id="split_documents" name="Documentation Complete?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_review" name="Forward for Review" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_review" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Verdicts Acceptable?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="start_grants" targetRef="register_application"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="register_application" targetRef="check_documents"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="check_documents" targetRef="split_documents"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_documents" targetRef="notify_incomplete" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf8" sourceRef="notify_incomplete" targetRef="split_documents"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="split_review" targetRef="review_feasibility"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="split_review" targetRef="review_budget"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="review_feasibility" targetRef="join_review"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="review_budget" targetRef="join_review"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="join_review" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="split_outcome" targetRef="send_rejection" name="At least one verdict negative">
      <bpmn:conditionExpression>At least one verdict negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf17" sourceRef="split_outcome" targetRef="issue_approval" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf18" sourceRef="send_rejection" targetRef="end_grants"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="issue_approval" targetRef="end_grants"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_applicant_pool_di" bpmnElement="actor_applicant_pool" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="1020" height="250"/>
