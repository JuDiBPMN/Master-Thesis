<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:process id="Process_Zarkan_Industries" name="Zarkan Industries" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Zarkan_Industries">
      <bpmn:lane id="csr" name="Customer Service Representative">
        <bpmn:flowNodeRef>start_complaint_handling</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_complaint_handling</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>handle_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_call_details</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>document_concerns</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>note_letter_receipt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>analyze_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>resolve_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>archive_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_complaint_type_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_complaint_type_join</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="other_departments" name="Other Departments">
        <bpmn:flowNodeRef>consult_other_departments</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_complaint_handling" name="Start Complaint Handling"/>
    <bpmn:endEvent id="end_complaint_handling" name="End Complaint Handling"/>
    <bpmn:task id="handle_complaint" name="Handle Complaint"/>
    <bpmn:task id="record_call_details" name="Record Call Details"/>
    <bpmn:task id="document_concerns" name="Document Concerns"/>
    <bpmn:task id="note_letter_receipt" name="Note Letter Receipt Date"/>
    <bpmn:task id="analyze_complaint" name="Analyze Complaint"/>
    <bpmn:task id="resolve_complaint" name="Resolve Complaint"/>
    <bpmn:task id="archive_complaint" name="Archive Complaint Details"/>
    <bpmn:task id="consult_other_departments" name="Consult Other Departments"/>
    <bpmn:exclusiveGateway id="gateway_complaint_type_split" name="Complaint Type?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_complaint_type_join" name="Complaint Registered" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_complaint_handling" targetRef="handle_complaint"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="handle_complaint" targetRef="gateway_complaint_type_split"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="gateway_complaint_type_split" targetRef="record_call_details" name="phone call">
      <bpmn:conditionExpression>phone call</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf4" sourceRef="gateway_complaint_type_split" targetRef="document_concerns" name="in-person complaint">
      <bpmn:conditionExpression>in-person complaint</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf5" sourceRef="gateway_complaint_type_split" targetRef="note_letter_receipt" name="letter">
      <bpmn:conditionExpression>letter</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="record_call_details" targetRef="gateway_complaint_type_join"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="document_concerns" targetRef="gateway_complaint_type_join"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="note_letter_receipt" targetRef="gateway_complaint_type_join"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="gateway_complaint_type_join" targetRef="analyze_complaint"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="analyze_complaint" targetRef="consult_other_departments"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="consult_other_departments" targetRef="resolve_complaint"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="resolve_complaint" targetRef="archive_complaint"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="archive_complaint" targetRef="end_complaint_handling"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_Zarkan_Industries">
      <bpmndi:BPMNShape id="csr_di" bpmnElement="csr" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="2810" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="other_departments_di" bpmnElement="other_departments" isHorizontal="true">
