      <bpmndi:BPMNShape id="gateway_complaint_type_split_di" bpmnElement="gateway_complaint_type_split" isMarkerVisible="true">
        <dc:Bounds x="685" y="175" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_complaint_type_join_di" bpmnElement="gateway_complaint_type_join" isMarkerVisible="true">
        <dc:Bounds x="1205" y="175" width="50" height="50"/>
