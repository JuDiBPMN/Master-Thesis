        <di:waypoint x="1140" y="360"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="965" y="455"/>
        <di:waypoint x="1070" y="455"/>
        <di:waypoint x="1070" y="565"/>
        <di:waypoint x="1175" y="565"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="1260" y="360"/>
        <di:waypoint x="1347" y="360"/>
        <di:waypoint x="1347" y="510"/>
        <di:waypoint x="1435" y="510"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="185" y="488"/>
        <di:waypoint x="550" y="488"/>
        <di:waypoint x="550" y="455"/>
        <di:waypoint x="915" y="455"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="965" y="455"/>
        <di:waypoint x="1052" y="455"/>
        <di:waypoint x="1052" y="470"/>
        <di:waypoint x="1140" y="470"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1260" y="470"/>
        <di:waypoint x="1330" y="470"/>
        <di:waypoint x="1330" y="415"/>
        <di:waypoint x="1400" y="415"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1520" y="415"/>
        <di:waypoint x="1611" y="415"/>
        <di:waypoint x="1611" y="455"/>
        <di:waypoint x="1702" y="455"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p0_di" bpmnElement="MsgFlow_p0">
        <di:waypoint x="1200" y="590"/>
        <di:waypoint x="1200" y="1035"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p1_di" bpmnElement="MsgFlow_p1">
        <di:waypoint x="1200" y="590"/>
        <di:waypoint x="1200" y="725"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p2_di" bpmnElement="MsgFlow_p2">
        <di:waypoint x="1200" y="1035"/>
        <di:waypoint x="160" y="513"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p3_di" bpmnElement="MsgFlow_p3">
        <di:waypoint x="1200" y="725"/>
        <di:waypoint x="160" y="513"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>