      <bpmn:conditionExpression>One or more verdicts negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf20" name="Both verdicts positive" sourceRef="split_outcome" targetRef="process_refund">
