<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Library" name="Library System" processRef="Process_Library"/>
    <bpmn:participant id="actor_Requester" name="Requester" processRef="Process_Requester"/>
    <bpmn:messageFlow id="Book_Not_Available_to_Catch_Book_Not_Available" name="Inform Requester of Unavailability" sourceRef="Book_Not_Available" targetRef="Catch_Book_Not_Available"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Library" name="Library System" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Library">
      <bpmn:lane id="Library_Staff" name="Library Staff">
        <bpmn:flowNodeRef>StartEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Book_Not_Available</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Check_Catalog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Inform_Requester</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Start_Checkout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Log_Book</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Retrieve_Book</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ExclusiveGateway</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent" name="Start"/>
    <bpmn:endEvent id="EndEvent" name="End"/>
    <bpmn:intermediateThrowEvent id="Book_Not_Available" name="Book Not Available">
      <bpmn:messageEventDefinition id="Book_Not_Available_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:userTask id="Check_Catalog" name="Check Catalog for Book Availability"/>
    <bpmn:userTask id="Inform_Requester" name="Inform Requester of Unavailability"/>
    <bpmn:userTask id="Start_Checkout" name="Start Checkout Procedure"/>
    <bpmn:userTask id="Log_Book" name="Log Book Against Requester's Account"/>
    <bpmn:userTask id="Retrieve_Book" name="Retrieve Book Using Automatic System"/>
    <bpmn:exclusiveGateway id="ExclusiveGateway" name="Check Book Availability" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="Start_to_Check_Catalog" sourceRef="StartEvent" targetRef="Check_Catalog"/>
    <bpmn:sequenceFlow id="Check_Catalog_to_ExclusiveGateway" sourceRef="Check_Catalog" targetRef="ExclusiveGateway"/>
    <bpmn:sequenceFlow id="ExclusiveGateway_to_Inform_Requester" sourceRef="ExclusiveGateway" targetRef="Inform_Requester"/>
    <bpmn:sequenceFlow id="Inform_Requester_to_Book_Not_Available" sourceRef="Inform_Requester" targetRef="Book_Not_Available"/>
    <bpmn:sequenceFlow id="ExclusiveGateway_to_Start_Checkout" sourceRef="ExclusiveGateway" targetRef="Start_Checkout"/>
    <bpmn:sequenceFlow id="Start_Checkout_to_Log_Book" sourceRef="Start_Checkout" targetRef="Log_Book"/>
    <bpmn:sequenceFlow id="Log_Book_to_Retrieve_Book" sourceRef="Log_Book" targetRef="Retrieve_Book"/>
    <bpmn:sequenceFlow id="Retrieve_Book_to_EndEvent" sourceRef="Retrieve_Book" targetRef="EndEvent"/>
  </bpmn:process>
  <bpmn:process id="Process_Requester" name="Requester" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Requester">
      <bpmn:lane id="Requester" name="Requester"/>
    </bpmn:laneSet>
    <bpmn:endEvent id="EndEvent_Requester" name="End"/>
    <bpmn:intermediateCatchEvent id="Catch_Book_Not_Available" name="Catch Book Not Available">
      <bpmn:messageEventDefinition id="Catch_Book_Not_Available_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Catch_Book_Not_Available_to_EndEvent_Requester" sourceRef="Catch_Book_Not_Available" targetRef="EndEvent_Requester"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Library_di" bpmnElement="actor_Library" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="2060" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Requester_di" bpmnElement="actor_Requester" isHorizontal="true">
        <dc:Bounds x="10" y="330" width="760" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Library_Staff_di" bpmnElement="Library_Staff" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="2030" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Requester_di" bpmnElement="Requester" isHorizontal="true">
        <dc:Bounds x="40" y="330" width="730" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_di" bpmnElement="StartEvent">
        <dc:Bounds x="172" y="127" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_di" bpmnElement="EndEvent">
        <dc:Bounds x="1732" y="127" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Book_Not_Available_di" bpmnElement="Book_Not_Available">
        <dc:Bounds x="1212" y="72" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Log_Book_di" bpmnElement="Log_Book">
        <dc:Bounds x="1170" y="138" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Check_Catalog_di" bpmnElement="Check_Catalog">
        <dc:Bounds x="390" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Inform_Requester_di" bpmnElement="Inform_Requester">
        <dc:Bounds x="910" y="50" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_Checkout_di" bpmnElement="Start_Checkout">
        <dc:Bounds x="910" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Retrieve_Book_di" bpmnElement="Retrieve_Book">
        <dc:Bounds x="1430" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ExclusiveGateway_di" bpmnElement="ExclusiveGateway" isMarkerVisible="true">
        <dc:Bounds x="685" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Requester_di" bpmnElement="EndEvent_Requester">
        <dc:Bounds x="432" y="422" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_Book_Not_Available_di" bpmnElement="Catch_Book_Not_Available">
        <dc:Bounds x="172" y="422" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Start_to_Check_Catalog_di" bpmnElement="Start_to_Check_Catalog">
        <di:waypoint x="208" y="145"/>
        <di:waypoint x="390" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Check_Catalog_to_ExclusiveGateway_di" bpmnElement="Check_Catalog_to_ExclusiveGateway">
        <di:waypoint x="510" y="145"/>
        <di:waypoint x="685" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="ExclusiveGateway_to_Inform_Requester_di" bpmnElement="ExclusiveGateway_to_Inform_Requester">
        <di:waypoint x="735" y="145"/>
        <di:waypoint x="822" y="145"/>
        <di:waypoint x="822" y="90"/>
        <di:waypoint x="910" y="90"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Inform_Requester_to_Book_Not_Available_di" bpmnElement="Inform_Requester_to_Book_Not_Available">
        <di:waypoint x="1030" y="90"/>
        <di:waypoint x="1212" y="90"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Catch_Book_Not_Available_to_EndEvent_Requester_di" bpmnElement="Catch_Book_Not_Available_to_EndEvent_Requester">
        <di:waypoint x="208" y="440"/>
        <di:waypoint x="432" y="440"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="ExclusiveGateway_to_Start_Checkout_di" bpmnElement="ExclusiveGateway_to_Start_Checkout">
        <di:waypoint x="735" y="145"/>
        <di:waypoint x="822" y="145"/>
        <di:waypoint x="822" y="200"/>
        <di:waypoint x="910" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Start_Checkout_to_Log_Book_di" bpmnElement="Start_Checkout_to_Log_Book">
        <di:waypoint x="1030" y="200"/>
        <di:waypoint x="1100" y="200"/>
        <di:waypoint x="1100" y="178"/>
        <di:waypoint x="1170" y="178"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Log_Book_to_Retrieve_Book_di" bpmnElement="Log_Book_to_Retrieve_Book">
        <di:waypoint x="1290" y="178"/>
        <di:waypoint x="1360" y="178"/>
        <di:waypoint x="1360" y="145"/>
        <di:waypoint x="1430" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Retrieve_Book_to_EndEvent_di" bpmnElement="Retrieve_Book_to_EndEvent">
        <di:waypoint x="1550" y="145"/>
        <di:waypoint x="1732" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Book_Not_Available_to_Catch_Book_Not_Available_di" bpmnElement="Book_Not_Available_to_Catch_Book_Not_Available">
        <di:waypoint x="1230" y="108"/>
        <di:waypoint x="190" y="422"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>