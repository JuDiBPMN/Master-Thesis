<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_library" name="Library" processRef="Process_library"/>
    <bpmn:participant id="actor_requester" name="Requester" processRef="Process_requester"/>
    <bpmn:messageFlow id="mf1" name="Book" sourceRef="retrieve_book" targetRef="end_requester"/>
    <bpmn:messageFlow id="mf2" name="Book unavailable notification" sourceRef="inform_requester" targetRef="start_requester"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="start_library" targetRef="request_book"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="request_book" targetRef="consult_catalog"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_library" name="Library" isExecutable="false">
    <bpmn:laneSet id="LaneSet_library">
      <bpmn:lane id="library_staff" name="Library Staff">
        <bpmn:flowNodeRef>start_library</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_library</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>consult_catalog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_availability</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>inform_requester</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>log_book</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>retrieve_book</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>exclusive_availability</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>exclusive_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>parallel_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_library" name="Request for Book Received"/>
    <bpmn:endEvent id="end_library" name="Book Request Handled"/>
    <bpmn:task id="consult_catalog" name="Consult Digital Catalog"/>
    <bpmn:task id="check_availability" name="Check Book Availability"/>
    <bpmn:task id="inform_requester" name="Inform Requester of Unavailability"/>
    <bpmn:task id="log_book" name="Log Book Against Requester's Account"/>
    <bpmn:task id="retrieve_book" name="Retrieve Book Using Automatic System"/>
    <bpmn:exclusiveGateway id="exclusive_availability" name="Book Available?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="exclusive_join" name="Both Tasks Complete" gatewayDirection="converging"/>
    <bpmn:parallelGateway id="parallel_join" name="Both Tasks Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="consult_catalog" targetRef="check_availability"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="check_availability" targetRef="exclusive_availability"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="exclusive_availability" targetRef="inform_requester" name="Book unavailable">
      <bpmn:conditionExpression>Book unavailable</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="exclusive_availability" targetRef="log_book" name="Book available">
      <bpmn:conditionExpression>Book available</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="log_book" targetRef="retrieve_book"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="retrieve_book" targetRef="exclusive_join"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="inform_requester" targetRef="exclusive_join"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="exclusive_join" targetRef="end_library"/>
  </bpmn:process>
  <bpmn:process id="Process_requester" name="Requester" isExecutable="false">
    <bpmn:laneSet id="LaneSet_requester">
      <bpmn:lane id="requester" name="Requester"/>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_requester" name="Request for Book"/>
    <bpmn:endEvent id="end_requester" name="Book Request Sent"/>
    <bpmn:task id="request_book" name="Request Book"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="start_requester" targetRef="end_requester"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_library_di" bpmnElement="actor_library" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="2060" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_requester_di" bpmnElement="actor_requester" isHorizontal="true">
        <dc:Bounds x="10" y="440" width="760" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="library_staff_di" bpmnElement="library_staff" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="2030" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="requester_di" bpmnElement="requester" isHorizontal="true">
        <dc:Bounds x="40" y="440" width="730" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_library_di" bpmnElement="start_library">
        <dc:Bounds x="172" y="87" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="consult_catalog_di" bpmnElement="consult_catalog">
        <dc:Bounds x="130" y="153" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="parallel_join_di" bpmnElement="parallel_join" isMarkerVisible="true">
        <dc:Bounds x="165" y="263" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_library_di" bpmnElement="end_library">
        <dc:Bounds x="1732" y="182" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="check_availability_di" bpmnElement="check_availability">
        <dc:Bounds x="390" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="inform_requester_di" bpmnElement="inform_requester">
        <dc:Bounds x="910" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="log_book_di" bpmnElement="log_book">
        <dc:Bounds x="910" y="215" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="retrieve_book_di" bpmnElement="retrieve_book">
        <dc:Bounds x="1170" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="exclusive_availability_di" bpmnElement="exclusive_availability" isMarkerVisible="true">
        <dc:Bounds x="685" y="175" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="exclusive_join_di" bpmnElement="exclusive_join" isMarkerVisible="true">
        <dc:Bounds x="1465" y="175" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_requester_di" bpmnElement="start_requester">
        <dc:Bounds x="172" y="492" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="request_book_di" bpmnElement="request_book">
        <dc:Bounds x="130" y="558" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_requester_di" bpmnElement="end_requester">
        <dc:Bounds x="432" y="547" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="250" y="193"/>
        <di:waypoint x="320" y="193"/>
        <di:waypoint x="320" y="200"/>
        <di:waypoint x="390" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="510" y="200"/>
        <di:waypoint x="685" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf5_di" bpmnElement="sf5">
        <di:waypoint x="735" y="200"/>
        <di:waypoint x="822" y="200"/>
        <di:waypoint x="822" y="145"/>
        <di:waypoint x="910" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="735" y="200"/>
        <di:waypoint x="822" y="200"/>
        <di:waypoint x="822" y="255"/>
        <di:waypoint x="910" y="255"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
        <di:waypoint x="1030" y="255"/>
        <di:waypoint x="1100" y="255"/>
        <di:waypoint x="1100" y="200"/>
        <di:waypoint x="1170" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="1290" y="200"/>
        <di:waypoint x="1465" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="1030" y="145"/>
        <di:waypoint x="1247" y="145"/>
        <di:waypoint x="1247" y="200"/>
