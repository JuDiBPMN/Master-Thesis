<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_retailer" name="Retailer" processRef="Process_retailer"/>
    <bpmn:participant id="actor_customer" name="Customer" processRef="Process_customer"/>
    <bpmn:messageFlow id="mf1" name="Return Request" sourceRef="submit_return_request" targetRef="register_return_request"/>
    <bpmn:messageFlow id="mf2" name="Return Rejection" sourceRef="notify_customer" targetRef="end_customer"/>
    <bpmn:messageFlow id="mf3" name="Refund Confirmation" sourceRef="send_confirmation" targetRef="end_customer"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="start_retailer" targetRef="submit_return_request"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="submit_return_request" targetRef="register_return_request"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="Verdict negative" sourceRef="split_outcome" targetRef="send_rejection"/>
    <bpmn:messageFlow id="MsgFlow_p4" name="Verdict positive" sourceRef="split_outcome" targetRef="approve_return"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_retailer" name="Retailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_retailer">
      <bpmn:lane id="customer_service" name="Customer Service">
        <bpmn:flowNodeRef>start_retailer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_retailer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_return_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_customer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>approve_return</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>process_refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_confirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="warehouse" name="Warehouse">
        <bpmn:flowNodeRef>inspect_product</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance" name="Finance">
        <bpmn:flowNodeRef>check_payment_eligibility</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_retailer" name="Start"/>
    <bpmn:endEvent id="end_retailer" name="End"/>
    <bpmn:task id="register_return_request" name="Register Return Request"/>
    <bpmn:task id="check_info" name="Check Information Completeness"/>
    <bpmn:task id="notify_customer" name="Notify Customer of Missing Info"/>
    <bpmn:task id="inspect_product" name="Inspect Returned Product"/>
    <bpmn:task id="check_payment_eligibility" name="Check Payment Eligibility"/>
    <bpmn:task id="review_outcomes" name="Review Combined Verdicts"/>
    <bpmn:task id="send_rejection" name="Send Return Rejection Notice"/>
    <bpmn:task id="approve_return" name="Approve Return"/>
    <bpmn:task id="process_refund" name="Process Refund"/>
    <bpmn:task id="send_confirmation" name="Send Refund Confirmation"/>
    <bpmn:exclusiveGateway id="split_info" name="Information Complete?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_info" name="Join after Info Check" gatewayDirection="converging"/>
    <bpmn:parallelGateway id="split_parallel" name="Start Parallel Checks" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Join after Parallel Checks" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_return_request" targetRef="check_info"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="check_info" targetRef="split_info"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="split_info" targetRef="notify_customer" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_info" targetRef="join_info" name="Complete">
      <bpmn:conditionExpression>Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="notify_customer" targetRef="join_info"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="join_info" targetRef="split_parallel"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="split_parallel" targetRef="inspect_product"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="split_parallel" targetRef="check_payment_eligibility"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="inspect_product" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="check_payment_eligibility" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="send_rejection" targetRef="end_retailer"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="approve_return" targetRef="process_refund"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="process_refund" targetRef="send_confirmation"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="send_confirmation" targetRef="end_retailer"/>
  </bpmn:process>
  <bpmn:process id="Process_customer" name="Customer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_customer">
      <bpmn:lane id="customer" name="Customer"/>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_customer" name="Start"/>
    <bpmn:endEvent id="end_customer" name="End"/>
    <bpmn:task id="submit_return_request" name="Submit Return Request"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="start_customer" targetRef="end_customer"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_retailer_di" bpmnElement="actor_retailer" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="2580" height="1410"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_customer_di" bpmnElement="actor_customer" isHorizontal="true">
        <dc:Bounds x="10" y="1490" width="760" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="customer_service_di" bpmnElement="customer_service" isHorizontal="true">
