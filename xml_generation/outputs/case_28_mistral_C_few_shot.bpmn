<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_csr_pool" name="CSR" processRef="Process_csr_pool"/>
    <bpmn:participant id="actor_zarkan_industries_pool" name="Zarkan Industries" processRef="Process_zarkan_industries_pool"/>
    <bpmn:messageFlow id="mf1" name="Complaint Details" sourceRef="register_complaint" targetRef="start_zarkan_industries"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_csr_pool" name="CSR" isExecutable="false">
    <bpmn:laneSet id="LaneSet_csr_pool">
      <bpmn:lane id="csr_lane" name="CSR">
        <bpmn:flowNodeRef>start_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>analyze_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>consult_departments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>resolve_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>archive_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>close_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_analysis_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_analysis_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_complaint" name="Start"/>
    <bpmn:endEvent id="end_complaint" name="End"/>
    <bpmn:task id="register_complaint" name="Register Complaint"/>
    <bpmn:task id="analyze_complaint" name="Analyze Complaint"/>
    <bpmn:task id="consult_departments" name="Consult Departments"/>
    <bpmn:task id="resolve_complaint" name="Resolve Complaint"/>
    <bpmn:task id="archive_complaint" name="Archive Complaint"/>
    <bpmn:task id="close_complaint" name="Close Complaint"/>
    <bpmn:exclusiveGateway id="gateway_analysis_split" name="Analysis Complete?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_analysis_join" name="Analysis Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_complaint" targetRef="register_complaint"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="register_complaint" targetRef="analyze_complaint"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="analyze_complaint" targetRef="gateway_analysis_split"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="gateway_analysis_split" targetRef="consult_departments"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="consult_departments" targetRef="resolve_complaint"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="resolve_complaint" targetRef="archive_complaint"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="archive_complaint" targetRef="close_complaint"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="gateway_analysis_split" targetRef="end_complaint" name="Unresolved">
      <bpmn:conditionExpression>Unresolved</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf9" sourceRef="gateway_analysis_join" targetRef="end_complaint"/>
  </bpmn:process>
  <bpmn:process id="Process_zarkan_industries_pool" name="Zarkan Industries" isExecutable="false">
    <bpmn:startEvent id="start_zarkan_industries" name="Complaint Received">
      <bpmn:messageEventDefinition id="start_zarkan_industries_def"/>
    </bpmn:startEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
