<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Bank" name="Bank, internal processes and departments, no external parties involved" processRef="Process_Bank"/>
    <bpmn:participant id="actor_Client" name="Client, external party" processRef="Process_Client"/>
    <bpmn:messageFlow id="ReceiveMortgageApplication" name="Receive Mortgage Application" sourceRef="MortgageApplicationReceived" targetRef="CreateMortgageFile"/>
    <bpmn:messageFlow id="FinancialStabilityAssessment" name="Financial Stability Assessment" sourceRef="CreateMortgageFile" targetRef="EvaluateFinancialStability"/>
    <bpmn:messageFlow id="IncomeStatementsGathered" name="Income Statements Gathered" sourceRef="EvaluateFinancialStability" targetRef="GatherIncomeStatements"/>
    <bpmn:messageFlow id="CreditApplicationsChecked" name="Credit Applications Checked" sourceRef="GatherIncomeStatements" targetRef="CheckCreditApplications"/>
    <bpmn:messageFlow id="RiskAnalysisPerformed" name="Risk Analysis Performed" sourceRef="CheckCreditApplications" targetRef="PerformRiskAnalysis"/>
    <bpmn:messageFlow id="CreditLineGranted" name="Credit Line Granted" sourceRef="PerformRiskAnalysis" targetRef="GrantLineOfCredit"/>
    <bpmn:messageFlow id="MortgageApplicationDeclined" name="Mortgage Application Declined" sourceRef="PerformRiskAnalysis" targetRef="DeclineMortgageApplication"/>
    <bpmn:messageFlow id="SendAssessmentResultToClient" name="Send Assessment Result to Client" sourceRef="GrantLineOfCredit" targetRef="AssessmentCompleted"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Bank" name="Bank, internal processes and departments, no external parties involved" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Bank">
      <bpmn:lane id="Bank" name="Mortgage Assessment"/>
    </bpmn:laneSet>
  </bpmn:process>
  <bpmn:process id="Process_Client" name="Client, external party" isExecutable="false"/>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Bank_di" bpmnElement="actor_Bank" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="400" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Client_di" bpmnElement="actor_Client" isHorizontal="true">
        <dc:Bounds x="10" y="300" width="400" height="250"/>
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>