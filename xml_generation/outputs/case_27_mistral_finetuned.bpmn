      <bpmndi:BPMNShape id="create_mortgage_file_di" bpmnElement="create_mortgage_file">
        <dc:Bounds x="390" y="440" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="evaluate_financial_stability_di" bpmnElement="evaluate_financial_stability">
        <dc:Bounds x="910" y="330" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gather_income_statements_di" bpmnElement="gather_income_statements">
        <dc:Bounds x="910" y="440" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="check_credit_applications_di" bpmnElement="check_credit_applications">
        <dc:Bounds x="910" y="550" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="perform_risk_analysis_di" bpmnElement="perform_risk_analysis">
        <dc:Bounds x="1430" y="440" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="grant_line_of_credit_di" bpmnElement="grant_line_of_credit">
        <dc:Bounds x="1950" y="385" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="decline_mortgage_application_di" bpmnElement="decline_mortgage_application">
        <dc:Bounds x="1950" y="495" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_parallel_split_di" bpmnElement="gateway_parallel_split" isMarkerVisible="true">
        <dc:Bounds x="685" y="455" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_parallel_join_di" bpmnElement="gateway_parallel_join" isMarkerVisible="true">
        <dc:Bounds x="1205" y="455" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_assessment_split_di" bpmnElement="gateway_assessment_split" isMarkerVisible="true">
        <dc:Bounds x="1725" y="455" width="50" height="50"/>
      </bpmndi:BPMNShape>
