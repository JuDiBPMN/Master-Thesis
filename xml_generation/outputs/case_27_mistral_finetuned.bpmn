      <bpmndi:BPMNShape id="gateway_assessment_join_di" bpmnElement="gateway_assessment_join" isMarkerVisible="true">
        <dc:Bounds x="165" y="488" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_bank_di" bpmnElement="end_bank">
        <dc:Bounds x="2252" y="462" width="36" height="36"/>
