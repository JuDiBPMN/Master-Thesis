<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_client_pool" name="Client Pool" processRef="Process_client_pool"/>
    <bpmn:participant id="actor_bank_pool" name="Bank Pool" processRef="Process_bank_pool"/>
    <bpmn:messageFlow id="mf1" name="Mortgage Application" sourceRef="receive_mortgage_application" targetRef="start_bank"/>
    <bpmn:messageFlow id="mf2" name="Mortgage Assessment Result" sourceRef="end_bank" targetRef="end_client"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="Mortgage assessment complete" sourceRef="end_bank" targetRef="end_client"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_client_pool" name="Client Pool" isExecutable="false">
    <bpmn:laneSet id="LaneSet_client_pool">
      <bpmn:lane id="client" name="Client">
        <bpmn:flowNodeRef>start_client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>receive_mortgage_application</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_client" name="Start"/>
    <bpmn:endEvent id="end_client" name="End"/>
    <bpmn:task id="receive_mortgage_application" name="Receive Mortgage Application"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_client" targetRef="receive_mortgage_application"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="receive_mortgage_application" targetRef="end_client"/>
  </bpmn:process>
  <bpmn:process id="Process_bank_pool" name="Bank Pool" isExecutable="false">
    <bpmn:laneSet id="LaneSet_bank_pool">
      <bpmn:lane id="bank" name="Bank">
        <bpmn:flowNodeRef>start_bank</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_bank</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>create_mortgage_file</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>evaluate_financial_stability</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gather_income_statements</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_credit_applications</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>perform_risk_analysis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>grant_line_of_credit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>decline_mortgage_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_assessment_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_assessment_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_bank" name="Mortgage Assessment Start">
      <bpmn:messageEventDefinition id="start_bank_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_bank" name="Mortgage Assessment End">
      <bpmn:messageEventDefinition id="end_bank_def"/>
    </bpmn:endEvent>
    <bpmn:task id="create_mortgage_file" name="Create Mortgage File"/>
    <bpmn:task id="evaluate_financial_stability" name="Evaluate Financial Stability"/>
    <bpmn:task id="gather_income_statements" name="Gather Income Statements"/>
    <bpmn:task id="check_credit_applications" name="Check for Other Credit Applications"/>
    <bpmn:task id="perform_risk_analysis" name="Perform In-depth Risk Analysis"/>
    <bpmn:task id="grant_line_of_credit" name="Grant Line of Credit"/>
    <bpmn:task id="decline_mortgage_application" name="Decline Mortgage Application"/>
    <bpmn:parallelGateway id="gateway_parallel_split" name="Start Concurrent Evaluation" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_join" name="Evaluation Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_assessment_split" name="Assessment Outcome?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_assessment_join" name="Assessment Decision Made" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="start_bank" targetRef="create_mortgage_file"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="create_mortgage_file" targetRef="gateway_parallel_split"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="gateway_parallel_split" targetRef="evaluate_financial_stability"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="gateway_parallel_split" targetRef="gather_income_statements"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="gateway_parallel_split" targetRef="check_credit_applications"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="evaluate_financial_stability" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="gather_income_statements" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="check_credit_applications" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="gateway_parallel_join" targetRef="perform_risk_analysis"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="perform_risk_analysis" targetRef="gateway_assessment_split"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="gateway_assessment_split" targetRef="grant_line_of_credit" name="Assessment is positive">
      <bpmn:conditionExpression>Assessment is positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf14" sourceRef="gateway_assessment_split" targetRef="decline_mortgage_application" name="Assessment is negative">
      <bpmn:conditionExpression>Assessment is negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf15" sourceRef="grant_line_of_credit" targetRef="end_bank"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="decline_mortgage_application" targetRef="end_bank"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="start_bank" targetRef="end_bank" name="Mortgage application received">
      <bpmn:conditionExpression>Mortgage application received</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_client_pool_di" bpmnElement="actor_client_pool" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="1020" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_bank_pool_di" bpmnElement="actor_bank_pool" isHorizontal="true">
        <dc:Bounds x="10" y="300" width="2580" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="client_di" bpmnElement="client" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="990" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="bank_di" bpmnElement="bank" isHorizontal="true">
        <dc:Bounds x="40" y="300" width="2550" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_client_di" bpmnElement="start_client">
        <dc:Bounds x="172" y="112" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_client_di" bpmnElement="end_client">
