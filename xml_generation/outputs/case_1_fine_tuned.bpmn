<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="1.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Customer" name="Customer" processRef="Process_Customer"/>
    <bpmn:participant id="Participant_Logistics" name="Logistics" processRef="Process_Logistics"/>
    <bpmn:participant id="Participant_Sales" name="Sales" processRef="Process_Sales"/>
    <bpmn:messageFlow id="MsgFlow_promoted_0" name="message" sourceRef="OrderPlaced" targetRef="CheckAvailability"/>
    <bpmn:messageFlow id="MsgFlow_promoted_1" name="message" sourceRef="CheckAvailability" targetRef="RejectOrder"/>
    <bpmn:messageFlow id="MsgFlow_promoted_2" name="message" sourceRef="CheckAvailability" targetRef="ConfirmOrder"/>
    <bpmn:messageFlow id="MsgFlow_promoted_3" name="message" sourceRef="ConfirmOrder" targetRef="ShipGoods"/>
    <bpmn:messageFlow id="MsgFlow_promoted_4" name="message" sourceRef="OrderConfirmed" targetRef="GoodsShipped"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Customer" name="Customer" isExecutable="false">
    <bpmn:startEvent id="OrderPlaced" name="Order Placed"/>
  </bpmn:process>
  <bpmn:process id="Process_Logistics" name="Logistics" isExecutable="false">
    <bpmn:endEvent id="GoodsShipped" name="Goods Shipped"/>
    <bpmn:task id="CheckAvailability" name="Check Availability"/>
    <bpmn:task id="ShipGoods" name="Ship Goods"/>
    <bpmn:exclusiveGateway id="CheckAvailabilityGateway" name="Check Availability" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="ShipGoods" targetRef="GoodsShipped"/>
  </bpmn:process>
  <bpmn:process id="Process_Sales" name="Sales" isExecutable="false">
    <bpmn:endEvent id="OrderRejected" name="Order Rejected"/>
    <bpmn:endEvent id="OrderConfirmed" name="Order Confirmed"/>
    <bpmn:task id="RejectOrder" name="Reject Order"/>
    <bpmn:task id="ConfirmOrder" name="Confirm Order"/>
    <bpmn:task id="SendInvoice" name="Send Invoice"/>
    <bpmn:sequenceFlow id="Flow_0" sourceRef="ConfirmOrder" targetRef="SendInvoice"/>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="RejectOrder" targetRef="OrderRejected"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="SendInvoice" targetRef="OrderConfirmed"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_Customer_di" bpmnElement="Participant_Customer" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="900" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Logistics_di" bpmnElement="Participant_Logistics" isHorizontal="true">
        <dc:Bounds x="10" y="240" width="900" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Sales_di" bpmnElement="Participant_Sales" isHorizontal="true">
        <dc:Bounds x="10" y="460" width="950" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="OrderPlaced_di" bpmnElement="OrderPlaced">
        <dc:Bounds x="90" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CheckAvailability_di" bpmnElement="CheckAvailability">
        <dc:Bounds x="90" y="300" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ShipGoods_di" bpmnElement="ShipGoods">
        <dc:Bounds x="250" y="300" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CheckAvailabilityGateway_di" bpmnElement="CheckAvailabilityGateway" isMarkerVisible="true">
        <dc:Bounds x="410" y="315" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GoodsShipped_di" bpmnElement="GoodsShipped">
        <dc:Bounds x="570" y="322" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="RejectOrder_di" bpmnElement="RejectOrder">
        <dc:Bounds x="90" y="520" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ConfirmOrder_di" bpmnElement="ConfirmOrder">
        <dc:Bounds x="250" y="520" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="OrderRejected_di" bpmnElement="OrderRejected">
        <dc:Bounds x="410" y="542" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendInvoice_di" bpmnElement="SendInvoice">
        <dc:Bounds x="570" y="520" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="OrderConfirmed_di" bpmnElement="OrderConfirmed">
        <dc:Bounds x="730" y="542" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_0_di" bpmnElement="Flow_0">
        <di:waypoint x="350" y="560"/>
        <di:waypoint x="570" y="560"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="190" y="560"/>
        <di:waypoint x="410" y="560"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="670" y="560"/>
        <di:waypoint x="730" y="560"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="350" y="340"/>
        <di:waypoint x="570" y="340"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_promoted_0_di" bpmnElement="MsgFlow_promoted_0">
        <di:waypoint x="108" y="138"/>
        <di:waypoint x="140" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_promoted_1_di" bpmnElement="MsgFlow_promoted_1">
        <di:waypoint x="140" y="380"/>
        <di:waypoint x="140" y="520"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_promoted_2_di" bpmnElement="MsgFlow_promoted_2">
        <di:waypoint x="140" y="380"/>
        <di:waypoint x="300" y="520"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_promoted_3_di" bpmnElement="MsgFlow_promoted_3">
        <di:waypoint x="300" y="520"/>
        <di:waypoint x="300" y="380"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_promoted_4_di" bpmnElement="MsgFlow_promoted_4">
        <di:waypoint x="748" y="542"/>
        <di:waypoint x="588" y="358"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>