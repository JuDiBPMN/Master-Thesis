<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="1.0">
  <bpmn:process id="Process_web_shop" name="Web Shop" isExecutable="false">
    <bpmn:laneSet id="LaneSet_web_shop">
      <bpmn:lane id="Anouk" name="Anouk">
        <bpmn:flowNodeRef>new_order_received</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>order_completed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>receive_new_order</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>pick_sweaters</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>assemble_parcel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>email_invoice</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Jan" name="Jan">
        <bpmn:flowNodeRef>collect_packaging</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>prepare_delivery</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>deliver_locally</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>deliver_nationally_postnl</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>deliver_internationally_dhl</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_delivery_type</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_delivery_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_delivery_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_delivery_approved_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="new_order_received" name="New Order Received"/>
    <bpmn:endEvent id="order_completed" name="Order Completed"/>
    <bpmn:task id="receive_new_order" name="Receive New Order"/>
    <bpmn:task id="pick_sweaters" name="Pick Out Sweaters"/>
    <bpmn:task id="collect_packaging" name="Collect Packaging Material"/>
    <bpmn:task id="assemble_parcel" name="Assemble Parcel"/>
    <bpmn:task id="prepare_delivery" name="Prepare Delivery"/>
    <bpmn:task id="deliver_locally" name="Deliver Locally"/>
    <bpmn:task id="deliver_nationally_postnl" name="Deliver Nationally (PostNL)"/>
    <bpmn:task id="deliver_internationally_dhl" name="Deliver Internationally (DHL)"/>
    <bpmn:task id="email_invoice" name="Email Invoice"/>
    <bpmn:exclusiveGateway id="gateway_delivery_type" name="Delivery Type" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_delivery_split" name="Deliver Locally/Nationally/Internationally" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_delivery_join" name="Delivery Prepared" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_delivery_approved_join" name="Delivery Approved?" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="new_order_received" targetRef="receive_new_order"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="receive_new_order" targetRef="pick_sweaters"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="pick_sweaters" targetRef="collect_packaging"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="collect_packaging" targetRef="assemble_parcel"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="assemble_parcel" targetRef="prepare_delivery"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="prepare_delivery" targetRef="gateway_delivery_type"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="gateway_delivery_type" targetRef="deliver_locally" name="Local">
      <bpmn:conditionExpression>Local</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf8" sourceRef="gateway_delivery_type" targetRef="deliver_nationally_postnl" name="National">
      <bpmn:conditionExpression>National</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf9" sourceRef="gateway_delivery_type" targetRef="deliver_internationally_dhl" name="International">
      <bpmn:conditionExpression>International</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf10" sourceRef="deliver_locally" targetRef="gateway_delivery_join"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="deliver_nationally_postnl" targetRef="gateway_delivery_join"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="deliver_internationally_dhl" targetRef="gateway_delivery_join"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="gateway_delivery_join" targetRef="email_invoice"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="email_invoice" targetRef="gateway_delivery_approved_join"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="gateway_delivery_approved_join" targetRef="order_completed"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_web_shop">
      <bpmndi:BPMNShape id="Anouk_di" bpmnElement="Anouk" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="1590" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Jan_di" bpmnElement="Jan" isHorizontal="true">
        <dc:Bounds x="40" y="180" width="1590" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="new_order_received_di" bpmnElement="new_order_received">
        <dc:Bounds x="110" y="82" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="order_completed_di" bpmnElement="order_completed">
        <dc:Bounds x="270" y="82" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="assemble_parcel_di" bpmnElement="assemble_parcel">
        <dc:Bounds x="430" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="email_invoice_di" bpmnElement="email_invoice">
        <dc:Bounds x="590" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="receive_new_order_di" bpmnElement="receive_new_order">
        <dc:Bounds x="750" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="pick_sweaters_di" bpmnElement="pick_sweaters">
        <dc:Bounds x="910" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="collect_packaging_di" bpmnElement="collect_packaging">
        <dc:Bounds x="110" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="prepare_delivery_di" bpmnElement="prepare_delivery">
        <dc:Bounds x="270" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_delivery_split_di" bpmnElement="gateway_delivery_split" isMarkerVisible="true">
        <dc:Bounds x="430" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_delivery_approved_join_di" bpmnElement="gateway_delivery_approved_join" isMarkerVisible="true">
        <dc:Bounds x="590" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_delivery_type_di" bpmnElement="gateway_delivery_type" isMarkerVisible="true">
        <dc:Bounds x="750" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="deliver_locally_di" bpmnElement="deliver_locally">
        <dc:Bounds x="910" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="deliver_nationally_postnl_di" bpmnElement="deliver_nationally_postnl">
        <dc:Bounds x="1070" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="deliver_internationally_dhl_di" bpmnElement="deliver_internationally_dhl">
        <dc:Bounds x="1230" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_delivery_join_di" bpmnElement="gateway_delivery_join" isMarkerVisible="true">
        <dc:Bounds x="1390" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="146" y="100"/>
        <di:waypoint x="750" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="850" y="100"/>
        <di:waypoint x="910" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="1010" y="100"/>
        <di:waypoint x="110" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="210" y="260"/>
        <di:waypoint x="430" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf5_di" bpmnElement="sf5">
        <di:waypoint x="530" y="100"/>
        <di:waypoint x="270" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="370" y="260"/>
        <di:waypoint x="750" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
        <di:waypoint x="800" y="260"/>
        <di:waypoint x="910" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="800" y="260"/>
        <di:waypoint x="1070" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="800" y="260"/>
        <di:waypoint x="1230" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf10_di" bpmnElement="sf10">
        <di:waypoint x="1010" y="260"/>
        <di:waypoint x="1390" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf11_di" bpmnElement="sf11">
        <di:waypoint x="1170" y="260"/>
        <di:waypoint x="1390" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf12_di" bpmnElement="sf12">
        <di:waypoint x="1330" y="260"/>
        <di:waypoint x="1390" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf13_di" bpmnElement="sf13">
        <di:waypoint x="1440" y="260"/>
        <di:waypoint x="590" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf14_di" bpmnElement="sf14">
        <di:waypoint x="690" y="100"/>
        <di:waypoint x="590" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf15_di" bpmnElement="sf15">
        <di:waypoint x="640" y="260"/>
        <di:waypoint x="270" y="100"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>