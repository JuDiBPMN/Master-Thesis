<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_applicant_pool" name="Applicant" processRef="Process_applicant_pool"/>
    <bpmn:participant id="actor_grants_office_pool" name="Grants Office" processRef="Process_grants_office_pool"/>
    <bpmn:messageFlow id="mf1" name="Grant Application" sourceRef="submit_application" targetRef="start_grants_office"/>
    <bpmn:messageFlow id="mf2" name="Missing Docs Notification" sourceRef="grants_administrator" targetRef="applicant"/>
    <bpmn:messageFlow id="mf3" name="Docs Resubmission" sourceRef="applicant" targetRef="grants_administrator"/>
    <bpmn:messageFlow id="mf4" name="Technical Verdict" sourceRef="technical_reviewer" targetRef="grants_administrator"/>
    <bpmn:messageFlow id="mf5" name="Finance Verdict" sourceRef="finance_officer" targetRef="grants_administrator"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_applicant_pool" name="Applicant" isExecutable="false">
    <bpmn:laneSet id="LaneSet_applicant_pool">
      <bpmn:lane id="applicant" name="Applicant">
        <bpmn:flowNodeRef>start_applicant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_applicant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>collect_docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>resubmit_docs</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_applicant" name="Start"/>
    <bpmn:endEvent id="end_applicant" name="Application Process Ends"/>
    <bpmn:task id="submit_application" name="Submit Grant Application"/>
    <bpmn:task id="collect_docs" name="Collect Missing Docs"/>
    <bpmn:task id="resubmit_docs" name="Resubmit Docs"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_applicant" targetRef="submit_application"/>
  </bpmn:process>
  <bpmn:process id="Process_grants_office_pool" name="Grants Office" isExecutable="false">
    <bpmn:laneSet id="LaneSet_grants_office_pool">
      <bpmn:lane id="grants_administrator" name="Grants Administrator">
        <bpmn:flowNodeRef>start_grants_office</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_completeness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_completeness_again</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>issue_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>issue_grant_approval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="technical_reviewer" name="Technical Reviewer">
        <bpmn:flowNodeRef>technical_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_technical_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance_officer" name="Finance Officer">
        <bpmn:flowNodeRef>budget_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_finance_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_grants_office" name="Application Received">
      <bpmn:messageEventDefinition id="start_grants_office_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_incomplete" name="Applicant Notified"/>
    <bpmn:endEvent id="end_rejected" name="Rejection Issued"/>
    <bpmn:endEvent id="end_approved" name="Grant Approved"/>
    <bpmn:task id="register_application" name="Register Application"/>
    <bpmn:task id="check_completeness" name="Check Application Completeness"/>
    <bpmn:task id="notify_incomplete" name="Notify Applicant of Missing Docs"/>
    <bpmn:task id="check_completeness_again" name="Check Application Completeness Again"/>
    <bpmn:task id="technical_review" name="Assess Project Feasibility"/>
    <bpmn:task id="record_technical_verdict" name="Record Technical Verdict"/>
    <bpmn:task id="budget_review" name="Review Proposed Budget"/>
    <bpmn:task id="record_finance_verdict" name="Record Finance Verdict"/>
    <bpmn:task id="review_outcomes" name="Review Combined Outcomes"/>
    <bpmn:task id="issue_rejection" name="Issue Rejection Notice"/>
    <bpmn:task id="issue_grant_approval" name="Issue Grant Approval Letter"/>
    <bpmn:exclusiveGateway id="split_complete" name="Application Complete?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward for Review" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Both Verdicts Positive?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="start_grants_office" targetRef="register_application"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_application" targetRef="check_completeness"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="check_completeness" targetRef="split_complete"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="split_complete" targetRef="notify_incomplete" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_complete" targetRef="split_parallel" name="Complete">
      <bpmn:conditionExpression>Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="notify_incomplete" targetRef="end_incomplete"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="split_parallel" targetRef="technical_review"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="split_parallel" targetRef="budget_review"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="technical_review" targetRef="record_technical_verdict"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="record_technical_verdict" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="budget_review" targetRef="record_finance_verdict"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="record_finance_verdict" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="split_outcome" targetRef="issue_rejection" name="One or more verdicts negative">
      <bpmn:conditionExpression>One or more verdicts negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf17" sourceRef="split_outcome" targetRef="issue_grant_approval" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf18" sourceRef="issue_rejection" targetRef="end_rejected"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="issue_grant_approval" targetRef="end_approved"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_applicant_pool_di" bpmnElement="actor_applicant_pool" isHorizontal="true">
