<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_gp_pool" name="GP" processRef="Process_gp_pool"/>
    <bpmn:participant id="actor_hospital_pool" name="Hospital" processRef="Process_hospital_pool"/>
    <bpmn:messageFlow id="mf1" name="Referral Request" sourceRef="submit_referral" targetRef="start_hospital"/>
    <bpmn:messageFlow id="mf2" name="Rejection Notice" sourceRef="notify_missing_docs" targetRef="end_gp_rejected"/>
    <bpmn:messageFlow id="mf3" name="Referral Package" sourceRef="forward_referral" targetRef="start_specialist"/>
    <bpmn:messageFlow id="mf4" name="Referral Package" sourceRef="forward_referral" targetRef="start_insurance"/>
    <bpmn:messageFlow id="mf5" name="Specialist Verdict" sourceRef="end_specialist_verdict" targetRef="join_verdicts"/>
    <bpmn:messageFlow id="mf6" name="Insurance Verdict" sourceRef="end_insurance_verdict" targetRef="join_verdicts"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="submit_referral" targetRef="register_referral"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="notify_missing_docs" targetRef="end_gp_rejected"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_gp_pool" name="GP" isExecutable="false">
    <bpmn:laneSet id="LaneSet_gp_pool">
      <bpmn:lane id="gp" name="GP">
        <bpmn:flowNodeRef>start_gp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_gp_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_referral</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_gp" name="Start"/>
    <bpmn:endEvent id="end_gp_rejected" name="Rejection Sent"/>
    <bpmn:task id="submit_referral" name="Submit Referral Request"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_gp" targetRef="submit_referral"/>
  </bpmn:process>
  <bpmn:process id="Process_hospital_pool" name="Hospital" isExecutable="false">
    <bpmn:laneSet id="LaneSet_hospital_pool">
      <bpmn:lane id="admissions_clerk" name="Admissions Clerk">
        <bpmn:flowNodeRef>start_hospital</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hospital_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hospital_approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_referral</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_documentation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_missing_docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>forward_referral</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_verdicts</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection_notice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_approval_notice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_verdicts</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_verdicts</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="specialist" name="Specialist">
        <bpmn:flowNodeRef>start_specialist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_specialist_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>conduct_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="insurance_officer" name="Insurance Officer">
        <bpmn:flowNodeRef>start_insurance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_insurance_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>verify_coverage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_coverage_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hospital" name="Referral Received">
      <bpmn:messageEventDefinition id="start_hospital_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_hospital_rejected" name="Rejection Sent"/>
    <bpmn:endEvent id="end_hospital_approved" name="Approval Sent"/>
    <bpmn:startEvent id="start_specialist" name="Referral Received">
      <bpmn:messageEventDefinition id="start_specialist_def"/>
    </bpmn:startEvent>
    <bpmn:startEvent id="start_insurance" name="Referral Received">
      <bpmn:messageEventDefinition id="start_insurance_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_specialist_verdict" name="Verdict Recorded"/>
    <bpmn:endEvent id="end_insurance_verdict" name="Coverage Verdict Recorded"/>
    <bpmn:task id="register_referral" name="Register Referral"/>
    <bpmn:task id="check_documentation" name="Check Documentation"/>
    <bpmn:task id="notify_missing_docs" name="Notify GP of Missing Docs"/>
    <bpmn:task id="forward_referral" name="Forward Referral to Specialist and Insurance"/>
    <bpmn:task id="conduct_assessment" name="Conduct Medical Assessment"/>
    <bpmn:task id="record_verdict" name="Record Verdict"/>
    <bpmn:task id="verify_coverage" name="Verify Coverage"/>
    <bpmn:task id="record_coverage_verdict" name="Record Coverage Verdict"/>
    <bpmn:task id="review_verdicts" name="Review Verdicts"/>
    <bpmn:task id="send_rejection_notice" name="Send Rejection Notice to GP"/>
    <bpmn:task id="send_approval_notice" name="Send Approval Notice to GP"/>
    <bpmn:parallelGateway id="split_verdicts" name="Split Verdicts" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_verdicts" name="Join Verdicts" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_referral" targetRef="check_documentation"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="check_documentation" targetRef="split_verdicts"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="split_verdicts" targetRef="notify_missing_docs" name="Missing Docs">
      <bpmn:conditionExpression>Missing Docs</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_verdicts" targetRef="forward_referral" name="Docs Complete">
      <bpmn:conditionExpression>Docs Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf8" sourceRef="forward_referral" targetRef="start_specialist"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="start_specialist" targetRef="conduct_assessment"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="conduct_assessment" targetRef="record_verdict"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="record_verdict" targetRef="join_verdicts"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="join_verdicts" targetRef="review_verdicts"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="review_verdicts" targetRef="send_rejection_notice" name="Negative Verdict">
      <bpmn:conditionExpression>Negative Verdict</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf14" sourceRef="review_verdicts" targetRef="send_approval_notice" name="Positive Verdict">
      <bpmn:conditionExpression>Positive Verdict</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf15" sourceRef="start_insurance" targetRef="verify_coverage"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="verify_coverage" targetRef="record_coverage_verdict"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="record_coverage_verdict" targetRef="join_verdicts"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_gp_pool_di" bpmnElement="actor_gp_pool" isHorizontal="true">
