  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_gp_pool" name="GP" processRef="Process_gp_pool"/>
    <bpmn:participant id="actor_admissions_pool" name="Admissions Office" processRef="Process_admissions_pool"/>
    <bpmn:participant id="actor_specialist_pool" name="Specialist Department" processRef="Process_specialist_pool"/>
    <bpmn:participant id="actor_insurance_pool" name="Insurance Office" processRef="Process_insurance_pool"/>
    <bpmn:messageFlow id="mf1" name="" sourceRef="submit_referral" targetRef="start_admissions"/>
    <bpmn:messageFlow id="Flow_1j3jx33" name="" sourceRef="notify_missing_docs" targetRef="Event_1q3jx2t"/>
    <bpmn:messageFlow id="Flow_1j3jx34" name="" sourceRef="send_rejection" targetRef="Event_1q3jx2p"/>
    <bpmn:messageFlow id="Flow_1j3jx35" name="" sourceRef="send_approval" targetRef="Event_0q3jx2r"/>
    <bpmn:messageFlow id="Flow_1j3jx36" name="" sourceRef="send_approval" targetRef="Event_0q3jx2q"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="submit_referral" targetRef="register_referral"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_gp_pool" name="GP" isExecutable="false">
    <bpmn:laneSet id="LaneSet_gp_pool">
      <bpmn:lane id="gp" name="GP">
        <bpmn:flowNodeRef>start_gp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1q3jx2s</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0q3jx2s</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1q3jx2t</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_referral</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_gp" name="Start"/>
    <bpmn:endEvent id="Event_1q3jx2s" name="Receive Rejection"/>
    <bpmn:endEvent id="Event_0q3jx2s" name="Receive Approval"/>
    <bpmn:intermediateCatchEvent id="Event_1q3jx2t" name="Receive Missing Docs Notification">
      <bpmn:messageEventDefinition id="Event_1q3jx2t_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="submit_referral" name="Submit Referral Request"/>
    <bpmn:sequenceFlow id="Flow_1j3jx2s" sourceRef="start_gp" targetRef="submit_referral"/>
    <bpmn:sequenceFlow id="Flow_1j3jx2t" sourceRef="submit_referral" targetRef="Event_1q3jx2s"/>
  </bpmn:process>
  <bpmn:process id="Process_admissions_pool" name="Admissions Office" isExecutable="false">
    <bpmn:laneSet id="LaneSet_admissions_pool">
      <bpmn:lane id="admissions_clerk" name="Admissions Clerk">
        <bpmn:flowNodeRef>Event_0q3jx2r</bpmn:flowNodeRef>
