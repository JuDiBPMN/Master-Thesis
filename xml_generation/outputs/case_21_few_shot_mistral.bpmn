      <bpmn:messageEventDefinition id="start_admissions_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_admissions_rejected" name="Rejection Sent"/>
    <bpmn:endEvent id="end_admissions" name="End"/>
    <bpmn:task id="register_referral" name="Register Referral"/>
    <bpmn:task id="check_documentation" name="Check Documentation"/>
    <bpmn:task id="notify_missing_docs" name="Notify GP of Missing Docs"/>
    <bpmn:task id="forward_referral" name="Forward Referral"/>
    <bpmn:task id="review_verdicts" name="Review Verdicts"/>
    <bpmn:task id="send_rejection" name="Send Rejection Notice"/>
    <bpmn:task id="send_approval" name="Send Treatment Approval"/>
    <bpmn:parallelGateway id="split_verdicts" name="Split Verdicts" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_verdicts" name="Join Verdicts" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="Flow_1j3jx2v" sourceRef="register_referral" targetRef="check_documentation"/>
    <bpmn:sequenceFlow id="Flow_1j3jx2w" sourceRef="check_documentation" targetRef="split_verdicts"/>
    <bpmn:sequenceFlow id="Flow_1j3jx2x" sourceRef="split_verdicts" targetRef="send_rejection" name="Negative verdict">
      <bpmn:conditionExpression>Negative verdict</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1j3jx2y" sourceRef="split_verdicts" targetRef="join_verdicts"/>
    <bpmn:sequenceFlow id="Flow_1j3jx2z" sourceRef="join_verdicts" targetRef="review_verdicts"/>
    <bpmn:sequenceFlow id="Flow_1j3jx30" sourceRef="review_verdicts" targetRef="send_approval"/>
    <bpmn:sequenceFlow id="Flow_1j3jx31" sourceRef="send_approval" targetRef="end_admissions"/>
    <bpmn:sequenceFlow id="Flow_1j3jx32" sourceRef="send_rejection" targetRef="end_admissions_rejected"/>
  </bpmn:process>
