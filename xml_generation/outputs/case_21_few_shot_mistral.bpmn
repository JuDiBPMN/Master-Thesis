        <bpmn:flowNodeRef>split_verdicts</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_verdicts</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:intermediateCatchEvent id="Event_0q3jx2r" name="Receive Approval Verdict">
      <bpmn:messageEventDefinition id="Event_0q3jx2r_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_0q3jx2q" name="Receive Coverage Verdict">
      <bpmn:messageEventDefinition id="Event_0q3jx2q_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="Event_1q3jx2p" name="Receive Negative Verdict"/>
    <bpmn:endEvent id="Event_1q3jx2o" name="Receive Positive Verdict"/>
