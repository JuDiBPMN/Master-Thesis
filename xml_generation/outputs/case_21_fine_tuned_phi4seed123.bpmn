<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Retailer" name="Retailer Pool" processRef="Process_Retailer"/>
    <bpmn:participant id="actor_Customer" name="Customer Pool" processRef="Process_Customer"/>
    <bpmn:messageFlow id="SubmitToRegister" name="Submit Return Request" sourceRef="SubmitReturnRequest" targetRef="ReturnRequestRegistered"/>
    <bpmn:messageFlow id="RegisterToSubmit" name="Return Request Registered" sourceRef="ReturnRequestRegistered" targetRef="SubmitReturnRequest"/>
    <bpmn:messageFlow id="InformationToCustomer" name="Information Incomplete" sourceRef="InformationIncomplete" targetRef="InformationIncomplete"/>
    <bpmn:messageFlow id="InformationFromCustomer" name="Information Complete" sourceRef="InformationComplete" targetRef="InformationComplete"/>
    <bpmn:messageFlow id="WarehouseToCustomerService" name="Warehouse Inspection Complete" sourceRef="WarehouseInspectionComplete" targetRef="WarehouseInspectionComplete"/>
    <bpmn:messageFlow id="FinanceToCustomerService" name="Payment Eligibility Check Complete" sourceRef="PaymentEligibilityCheckComplete" targetRef="PaymentEligibilityCheckComplete"/>
    <bpmn:messageFlow id="RejectToCustomer" name="Return Rejected" sourceRef="ReturnRejected" targetRef="ReturnRejected"/>
    <bpmn:messageFlow id="ApproveToCustomer" name="Return Approved" sourceRef="ReturnApproved" targetRef="ReturnApproved"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Retailer" name="Retailer Pool" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Retailer">
      <bpmn:lane id="CustomerService" name="Customer Service">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReturnRequestRegistered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>InformationIncomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>InformationComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>WarehouseInspectionComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PaymentEligibilityCheckComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReturnRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReturnApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RegisterReturnRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CheckInformation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>NotifyCustomerMissingInfo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ForwardToWarehouse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ForwardToFinance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReviewOutcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendRejectionNotice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ApproveReturn</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ProcessRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SendRefundConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CheckInfoGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ReviewOutcomesGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ParallelGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ParallelJoinGateway</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Warehouse" name="Warehouse">
        <bpmn:flowNodeRef>InspectProduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecordWarehouseVerdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Finance" name="Finance">
        <bpmn:flowNodeRef>CheckPaymentEligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RecordFinanceVerdict</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="Start"/>
    <bpmn:intermediateThrowEvent id="ReturnRequestRegistered" name="Return Request Registered">
      <bpmn:messageEventDefinition id="ReturnRequestRegistered_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="InformationIncomplete" name="Information Incomplete">
      <bpmn:messageEventDefinition id="InformationIncomplete_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="InformationComplete" name="Information Complete">
      <bpmn:messageEventDefinition id="InformationComplete_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="WarehouseInspectionComplete" name="Warehouse Inspection Complete">
      <bpmn:messageEventDefinition id="WarehouseInspectionComplete_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="PaymentEligibilityCheckComplete" name="Payment Eligibility Check Complete">
      <bpmn:messageEventDefinition id="PaymentEligibilityCheckComplete_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="ReturnRejected" name="Return Rejected">
      <bpmn:messageEventDefinition id="ReturnRejected_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="ReturnApproved" name="Return Approved">
      <bpmn:messageEventDefinition id="ReturnApproved_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="End" name="End"/>
    <bpmn:task id="RegisterReturnRequest" name="Register Return Request"/>
    <bpmn:task id="CheckInformation" name="Check Information Completeness"/>
    <bpmn:task id="NotifyCustomerMissingInfo" name="Notify Customer of Missing Information"/>
    <bpmn:task id="ForwardToWarehouse" name="Forward to Warehouse"/>
    <bpmn:task id="ForwardToFinance" name="Forward to Finance"/>
    <bpmn:task id="InspectProduct" name="Inspect Product"/>
    <bpmn:task id="RecordWarehouseVerdict" name="Record Warehouse Verdict"/>
    <bpmn:task id="CheckPaymentEligibility" name="Check Payment Eligibility"/>
    <bpmn:task id="RecordFinanceVerdict" name="Record Finance Verdict"/>
    <bpmn:task id="ReviewOutcomes" name="Review Outcomes"/>
    <bpmn:task id="SendRejectionNotice" name="Send Return Rejection Notice"/>
    <bpmn:task id="ApproveReturn" name="Approve Return"/>
    <bpmn:task id="ProcessRefund" name="Process Refund"/>
    <bpmn:task id="SendRefundConfirmation" name="Send Refund Confirmation"/>
    <bpmn:exclusiveGateway id="CheckInfoGateway" name="Check Information Gateway" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="ReviewOutcomesGateway" name="Review Outcomes Gateway" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="ParallelGateway" name="Parallel Gateway" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="ParallelJoinGateway" name="Parallel Join Gateway" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="StartToRegister" sourceRef="Start" targetRef="RegisterReturnRequest"/>
    <bpmn:sequenceFlow id="RegisterToCheck" sourceRef="RegisterReturnRequest" targetRef="CheckInformation"/>
    <bpmn:sequenceFlow id="CheckToGateway" sourceRef="CheckInformation" targetRef="CheckInfoGateway"/>
    <bpmn:sequenceFlow id="GatewayToNotify" sourceRef="CheckInfoGateway" targetRef="NotifyCustomerMissingInfo"/>
    <bpmn:sequenceFlow id="NotifyToEnd" sourceRef="NotifyCustomerMissingInfo" targetRef="End"/>
    <bpmn:sequenceFlow id="GatewayToForward" sourceRef="CheckInfoGateway" targetRef="ForwardToWarehouse"/>
    <bpmn:sequenceFlow id="ForwardToThrow" sourceRef="ForwardToWarehouse" targetRef="ReturnRequestRegistered"/>
    <bpmn:sequenceFlow id="ThrowToParallel" sourceRef="ReturnRequestRegistered" targetRef="ParallelGateway"/>
    <bpmn:sequenceFlow id="ParallelToWarehouse" sourceRef="ParallelGateway" targetRef="InspectProduct"/>
    <bpmn:sequenceFlow id="WarehouseToRecord" sourceRef="InspectProduct" targetRef="RecordWarehouseVerdict"/>
    <bpmn:sequenceFlow id="RecordToWarehouse" sourceRef="RecordWarehouseVerdict" targetRef="WarehouseInspectionComplete"/>
    <bpmn:sequenceFlow id="ParallelToFinance" sourceRef="ParallelGateway" targetRef="CheckPaymentEligibility"/>
    <bpmn:sequenceFlow id="FinanceToRecord" sourceRef="CheckPaymentEligibility" targetRef="RecordFinanceVerdict"/>
    <bpmn:sequenceFlow id="RecordToFinance" sourceRef="RecordFinanceVerdict" targetRef="PaymentEligibilityCheckComplete"/>
    <bpmn:sequenceFlow id="WarehouseToJoin" sourceRef="WarehouseInspectionComplete" targetRef="ParallelJoinGateway"/>
    <bpmn:sequenceFlow id="FinanceToJoin" sourceRef="PaymentEligibilityCheckComplete" targetRef="ParallelJoinGateway"/>
    <bpmn:sequenceFlow id="JoinToReview" sourceRef="ParallelJoinGateway" targetRef="ReviewOutcomes"/>
    <bpmn:sequenceFlow id="ReviewToGateway" sourceRef="ReviewOutcomes" targetRef="ReviewOutcomesGateway"/>
    <bpmn:sequenceFlow id="GatewayToReject" sourceRef="ReviewOutcomesGateway" targetRef="SendRejectionNotice"/>
    <bpmn:sequenceFlow id="RejectToEnd" sourceRef="SendRejectionNotice" targetRef="End"/>
    <bpmn:sequenceFlow id="GatewayToApprove" sourceRef="ReviewOutcomesGateway" targetRef="ApproveReturn"/>
    <bpmn:sequenceFlow id="ApproveToProcess" sourceRef="ApproveReturn" targetRef="ProcessRefund"/>
    <bpmn:sequenceFlow id="ProcessToConfirm" sourceRef="ProcessRefund" targetRef="SendRefundConfirmation"/>
    <bpmn:sequenceFlow id="ConfirmToEnd" sourceRef="SendRefundConfirmation" targetRef="End"/>
  </bpmn:process>
  <bpmn:process id="Process_Customer" name="Customer Pool" isExecutable="false">
