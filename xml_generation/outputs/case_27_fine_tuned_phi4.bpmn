<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Bank" name="Bank" processRef="Process_Bank"/>
    <bpmn:participant id="actor_Client" name="Client" processRef="Process_Client"/>
    <bpmn:messageFlow id="mf1" name="Mortgage Application" sourceRef="Receive_Mortgage_Application" targetRef="Start_Bank"/>
    <bpmn:messageFlow id="mf2" name="Line of Credit" sourceRef="Grant_Line_of_Credit" targetRef="End_Client_Granted"/>
    <bpmn:messageFlow id="mf3" name="Mortgage Application Declined" sourceRef="Decline_Mortgage_Application" targetRef="End_Client_Declined"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="Grant_Line_of_Credit" targetRef="End_Client_Granted"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="Decline_Mortgage_Application" targetRef="End_Client_Declined"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Bank" name="Bank" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Bank">
      <bpmn:lane id="Bank_Customer_Service" name="Bank Customer Service">
        <bpmn:flowNodeRef>Start_Bank</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Create_Mortgage_File</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Bank_Operations" name="Bank Operations">
        <bpmn:flowNodeRef>Evaluate_Financial_Stability</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gather_Income_Statements</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Check_for_Credit_Applications</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Parallel_Split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Parallel_Join</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Bank_Finance" name="Bank Finance">
        <bpmn:flowNodeRef>End_Bank_Declined</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Bank_Granted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Perform_Risk_Analysis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Grant_Line_of_Credit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Decline_Mortgage_Application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Exclusive_Split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Exclusive_Join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Bank" name="Mortgage Assessment Start"/>
    <bpmn:endEvent id="End_Bank_Declined" name="Mortgage Assessment End (Declined)"/>
    <bpmn:endEvent id="End_Bank_Granted" name="Mortgage Assessment End (Granted)"/>
    <bpmn:task id="Create_Mortgage_File" name="Create Mortgage File"/>
    <bpmn:task id="Evaluate_Financial_Stability" name="Evaluate Financial Stability"/>
    <bpmn:task id="Gather_Income_Statements" name="Gather Income Statements"/>
    <bpmn:task id="Check_for_Credit_Applications" name="Check for Credit Applications"/>
    <bpmn:task id="Perform_Risk_Analysis" name="Perform In-depth Risk Analysis"/>
    <bpmn:task id="Grant_Line_of_Credit" name="Grant Line of Credit"/>
    <bpmn:task id="Decline_Mortgage_Application" name="Decline Mortgage Application"/>
    <bpmn:parallelGateway id="Parallel_Split" name="Concurrent Evaluation Start" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="Parallel_Join" name="Concurrent Evaluation Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="Exclusive_Split" name="Assessment Outcome?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="Exclusive_Join" name="Assessment Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="Start_Bank" targetRef="Create_Mortgage_File"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="Create_Mortgage_File" targetRef="Parallel_Split"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="Parallel_Split" targetRef="Evaluate_Financial_Stability"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="Parallel_Split" targetRef="Gather_Income_Statements"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="Parallel_Split" targetRef="Check_for_Credit_Applications"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="Evaluate_Financial_Stability" targetRef="Parallel_Join"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="Gather_Income_Statements" targetRef="Parallel_Join"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="Check_for_Credit_Applications" targetRef="Parallel_Join"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="Parallel_Join" targetRef="Perform_Risk_Analysis"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="Perform_Risk_Analysis" targetRef="Exclusive_Split"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="Exclusive_Split" targetRef="Grant_Line_of_Credit" name="Assessment is positive">
      <bpmn:conditionExpression>Assessment is positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf14" sourceRef="Exclusive_Split" targetRef="Decline_Mortgage_Application" name="Assessment is negative">
      <bpmn:conditionExpression>Assessment is negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf17" sourceRef="Start_Bank" targetRef="End_Bank_Declined"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="Start_Bank" targetRef="End_Bank_Granted"/>
  </bpmn:process>
  <bpmn:process id="Process_Client" name="Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Client">
      <bpmn:lane id="Client" name="Client"/>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Client" name="Start"/>
    <bpmn:endEvent id="End_Client_Declined" name="Mortgage Application Declined"/>
    <bpmn:endEvent id="End_Client_Granted" name="Line of Credit Granted"/>
    <bpmn:task id="Receive_Mortgage_Application" name="Receive Mortgage Application"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="Start_Client" targetRef="Receive_Mortgage_Application"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="Receive_Mortgage_Application" targetRef="End_Client_Declined"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Bank_di" bpmnElement="actor_Bank" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="2320" height="1080"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Client_di" bpmnElement="actor_Client" isHorizontal="true">
        <dc:Bounds x="10" y="1160" width="1020" height="250"/>
