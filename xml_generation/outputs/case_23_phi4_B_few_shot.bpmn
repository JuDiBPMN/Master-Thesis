      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lookup_billing_info_di" bpmnElement="lookup_billing_info">
        <dc:Bounds x="390" y="525" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_invoice_di" bpmnElement="review_invoice">
        <dc:Bounds x="650" y="525" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="write_explanation_email_di" bpmnElement="write_explanation_email">
        <dc:Bounds x="1170" y="470" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="create_ticket_di" bpmnElement="create_ticket">
        <dc:Bounds x="1170" y="580" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_mistake_found_di" bpmnElement="split_mistake_found" isMarkerVisible="true">
        <dc:Bounds x="945" y="540" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="send_new_invoice_di" bpmnElement="send_new_invoice">
        <dc:Bounds x="2252" y="797" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="investigate_mistake_di" bpmnElement="investigate_mistake">
        <dc:Bounds x="1430" y="775" width="120" height="80"/>
