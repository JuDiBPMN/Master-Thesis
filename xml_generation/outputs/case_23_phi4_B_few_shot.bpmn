      <bpmndi:BPMNShape id="end_client_mistake_corrected_di" bpmnElement="end_client_mistake_corrected">
        <dc:Bounds x="432" y="160" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="write_complaint_email_di" bpmnElement="write_complaint_email">
        <dc:Bounds x="390" y="226" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="receive_complaint_di" bpmnElement="receive_complaint">
