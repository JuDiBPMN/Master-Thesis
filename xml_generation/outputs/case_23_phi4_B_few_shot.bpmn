<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_client_pool" name="Client" processRef="Process_client_pool"/>
    <bpmn:participant id="actor_brightwave_energy_pool" name="BrightWave Energy" processRef="Process_brightwave_energy_pool"/>
    <bpmn:messageFlow id="mf1" name="Complaint Email" sourceRef="send_complaint" targetRef="receive_complaint"/>
    <bpmn:messageFlow id="mf2" name="Explanation Email" sourceRef="send_explanation" targetRef="receive_explanation"/>
    <bpmn:messageFlow id="mf3" name="New Invoice Email" sourceRef="send_new_invoice" targetRef="receive_new_invoice"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="send_explanation" targetRef="receive_explanation"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="send_new_invoice" targetRef="receive_new_invoice"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_client_pool" name="Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_client_pool">
      <bpmn:lane id="client" name="Client">
        <bpmn:flowNodeRef>start_client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>receive_explanation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>receive_new_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_client_no_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_client_mistake_corrected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>write_complaint_email</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_client" name="Start"/>
    <bpmn:intermediateThrowEvent id="send_complaint" name="Send Complaint Email">
      <bpmn:messageEventDefinition id="send_complaint_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="receive_explanation" name="Receive Explanation">
      <bpmn:messageEventDefinition id="receive_explanation_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="receive_new_invoice" name="Receive New Invoice">
      <bpmn:messageEventDefinition id="receive_new_invoice_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_client_no_mistake" name="End - No Mistake"/>
    <bpmn:endEvent id="end_client_mistake_corrected" name="End - Mistake Corrected"/>
    <bpmn:task id="write_complaint_email" name="Write Complaint Email"/>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="start_client" targetRef="write_complaint_email"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="write_complaint_email" targetRef="send_complaint"/>
    <bpmn:sequenceFlow id="Flow_9" sourceRef="receive_explanation" targetRef="end_client_no_mistake"/>
    <bpmn:sequenceFlow id="Flow_16" sourceRef="receive_new_invoice" targetRef="end_client_mistake_corrected"/>
  </bpmn:process>
  <bpmn:process id="Process_brightwave_energy_pool" name="BrightWave Energy" isExecutable="false">
    <bpmn:laneSet id="LaneSet_brightwave_energy_pool">
      <bpmn:lane id="customer_service" name="Customer Service">
        <bpmn:flowNodeRef>receive_complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_explanation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>lookup_billing_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>write_explanation_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>create_ticket</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_mistake_found</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="invoicing_department" name="Invoicing Department">
        <bpmn:flowNodeRef>send_new_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>investigate_mistake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>correct_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>generate_new_invoice</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:intermediateCatchEvent id="receive_complaint" name="Receive Complaint">
      <bpmn:messageEventDefinition id="receive_complaint_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="send_explanation" name="Send Explanation Email">
      <bpmn:messageEventDefinition id="send_explanation_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="send_new_invoice" name="Send New Invoice">
      <bpmn:messageEventDefinition id="send_new_invoice_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:task id="lookup_billing_info" name="Lookup Billing Information"/>
    <bpmn:task id="review_invoice" name="Review Invoice"/>
    <bpmn:task id="write_explanation_email" name="Write Explanation Email"/>
    <bpmn:task id="create_ticket" name="Create Ticket"/>
    <bpmn:task id="investigate_mistake" name="Investigate Invoicing Mistake"/>
    <bpmn:task id="correct_invoice" name="Correct Invoice"/>
    <bpmn:task id="generate_new_invoice" name="Generate New Invoice"/>
    <bpmn:exclusiveGateway id="split_mistake_found" name="Mistake Found?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="receive_complaint" targetRef="lookup_billing_info"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="lookup_billing_info" targetRef="review_invoice"/>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="review_invoice" targetRef="split_mistake_found"/>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="split_mistake_found" targetRef="write_explanation_email" name="No mistake">
      <bpmn:conditionExpression>No mistake</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_7" sourceRef="write_explanation_email" targetRef="send_explanation"/>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="split_mistake_found" targetRef="create_ticket" name="Mistake found">
      <bpmn:conditionExpression>Mistake found</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="create_ticket" targetRef="investigate_mistake"/>
    <bpmn:sequenceFlow id="Flow_12" sourceRef="investigate_mistake" targetRef="correct_invoice"/>
    <bpmn:sequenceFlow id="Flow_13" sourceRef="correct_invoice" targetRef="generate_new_invoice"/>
    <bpmn:sequenceFlow id="Flow_14" sourceRef="generate_new_invoice" targetRef="send_new_invoice"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_client_pool_di" bpmnElement="actor_client_pool" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="1020" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_brightwave_energy_pool_di" bpmnElement="actor_brightwave_energy_pool" isHorizontal="true">
        <dc:Bounds x="10" y="440" width="2580" height="500"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="client_di" bpmnElement="client" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="990" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="customer_service_di" bpmnElement="customer_service" isHorizontal="true">
