<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_customer_pool" name="Customer" processRef="Process_customer_pool"/>
    <bpmn:participant id="actor_ecommerce_pool" name="E-Commerce Company" processRef="Process_ecommerce_pool"/>
    <bpmn:messageFlow id="mf1" name="Return Request" sourceRef="submit_return" targetRef="start_cs"/>
    <bpmn:messageFlow id="Flow_19rlkps" name="Rejection Notice" sourceRef="notify_rejected" targetRef="Event_0muyk3x"/>
    <bpmn:messageFlow id="Flow_14qsqvk" name="Confirmation" sourceRef="send_confirmation" targetRef="Event_0tpcr9s"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_customer_pool" name="Customer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_customer_pool">
      <bpmn:lane id="customer" name="Customer">
        <bpmn:flowNodeRef>start_customer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0muyk3x</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0tpcr9s</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0lnnv01</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1r6yhp5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_return</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_customer" name="Start"/>
    <bpmn:intermediateCatchEvent id="Event_0muyk3x" name="Receive rejection">
      <bpmn:messageEventDefinition id="Event_0muyk3x_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_0tpcr9s" name="Receive confirmation">
      <bpmn:messageEventDefinition id="Event_0tpcr9s_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="Event_0lnnv01" name="Return Rejected"/>
    <bpmn:endEvent id="Event_1r6yhp5" name="Return Confirmed"/>
    <bpmn:task id="submit_return" name="Submit Return Request"/>
    <bpmn:sequenceFlow id="Flow_1kd72rx" sourceRef="start_customer" targetRef="submit_return"/>
    <bpmn:sequenceFlow id="Flow_0vatbql" sourceRef="Event_0muyk3x" targetRef="Event_0lnnv01"/>
    <bpmn:sequenceFlow id="Flow_1kdv6t5" sourceRef="Event_0tpcr9s" targetRef="Event_1r6yhp5"/>
  </bpmn:process>
  <bpmn:process id="Process_ecommerce_pool" name="E-Commerce Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_ecommerce_pool">
      <bpmn:lane id="customer_service" name="Customer Service">
        <bpmn:flowNodeRef>start_cs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_cs_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_cs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>verify_eligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_confirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_eligible</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="warehouse" name="Warehouse">
        <bpmn:flowNodeRef>arrange_collection</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance" name="Finance">
        <bpmn:flowNodeRef>initiate_refund</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_cs" name="Return Request Received">
      <bpmn:messageEventDefinition id="start_cs_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_cs_rejected" name="Rejection Sent"/>
    <bpmn:endEvent id="end_cs" name="End"/>
    <bpmn:task id="verify_eligibility" name="Verify Return Eligibility"/>
    <bpmn:task id="notify_rejected" name="Notify Customer of Rejection"/>
    <bpmn:task id="send_confirmation" name="Send Confirmation to Customer"/>
    <bpmn:task id="arrange_collection" name="Arrange Item Collection"/>
    <bpmn:task id="initiate_refund" name="Initiate Refund Process"/>
    <bpmn:exclusiveGateway id="split_eligible" name="Item Eligible for Return?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_parallel" name="Start Parallel Processing" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Tasks Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_cs" targetRef="verify_eligibility"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="verify_eligibility" targetRef="split_eligible"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="split_eligible" targetRef="notify_rejected" name="Not eligible">
      <bpmn:conditionExpression>Not eligible</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf4" sourceRef="split_eligible" targetRef="split_parallel" name="Eligible">
      <bpmn:conditionExpression>Eligible</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf5" sourceRef="notify_rejected" targetRef="end_cs_rejected"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_parallel" targetRef="arrange_collection"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="split_parallel" targetRef="initiate_refund"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="arrange_collection" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="initiate_refund" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="join_parallel" targetRef="send_confirmation"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="send_confirmation" targetRef="end_cs"/>
  </bpmn:process>
