<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_supplier_pool" name="Supplier" processRef="Process_supplier_pool"/>
    <bpmn:participant id="actor_company_pool" name="Company" processRef="Process_company_pool"/>
    <bpmn:messageFlow id="mf1" name="Invoice" sourceRef="submit_invoice" targetRef="start_ap"/>
    <bpmn:messageFlow id="mf2" name="Discrepancy Notice" sourceRef="notify_discrepancy" targetRef="end_supplier_rejected"/>
    <bpmn:messageFlow id="mf3" name="Rejection Notice" sourceRef="send_rejection" targetRef="end_supplier_rejected"/>
    <bpmn:messageFlow id="mf4" name="Payment Confirmation" sourceRef="process_payment" targetRef="end_supplier_paid"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_supplier_pool" name="Supplier" isExecutable="false">
    <bpmn:laneSet id="LaneSet_supplier_pool">
      <bpmn:lane id="supplier" name="Supplier">
        <bpmn:flowNodeRef>start_supplier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_supplier_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_supplier_paid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_invoice</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_supplier" name="Start"/>
    <bpmn:endEvent id="end_supplier_rejected" name="Invoice Rejected"/>
    <bpmn:endEvent id="end_supplier_paid" name="Payment Confirmed"/>
    <bpmn:task id="submit_invoice" name="Submit Invoice"/>
  </bpmn:process>
  <bpmn:process id="Process_company_pool" name="Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_company_pool">
      <bpmn:lane id="accounts_payable" name="Accounts Payable">
        <bpmn:flowNodeRef>start_ap</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_discrepancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_paid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_match</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_discrepancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>process_payment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_match</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="budget_control" name="Budget Controller">
        <bpmn:flowNodeRef>verify_budget</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_budget</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="line_manager" name="Line Manager">
        <bpmn:flowNodeRef>approve_expenditure</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_approval</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_ap" name="Invoice Received">
      <bpmn:messageEventDefinition id="start_ap_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_discrepancy" name="Supplier Notified"/>
    <bpmn:endEvent id="end_rejected" name="Rejection Sent"/>
    <bpmn:endEvent id="end_paid" name="Payment Processed"/>
    <bpmn:task id="register_invoice" name="Register Invoice"/>
    <bpmn:task id="check_match" name="Check Invoice Against PO"/>
    <bpmn:task id="notify_discrepancy" name="Notify Supplier of Discrepancy"/>
    <bpmn:task id="review_outcomes" name="Review Combined Verdicts"/>
    <bpmn:task id="send_rejection" name="Send Rejection Notice"/>
    <bpmn:task id="process_payment" name="Process Payment"/>
    <bpmn:task id="verify_budget" name="Verify Budget Availability"/>
    <bpmn:task id="record_budget" name="Record Budget Verdict"/>
    <bpmn:task id="approve_expenditure" name="Review and Approve Expenditure"/>
    <bpmn:task id="record_approval" name="Record Approval Verdict"/>
    <bpmn:exclusiveGateway id="split_match" name="Invoice Matches PO?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward for Verification" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Both Verdicts Positive?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_ap" targetRef="register_invoice"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="register_invoice" targetRef="check_match"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="check_match" targetRef="split_match"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="split_match" targetRef="notify_discrepancy" name="No match">
      <bpmn:conditionExpression>No match</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf5" sourceRef="split_match" targetRef="split_parallel" name="Match confirmed">
      <bpmn:conditionExpression>Match confirmed</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="notify_discrepancy" targetRef="end_discrepancy"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="split_parallel" targetRef="verify_budget"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="split_parallel" targetRef="approve_expenditure"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="verify_budget" targetRef="record_budget"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="record_budget" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="approve_expenditure" targetRef="record_approval"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="record_approval" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="split_outcome" targetRef="send_rejection" name="One or more verdicts negative">
      <bpmn:conditionExpression>One or more verdicts negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf16" sourceRef="split_outcome" targetRef="process_payment" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf17" sourceRef="send_rejection" targetRef="end_rejected"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="process_payment" targetRef="end_paid"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_supplier_pool_di" bpmnElement="actor_supplier_pool" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="2270" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_company_pool_di" bpmnElement="actor_company_pool" isHorizontal="true">
        <dc:Bounds x="10" y="220" width="2460" height="480"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="supplier_di" bpmnElement="supplier" isHorizontal="true">
