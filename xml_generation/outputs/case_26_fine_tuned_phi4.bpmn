<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_HR_manager" name="HR Manager" processRef="Process_HR_manager"/>
    <bpmn:participant id="actor_Business_manager" name="Business Manager" processRef="Process_Business_manager"/>
    <bpmn:participant id="actor_Candidate" name="Candidate" processRef="Process_Candidate"/>
    <bpmn:messageFlow id="mf1" name="Candidate Receives Invitation" sourceRef="start_Candidate" targetRef="start_HR"/>
    <bpmn:messageFlow id="mf2" name="Candidate Receives Contract" sourceRef="end_HR_success" targetRef="end_Candidate"/>
    <bpmn:messageFlow id="mf3" name="Candidate Receives Rejection" sourceRef="end_HR_failure" targetRef="end_Candidate"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="parallel_split" targetRef="second_assessment"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="second_assessment" targetRef="exclusive_split"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="start_Business" targetRef="parallel_join"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="end_HR_success" targetRef="end_Business"/>
    <bpmn:messageFlow id="MsgFlow_p4" name="" sourceRef="end_HR_failure" targetRef="end_Business"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_HR_manager" name="HR Manager" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HR_manager">
      <bpmn:lane id="HR_manager_lane" name="HR Manager Lane">
        <bpmn:flowNodeRef>start_HR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_HR_success</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_HR_failure</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>introduction_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>discuss_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>inform_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>prepare_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>close_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>exclusive_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>exclusive_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_HR" name="Start"/>
    <bpmn:endEvent id="end_HR_success" name="Candidate Contract Prepared"/>
    <bpmn:endEvent id="end_HR_failure" name="Application Closed"/>
    <bpmn:task id="introduction_interview" name="Perform Introduction Interview"/>
    <bpmn:task id="discuss_candidate" name="Discuss Candidate with Business Manager"/>
    <bpmn:task id="inform_candidate" name="Inform Candidate about Application"/>
    <bpmn:task id="prepare_contract" name="Prepare Contract"/>
    <bpmn:task id="close_application" name="Close Application Process"/>
    <bpmn:parallelGateway id="parallel_split" name="Start Concurrent Tasks" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="parallel_join" name="Both Tasks Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="exclusive_split" name="Assessment Successful?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="exclusive_join" name="Assessment Outcome Decided" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_HR" targetRef="introduction_interview"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="introduction_interview" targetRef="discuss_candidate"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="discuss_candidate" targetRef="inform_candidate"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="inform_candidate" targetRef="parallel_split"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="parallel_split" targetRef="prepare_contract"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="prepare_contract" targetRef="exclusive_split"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="exclusive_split" targetRef="end_HR_success" name="Assessment successful">
      <bpmn:conditionExpression>Assessment successful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf10" sourceRef="exclusive_split" targetRef="close_application" name="Assessment not successful">
      <bpmn:conditionExpression>Assessment not successful</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf11" sourceRef="close_application" targetRef="end_HR_failure"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="parallel_join" targetRef="end_HR_success"/>
  </bpmn:process>
  <bpmn:process id="Process_Business_manager" name="Business Manager" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Business_manager">
      <bpmn:lane id="Business_manager_lane" name="Business Manager Lane">
        <bpmn:flowNodeRef>start_Business</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_Business</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>second_assessment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_Business" name="Candidate Assessment Started"/>
    <bpmn:endEvent id="end_Business" name="Candidate Assessment Complete"/>
    <bpmn:task id="second_assessment" name="Perform Second Assessment"/>
  </bpmn:process>
  <bpmn:process id="Process_Candidate" name="Candidate" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Candidate">
      <bpmn:lane id="Candidate_lane" name="Candidate Lane">
        <bpmn:flowNodeRef>start_Candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_Candidate</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_Candidate" name="Candidate Receives Invitation"/>
    <bpmn:endEvent id="end_Candidate" name="Candidate Assessment Complete"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="start_Candidate" targetRef="end_Candidate"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_HR_manager_di" bpmnElement="actor_HR_manager" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="2580" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Business_manager_di" bpmnElement="actor_Business_manager" isHorizontal="true">
        <dc:Bounds x="10" y="440" width="2580" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Candidate_di" bpmnElement="actor_Candidate" isHorizontal="true">
        <dc:Bounds x="10" y="720" width="760" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="HR_manager_lane_di" bpmnElement="HR_manager_lane" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="2550" height="360"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Business_manager_lane_di" bpmnElement="Business_manager_lane" isHorizontal="true">
        <dc:Bounds x="40" y="440" width="2550" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Candidate_lane_di" bpmnElement="Candidate_lane" isHorizontal="true">
        <dc:Bounds x="40" y="720" width="730" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_HR_di" bpmnElement="start_HR">
        <dc:Bounds x="172" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="parallel_join_di" bpmnElement="parallel_join" isMarkerVisible="true">
        <dc:Bounds x="165" y="168" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="exclusive_join_di" bpmnElement="exclusive_join" isMarkerVisible="true">
        <dc:Bounds x="165" y="248" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_HR_success_di" bpmnElement="end_HR_success">
        <dc:Bounds x="1992" y="127" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="close_application_di" bpmnElement="close_application">
        <dc:Bounds x="1950" y="193" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_HR_failure_di" bpmnElement="end_HR_failure">
        <dc:Bounds x="2252" y="182" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="introduction_interview_di" bpmnElement="introduction_interview">
        <dc:Bounds x="390" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="discuss_candidate_di" bpmnElement="discuss_candidate">
        <dc:Bounds x="650" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="inform_candidate_di" bpmnElement="inform_candidate">
        <dc:Bounds x="910" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="prepare_contract_di" bpmnElement="prepare_contract">
        <dc:Bounds x="1430" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="parallel_split_di" bpmnElement="parallel_split" isMarkerVisible="true">
        <dc:Bounds x="1205" y="175" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="exclusive_split_di" bpmnElement="exclusive_split" isMarkerVisible="true">
        <dc:Bounds x="1725" y="175" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_Business_di" bpmnElement="start_Business">
        <dc:Bounds x="172" y="532" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_Business_di" bpmnElement="end_Business">
        <dc:Bounds x="2252" y="532" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="second_assessment_di" bpmnElement="second_assessment">
        <dc:Bounds x="1690" y="510" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_Candidate_di" bpmnElement="start_Candidate">
        <dc:Bounds x="172" y="812" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_Candidate_di" bpmnElement="end_Candidate">
        <dc:Bounds x="432" y="812" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="208" y="120"/>
        <di:waypoint x="299" y="120"/>
        <di:waypoint x="299" y="200"/>
        <di:waypoint x="390" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="510" y="200"/>
        <di:waypoint x="650" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="770" y="200"/>
        <di:waypoint x="910" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="1030" y="200"/>
        <di:waypoint x="1205" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="1255" y="200"/>
        <di:waypoint x="1430" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="1550" y="200"/>
        <di:waypoint x="1725" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="1775" y="200"/>
        <di:waypoint x="1883" y="200"/>
        <di:waypoint x="1883" y="145"/>
        <di:waypoint x="1992" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf10_di" bpmnElement="sf10">
        <di:waypoint x="1775" y="200"/>
        <di:waypoint x="1862" y="200"/>
        <di:waypoint x="1862" y="233"/>
        <di:waypoint x="1950" y="233"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf11_di" bpmnElement="sf11">
        <di:waypoint x="2070" y="233"/>
        <di:waypoint x="2161" y="233"/>
        <di:waypoint x="2161" y="200"/>
        <di:waypoint x="2252" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf12_di" bpmnElement="sf12">
        <di:waypoint x="215" y="193"/>
        <di:waypoint x="1103" y="193"/>
        <di:waypoint x="1103" y="145"/>
        <di:waypoint x="1992" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf16_di" bpmnElement="sf16">
        <di:waypoint x="208" y="830"/>
        <di:waypoint x="432" y="830"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="mf1_di" bpmnElement="mf1">
        <di:waypoint x="190" y="812"/>
        <di:waypoint x="190" y="138"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="mf2_di" bpmnElement="mf2">
        <di:waypoint x="2010" y="163"/>
        <di:waypoint x="450" y="812"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="mf3_di" bpmnElement="mf3">
        <di:waypoint x="2270" y="218"/>
        <di:waypoint x="450" y="812"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p0_di" bpmnElement="MsgFlow_p0">
        <di:waypoint x="1230" y="225"/>
        <di:waypoint x="1750" y="510"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p1_di" bpmnElement="MsgFlow_p1">
        <di:waypoint x="1750" y="510"/>
        <di:waypoint x="1750" y="225"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p2_di" bpmnElement="MsgFlow_p2">
        <di:waypoint x="190" y="532"/>
        <di:waypoint x="190" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p3_di" bpmnElement="MsgFlow_p3">
