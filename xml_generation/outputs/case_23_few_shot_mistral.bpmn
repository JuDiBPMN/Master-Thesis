<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_ecommerce_company" name="E-commerce Company" processRef="Process_ecommerce_company"/>
    <bpmn:messageFlow id="mf1" name="Return Request" sourceRef="submit_return_request" targetRef="verify_eligibility"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_ecommerce_company" name="E-commerce Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_ecommerce_company">
      <bpmn:lane id="customer_service_team" name="Customer Service Team">
        <bpmn:flowNodeRef>end_return_process</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>verify_eligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_customer_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_confirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_eligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_confirmation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="warehouse_team" name="Warehouse Team">
        <bpmn:flowNodeRef>arrange_collection</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance_team" name="Finance Team">
        <bpmn:flowNodeRef>initiate_refund</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="customer" name="Customer">
        <bpmn:flowNodeRef>start_return_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_return_request</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_return_request" name="Start Return Request"/>
    <bpmn:endEvent id="end_return_process" name="End Return Process"/>
    <bpmn:task id="submit_return_request" name="Submit Return Request"/>
    <bpmn:task id="verify_eligibility" name="Verify Eligibility"/>
    <bpmn:task id="notify_customer_rejected" name="Notify Customer of Rejection"/>
    <bpmn:task id="arrange_collection" name="Arrange Collection"/>
    <bpmn:task id="initiate_refund" name="Initiate Refund"/>
    <bpmn:task id="send_confirmation" name="Send Confirmation"/>
    <bpmn:exclusiveGateway id="gateway_eligibility" name="Item Eligibility" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel" name="Parallel Processes" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_confirmation" name="Confirmation Sent" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_return_request" targetRef="verify_eligibility"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="verify_eligibility" targetRef="gateway_eligibility"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="gateway_eligibility" targetRef="notify_customer_rejected"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="gateway_eligibility" targetRef="gateway_parallel"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="gateway_parallel" targetRef="arrange_collection"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="gateway_parallel" targetRef="initiate_refund"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="arrange_collection" targetRef="gateway_confirmation"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="initiate_refund" targetRef="gateway_confirmation"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="gateway_confirmation" targetRef="send_confirmation"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="send_confirmation" targetRef="end_return_process"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_ecommerce_company_di" bpmnElement="actor_ecommerce_company" isHorizontal="true">
