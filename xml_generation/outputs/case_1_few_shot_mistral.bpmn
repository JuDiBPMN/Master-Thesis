<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_yamaha" name="Yamaha" processRef="Process_yamaha"/>
    <bpmn:participant id="actor_customer" name="Customer" processRef="Process_customer"/>
    <bpmn:messageFlow id="mf1" name="Order Rejection Notification" sourceRef="order_rejection" targetRef="start_order"/>
    <bpmn:messageFlow id="mf2" name="Shipment Notification" sourceRef="ship_goods" targetRef="start_invoice"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_yamaha" name="Yamaha" isExecutable="false">
    <bpmn:laneSet id="LaneSet_yamaha">
      <bpmn:lane id="sales_lane" name="Sales">
        <bpmn:flowNodeRef>end_order_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_order_confirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>start_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>order_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>order_confirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_shipment_invoice</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="logistics_lane" name="Logistics">
        <bpmn:flowNodeRef>start_order</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_shipment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_stock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ship_goods</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_stock</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_order" name="Start Order"/>
    <bpmn:endEvent id="end_order_rejected" name="Order Rejected"/>
    <bpmn:endEvent id="end_order_confirmed" name="Order Confirmed"/>
    <bpmn:startEvent id="start_invoice" name="Start Invoice"/>
    <bpmn:endEvent id="end_shipment" name="End Shipment"/>
    <bpmn:task id="check_stock" name="Check Stock"/>
    <bpmn:task id="order_rejection" name="Order Rejection"/>
    <bpmn:task id="order_confirmation" name="Order Confirmation"/>
    <bpmn:task id="send_invoice" name="Send Invoice"/>
    <bpmn:task id="ship_goods" name="Ship Goods"/>
    <bpmn:exclusiveGateway id="split_stock" name="Stock Available?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_shipment_invoice" name="Both Tasks Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_order" targetRef="check_stock"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="check_stock" targetRef="split_stock"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="split_stock" targetRef="order_rejection" name="No stock">
      <bpmn:conditionExpression>No stock</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf4" sourceRef="split_stock" targetRef="order_confirmation" name="Stock available">
      <bpmn:conditionExpression>Stock available</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf5" sourceRef="order_confirmation" targetRef="join_shipment_invoice"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="send_invoice" targetRef="join_shipment_invoice"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="ship_goods" targetRef="end_shipment"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="join_shipment_invoice" targetRef="end_order_confirmed"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="start_invoice" targetRef="send_invoice"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="start_order" targetRef="send_invoice"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="end_shipment" targetRef="end_order_confirmed"/>
  </bpmn:process>
  <bpmn:process id="Process_customer" name="Customer" isExecutable="false"/>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_yamaha_di" bpmnElement="actor_yamaha" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="1320" height="320"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_customer_di" bpmnElement="actor_customer" isHorizontal="true">
        <dc:Bounds x="10" y="380" width="400" height="180"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sales_lane_di" bpmnElement="sales_lane" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="1290" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="logistics_lane_di" bpmnElement="logistics_lane" isHorizontal="true">
        <dc:Bounds x="40" y="180" width="1290" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_order_rejected_di" bpmnElement="end_order_rejected">
        <dc:Bounds x="132" y="55" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_invoice_di" bpmnElement="start_invoice">
        <dc:Bounds x="132" y="108" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_order_confirmed_di" bpmnElement="end_order_confirmed">
        <dc:Bounds x="1082" y="82" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="order_rejection_di" bpmnElement="order_rejection">
        <dc:Bounds x="670" y="33" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="order_confirmation_di" bpmnElement="order_confirmation">
        <dc:Bounds x="670" y="86" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="send_invoice_di" bpmnElement="send_invoice">
        <dc:Bounds x="290" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="join_shipment_invoice_di" bpmnElement="join_shipment_invoice" isMarkerVisible="true">
        <dc:Bounds x="885" y="75" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_order_di" bpmnElement="start_order">
        <dc:Bounds x="132" y="215" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ship_goods_di" bpmnElement="ship_goods">
        <dc:Bounds x="100" y="246" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_shipment_di" bpmnElement="end_shipment">
        <dc:Bounds x="322" y="215" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="check_stock_di" bpmnElement="check_stock">
        <dc:Bounds x="290" y="246" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_stock_di" bpmnElement="split_stock" isMarkerVisible="true">
        <dc:Bounds x="505" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="168" y="233"/>
        <di:waypoint x="229" y="233"/>
        <di:waypoint x="229" y="286"/>
        <di:waypoint x="290" y="286"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="390" y="286"/>
        <di:waypoint x="447" y="286"/>
        <di:waypoint x="447" y="260"/>
        <di:waypoint x="505" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="555" y="260"/>
        <di:waypoint x="612" y="260"/>
        <di:waypoint x="612" y="73"/>
        <di:waypoint x="670" y="73"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="555" y="260"/>
        <di:waypoint x="612" y="260"/>
        <di:waypoint x="612" y="126"/>
        <di:waypoint x="670" y="126"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf5_di" bpmnElement="sf5">
        <di:waypoint x="770" y="126"/>
        <di:waypoint x="827" y="126"/>
        <di:waypoint x="827" y="100"/>
        <di:waypoint x="885" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="390" y="100"/>
        <di:waypoint x="885" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
        <di:waypoint x="200" y="286"/>
        <di:waypoint x="261" y="286"/>
        <di:waypoint x="261" y="233"/>
        <di:waypoint x="322" y="233"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="935" y="100"/>
        <di:waypoint x="1082" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf9_di" bpmnElement="sf9">
        <di:waypoint x="168" y="126"/>
        <di:waypoint x="229" y="126"/>
        <di:waypoint x="229" y="100"/>
        <di:waypoint x="290" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf10_di" bpmnElement="sf10">
        <di:waypoint x="168" y="233"/>
        <di:waypoint x="229" y="233"/>
        <di:waypoint x="229" y="100"/>
        <di:waypoint x="290" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf11_di" bpmnElement="sf11">
        <di:waypoint x="358" y="233"/>
        <di:waypoint x="720" y="233"/>
        <di:waypoint x="720" y="100"/>
        <di:waypoint x="1082" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="mf1_di" bpmnElement="mf1">
        <di:waypoint x="720" y="33"/>
        <di:waypoint x="150" y="251"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="mf2_di" bpmnElement="mf2">
        <di:waypoint x="150" y="246"/>
        <di:waypoint x="150" y="144"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>