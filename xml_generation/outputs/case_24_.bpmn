<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_client_pool" name="Client" processRef="Process_client_pool"/>
    <bpmn:participant id="actor_support_pool" name="Support Desk" processRef="Process_support_pool"/>
    <bpmn:participant id="actor_dev_pool" name="Development Team" processRef="Process_dev_pool"/>
    <bpmn:messageFlow id="mf1" name="Bug Report" sourceRef="submit_bug" targetRef="start_support"/>
    <bpmn:messageFlow id="mf2" name="Escalated Bug Report" sourceRef="escalate_bug" targetRef="start_dev"/>
    <bpmn:messageFlow id="mf3" name="Future Fix Notice" sourceRef="notify_future" targetRef="end_client_low"/>
    <bpmn:messageFlow id="mf4" name="Closure Notification" sourceRef="close_report" targetRef="confirm_resolution"/>
    <bpmn:messageFlow id="mf5" name="Fix Notification" sourceRef="notify_support" targetRef="confirm_resolution"/>
    <bpmn:messageFlow id="mf6" name="Resolution Confirmation" sourceRef="confirm_resolution" targetRef="end_client_resolved"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_client_pool" name="Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_client_pool">
      <bpmn:lane id="client" name="Client">
        <bpmn:flowNodeRef>start_client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_client_low</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_client_resolved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_bug</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_client" name="Start"/>
    <bpmn:endEvent id="end_client_low" name="Future Fix Acknowledged"/>
    <bpmn:endEvent id="end_client_resolved" name="Resolution Confirmed"/>
    <bpmn:task id="submit_bug" name="Submit Bug Report"/>
  </bpmn:process>
  <bpmn:process id="Process_support_pool" name="Support Desk" isExecutable="false">
    <bpmn:laneSet id="LaneSet_support_pool">
      <bpmn:lane id="support" name="Support Desk">
        <bpmn:flowNodeRef>start_support</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_support_low</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_support_resolved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_report</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>log_backlog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_future</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>escalate_bug</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>confirm_resolution</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_severity</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_support" name="Bug Report Received">
      <bpmn:messageEventDefinition id="start_support_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_support_low" name="Client Notified"/>
    <bpmn:endEvent id="end_support_resolved" name="Resolution Confirmed"/>
    <bpmn:task id="review_report" name="Review Bug Report"/>
    <bpmn:task id="log_backlog" name="Log Bug in Backlog"/>
    <bpmn:task id="notify_future" name="Notify Client: Future Release Fix"/>
    <bpmn:task id="escalate_bug" name="Escalate Bug to Development Team"/>
    <bpmn:task id="confirm_resolution" name="Confirm Resolution with Client"/>
    <bpmn:exclusiveGateway id="split_severity" name="Bug Severity?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_support" targetRef="review_report"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="review_report" targetRef="split_severity"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="split_severity" targetRef="log_backlog" name="Low severity">
      <bpmn:conditionExpression>Low severity</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf4" sourceRef="split_severity" targetRef="escalate_bug" name="High severity">
      <bpmn:conditionExpression>High severity</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf5" sourceRef="log_backlog" targetRef="notify_future"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="notify_future" targetRef="end_support_low"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="confirm_resolution" targetRef="end_support_resolved"/>
  </bpmn:process>
  <bpmn:process id="Process_dev_pool" name="Development Team" isExecutable="false">
    <bpmn:laneSet id="LaneSet_dev_pool">
      <bpmn:lane id="dev_team" name="Development Team">
        <bpmn:flowNodeRef>start_dev</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_dev_closed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_dev_fixed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>investigate_bug</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>close_report</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>deploy_fix</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_support</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_reproducible</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_dev" name="Bug Report Received">
      <bpmn:messageEventDefinition id="start_dev_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_dev_closed" name="Report Closed"/>
    <bpmn:endEvent id="end_dev_fixed" name="Fix Deployed"/>
    <bpmn:task id="investigate_bug" name="Investigate Bug"/>
    <bpmn:task id="close_report" name="Close Bug Report"/>
    <bpmn:task id="deploy_fix" name="Deploy Fix"/>
    <bpmn:task id="notify_support" name="Notify Support Desk of Fix"/>
    <bpmn:exclusiveGateway id="split_reproducible" name="Bug Reproducible?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="start_dev" targetRef="investigate_bug"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="investigate_bug" targetRef="split_reproducible"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="split_reproducible" targetRef="close_report" name="Cannot be reproduced">
      <bpmn:conditionExpression>Cannot be reproduced</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf10" sourceRef="split_reproducible" targetRef="deploy_fix" name="Reproducible">
      <bpmn:conditionExpression>Reproducible</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf11" sourceRef="close_report" targetRef="end_dev_closed"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="deploy_fix" targetRef="notify_support"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="notify_support" targetRef="end_dev_fixed"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_client_pool_di" bpmnElement="actor_client_pool" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="1130" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_support_pool_di" bpmnElement="actor_support_pool" isHorizontal="true">
        <dc:Bounds x="10" y="220" width="1320" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_dev_pool_di" bpmnElement="actor_dev_pool" isHorizontal="true">
        <dc:Bounds x="10" y="420" width="1320" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="client_di" bpmnElement="client" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="1100" height="160"/>
