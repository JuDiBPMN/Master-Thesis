      <bpmndi:BPMNShape id="start_client_di" bpmnElement="start_client">
        <dc:Bounds x="132" y="42" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_client_resolved_di" bpmnElement="end_client_resolved">
        <dc:Bounds x="132" y="82" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="submit_bug_di" bpmnElement="submit_bug">
