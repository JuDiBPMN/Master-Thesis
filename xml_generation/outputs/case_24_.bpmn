<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_applicant_pool" name="Applicant" processRef="Process_applicant_pool"/>
    <bpmn:participant id="actor_council_pool" name="City Council" processRef="Process_council_pool"/>
    <bpmn:messageFlow id="mf1" name="Permit Application" sourceRef="submit_application" targetRef="start_council"/>
    <bpmn:messageFlow id="mf2" name="Incomplete Notice" sourceRef="notify_incomplete" targetRef="end_applicant_reject"/>
    <bpmn:messageFlow id="mf3" name="Rejection Notice" sourceRef="issue_rejection" targetRef="end_applicant_reject"/>
    <bpmn:messageFlow id="mf4" name="Building Permit" sourceRef="issue_permit" targetRef="end_applicant_permit"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_applicant_pool" name="Applicant" isExecutable="false">
    <bpmn:laneSet id="LaneSet_applicant_pool">
      <bpmn:lane id="applicant" name="Applicant">
        <bpmn:flowNodeRef>start_applicant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_applicant_reject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_applicant_permit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_application</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_applicant" name="Start"/>
    <bpmn:endEvent id="end_applicant_reject" name="Application Rejected"/>
    <bpmn:endEvent id="end_applicant_permit" name="Permit Received"/>
    <bpmn:task id="submit_application" name="Submit Permit Application"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_applicant" targetRef="submit_application"/>
  </bpmn:process>
  <bpmn:process id="Process_council_pool" name="City Council" isExecutable="false">
    <bpmn:laneSet id="LaneSet_council_pool">
      <bpmn:lane id="permits_office" name="Permits Office">
        <bpmn:flowNodeRef>start_council</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_permitted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_completeness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_incomplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>issue_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>issue_permit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="urban_planning" name="Urban Planning">
        <bpmn:flowNodeRef>zoning_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_zoning</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="safety_inspection" name="Safety Inspection">
        <bpmn:flowNodeRef>safety_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_safety</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_council" name="Application Received">
      <bpmn:messageEventDefinition id="start_council_def"/>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_incomplete" name="Applicant Notified"/>
    <bpmn:endEvent id="end_rejected" name="Rejection Issued"/>
    <bpmn:endEvent id="end_permitted" name="Permit Issued"/>
    <bpmn:task id="register_application" name="Register Application"/>
    <bpmn:task id="check_completeness" name="Check Application Completeness"/>
    <bpmn:task id="notify_incomplete" name="Notify Applicant of Missing Info"/>
    <bpmn:task id="review_outcomes" name="Review Combined Verdicts"/>
    <bpmn:task id="issue_rejection" name="Issue Rejection Notice"/>
    <bpmn:task id="issue_permit" name="Issue Building Permit"/>
    <bpmn:task id="zoning_check" name="Assess Zoning Compliance"/>
    <bpmn:task id="record_zoning" name="Record Zoning Verdict"/>
    <bpmn:task id="safety_review" name="Conduct Structural Safety Review"/>
    <bpmn:task id="record_safety" name="Record Safety Verdict"/>
    <bpmn:exclusiveGateway id="split_complete" name="Application Complete?" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward for Review" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Both Verdicts Positive?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="start_council" targetRef="register_application"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_application" targetRef="check_completeness"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="check_completeness" targetRef="split_complete"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="split_complete" targetRef="notify_incomplete" name="Incomplete">
      <bpmn:conditionExpression>Incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_complete" targetRef="split_parallel" name="Complete">
      <bpmn:conditionExpression>Complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="notify_incomplete" targetRef="end_incomplete"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="split_parallel" targetRef="zoning_check"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="split_parallel" targetRef="safety_review"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="zoning_check" targetRef="record_zoning"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="record_zoning" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="safety_review" targetRef="record_safety"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="record_safety" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="split_outcome" targetRef="issue_rejection" name="One or more verdicts negative">
      <bpmn:conditionExpression>One or more verdicts negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf17" sourceRef="split_outcome" targetRef="issue_permit" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf18" sourceRef="issue_rejection" targetRef="end_rejected"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="issue_permit" targetRef="end_permitted"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_applicant_pool_di" bpmnElement="actor_applicant_pool" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="560" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_council_pool_di" bpmnElement="actor_council_pool" isHorizontal="true">
