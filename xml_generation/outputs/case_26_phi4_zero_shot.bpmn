      <bpmndi:BPMNEdge id="message_flow_inform_di" bpmnElement="message_flow_inform">
        <di:waypoint x="970" y="196"/>
        <di:waypoint x="1490" y="672"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p0_di" bpmnElement="MsgFlow_p0">
        <di:waypoint x="970" y="196"/>
        <di:waypoint x="1490" y="672"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MsgFlow_p1_di" bpmnElement="MsgFlow_p1">
        <di:waypoint x="1490" y="672"/>
        <di:waypoint x="1490" y="435"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>