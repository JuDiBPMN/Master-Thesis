  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_hr_manager_pool" name="HR Manager" processRef="Process_hr_manager_pool"/>
    <bpmn:participant id="actor_business_manager_pool" name="Business Manager" processRef="Process_business_manager_pool"/>
    <bpmn:messageFlow id="mf1" name="Send Candidate Information" sourceRef="Event_0j3q3w" targetRef="start_bm"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="discuss_candidate" targetRef="join_assessment"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="Event_0v3xzr" targetRef="Event_1k3yhg"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="Discussed with Business Manager" sourceRef="split_discuss" targetRef="end_bm"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_hr_manager_pool" name="HR Manager" isExecutable="false">
    <bpmn:laneSet id="LaneSet_hr_manager_pool">
