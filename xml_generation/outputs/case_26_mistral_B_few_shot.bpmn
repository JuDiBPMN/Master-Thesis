        <bpmn:flowNodeRef>inform_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_discuss</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hr" name="Start"/>
    <bpmn:intermediateThrowEvent id="Event_0j3q3w" name="Introduction Interview Finished">
      <bpmn:messageEventDefinition id="Event_0j3q3w_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Event_1q3x2v" name="Discuss Candidate with Business Manager">
      <bpmn:messageEventDefinition id="Event_1q3x2v_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="Event_1k3yhg" name="Contract Preparation">
      <bpmn:messageEventDefinition id="Event_1k3yhg_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_hr" name="End"/>
    <bpmn:task id="introduction_interview" name="Introduction Interview"/>
    <bpmn:task id="discuss_candidate" name="Discuss Candidate"/>
    <bpmn:task id="inform_candidate" name="Inform Candidate"/>
    <bpmn:exclusiveGateway id="split_discuss" name="Discuss with Business Manager?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="Flow_1j3q3w0" sourceRef="start_hr" targetRef="introduction_interview"/>
    <bpmn:sequenceFlow id="Flow_03xzr1" sourceRef="introduction_interview" targetRef="Event_0j3q3w"/>
    <bpmn:sequenceFlow id="Flow_1q3x2v0" sourceRef="Event_1q3x2v" targetRef="split_discuss"/>
    <bpmn:sequenceFlow id="Flow_0x3w5e0" sourceRef="split_discuss" targetRef="discuss_candidate"/>
    <bpmn:sequenceFlow id="Flow_03xw5e1" sourceRef="split_discuss" targetRef="end_hr" name="Not discussed with Business Manager">
      <bpmn:conditionExpression>Not discussed with Business Manager</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmn:process id="Process_business_manager_pool" name="Business Manager" isExecutable="false">
    <bpmn:laneSet id="LaneSet_business_manager_pool">
