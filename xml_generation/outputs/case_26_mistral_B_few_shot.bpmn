    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_bm" name="End"/>
    <bpmn:task id="second_assessment" name="Second Assessment"/>
    <bpmn:parallelGateway id="join_assessment" name="Assessment Completed" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="Flow_0v3xzr1" sourceRef="join_assessment" targetRef="Event_0v3xzr"/>
  </bpmn:process>
