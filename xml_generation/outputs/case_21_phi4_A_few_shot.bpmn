<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Retailer" name="Retailer" processRef="Process_Retailer"/>
    <bpmn:participant id="actor_Customer" name="Customer" processRef="Process_Customer"/>
    <bpmn:messageFlow id="mf1" name="" sourceRef="notify_customer_missing_info" targetRef="end_customer"/>
    <bpmn:messageFlow id="mf2" name="" sourceRef="send_rejection_notice" targetRef="end_customer"/>
    <bpmn:messageFlow id="mf3" name="" sourceRef="send_refund_confirmation" targetRef="end_customer"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Retailer" name="Retailer" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Retailer">
      <bpmn:lane id="customer_service" name="Customer Service">
        <bpmn:flowNodeRef>start_customer_service</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_customer_service</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_return_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_information</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_customer_missing_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>forward_to_warehouse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>forward_to_finance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection_notice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>approve_return</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>process_refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_refund_confirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_information_check</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_outcome_review</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="warehouse_team" name="Warehouse Team">
        <bpmn:flowNodeRef>inspect_product</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance_department" name="Finance Department">
        <bpmn:flowNodeRef>check_payment_eligibility</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_customer_service" name="Start"/>
    <bpmn:endEvent id="end_customer_service" name="End"/>
    <bpmn:task id="register_return_request" name="Register Return Request"/>
    <bpmn:task id="check_information" name="Check Information"/>
    <bpmn:task id="notify_customer_missing_info" name="Notify Customer of Missing Information"/>
    <bpmn:task id="forward_to_warehouse" name="Forward to Warehouse"/>
    <bpmn:task id="forward_to_finance" name="Forward to Finance"/>
    <bpmn:task id="inspect_product" name="Inspect Product"/>
    <bpmn:task id="check_payment_eligibility" name="Check Payment Eligibility"/>
    <bpmn:task id="review_outcomes" name="Review Outcomes"/>
    <bpmn:task id="send_rejection_notice" name="Send Rejection Notice"/>
    <bpmn:task id="approve_return" name="Approve Return"/>
    <bpmn:task id="process_refund" name="Process Refund"/>
    <bpmn:task id="send_refund_confirmation" name="Send Refund Confirmation"/>
    <bpmn:exclusiveGateway id="gateway_information_check" name="Information Check" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_split" name="Start Concurrent Verdicts" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_join" name="Verdicts Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_outcome_review" name="Outcome Review" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_customer_service" targetRef="register_return_request"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="register_return_request" targetRef="check_information"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="check_information" targetRef="gateway_information_check"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="gateway_information_check" targetRef="notify_customer_missing_info" name="information is incomplete">
      <bpmn:conditionExpression>information is incomplete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf5" sourceRef="gateway_information_check" targetRef="forward_to_warehouse" name="information is complete">
      <bpmn:conditionExpression>information is complete</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf6" sourceRef="forward_to_warehouse" targetRef="forward_to_finance"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="forward_to_warehouse" targetRef="gateway_parallel_split"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="gateway_parallel_split" targetRef="inspect_product"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="gateway_parallel_split" targetRef="check_payment_eligibility"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="inspect_product" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="check_payment_eligibility" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="gateway_parallel_join" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="review_outcomes" targetRef="gateway_outcome_review"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="gateway_outcome_review" targetRef="send_rejection_notice" name="either verdict is negative">
      <bpmn:conditionExpression>either verdict is negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf15" sourceRef="gateway_outcome_review" targetRef="approve_return" name="both verdicts are positive">
      <bpmn:conditionExpression>both verdicts are positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf16" sourceRef="approve_return" targetRef="process_refund"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="process_refund" targetRef="send_refund_confirmation"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="send_rejection_notice" targetRef="end_customer_service"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="send_refund_confirmation" targetRef="end_customer_service"/>
  </bpmn:process>
  <bpmn:process id="Process_Customer" name="Customer" isExecutable="false">
    <bpmn:endEvent id="end_customer" name="End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Retailer_di" bpmnElement="actor_Retailer" isHorizontal="true">
