<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:process id="Process_insurance_pool" name="Insurance Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_insurance_pool">
      <bpmn:lane id="claims_intake" name="Claims Intake">
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>receive_claim</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>assign_handler</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="claims_handler" name="Claims Handler">
        <bpmn:flowNodeRef>end_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_claim</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>evaluate_results</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>reject_claim</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>request_documents</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>notify_approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_evaluation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_recheck</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="fraud_detection" name="Fraud Detection">
        <bpmn:flowNodeRef>fraud_check</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="assessment" name="Assessment">
        <bpmn:flowNodeRef>review_documents</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="finance" name="Finance">
        <bpmn:flowNodeRef>process_payment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start" name="Claim Received"/>
    <bpmn:endEvent id="end_rejected" name="Claim Rejected"/>
    <bpmn:endEvent id="end_approved" name="Claim Approved"/>
    <bpmn:task id="receive_claim" name="Receive Claim"/>
    <bpmn:task id="assign_handler" name="Assign Claims Handler"/>
    <bpmn:task id="register_claim" name="Register Claim"/>
    <bpmn:task id="evaluate_results" name="Evaluate Combined Results"/>
    <bpmn:task id="reject_claim" name="Reject Claim"/>
    <bpmn:task id="notify_rejected" name="Notify Customer of Rejection"/>
    <bpmn:task id="request_documents" name="Request Additional Documents"/>
    <bpmn:task id="notify_approved" name="Notify Customer of Approval"/>
    <bpmn:task id="fraud_check" name="Run Automated Fraud Check"/>
    <bpmn:task id="review_documents" name="Review Supporting Documents"/>
    <bpmn:task id="process_payment" name="Process Payment"/>
    <bpmn:parallelGateway id="split_parallel" name="Start Parallel Checks" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Checks Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_evaluation" name="Evaluation Outcome?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_recheck" name="Re-evaluation Loop Join" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start" targetRef="receive_claim"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="receive_claim" targetRef="assign_handler"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="assign_handler" targetRef="register_claim"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="register_claim" targetRef="split_parallel"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="split_parallel" targetRef="fraud_check"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_parallel" targetRef="review_documents"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="fraud_check" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="review_documents" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="join_parallel" targetRef="join_recheck"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="join_recheck" targetRef="evaluate_results"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="evaluate_results" targetRef="split_evaluation"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="split_evaluation" targetRef="reject_claim" name="Fraudulent">
      <bpmn:conditionExpression>Fraudulent</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf13" sourceRef="split_evaluation" targetRef="request_documents" name="Documentation insufficient">
      <bpmn:conditionExpression>Documentation insufficient</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf14" sourceRef="split_evaluation" targetRef="process_payment" name="Approved">
      <bpmn:conditionExpression>Approved</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf15" sourceRef="reject_claim" targetRef="notify_rejected"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="notify_rejected" targetRef="end_rejected"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="request_documents" targetRef="review_documents"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="process_payment" targetRef="notify_approved"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="notify_approved" targetRef="end_approved"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
