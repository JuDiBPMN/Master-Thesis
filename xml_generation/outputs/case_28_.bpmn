<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_candidate_pool" name="Candidate" processRef="Process_candidate_pool"/>
    <bpmn:participant id="actor_company_pool" name="Company" processRef="Process_company_pool"/>
    <bpmn:messageFlow id="mf1" name="Vacancy Request" sourceRef="start_vacancy" targetRef="start_hr"/>
    <bpmn:messageFlow id="mf2" name="Job Application" sourceRef="apply_vacancy" targetRef="screen_applications"/>
    <bpmn:messageFlow id="mf3" name="Personality Assessment" sourceRef="send_assessment" targetRef="catch_assessment"/>
    <bpmn:messageFlow id="mf4" name="Completed Assessment" sourceRef="submit_assessment" targetRef="catch_submission"/>
    <bpmn:messageFlow id="mf5" name="Rejection Email" sourceRef="throw_rejection" targetRef="catch_rejection"/>
    <bpmn:messageFlow id="mf6" name="Job Offer" sourceRef="throw_offer" targetRef="catch_offer"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_candidate_pool" name="Candidate" isExecutable="false">
    <bpmn:laneSet id="LaneSet_candidate_pool">
      <bpmn:lane id="candidate" name="Candidate">
        <bpmn:flowNodeRef>start_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_candidate_rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_candidate_offered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>apply_vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>complete_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_assessment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_candidate" name="Start"/>
    <bpmn:intermediateCatchEvent id="catch_assessment" name="Personality Assessment Received">
      <bpmn:messageEventDefinition id="catch_assessment_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="catch_rejection" name="Rejection Email Received">
      <bpmn:messageEventDefinition id="catch_rejection_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_candidate_rejected" name="Ended: Application Rejected"/>
    <bpmn:intermediateCatchEvent id="catch_offer" name="Job Offer Received">
      <bpmn:messageEventDefinition id="catch_offer_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_candidate_offered" name="Ended: Job Offer Received"/>
    <bpmn:task id="apply_vacancy" name="Apply for Vacancy"/>
    <bpmn:task id="complete_assessment" name="Complete Personality Assessment"/>
    <bpmn:task id="submit_assessment" name="Submit Personality Assessment"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_candidate" targetRef="apply_vacancy"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="catch_assessment" targetRef="complete_assessment"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="complete_assessment" targetRef="submit_assessment"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="catch_rejection" targetRef="end_candidate_rejected"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="catch_offer" targetRef="end_candidate_offered"/>
  </bpmn:process>
  <bpmn:process id="Process_company_pool" name="Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_company_pool">
      <bpmn:lane id="hr_recruiter" name="HR Recruiter">
        <bpmn:flowNodeRef>start_hr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_submission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>throw_offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>screen_applications</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>score_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_parallel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_outcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_outcome</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="hiring_manager" name="Hiring Manager">
        <bpmn:flowNodeRef>start_vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>conduct_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_interview</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hr" name="Vacancy Request Received">
      <bpmn:messageEventDefinition id="start_hr_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="catch_submission" name="Assessment Submission Received">
      <bpmn:messageEventDefinition id="catch_submission_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateThrowEvent id="throw_rejection" name="Send Rejection Email">
      <bpmn:messageEventDefinition id="throw_rejection_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="throw_offer" name="Send Job Offer">
      <bpmn:messageEventDefinition id="throw_offer_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="end_hr" name="Process Complete"/>
    <bpmn:startEvent id="start_vacancy" name="Start"/>
    <bpmn:task id="register_vacancy" name="Register Vacancy and Post Job Ad"/>
    <bpmn:task id="screen_applications" name="Screen Applications and Shortlist"/>
    <bpmn:task id="send_assessment" name="Send Personality Assessment"/>
    <bpmn:task id="score_assessment" name="Score Personality Assessment"/>
    <bpmn:task id="record_assessment" name="Record Assessment Verdict"/>
    <bpmn:task id="review_outcomes" name="Review Combined Verdicts"/>
    <bpmn:task id="send_rejection" name="Send Rejection Email"/>
    <bpmn:task id="send_offer" name="Send Job Offer"/>
    <bpmn:task id="conduct_interview" name="Conduct Technical Interview"/>
    <bpmn:task id="record_interview" name="Record Interview Verdict"/>
    <bpmn:parallelGateway id="split_parallel" name="Forward for Evaluation" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="join_parallel" name="Both Verdicts Recorded" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_outcome" name="Both Verdicts Positive?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_outcome" name="Merge Outcome Paths" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="start_vacancy" targetRef="conduct_interview"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="conduct_interview" targetRef="record_interview"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="record_interview" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="start_hr" targetRef="register_vacancy"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="register_vacancy" targetRef="screen_applications"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="screen_applications" targetRef="split_parallel"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="split_parallel" targetRef="send_assessment"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="split_parallel" targetRef="conduct_interview"/>
    <bpmn:sequenceFlow id="sf14" sourceRef="send_assessment" targetRef="catch_submission"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="catch_submission" targetRef="score_assessment"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="score_assessment" targetRef="record_assessment"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="record_assessment" targetRef="join_parallel"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="join_parallel" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="review_outcomes" targetRef="split_outcome"/>
    <bpmn:sequenceFlow id="sf20" sourceRef="split_outcome" targetRef="send_rejection" name="One or more verdicts negative">
      <bpmn:conditionExpression>One or more verdicts negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf21" sourceRef="split_outcome" targetRef="send_offer" name="Both verdicts positive">
      <bpmn:conditionExpression>Both verdicts positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf22" sourceRef="send_rejection" targetRef="throw_rejection"/>
    <bpmn:sequenceFlow id="sf23" sourceRef="send_offer" targetRef="throw_offer"/>
    <bpmn:sequenceFlow id="sf24" sourceRef="throw_rejection" targetRef="join_outcome"/>
    <bpmn:sequenceFlow id="sf25" sourceRef="throw_offer" targetRef="join_outcome"/>
    <bpmn:sequenceFlow id="sf26" sourceRef="join_outcome" targetRef="end_hr"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
