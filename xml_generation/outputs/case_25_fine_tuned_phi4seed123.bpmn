<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_Library" name="Library System" processRef="Process_Library"/>
    <bpmn:participant id="actor_Requester" name="Requester" processRef="Process_Requester"/>
    <bpmn:messageFlow id="Book_Not_Available_to_Requester" name="Book Not Available" sourceRef="Book_Not_Available" targetRef="Receive_Book_Not_Available"/>
    <bpmn:messageFlow id="Receive_Book_Not_Available_End_Requester" name="Receive Book Not Available" sourceRef="Receive_Book_Not_Available" targetRef="End_Requester"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Library" name="Library System" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Library">
      <bpmn:lane id="Library_Staff" name="Staff">
        <bpmn:flowNodeRef>Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Book_Not_Available</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Book_Available</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Check_Catalog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Inform_Requester</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Log_Book</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Retrieve_Book</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Check_Availability</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Checkout_Procedure</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Checkout_Complete</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start" name="Start"/>
    <bpmn:intermediateThrowEvent id="Book_Not_Available" name="Book Not Available">
      <bpmn:messageEventDefinition id="Book_Not_Available_def"/>
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Book_Available" name="Book Available">
      <bpmn:messageEventDefinition id="Book_Available_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="End" name="End"/>
    <bpmn:task id="Check_Catalog" name="Check Catalog"/>
    <bpmn:task id="Inform_Requester" name="Inform Requester"/>
    <bpmn:task id="Log_Book" name="Log Book"/>
    <bpmn:task id="Retrieve_Book" name="Retrieve Book"/>
    <bpmn:exclusiveGateway id="Check_Availability" name="Check Availability" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="Checkout_Procedure" name="Checkout Procedure" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="Checkout_Complete" name="Checkout Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="Start_Check_Catalog" sourceRef="Start" targetRef="Check_Catalog"/>
    <bpmn:sequenceFlow id="Check_Catalog_Check_Availability" sourceRef="Check_Catalog" targetRef="Check_Availability"/>
    <bpmn:sequenceFlow id="Check_Availability_Book_Not_Available" sourceRef="Check_Availability" targetRef="Book_Not_Available"/>
    <bpmn:sequenceFlow id="Book_Not_Available_Inform_Requester" sourceRef="Book_Not_Available" targetRef="Inform_Requester"/>
    <bpmn:sequenceFlow id="Inform_Requester_End" sourceRef="Inform_Requester" targetRef="End"/>
    <bpmn:sequenceFlow id="Check_Availability_Book_Available" sourceRef="Check_Availability" targetRef="Book_Available"/>
    <bpmn:sequenceFlow id="Book_Available_Checkout_Procedure" sourceRef="Book_Available" targetRef="Checkout_Procedure"/>
    <bpmn:sequenceFlow id="Checkout_Procedure_Log_Book" sourceRef="Checkout_Procedure" targetRef="Log_Book"/>
    <bpmn:sequenceFlow id="Checkout_Procedure_Retrieve_Book" sourceRef="Checkout_Procedure" targetRef="Retrieve_Book"/>
    <bpmn:sequenceFlow id="Log_Book_Checkout_Complete" sourceRef="Log_Book" targetRef="Checkout_Complete"/>
    <bpmn:sequenceFlow id="Retrieve_Book_Checkout_Complete" sourceRef="Retrieve_Book" targetRef="Checkout_Complete"/>
    <bpmn:sequenceFlow id="Checkout_Complete_End" sourceRef="Checkout_Complete" targetRef="End"/>
  </bpmn:process>
  <bpmn:process id="Process_Requester" name="Requester" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Requester">
      <bpmn:lane id="Requester" name="Requester"/>
    </bpmn:laneSet>
    <bpmn:intermediateCatchEvent id="Receive_Book_Not_Available" name="Receive Book Not Available">
      <bpmn:messageEventDefinition id="Receive_Book_Not_Available_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="End_Requester" name="End Requester"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_Library_di" bpmnElement="actor_Library" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="2320" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_Requester_di" bpmnElement="actor_Requester" isHorizontal="true">
