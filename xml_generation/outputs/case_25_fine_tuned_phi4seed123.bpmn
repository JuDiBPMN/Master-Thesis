      <bpmndi:BPMNShape id="Book_Not_Available_di" bpmnElement="Book_Not_Available">
        <dc:Bounds x="952" y="94" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Book_Available_di" bpmnElement="Book_Available">
