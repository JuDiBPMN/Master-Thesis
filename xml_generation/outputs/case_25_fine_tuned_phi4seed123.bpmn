        <di:waypoint x="685" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Check_Availability_Book_Not_Available_di" bpmnElement="Check_Availability_Book_Not_Available">
        <di:waypoint x="735" y="145"/>
        <di:waypoint x="843" y="145"/>
        <di:waypoint x="843" y="112"/>
        <di:waypoint x="952" y="112"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Book_Not_Available_Inform_Requester_di" bpmnElement="Book_Not_Available_Inform_Requester">
