      <bpmndi:BPMNShape id="Checkout_Complete_di" bpmnElement="Checkout_Complete" isMarkerVisible="true">
        <dc:Bounds x="1725" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Receive_Book_Not_Available_di" bpmnElement="Receive_Book_Not_Available">
        <dc:Bounds x="952" y="422" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Requester_di" bpmnElement="End_Requester">
        <dc:Bounds x="172" y="422" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Start_Check_Catalog_di" bpmnElement="Start_Check_Catalog">
        <di:waypoint x="208" y="145"/>
        <di:waypoint x="390" y="145"/>
      </bpmndi:BPMNEdge>
