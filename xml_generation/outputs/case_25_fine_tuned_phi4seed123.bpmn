        <di:waypoint x="843" y="178"/>
        <di:waypoint x="952" y="178"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Book_Available_Checkout_Procedure_di" bpmnElement="Book_Available_Checkout_Procedure">
