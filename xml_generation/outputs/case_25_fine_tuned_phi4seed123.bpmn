      <bpmndi:BPMNShape id="Inform_Requester_di" bpmnElement="Inform_Requester">
        <dc:Bounds x="1170" y="65" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Checkout_Procedure_di" bpmnElement="Checkout_Procedure" isMarkerVisible="true">
        <dc:Bounds x="1205" y="175" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Log_Book_di" bpmnElement="Log_Book">
        <dc:Bounds x="1430" y="50" width="120" height="80"/>
