<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:process id="Process_HR_Department" name="HR Department" isExecutable="false">
    <bpmn:laneSet id="LaneSet_HR_Department">
      <bpmn:lane id="hr_manager" name="HR Manager">
        <bpmn:flowNodeRef>start_hr_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_hr_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>introduction_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>discuss_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>inform_candidate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>second_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>prepare_contract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>close_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hr_manager" name="Start"/>
    <bpmn:endEvent id="end_hr_manager" name="End"/>
    <bpmn:task id="introduction_interview" name="Introduction Interview"/>
    <bpmn:task id="discuss_candidate" name="Discuss Candidate"/>
    <bpmn:task id="inform_candidate" name="Inform Candidate"/>
    <bpmn:task id="second_assessment" name="Second Assessment"/>
    <bpmn:task id="prepare_contract" name="Prepare Contract"/>
    <bpmn:task id="close_application" name="Close Application Process"/>
    <bpmn:parallelGateway id="gateway_parallel_split" name="Start Concurrent Activities" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_join" name="Activities Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_hr_manager" targetRef="introduction_interview"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="introduction_interview" targetRef="gateway_parallel_split"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="gateway_parallel_split" targetRef="discuss_candidate"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="gateway_parallel_split" targetRef="inform_candidate"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="discuss_candidate" targetRef="second_assessment"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="second_assessment" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="gateway_parallel_join" targetRef="prepare_contract"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="prepare_contract" targetRef="end_hr_manager"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_HR_Department">
      <bpmndi:BPMNShape id="hr_manager_di" bpmnElement="hr_manager" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="2290" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_hr_manager_di" bpmnElement="start_hr_manager">
        <dc:Bounds x="172" y="72" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="close_application_di" bpmnElement="close_application">
        <dc:Bounds x="130" y="138" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_hr_manager_di" bpmnElement="end_hr_manager">
        <dc:Bounds x="1992" y="127" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="introduction_interview_di" bpmnElement="introduction_interview">
        <dc:Bounds x="390" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="discuss_candidate_di" bpmnElement="discuss_candidate">
        <dc:Bounds x="910" y="50" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="inform_candidate_di" bpmnElement="inform_candidate">
        <dc:Bounds x="910" y="160" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="second_assessment_di" bpmnElement="second_assessment">
        <dc:Bounds x="1170" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="prepare_contract_di" bpmnElement="prepare_contract">
        <dc:Bounds x="1690" y="105" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_parallel_split_di" bpmnElement="gateway_parallel_split" isMarkerVisible="true">
        <dc:Bounds x="685" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_parallel_join_di" bpmnElement="gateway_parallel_join" isMarkerVisible="true">
        <dc:Bounds x="1465" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="208" y="90"/>
        <di:waypoint x="299" y="90"/>
        <di:waypoint x="299" y="145"/>
        <di:waypoint x="390" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <di:waypoint x="510" y="145"/>
        <di:waypoint x="685" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <di:waypoint x="735" y="145"/>
        <di:waypoint x="822" y="145"/>
        <di:waypoint x="822" y="90"/>
        <di:waypoint x="910" y="90"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf4_di" bpmnElement="sf4">
        <di:waypoint x="735" y="145"/>
        <di:waypoint x="822" y="145"/>
        <di:waypoint x="822" y="200"/>
        <di:waypoint x="910" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf5_di" bpmnElement="sf5">
        <di:waypoint x="1030" y="90"/>
        <di:waypoint x="1100" y="90"/>
        <di:waypoint x="1100" y="145"/>
        <di:waypoint x="1170" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf6_di" bpmnElement="sf6">
        <di:waypoint x="1290" y="145"/>
        <di:waypoint x="1465" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf7_di" bpmnElement="sf7">
        <di:waypoint x="1515" y="145"/>
        <di:waypoint x="1690" y="145"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf8_di" bpmnElement="sf8">
        <di:waypoint x="1810" y="145"/>
        <di:waypoint x="1992" y="145"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>