<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_client_pool" name="Client Company" processRef="Process_client_pool"/>
    <bpmn:participant id="actor_recruiter_pool" name="Recruitment Agency" processRef="Process_recruiter_pool"/>
    <bpmn:messageFlow id="mf1" name="Job Vacancy" sourceRef="post_vacancy" targetRef="start_recruiter"/>
    <bpmn:messageFlow id="mf2" name="Candidate Profiles" sourceRef="submit_profiles" targetRef="review_profiles"/>
    <bpmn:messageFlow id="mf3" name="Profile Decision" sourceRef="review_profiles" targetRef="catch_profile_decision"/>
    <bpmn:messageFlow id="mf4" name="Interview Schedule" sourceRef="schedule_interviews" targetRef="conduct_interviews"/>
    <bpmn:messageFlow id="mf5" name="Hiring Decision" sourceRef="conduct_interviews" targetRef="catch_hiring_decision"/>
    <bpmn:messageFlow id="mf6" name="Placement Confirmation" sourceRef="issue_confirmation" targetRef="end_client"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_client_pool" name="Client Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_client_pool">
      <bpmn:lane id="client" name="Client Company">
        <bpmn:flowNodeRef>start_client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_client</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>post_vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_profiles</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>conduct_interviews</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_client" name="Start"/>
    <bpmn:endEvent id="end_client" name="Candidate Placed"/>
    <bpmn:task id="post_vacancy" name="Post Job Vacancy"/>
    <bpmn:task id="review_profiles" name="Review Candidate Profiles"/>
    <bpmn:task id="conduct_interviews" name="Conduct Interviews"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_client" targetRef="post_vacancy"/>
  </bpmn:process>
  <bpmn:process id="Process_recruiter_pool" name="Recruitment Agency" isExecutable="false">
    <bpmn:laneSet id="LaneSet_recruiter_pool">
      <bpmn:lane id="recruiter" name="Recruiter">
        <bpmn:flowNodeRef>start_recruiter</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_profile_decision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>catch_hiring_decision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_recruiter</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>receive_vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>screen_database</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>post_externally</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>shortlist_candidates</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_profiles</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>schedule_interviews</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>issue_confirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_candidates</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_shortlist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_profile</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>join_new_search</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>split_hiring</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_recruiter" name="Vacancy Received">
      <bpmn:messageEventDefinition id="start_recruiter_def"/>
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="catch_profile_decision" name="Profile Decision Received">
      <bpmn:messageEventDefinition id="catch_profile_decision_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="catch_hiring_decision" name="Hiring Decision Received">
      <bpmn:messageEventDefinition id="catch_hiring_decision_def"/>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_recruiter" name="Placement Confirmed"/>
    <bpmn:task id="receive_vacancy" name="Receive Job Vacancy"/>
    <bpmn:task id="screen_database" name="Screen Candidate Database"/>
    <bpmn:task id="post_externally" name="Post Vacancy Externally"/>
    <bpmn:task id="shortlist_candidates" name="Shortlist Candidates"/>
    <bpmn:task id="submit_profiles" name="Submit Candidate Profiles"/>
    <bpmn:task id="schedule_interviews" name="Schedule Interviews"/>
    <bpmn:task id="issue_confirmation" name="Issue Placement Confirmation"/>
    <bpmn:exclusiveGateway id="split_candidates" name="Suitable Candidates Found?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_shortlist" name="Shortlist Ready" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_profile" name="Profiles Accepted?" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="join_new_search" name="New Search Loop Join" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="split_hiring" name="Candidate Selected?" gatewayDirection="diverging"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="start_recruiter" targetRef="join_new_search"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="join_new_search" targetRef="receive_vacancy"/>
    <bpmn:sequenceFlow id="sf4" sourceRef="receive_vacancy" targetRef="screen_database"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="screen_database" targetRef="split_candidates"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="split_candidates" targetRef="post_externally" name="No suitable candidates">
      <bpmn:conditionExpression>No suitable candidates</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf7" sourceRef="split_candidates" targetRef="join_shortlist" name="Suitable candidates found">
      <bpmn:conditionExpression>Suitable candidates found</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf8" sourceRef="post_externally" targetRef="join_shortlist"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="join_shortlist" targetRef="shortlist_candidates"/>
    <bpmn:sequenceFlow id="sf10" sourceRef="shortlist_candidates" targetRef="submit_profiles"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="catch_profile_decision" targetRef="split_profile"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="split_profile" targetRef="join_new_search" name="All profiles rejected">
      <bpmn:conditionExpression>All profiles rejected</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf13" sourceRef="split_profile" targetRef="schedule_interviews" name="Candidates selected for interview">
      <bpmn:conditionExpression>Candidates selected for interview</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf14" sourceRef="schedule_interviews" targetRef="catch_hiring_decision"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="catch_hiring_decision" targetRef="split_hiring"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="split_hiring" targetRef="join_new_search" name="No candidate selected">
      <bpmn:conditionExpression>No candidate selected</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf17" sourceRef="split_hiring" targetRef="issue_confirmation" name="Candidate selected">
      <bpmn:conditionExpression>Candidate selected</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf18" sourceRef="issue_confirmation" targetRef="end_recruiter"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_client_pool_di" bpmnElement="actor_client_pool" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="560" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actor_recruiter_pool_di" bpmnElement="actor_recruiter_pool" isHorizontal="true">
        <dc:Bounds x="10" y="220" width="2650" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="client_di" bpmnElement="client" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="530" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="recruiter_di" bpmnElement="recruiter" isHorizontal="true">
        <dc:Bounds x="40" y="220" width="2620" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_client_di" bpmnElement="start_client">
        <dc:Bounds x="132" y="34" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_client_di" bpmnElement="end_client">
        <dc:Bounds x="132" y="66" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="review_profiles_di" bpmnElement="review_profiles">
        <dc:Bounds x="100" y="76" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="conduct_interviews_di" bpmnElement="conduct_interviews">
        <dc:Bounds x="100" y="108" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="post_vacancy_di" bpmnElement="post_vacancy">
        <dc:Bounds x="290" y="60" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_recruiter_di" bpmnElement="start_recruiter">
        <dc:Bounds x="132" y="255" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="catch_profile_decision_di" bpmnElement="catch_profile_decision">
        <dc:Bounds x="132" y="308" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="catch_hiring_decision_di" bpmnElement="catch_hiring_decision">
        <dc:Bounds x="702" y="282" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_recruiter_di" bpmnElement="end_recruiter">
        <dc:Bounds x="1272" y="255" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="receive_vacancy_di" bpmnElement="receive_vacancy">
        <dc:Bounds x="1240" y="286" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="screen_database_di" bpmnElement="screen_database">
        <dc:Bounds x="1430" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="post_externally_di" bpmnElement="post_externally">
        <dc:Bounds x="1810" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shortlist_candidates_di" bpmnElement="shortlist_candidates">
        <dc:Bounds x="2190" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="submit_profiles_di" bpmnElement="submit_profiles">
        <dc:Bounds x="2380" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="schedule_interviews_di" bpmnElement="schedule_interviews">
        <dc:Bounds x="480" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="issue_confirmation_di" bpmnElement="issue_confirmation">
        <dc:Bounds x="1050" y="233" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="join_new_search_di" bpmnElement="join_new_search" isMarkerVisible="true">
        <dc:Bounds x="1075" y="301" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_candidates_di" bpmnElement="split_candidates" isMarkerVisible="true">
        <dc:Bounds x="1645" y="275" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="join_shortlist_di" bpmnElement="join_shortlist" isMarkerVisible="true">
        <dc:Bounds x="2025" y="275" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_profile_di" bpmnElement="split_profile" isMarkerVisible="true">
        <dc:Bounds x="315" y="275" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="split_hiring_di" bpmnElement="split_hiring" isMarkerVisible="true">
        <dc:Bounds x="885" y="275" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <di:waypoint x="168" y="52"/>
        <di:waypoint x="229" y="52"/>
        <di:waypoint x="229" y="100"/>
        <di:waypoint x="290" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
