<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_marketing_agency" name="Marketing Agency" processRef="Process_marketing_agency"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="project_manager" targetRef="exclusive_gateway_approval"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_marketing_agency" name="Marketing Agency" isExecutable="false">
    <bpmn:laneSet id="LaneSet_marketing_agency">
      <bpmn:lane id="creative_director" name="Creative Director">
        <bpmn:flowNodeRef>start_event</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>receive_campaign_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>assign_project</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>parallel_gateway_assign</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="project_manager" name="Project Manager">
        <bpmn:flowNodeRef>end_event</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>project_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>publish_campaign</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>exclusive_gateway_approval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>parallel_gateway_revisions</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="copywriter" name="Copywriter">
        <bpmn:flowNodeRef>copywriting_draft</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="graphic_designer" name="Graphic Designer">
        <bpmn:flowNodeRef>graphic_design</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="social_media_manager" name="Social Media Manager">
        <bpmn:flowNodeRef>social_media_planning</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_event" name="Start"/>
    <bpmn:endEvent id="end_event" name="End"/>
    <bpmn:task id="receive_campaign_request" name="Receive request"/>
    <bpmn:task id="assign_project" name="Assign project"/>
    <bpmn:task id="copywriting_draft" name="Draft text"/>
    <bpmn:task id="graphic_design" name="Create visual assets"/>
    <bpmn:task id="social_media_planning" name="Define posting schedule"/>
    <bpmn:task id="project_review" name="Review package"/>
    <bpmn:task id="publish_campaign" name="Publish campaign"/>
    <bpmn:parallelGateway id="parallel_gateway_assign" name="Parallel gateway - Assign tasks" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="exclusive_gateway_approval" name="Exclusive gateway - Client approval" gatewayDirection="converging"/>
    <bpmn:parallelGateway id="parallel_gateway_revisions" name="Parallel gateway - Revisions" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf_receive_request_assign_project" sourceRef="receive_campaign_request" targetRef="assign_project"/>
    <bpmn:sequenceFlow id="sf_assign_project_parallel_gateway" sourceRef="assign_project" targetRef="parallel_gateway_assign"/>
    <bpmn:sequenceFlow id="sf_parallel_gateway_assign_copywriting_draft" sourceRef="parallel_gateway_assign" targetRef="copywriting_draft"/>
    <bpmn:sequenceFlow id="sf_parallel_gateway_assign_graphic_design" sourceRef="parallel_gateway_assign" targetRef="graphic_design"/>
    <bpmn:sequenceFlow id="sf_parallel_gateway_assign_social_media_planning" sourceRef="parallel_gateway_assign" targetRef="social_media_planning"/>
    <bpmn:sequenceFlow id="sf_exclusive_gateway_approval_publish" sourceRef="exclusive_gateway_approval" targetRef="publish_campaign"/>
    <bpmn:sequenceFlow id="sf_exclusive_gateway_approval_revisions" sourceRef="exclusive_gateway_approval" targetRef="parallel_gateway_revisions"/>
    <bpmn:sequenceFlow id="sf_parallel_gateway_revisions_assign_project" sourceRef="parallel_gateway_revisions" targetRef="assign_project"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="actor_marketing_agency_di" bpmnElement="actor_marketing_agency" isHorizontal="true">
