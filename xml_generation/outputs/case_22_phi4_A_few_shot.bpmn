<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="BPMN Pipeline" exporterVersion="2.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="actor_company" name="Company" processRef="Process_company"/>
    <bpmn:participant id="actor_candidate" name="Candidate" processRef="Process_candidate"/>
    <bpmn:messageFlow id="mf1" name="" sourceRef="conduct_interview" targetRef="intermediateCatchEvent_interview"/>
    <bpmn:messageFlow id="mf2" name="" sourceRef="intermediateThrowEvent_interview" targetRef="record_interview_verdict"/>
    <bpmn:messageFlow id="mf3" name="" sourceRef="score_assessment" targetRef="intermediateCatchEvent_assessment"/>
    <bpmn:messageFlow id="mf4" name="" sourceRef="intermediateThrowEvent_assessment" targetRef="record_assessment_verdict"/>
    <bpmn:messageFlow id="MsgFlow_p0" name="" sourceRef="post_job_advertisement" targetRef="apply_for_vacancy"/>
    <bpmn:messageFlow id="MsgFlow_p1" name="" sourceRef="apply_for_vacancy" targetRef="screen_applications"/>
    <bpmn:messageFlow id="MsgFlow_p2" name="" sourceRef="gateway_parallel_split" targetRef="complete_personality_assessment"/>
    <bpmn:messageFlow id="MsgFlow_p3" name="" sourceRef="submit_personality_assessment" targetRef="score_assessment"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_company" name="Company" isExecutable="false">
    <bpmn:laneSet id="LaneSet_company">
      <bpmn:lane id="hiring_manager" name="Hiring Manager">
        <bpmn:flowNodeRef>start_hiring_manager</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_vacancy_request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>conduct_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_interview_verdict</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="hr_department" name="HR Department">
        <bpmn:flowNodeRef>end_hr_department</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>register_vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>post_job_advertisement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>screen_applications</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>schedule_interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_personality_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>score_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>record_assessment_verdict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>review_outcomes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>write_rejection_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_rejection_email</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>draft_job_offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>send_job_offer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_parallel_join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_outcome_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gateway_outcome_join</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start_hiring_manager" name="Start"/>
    <bpmn:endEvent id="end_hr_department" name="End"/>
    <bpmn:task id="submit_vacancy_request" name="Submit Vacancy Request"/>
    <bpmn:task id="register_vacancy" name="Register Vacancy"/>
    <bpmn:task id="post_job_advertisement" name="Post Job Advertisement"/>
    <bpmn:task id="screen_applications" name="Screen Applications"/>
    <bpmn:task id="schedule_interview" name="Schedule Technical Interview"/>
    <bpmn:task id="send_personality_assessment" name="Send Personality Assessment"/>
    <bpmn:task id="conduct_interview" name="Conduct Technical Interview"/>
    <bpmn:task id="record_interview_verdict" name="Record Interview Verdict"/>
    <bpmn:task id="score_assessment" name="Score Personality Assessment"/>
    <bpmn:task id="record_assessment_verdict" name="Record Assessment Verdict"/>
    <bpmn:task id="review_outcomes" name="Review Combined Outcomes"/>
    <bpmn:task id="write_rejection_email" name="Write Rejection Email"/>
    <bpmn:task id="send_rejection_email" name="Send Rejection Email"/>
    <bpmn:task id="draft_job_offer" name="Draft Job Offer"/>
    <bpmn:task id="send_job_offer" name="Send Job Offer"/>
    <bpmn:parallelGateway id="gateway_parallel_split" name="Start Concurrent Activities" gatewayDirection="diverging"/>
    <bpmn:parallelGateway id="gateway_parallel_join" name="Concurrent Activities Complete" gatewayDirection="converging"/>
    <bpmn:exclusiveGateway id="gateway_outcome_split" name="Outcome Decision" gatewayDirection="diverging"/>
    <bpmn:exclusiveGateway id="gateway_outcome_join" name="Outcome Process Complete" gatewayDirection="converging"/>
    <bpmn:sequenceFlow id="sf1" sourceRef="start_hiring_manager" targetRef="submit_vacancy_request"/>
    <bpmn:sequenceFlow id="sf2" sourceRef="submit_vacancy_request" targetRef="register_vacancy"/>
    <bpmn:sequenceFlow id="sf3" sourceRef="register_vacancy" targetRef="post_job_advertisement"/>
    <bpmn:sequenceFlow id="sf6" sourceRef="screen_applications" targetRef="schedule_interview"/>
    <bpmn:sequenceFlow id="sf7" sourceRef="schedule_interview" targetRef="send_personality_assessment"/>
    <bpmn:sequenceFlow id="sf8" sourceRef="send_personality_assessment" targetRef="gateway_parallel_split"/>
    <bpmn:sequenceFlow id="sf9" sourceRef="gateway_parallel_split" targetRef="conduct_interview"/>
    <bpmn:sequenceFlow id="sf11" sourceRef="conduct_interview" targetRef="record_interview_verdict"/>
    <bpmn:sequenceFlow id="sf12" sourceRef="record_interview_verdict" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf15" sourceRef="score_assessment" targetRef="record_assessment_verdict"/>
    <bpmn:sequenceFlow id="sf16" sourceRef="record_assessment_verdict" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="sf17" sourceRef="gateway_parallel_join" targetRef="review_outcomes"/>
    <bpmn:sequenceFlow id="sf18" sourceRef="review_outcomes" targetRef="gateway_outcome_split"/>
    <bpmn:sequenceFlow id="sf19" sourceRef="gateway_outcome_split" targetRef="write_rejection_email" name="either verdict is negative">
      <bpmn:conditionExpression>either verdict is negative</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf20" sourceRef="write_rejection_email" targetRef="send_rejection_email"/>
    <bpmn:sequenceFlow id="sf21" sourceRef="send_rejection_email" targetRef="gateway_outcome_join"/>
    <bpmn:sequenceFlow id="sf22" sourceRef="gateway_outcome_split" targetRef="draft_job_offer" name="both verdicts are positive">
      <bpmn:conditionExpression>both verdicts are positive</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf23" sourceRef="draft_job_offer" targetRef="send_job_offer"/>
    <bpmn:sequenceFlow id="sf24" sourceRef="send_job_offer" targetRef="gateway_outcome_join"/>
    <bpmn:sequenceFlow id="sf25" sourceRef="gateway_outcome_join" targetRef="end_hr_department"/>
  </bpmn:process>
  <bpmn:process id="Process_candidate" name="Candidate" isExecutable="false">
    <bpmn:laneSet id="LaneSet_candidate">
      <bpmn:lane id="candidate_application" name="Candidate Application">
        <bpmn:flowNodeRef>end_candidate_application</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>apply_for_vacancy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>complete_personality_assessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>submit_personality_assessment</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:endEvent id="end_candidate_application" name="End"/>
    <bpmn:task id="apply_for_vacancy" name="Apply for Vacancy"/>
    <bpmn:task id="complete_personality_assessment" name="Complete Personality Assessment"/>
    <bpmn:task id="submit_personality_assessment" name="Submit Personality Assessment"/>
    <bpmn:sequenceFlow id="sf13" sourceRef="complete_personality_assessment" targetRef="submit_personality_assessment"/>
  </bpmn:process>
