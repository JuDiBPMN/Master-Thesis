      "name": "Assess Request for Approval",
      "type": "task",
      "participant": "manager"
    },
    {
      "id": "initiate_project_plan",
      "name": "Initiate Project Plan",
      "type": "task",
      "participant": "manager"
    },
    {
      "id": "lay_out_timeline",
      "name": "Lay Out Timeline",
      "type": "task",
      "participant": "manager"
    },
    {
      "id": "set_up_budget",
      "name": "Set Up Budget",
      "type": "task",
      "participant": "manager"
    },
    {
