    "type": "output"
  },
  {
    "from": "assess_request",
    "to": "request_for_approval",
    "type": "output"
  },
  {
    "from": "initiate_project_plan",
    "to": "project_plan",
    "type": "output"
  },
  {
    "from": "lay_out_timeline",
    "to": "project_plan",
    "type": "output"
  },
  {
    "from": "set_up_budget",
    "to": "project_plan",
    "type": "output"
  },
  {
    "from": "state_resources",
    "to": "project_plan",
    "type": "output"
  }
  ]
}