      "participant": "manager",
      "eventDefinition": "none"
    }
  ],
  "gateways": [
    {
      "id": "gateway_approved_split",
      "name": "Project Approved?",
      "type": "exclusiveGateway",
      "participant": "manager",
      "gatewayDirection": "diverging"
    },
    {
      "id": "gateway_planning_split",
      "name": "Plan in Parallel",
      "type": "parallelGateway",
      "participant": "manager",
      "gatewayDirection": "diverging"
    },
    {
      "id": "gateway_planning_join",
      "name": "Planning Complete",
      "type": "parallelGateway",
      "participant": "manager",
      "gatewayDirection": "converging"
    },
    {
      "id": "gateway_approved_join",
      "name": "Approval/Disapproval Complete",
      "type": "exclusiveGateway",
      "participant": "manager",
      "gatewayDirection": "converging"
    }
  ],
  "sequence_flows": [
    { "id": "sf1",  "from": "start_employee",        "to": "initiate_project_plan" },
    { "id": "sf2",  "from": "initiate_project_plan",  "to": "record_idea" },
    { "id": "sf3",  "from": "record_idea",            "to": "express_value" },
    { "id": "sf4",  "from": "express_value",        "to": "submit_request" },
    { "id": "sf5",  "from": "submit_request",        "to": "assess_request" },
    { "id": "sf6",  "from": "assess_request",         "to": "gateway_approved_split" },
    { "id": "sf7",  "from": "gateway_approved_split", "to": "initiate_project_plan", "condition": "Approved" },
    { "id": "sf8",  "from": "gateway_approved_split", "to": "communicate_rejection", "condition": "Rejected" },
    { "id": "sf9",  "from": "initiate_project_plan",  "to": "gateway_planning_split" },
    { "id": "sf10",  "from": "gateway_planning_split", "to": "lay_out_timeline" },
    { "id": "sf11",  "from": "gateway_planning_split", "to": "set_up_budget" },
    { "id": "sf12", "from": "gateway_planning_split", "to": "state_resources" },
    { "id": "sf13", "from": "lay_out_timeline",       "to": "gateway_planning_join" },
    { "id": "sf14", "from": "set_up_budget",          "to": "gateway_planning_join" },
    { "id": "sf15", "from": "state_resources",        "to": "gateway_planning_join" },
    { "id": "sf16", "from": "gateway_planning_join",  "to":  "start_project" },
    { "id": "sf17", "from": "communicate_rejection",  "to": "gateway_approved_join" },
    { "id": "sf19", "from": "start_project",  "to": "gateway_approved_join" },
    { "id": "sf20", "from": "gateway_approved_join",  "to": "end_manager" }
  ],
  "message_flows": [],
  "data": [{"id": "document_idea",
          "name": "document of basic idea"
          },
          {"id": "request_for_approval",
           "name": "request for approval"
           },
          {"id": "project_plan",
           "name": "project plan"}
          ],
