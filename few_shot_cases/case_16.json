{
    "pools": [
      { "id": "retailer_pool",   "name": "Retailer" },
      { "id": "logistics_pool",  "name": "Logistics Company" }
    ],
    "lanes": [
      { "id": "retailer",           "name": "Retailer",            "pool": "retailer_pool" },
      { "id": "logistics_coord",    "name": "Logistics Coordinator","pool": "logistics_pool" },
      { "id": "warehouse",          "name": "Warehouse",           "pool": "logistics_pool" },
      { "id": "transport_planning", "name": "Transport Planning",  "pool": "logistics_pool" },
      { "id": "driver",             "name": "Driver",              "pool": "logistics_pool" }
    ],
    "tasks": [
      { "id": "confirm_order",       "name": "Confirm New Order",              "type": "task", "lane": "retailer" },
      { "id": "register_shipment",   "name": "Register Shipment",              "type": "task", "lane": "logistics_coord" },
      { "id": "generate_label",      "name": "Generate Shipping Label",        "type": "task", "lane": "logistics_coord" },
      { "id": "hand_to_driver",      "name": "Hand Parcel to Driver",          "type": "task", "lane": "logistics_coord" },
      { "id": "pick_pack",           "name": "Pick and Pack Items",            "type": "task", "lane": "warehouse" },
      { "id": "schedule_redelivery", "name": "Schedule Redelivery Attempt",    "type": "task", "lane": "warehouse" },
      { "id": "assign_driver",       "name": "Assign Driver and Vehicle",      "type": "task", "lane": "transport_planning" },
      { "id": "deliver_parcel",      "name": "Deliver Parcel to Customer",     "type": "task", "lane": "driver" },
      { "id": "mark_delivered",      "name": "Mark Shipment as Delivered",     "type": "task", "lane": "driver" },
      { "id": "return_parcel",       "name": "Return Parcel to Warehouse",     "type": "task", "lane": "driver" }
    ],
    "events": [
      { "id": "start_retailer",   "name": "Start",               "type": "startEvent", "lane": "retailer",        "eventDefinition": "none" },
      { "id": "end_retailer",     "name": "Order Shipped",        "type": "endEvent",   "lane": "retailer",        "eventDefinition": "none" },
      { "id": "start_logistics",  "name": "Order Confirmed",      "type": "startEvent", "lane": "logistics_coord", "eventDefinition": "message" },
      { "id": "end_delivered",    "name": "Shipment Delivered",   "type": "endEvent",   "lane": "driver",          "eventDefinition": "none" }
    ],
    "gateways": [
      { "id": "split_parallel",    "name": "Start Parallel Tracks",    "type": "parallelGateway",  "lane": "logistics_coord", "gatewayDirection": "diverging" },
      { "id": "join_parallel",     "name": "Both Tracks Complete",     "type": "parallelGateway",  "lane": "logistics_coord", "gatewayDirection": "converging" },
      { "id": "split_delivery",    "name": "Delivery Successful?",     "type": "exclusiveGateway", "lane": "driver",          "gatewayDirection": "diverging" },
      { "id": "join_retry",        "name": "Delivery Retry Join",      "type": "exclusiveGateway", "lane": "driver",          "gatewayDirection": "converging" }
    ],
    "sequence_flows": [
      { "id": "sf1",  "from": "start_retailer",    "to": "confirm_order" },
      { "id": "sf2",  "from": "start_logistics",   "to": "register_shipment" },
      { "id": "sf3",  "from": "register_shipment", "to": "split_parallel" },
      { "id": "sf4",  "from": "split_parallel",    "to": "pick_pack" },
      { "id": "sf5",  "from": "split_parallel",    "to": "assign_driver" },
      { "id": "sf6",  "from": "pick_pack",          "to": "join_parallel" },
      { "id": "sf7",  "from": "assign_driver",      "to": "join_parallel" },
      { "id": "sf8",  "from": "join_parallel",      "to": "generate_label" },
      { "id": "sf9",  "from": "generate_label",     "to": "hand_to_driver" },
      { "id": "sf10", "from": "hand_to_driver",     "to": "join_retry" },
      { "id": "sf11", "from": "join_retry",         "to": "deliver_parcel" },
      { "id": "sf12", "from": "deliver_parcel",     "to": "split_delivery" },
      { "id": "sf13", "from": "split_delivery",     "to": "mark_delivered",      "condition": "Delivery successful" },
      { "id": "sf14", "from": "split_delivery",     "to": "return_parcel",       "condition": "Customer unavailable" },
      { "id": "sf15", "from": "mark_delivered",     "to": "end_delivered" },
      { "id": "sf16", "from": "return_parcel",      "to": "schedule_redelivery" },
      { "id": "sf17", "from": "schedule_redelivery","to": "join_retry" }
    ],
    "message_flows": [
      { "id": "mf1", "from": "confirm_order",   "to": "start_logistics", "name": "Order Confirmation" },
      { "id": "mf2", "from": "mark_delivered",  "to": "end_retailer",    "name": "Delivery Confirmation" }
    ],
    "data": [],
    "data_associations": []
