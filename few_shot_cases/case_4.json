{
  "pools": [
     {
      "id": "procurement_process",
      "name": "Procurement Process"
    }
  ],
    "lanes": [  
    {
      "id": "product_manager",
      "name": "Product Manager",
      "pool": "procurement_process"
    },
    {
      "id": "product_owner",
      "name": "Product Owner",
      "pool": "procurement_process"
    }
  ],
  "tasks": [
    {
      "id": "request_product_quotes",
      "name": "Request Product Quotes",
      "type": "task",
      "lane": "product_manager"
    },
    {
      "id": "receive_all_quotes",
      "name": "Receive All Quotes",
      "type": "task",
      "lane": "product_manager"
    },
    {
      "id": "evaluate_delivery_options",
      "name": "Evaluate Delivery Options",
      "type": "task",
      "lane": "product_manager"
    },
    {
      "id": "evaluate_quotes",
      "name": "Evaluate Quotes",
      "type": "task",
      "lane": "product_owner"
    },
    {
      "id": "sign_contract",
      "name": "Sign Contract",
      "type": "task",
      "lane": "product_manager"
    }
  ],
  "events": [
    {
      "id": "start_product_manager",
      "name": "Start",
      "type": "startEvent",
      "lane": "product_manager",
      "eventDefinition": "none"
    },
    {
      "id": "end_product_manager",
      "name": "End",
      "type": "endEvent",
      "lane": "product_manager",
      "eventDefinition": "none"
    }
  ],
  "gateways": [
    {
      "id": "gateway_parallel_split",
      "name": "Start Simultaneous Tasks",
      "type": "parallelGateway",
      "lane": "product_manager",
      "gatewayDirection": "diverging"
    },
    {
      "id": "gateway_parallel_join",
      "name": "Both Tasks Complete",
      "type": "parallelGateway",
      "lane": "product_manager",
      "gatewayDirection": "converging"
    }
  ],
  "sequence_flows": [
    { "id": "sf1", "from": "start_product_manager", "to": "gateway_parallel_split" },
    { "id": "sf2", "from": "gateway_parallel_split", "to": "request_product_quotes" },
    { "id": "sf3", "from": "gateway_parallel_split", "to": "evaluate_delivery_options" },
    { "id": "sf4", "from": "request_product_quotes", "to": "receive_all_quotes" },
    { "id": "sf5", "from": "receive_all_quotes", "to": "gateway_parallel_join" },
    { "id": "sf6", "from": "evaluate_delivery_options", "to": "gateway_parallel_join" },
    { "id": "sf7", "from": "gateway_parallel_join", "to": "evaluate_quotes" },
    { "id": "sf8", "from": "evaluate_quotes", "to": "sign_contract" },
    { "id": "sf9", "from": "sign_contract", "to": "end_product_manager" }
  ],
  "message_flows": []
}