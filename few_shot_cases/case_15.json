{
    "pools": [
      { "id": "publishing_house", "name": "Publishing House" }
    ],
    "lanes": [
      { "id": "editorial_manager", "name": "Editorial Manager", "pool": "publishing_house" },
      { "id": "editor",            "name": "Editor",            "pool": "publishing_house" },
      { "id": "layout_designer",   "name": "Layout Designer",   "pool": "publishing_house" },
      { "id": "print_manager",     "name": "Print Manager",     "pool": "publishing_house" }
    ],
    "tasks": [
      { "id": "assign_manuscript",    "name": "Assign Manuscript",             "type": "task", "lane": "editorial_manager" },
      { "id": "proofread_manuscript", "name": "Proofread and Correct Manuscript","type": "task","lane": "editor" },
      { "id": "format_pages",        "name": "Format Pages and Design Cover",  "type": "task", "lane": "layout_designer" },
      { "id": "send_to_printer",     "name": "Send Files to Printer",          "type": "task", "lane": "print_manager" },
      { "id": "produce_proof",       "name": "Produce Proof Copy",             "type": "task", "lane": "print_manager" },
      { "id": "review_proof",        "name": "Review Proof",                   "type": "task", "lane": "editorial_manager" },
      { "id": "place_print_order",   "name": "Place Full Print Order",         "type": "task", "lane": "print_manager" },
      { "id": "identify_issues",     "name": "Identify Proof Issues",          "type": "task", "lane": "editorial_manager" },
      { "id": "apply_corrections",   "name": "Apply Corrections",              "type": "task", "lane": "layout_designer" }
    ],
    "events": [
      { "id": "start",               "name": "Manuscript Accepted",            "type": "startEvent",            "lane": "editorial_manager", "eventDefinition": "none" },
      { "id": "end",                 "name": "Print Order Placed",             "type": "endEvent",              "lane": "print_manager",     "eventDefinition": "none" },
      { "id": "proof_requested",     "name": "New Proof Requested",            "type": "intermediateThrowEvent","lane": "print_manager",     "eventDefinition": "none" }
    ],
    "gateways": [
      { "id": "split_parallel",      "name": "Assign Parallel Tracks",         "type": "parallelGateway",  "lane": "editorial_manager", "gatewayDirection": "diverging" },
      { "id": "join_parallel",       "name": "Both Tracks Complete",           "type": "parallelGateway",  "lane": "print_manager",     "gatewayDirection": "converging" },
      { "id": "split_proof",         "name": "Proof Approved?",                "type": "exclusiveGateway", "lane": "editorial_manager", "gatewayDirection": "diverging" },
      { "id": "join_proof_loop",     "name": "Proof Review Loop Join",         "type": "exclusiveGateway", "lane": "print_manager",     "gatewayDirection": "converging" }
    ],
    "sequence_flows": [
      { "id": "sf1",  "from": "start",               "to": "assign_manuscript" },
      { "id": "sf2",  "from": "assign_manuscript",    "to": "split_parallel" },
      { "id": "sf3",  "from": "split_parallel",       "to": "proofread_manuscript" },
      { "id": "sf4",  "from": "split_parallel",       "to": "format_pages" },
      { "id": "sf5",  "from": "proofread_manuscript", "to": "join_parallel" },
      { "id": "sf6",  "from": "format_pages",         "to": "join_parallel" },
      { "id": "sf7",  "from": "join_parallel",        "to": "send_to_printer" },
      { "id": "sf8",  "from": "send_to_printer",      "to": "join_proof_loop" },
      { "id": "sf9",  "from": "join_proof_loop",      "to": "produce_proof" },
      { "id": "sf10", "from": "produce_proof",        "to": "review_proof" },
      { "id": "sf11", "from": "review_proof",         "to": "split_proof" },
      { "id": "sf12", "from": "split_proof",          "to": "place_print_order",  "condition": "Proof approved" },
      { "id": "sf13", "from": "split_proof",          "to": "identify_issues",    "condition": "Proof rejected" },
      { "id": "sf14", "from": "identify_issues",      "to": "apply_corrections" },
      { "id": "sf15", "from": "apply_corrections",    "to": "proof_requested" },
      { "id": "sf16", "from": "proof_requested",      "to": "join_proof_loop" },
      { "id": "sf17", "from": "place_print_order",    "to": "end" }
    ],
    "message_flows": [],
    "data": [],
    "data_associations": []
  }