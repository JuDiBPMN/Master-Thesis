{
  "pools": [
    { "id": "gp_pool",       "name": "General Practitioner" },
    { "id": "hospital_pool", "name": "Hospital" }
  ],
  "lanes": [
    { "id": "gp",          "name": "General Practitioner", "pool": "gp_pool" },
    { "id": "admissions",  "name": "Admissions Office",    "pool": "hospital_pool" },
    { "id": "specialist",  "name": "Specialist Department","pool": "hospital_pool" },
    { "id": "insurance",   "name": "Insurance Office",     "pool": "hospital_pool" }
  ],
  "tasks": [
    { "id": "submit_referral",    "name": "Submit Referral Request",       "type": "task", "lane": "gp" },
    { "id": "register_referral",  "name": "Register Referral",             "type": "task", "lane": "admissions" },
    { "id": "check_docs",         "name": "Check Medical Documentation",   "type": "task", "lane": "admissions" },
    { "id": "review_outcomes",    "name": "Review Combined Verdicts",      "type": "task", "lane": "admissions" },
    { "id": "medical_assessment", "name": "Conduct Medical Assessment",    "type": "task", "lane": "specialist" },
    { "id": "record_medical",     "name": "Record Medical Verdict",        "type": "task", "lane": "specialist" },
    { "id": "verify_coverage",    "name": "Verify Insurance Coverage",     "type": "task", "lane": "insurance" },
    { "id": "record_coverage",    "name": "Record Coverage Verdict",       "type": "task", "lane": "insurance" }
  ],
  "events": [
    { "id": "start_gp",                "name": "Start",                        "type": "startEvent",            "lane": "gp",         "eventDefinition": "none" },
    { "id": "catch_incomplete_gp",     "name": "Incomplete Notice Received",   "type": "intermediateCatchEvent","lane": "gp",         "eventDefinition": "message" },
    { "id": "end_gp_incomplete",       "name": "Ended: Incomplete Docs",       "type": "endEvent",              "lane": "gp",         "eventDefinition": "none" },
    { "id": "catch_rejection_gp",      "name": "Rejection Notice Received",    "type": "intermediateCatchEvent","lane": "gp",         "eventDefinition": "message" },
    { "id": "end_gp_rejected",         "name": "Ended: Referral Rejected",     "type": "endEvent",              "lane": "gp",         "eventDefinition": "none" },
    { "id": "catch_approval_gp",       "name": "Approval Received",            "type": "intermediateCatchEvent","lane": "gp",         "eventDefinition": "message" },
    { "id": "end_gp_approved",         "name": "Ended: Referral Approved",     "type": "endEvent",              "lane": "gp",         "eventDefinition": "none" },
    { "id": "start_admissions",        "name": "Referral Received",            "type": "startEvent",            "lane": "admissions", "eventDefinition": "message" },
    { "id": "throw_incomplete",        "name": "Notify GP of Missing Documents","type": "intermediateThrowEvent","lane": "admissions", "eventDefinition": "message" },
    { "id": "end_admissions_incomplete","name": "Incomplete Docs",             "type": "endEvent",              "lane": "admissions", "eventDefinition": "none" },
    { "id": "throw_rejection",         "name": "Send Rejection Notice",        "type": "intermediateThrowEvent","lane": "admissions", "eventDefinition": "message" },
    { "id": "throw_approval",          "name": "Send Treatment Approval",      "type": "intermediateThrowEvent","lane": "admissions", "eventDefinition": "message" },
    { "id": "end_admissions",          "name": "Process Complete",             "type": "endEvent",              "lane": "admissions", "eventDefinition": "none" }
  ],
  "gateways": [
    { "id": "split_complete", "name": "Documentation Complete?", "type": "exclusiveGateway", "lane": "admissions", "gatewayDirection": "diverging" },
    { "id": "split_parallel", "name": "Forward for Review",      "type": "parallelGateway",  "lane": "admissions", "gatewayDirection": "diverging" },
    { "id": "join_parallel",  "name": "Both Verdicts Recorded",  "type": "parallelGateway",  "lane": "admissions", "gatewayDirection": "converging" },
    { "id": "split_outcome",  "name": "Both Verdicts Positive?", "type": "exclusiveGateway", "lane": "admissions", "gatewayDirection": "diverging" },
    { "id": "join_outcome",   "name": "Merge Outcome Paths",     "type": "exclusiveGateway", "lane": "admissions", "gatewayDirection": "converging" }
  ],
  "sequence_flows": [
    { "id": "sf1",  "from": "start_gp",             "to": "submit_referral" },
    { "id": "sf2",  "from": "start_admissions",      "to": "register_referral" },
    { "id": "sf3",  "from": "register_referral",     "to": "check_docs" },
    { "id": "sf4",  "from": "check_docs",            "to": "split_complete" },
    { "id": "sf5",  "from": "split_complete",        "to": "throw_incomplete",   "condition": "Incomplete" },
    { "id": "sf6",  "from": "split_complete",        "to": "split_parallel",     "condition": "Complete" },
    { "id": "sf7",  "from": "throw_incomplete",      "to": "end_admissions_incomplete" },
    { "id": "sf8",  "from": "split_parallel",        "to": "medical_assessment" },
    { "id": "sf9",  "from": "split_parallel",        "to": "verify_coverage" },
    { "id": "sf10", "from": "medical_assessment",    "to": "record_medical" },
    { "id": "sf11", "from": "record_medical",        "to": "join_parallel" },
    { "id": "sf12", "from": "verify_coverage",       "to": "record_coverage" },
    { "id": "sf13", "from": "record_coverage",       "to": "join_parallel" },
    { "id": "sf14", "from": "join_parallel",         "to": "review_outcomes" },
    { "id": "sf15", "from": "review_outcomes",       "to": "split_outcome" },
    { "id": "sf16", "from": "split_outcome",         "to": "throw_rejection",    "condition": "One or more verdicts negative" },
    { "id": "sf17", "from": "split_outcome",         "to": "throw_approval",     "condition": "Both verdicts positive" },
    { "id": "sf18", "from": "throw_rejection",       "to": "join_outcome" },
    { "id": "sf19", "from": "throw_approval",        "to": "join_outcome" },
    { "id": "sf20", "from": "join_outcome",          "to": "end_admissions" },
    { "id": "sf21", "from": "catch_incomplete_gp",   "to": "end_gp_incomplete" },
    { "id": "sf22", "from": "catch_rejection_gp",    "to": "end_gp_rejected" },
    { "id": "sf23", "from": "catch_approval_gp",     "to": "end_gp_approved" }
  ],
  "message_flows": [
    { "id": "mf1", "from": "submit_referral",  "to": "start_admissions",    "name": "Referral Request" },
    { "id": "mf2", "from": "throw_incomplete", "to": "catch_incomplete_gp", "name": "Incomplete Notice" },
    { "id": "mf3", "from": "throw_rejection",  "to": "catch_rejection_gp",  "name": "Rejection Notice" },
    { "id": "mf4", "from": "throw_approval",   "to": "catch_approval_gp",   "name": "Treatment Approval" }
  ],
  "data": [],
  "data_associations": []
}