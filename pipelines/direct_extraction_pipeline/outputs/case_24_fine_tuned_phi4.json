{
  "pools": [
    {
      "id": "applicant_pool",
      "name": "Applicant Organisation"
    },
    {
      "id": "grants_office",
      "name": "Government Grants Office"
    }
  ],
  "lanes": [
    {
      "id": "applicant",
      "name": "Applicant",
      "pool": "applicant_pool"
    },
    {
      "id": "grants_administrator",
      "name": "Grants Administrator",
      "pool": "grants_office"
    },
    {
      "id": "technical_reviewer",
      "name": "Technical Reviewer",
      "pool": "grants_office"
    },
    {
      "id": "finance_officer",
      "name": "Finance Officer",
      "pool": "grants_office"
    }
  ],
  "tasks": [
    {
      "id": "submit_application",
      "name": "Submit Grant Application",
      "type": "task",
      "lane": "applicant"
    },
    {
      "id": "register_application",
      "name": "Register Application",
      "type": "task",
      "lane": "grants_administrator"
    },
    {
      "id": "check_documents",
      "name": "Check Documentation Completeness",
      "type": "task",
      "lane": "grants_administrator"
    },
    {
      "id": "notify_applicant",
      "name": "Notify Applicant of Missing Documents",
      "type": "task",
      "lane": "grants_administrator"
    },
    {
      "id": "collect_documents",
      "name": "Collect Missing Documents",
      "type": "task",
      "lane": "applicant"
    },
    {
      "id": "review_feasibility",
      "name": "Assess Project Feasibility",
      "type": "task",
      "lane": "technical_reviewer"
    },
    {
      "id": "review_budget",
      "name": "Review Budget Adequacy",
      "type": "task",
      "lane": "finance_officer"
    },
    {
      "id": "review_outcomes",
      "name": "Review Combined Verdicts",
      "type": "task",
      "lane": "grants_administrator},{"
    }
  ],
  "events": [
    {
      "id": "start_applicant",
      "name": "Start",
      "type": "startEvent",
      "lane": "applicant",
      "eventDefinition": "none"
    },
    {
      "id": "end_applicant",
      "name": "End",
      "type": "endEvent",
      "lane": "applicant",
      "eventDefinition": "none"
    },
    {
      "id": "start_grants_office",
      "name": "Application Received",
      "type": "startEvent",
      "lane": "grants_administrator",
      "eventDefinition": "message"
    },
    {
      "id": "end_grants_office",
      "name": "Grant Approved/Rejected",
      "type": "endEvent",
      "lane": "grants_administrator",
      "eventDefinition": "none"
    }
  ],
  "gateways": [
    {
      "id": "split_documents",
      "name": "Documents Complete?",
      "type": "exclusiveGateway",
      "lane": "grants_administrator",
      "gatewayDirection": "diverging"
    },
    {
      "id": "join_documents",
      "name": "Documents Review Complete",
      "type": "exclusiveGateway",
      "lane": "grants_administrator",
      "gatewayDirection": "converging"
    },
    {
      "id": "split_review",
      "name": "Forward for Review",
      "type": "parallelGateway",
      "lane": "grants_administrator",
      "gatewayDirection": "diverging"
    },
    {
      "id": "join_review",
      "name": "Both Reviews Complete",
      "type": "parallelGateway",
      "lane": "grants_administrator",
      "gatewayDirection": "converging"
    },
    {
      "id": "split_outcome",
      "name": "Verdicts?",
      "type": "exclusiveGateway",
      "lane": "grants_administrator",
      "gatewayDirection": "diverging"
    },
    {
      "id": "join_outcome",
      "name": "Outcome Review Complete",
      "type": "exclusiveGateway",
      "lane": "grants_administrator",
      "gatewayDirection": "converging"
    }
  ],
  "sequence_flows": [
    {
      "id": "sf1",
      "from": "start_applicant",
      "to": "submit_application"
    },
    {
      "id": "sf2",
      "from": "submit_application",
      "to": "end_applicant"
    },
    {
      "id": "sf3",
      "from": "start_grants_office",
      "to": "register_application"
    },
    {
      "id": "sf4",
      "from": "register_application",
      "to": "check_documents"
    },
    {
      "id": "sf5",
      "from": "check_documents",
      "to": "split_documents"
    },
    {
      "id": "sf6",
      "from": "split_documents",
      "to": "notify_applicant",
      "condition": "Incomplete"
    },
    {
      "id": "sf7",
      "from": "split_documents",
      "to": "collect_documents",
      "condition": "Complete"
    },
    {
      "id": "sf8",
      "from": "notify_applicant",
      "to": "join_documents"
    },
    {
      "id": "sf9",
      "from": "collect_documents",
      "to": "join_documents"
    },
    {
      "id": "sf10",
      "from": "join_documents",
      "to": "review_feasibility"
    },
    {
      "id": "sf11",
      "from": "review_feasibility",
      "to": "join_review"
    },
    {
      "id": "sf12",
      "from": "join_review",
      "to": "review_budget"
    },
    {
      "id": "sf13",
      "from": "review_budget",
      "to": "join_outcome"
    },
    {
      "id": "sf14",
      "from": "join_outcome",
      "to": "review_outcomes"
    },
    {
      "id": "sf15",
      "from": "review_outcomes",
      "to": "split_outcome"
    },
    {
      "id": "sf16",
      "from": "split_outcome",
      "to": "join_outcome",
      "condition": "Both positive"
    },
    {
      "id": "sf17",
      "from": "split_outcome",
      "to": "end_grants_office",
      "condition": "One or more negative"
    },
    {
      "id": "sf18",
      "from": "join_outcome",
      "to": "end_grants_office",
      "condition": "Both positive"
    },
    {
      "id": "mf1",
      "from": "submit_application",
      "to": "start_grants_office",
      "condition": "Grant Application"
    },
    {
      "id": "mf2",
      "from": "notify_applicant",
      "to": "start_grants_office",
      "condition": "Missing Document Notice"
    },
    {
      "id": "mf3",
      "from": "collect_documents",
      "to": "start_grants_office",
      "condition": "Resubmitted Documents"
    },
    {
      "id": "mf4",
      "from": "join_review",
      "to": "review_outcomes",
      "condition": "Reviewed"
    },
    {
      "id": "mf5",
      "from": "review_outcome",
      "to": "join_outcome",
      "condition": "Outcome"
    },
    {
      "id": "mf6",
      "from": "join_outcome",
      "to": "end_grants_office",
      "condition": "Outcome"
    },
    {
      "id": "mf7",
      "from": "end_grants_office",
      "to": "end_applicant",
      "condition": "Grant Approval/Rejection"
    }
  ],
  "message_flows": []
}