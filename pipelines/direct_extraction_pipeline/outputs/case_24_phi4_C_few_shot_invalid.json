      "to": "split_documentation"
    },
    {
      "id": "sf5",
      "from": "split_documentation",
      "to": "notify_missing_documents",
      "condition": "Incomplete"
    },
    {
      "id": "sf6",
      "from": "notify_missing_documents",
      "to": "end_incomplete"
    },
    {
      "id": "sf7",
      "from": "split_documentation",
      "to": "split_parallel",
      "condition": "Complete"
    },
    {
      "id": "sf8",
      "from": "split_parallel",
      "to": "assess_project_feasibility"
    },
    {
      "id": "sf9",
      "from": "split_parallel",
      "to": "review_proposed_budget"
    },
    {
      "id": "sf10",
      "from": "assess_project_feasibility",
      "to": "record_technical_verdict"
    },
    {
      "id": "sf11",
      "from": "record_technical_verdict",
      "to": "join_parallel"
    },
    {
      "id": "sf12",
      "from": "review_proposed_budget",
      "to": "record_finance_verdict"
    },
    {
      "id": "sf13",
      "from": "record_finance_verdict",
      "to": "join_parallel"
    },
    {
      "id": "sf14",
      "from": "join_parallel",
      "to": "review_outcomes"
    },
    {
      "id": "sf15",
      "from": "review_outcomes",
      "to": "split_outcome"
    },
    {
      "id": "sf16",
      "from": "split_outcome",
      "to": "issue_rejection_notice",
      "condition": "One or more verdicts negative"
    },
    {
      "id": "sf17",
      "from": "split_outcome",
      "to": "issue_approval_letter",
      "condition": "Both verdicts positive"
    },
    {
      "id": "sf18",
      "from": "issue_rejection_notice",
      "to": "end_rejected"
    },
    {
      "id": "sf19",
      "from": "issue_approval_letter",
      "to": "end_approved"
    },
    {
      "id": "sf20",
      "from": "end_incomplete",
      "to": "collect_missing_documents"
    },
    {
      "id": "sf21",
      "from": "collect_missing_documents",
      "to": "resubmit_documents"
    },
    {
      "id": "sf22",
      "from": "resubmit_documents",
      "to": "check_documentation_again"
