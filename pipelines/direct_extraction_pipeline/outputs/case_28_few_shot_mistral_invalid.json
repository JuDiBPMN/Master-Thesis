{
  "pools": [
    {
      "id": "insurance_company",
      "name": "Insurance Company"
    }
  ],
  "lanes": [
    {
      "id": "claims_intake",
      "name": "Claims Intake",
      "pool": "insurance_company"
    },
    {
      "id": "claims_handler",
      "name": "Claims Handler",
      "pool": "insurance_company"
    },
    {
      "id": "fraud_detection",
      "name": "Fraud Detection",
      "pool": "insurance_company"
    },
    {
      "id": "assessment_team",
      "name": "Assessment Team",
      "pool": "insurance_company"
    },
    {
      "id": "finance",
      "name": "Finance",
      "pool": "insurance_company"
    }
  ],
  "tasks": [
    {
      "id": "register_claim",
      "name": "Register Claim",
      "type": "task",
      "lane": "claims_intake"
    },
    {
      "id": "assign_claims_handler",
      "name": "Assign Claims Handler",
      "type": "task",
      "lane": "claims_intake"
    },
    {
      "id": "run_fraud_check",
      "name": "Run Fraud Check",
      "type": "task",
      "lane": "fraud_detection"
    },
    {
      "id": "review_documents",
      "name": "Review Documents",
      "type": "task",
      "lane": "assessment_team"
    },
    {
      "id": "request_additional_documents",
      "name": "Request Additional Documents",
      "type": "task",
      "lane": "claims_handler"
    },
    {
      "id": "re_review_documents",
      "name": "Re-review Documents",
      "type": "task",
      "lane": "assessment_team"
    },
    {
      "id": "evaluate_results",
      "name": "Evaluate Results",
      "type": "task",
      "lane": "claims_handler"
    },
    {
      "id": "process_payment",
      "name": "Process Payment",
      "type": "task",
      "lane": "finance"
    }
  ],
  "events": [
    {
      "id": "start_claim",
      "name": "New Claim Received",
      "type": "startEvent",
      "lane": "claims_intake",
      "eventDefinition": "none"
    },
    {
      "id": "end_claim_rejected",
      "name": "Claim Rejected",
      "type": "endEvent",
      "lane": "claims_handler",
      "eventDefinition": "none"
    },
    {
      "id": "end_claim_approved",
      "name": "Claim Approved",
      "type": "endEvent",
      "lane": "claims_handler",
      "eventDefinition": "none"
    }
  ],
  "gateways": [
    {
      "id": "split_parallel_checks",
      "name": "Parallel Checks",
      "type": "parallelGateway",
      "lane": "claims_handler",
      "gatewayDirection": "diverging"
    },
    {
      "id": "join_parallel_checks",
      "name": "Both Checks Complete",
      "type": "parallelGateway",
      "lane": "claims_handler",
      "gatewayDirection": "converging"
    },
    {
      "id": "split_approval",
      "name": "Claim Approval?",
      "type": "exclusiveGateway",
      "lane": "claims_handler",
      "gatewayDirection": "diverging"
    },
    {
      "id": "join_approval",
      "name": "Approval Join",
      "type": "exclusiveGateway",
      "lane": "claims_handler",
      "gatewayDirection": "converging"
    }
  ],
  "sequence_flows": [
    {
      "id": "sf1",
      "from": "start_claim",
      "to": "assign_claims_handler"
    },
    {
      "id": "sf2",
      "from": "assign_claims_handler",
      "to": "split_parallel_checks"
    },
    {
      "id": "sf3",
      "from": "split_parallel_checks",
      "to": "run_fraud_check"
    },
    {
      "id": "sf4",
      "from": "split_parallel_checks",
      "to": "review_documents"
    },
    {
      "id": "sf5",
      "from": "run_fraud_check",
      "to": "join_parallel_checks"
    },
    {
      "id": "sf6",
      "from": "review_documents",
      "to": "join_parallel_checks"
    },
    {
      "id": "sf7",
      "from": "join_parallel_checks",
      "to": "evaluate_results"
    },
    {
      "id": "sf8",
      "from": "evaluate_results",
      "to": "split_approval"
    },
    {
      "id": "sf9",
      "from": "split_approval",
      "to": "process_payment",
      "condition": "Approved"
    },
    {
      "id": "sf10",
      "from": "split_approval",
      "to": "request_additional_documents",
      "condition": "Insufficient Documentation"
    },
    {
      "id": "sf11",
      "from": "request_additional_documents",
      "to": "re_review_documents"
    },
    {
      "id": "sf12",
      "from": "re_review_documents",
      "to": "join_approval"
    }
  ],
  "message_flows": [],
  "data": [
    {
      "id": "claim_data",
      "name": "Claim Data"
    }
  ],
  "data_associations": [
    {
      "from": "register_claim",
      "to": "claim_data",
      "type": "output"
    },
    {
      "from": "request_additional_documents",
      "to": "claim_data",
      "type": "input"
    }
  ]
}