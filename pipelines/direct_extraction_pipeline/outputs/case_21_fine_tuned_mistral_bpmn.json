{
  "participants": [
    {
      "id": "GP",
      "name": "General Practitioner",
      "type": "pool"
    },
    {
      "id": "admissions_office",
      "name": "Admissions Office",
      "type": "pool"
    },
    {
      "id": "specialist_department",
      "name": "Specialist Department",
      "type": "pool"
    },
    {
      "id": "insurance_office",
      "name": "Insurance Office",
      "type": "pool"
    }
  ],
  "tasks": [
    {
      "id": "submit_referral",
      "name": "Submit Referral Request",
      "type": "task",
      "participant": "GP"
    },
    {
      "id": "register_referral",
      "name": "Register Referral",
      "type": "task",
      "participant": "admissions_office"
    },
    {
      "id": "check_documentation",
      "name": "Check Documentation Completeness",
      "type": "task",
      "participant": "admissions_office"
    },
    {
      "id": "notify_gp",
      "name": "Notify GP of Missing Documents",
      "type": "task",
      "participant": "admissions_office"
    },
    {
      "id": "record_verdict",
      "name": "Record Medical Assessment Verdict",
      "type": "task",
      "participant": "specialist_department"
    },
    {
      "id": "verify_coverage",
      "name": "Verify Patient Coverage",
      "type": "task",
      "participant": "insurance_office"
    },
    {
      "id": "review_verdicts",
      "name": "Review Combined Verdicts",
      "type": "task",
      "participant": "admissions_office"
    },
    {
      "id": "send_rejection",
      "name": "Send Rejection Notice to GP",
      "type": "task",
      "participant": "admissions_office"
    },
    {
      "id": "send_approval",
      "name": "Send Treatment Approval to GP",
      "type": "task",
      "participant": "admissions_office"
    }
  ],
  "events": [
    {
      "id": "start_gp",
      "name": "Start",
      "type": "startEvent",
      "participant": "GP",
      "eventDefinition": "none"
    },
    {
      "id": "end_gp_rejected",
      "name": "Referral Rejected",
      "type": "endEvent",
      "participant": "GP",
      "eventDefinition": "none"
    },
    {
      "id": "end_gp_approved",
      "name": "Treatment Approved",
      "type": "endEvent",
      "participant": "GP",
      "eventDefinition": "none"
    },
    {
      "id": "start_admissions",
      "name": "Referral Received",
      "type": "startEvent",
      "participant": "admissions_office",
      "eventDefinition": "message"
    },
    {
      "id": "end_admissions_rejected",
      "name": "Referral Rejected",
      "type": "endEvent",
      "participant": "admissions_office",
      "eventDefinition": "none"
    },
    {
      "id": "end_admissions_approved",
      "name": "Treatment Approved",
      "type": "endEvent",
      "participant": "admissions_office",
      "eventDefinition": "none"
    }
  ],
  "gateways": [
    {
      "id": "split_documentation",
      "name": "Documentation Complete?",
      "type": "exclusiveGateway",
      "participant": "admissions_office",
      "gatewayDirection": "diverging"
    },
    {
      "id": "split_parallel",
      "name": "Forward Referral for Assessment and Verification",
      "type": "parallelGateway",
      "participant": "admissions_office",
      "gatewayDirection": "diverging"
    },
    {
      "id": "join_parallel",
      "name": "Both Verdicts Recorded",
      "type": "parallelGateway",
      "participant": "admissions_office",
      "gatewayDirection": "converging"
    },
    {
      "id": "split_outcome",
      "name": "Both Verdicts Positive?",
      "type": "exclusiveGateway",
      "participant": "admissions_office",
      "gatewayDirection": "diverging"
    }
  ],
  "sequence_flows": [
    {
      "from": "start_gp",
      "to": "submit_referral"
    },
    {
      "from": "submit_referral",
      "to": "end_gp_approved"
    },
    {
      "from": "start_admissions",
      "to": "register_referral"
    },
    {
      "from": "register_referral",
      "to": "check_documentation"
    },
    {
      "from": "check_documentation",
      "to": "split_documentation"
    },
    {
      "from": "split_documentation",
      "to": "notify_gp",
      "condition": "Incomplete documentation"
    },
    {
      "from": "split_documentation",
      "to": "split_parallel",
      "condition": "Documentation complete"
    },
    {
      "from": "notify_gp",
      "to": "split_documentation"
    },
    {
      "from": "split_parallel",
      "to": "record_verdict",
      "condition": "Specialist Department"
    },
    {
      "from": "split_parallel",
      "to": "verify_coverage",
      "condition": "Insurance Office"
    },
    {
      "from": "record_verdict",
      "to": "join_parallel"
    },
    {
      "from": "verify_coverage",
      "to": "join_parallel"
    },
    {
      "from": "join_parallel",
      "to": "review_verdicts"
    },
    {
      "from": "review_verdicts",
      "to": "split_outcome"
    },
    {
      "from": "split_outcome",
      "to": "send_rejection",
      "condition": "At least one verdict negative"
    },
    {
      "from": "split_outcome",
      "to": "send_approval",
      "condition": "Both verdicts positive"
    },
    {
      "from": "send_rejection",
      "to": "end_admissions_rejected"
    },
    {
      "from": "send_approval",
      "to": "end_admissions_approved"
    },
    {
      "from": "end_admissions_rejected",
      "to": "end_gp_rejected"
    },
    {
      "from": "end_admissions_approved",
      "to": "end_gp_approved"
    }
  ],
  "message_flows": [
    {
      "from": "start_gp",
      "to": "start_admissions",
      "name": "Referral Request"
    },
    {
      "from": "send_rejection",
      "to": "end_gp_rejected",
      "name": "Rejection Notice"
    },
    {
      "from": "send_approval",
      "to": "end_gp_approved",
      "name": "Treatment Approval"
    }
  ],
  "data": []
}