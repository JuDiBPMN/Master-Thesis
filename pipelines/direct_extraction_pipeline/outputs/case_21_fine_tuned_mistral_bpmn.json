  "gateways": [
    {
      "id": "split_documentation",
      "name": "Documentation Complete?",
      "type": "exclusiveGateway",
      "participant": "admissions_office",
      "gatewayDirection": "diverging"
    },
    {
      "id": "split_parallel",
      "name": "Forward for Assessment and Verification",
      "type": "parallelGateway",
      "participant": "admissions_office",
      "gatewayDirection": "diverging"
    },
    {
      "id": "join_parallel",
      "name": "Both Verdicts Recorded",
      "type": "parallelGateway",
      "participant": "admissions_office",
      "gatewayDirection": "converging"
    },
    {
      "id": "split_outcome",
      "name": "Outcome?",
      "type": "exclusiveGateway",
      "participant": "admissions_office",
      "gatewayDirection": "diverging"
    }
  ],
  "sequence_flows": [
    {
      "from": "start_GP",
      "to": "submit_referral"
    },
    {
      "from": "start_admissions",
      "to": "register_referral"
    },
    {
      "from": "register_referral",
      "to": "check_documentation"
    },
    {
      "from": "check_documentation",
      "to": "split_documentation"
    },
    {
      "from": "split_documentation",
      "to": "notify_incomplete",
      "condition": "Incomplete"
    },
    {
      "from": "split_documentation",
      "to": "join_parallel",
      "condition": "Complete"
    },
    {
      "from": "notify_incomplete",
      "to": "split_documentation"
    },
    {
      "from": "join_parallel",
      "to": "split_parallel"
    },
    {
      "from": "split_parallel",
      "to": "assess_referral"
    },
    {
      "from": "split_parallel",
      "to": "verify_coverage"
    },
    {
      "from": "assess_referral",
      "to": "record_verdict"
    },
    {
      "from": "record_verdict",
      "to": "join_parallel"
    },
    {
      "from": "verify_coverage",
      "to": "record_coverage_verdict"
    },
    {
      "from": "record_coverage_verdict",
      "to": "join_parallel"
    },
    {
      "from": "join_parallel",
      "to": "review_outcomes"
    },
    {
      "from": "review_outcomes",
      "to": "split_outcome"
    },
    {
      "from": "split_outcome",
      "to": "send_rejection",
      "condition": "Negative"
    },
    {
      "from": "split_outcome",
      "to": "send_approval",
      "condition": "Positive"
    },
    {
      "from": "start_specialist",
      "to": "assess_referral"
    },
    {
      "from": "start_insurance",
      "to": "verify_coverage"
    },
    {
      "from": "send_rejection",
      "to": "end_admissions_rejected"
    },
    {
      "from": "send_approval",
      "to": "end_admissions_approved"
    }
  ],
  "message_flows": [
    {
      "from": "submit_referral",
      "to": "start_admissions",
      "name": "Referral Request"
    },
    {
      "from": "notify_incomplete",
      "to": "submit_referral",
      "name": "Incomplete Documentation Notice"
    },
    {
      "from": "join_parallel",
      "to": "specialist_department",
      "name": "Referral for Assessment"
    },
    {
      "from": "join_parallel",
      "to": "insurance_office",
      "name": "Referral for Coverage Verification"
    },
    {
      "from": "record_verdict",
      "to": "admissions_office",
      "name": "Specialist Verdict"
    },
    {
      "from": "record_coverage_verdict",
      "to": "admissions_office",
      "name": "Coverage Verdict"
    }
  ],
  "data": []
}