  "tasks": [
    {
      "id": "Order_Placement",
      "name": "Customer places an order on the website",
      "type": "task",
      "participant": "Customer",
      "lane": "Primary"
    },
    {
      "id": "Stock_Availability_Check",
      "name": "Logistics department checks stock availability",
      "type": "task",
      "participant": "Logistics_Department",
      "lane": "Primary"
    },
    {
      "id": "Stock_Check_Failed",
      "name": "Stock not available, order is rejected",
      "type": "task",
      "participant": "Logistics_Department",
      "lane": "Primary"
    },
    {
      "id": "Order_Rejection",
      "name": "Order is rejected and customer is reimbursed",
      "type": "task",
      "participant": "Sales_Department",
      "lane": "Primary"
    },
    {
      "id": "Stock_Check_Succeeded",
      "name": "Stock is available, order is confirmed",
      "type": "task",
      "participant": "Logistics_Department",
      "lane": "Primary"
    },
    {
      "id": "Order_Confirmation",
      "name": "Order is confirmed and invoice is generated",
      "type": "task",
      "participant": "Sales_Department",
      "lane": "Primary"
    },
    {
      "id": "Invoice_Generation",
      "name": "Invoice is generated and sent to customer",
      "type": "task",
      "participant": "Sales_Department",
      "lane": "Primary"
    },
    {
      "id": "Goods_Preparation",
      "name": "Goods are prepared for shipping",
      "type": "task",
      "participant": "Logistics_Department",
      "lane": "Primary"
    },
    {
      "id": "Shipment_Preparation",
      "name": "Shipment is prepared",
      "type": "task",
      "participant": "Logistics_Department",
      "lane": "Primary"
    },
    {
      "id": "Goods_Shipped",
      "name": "Goods are shipped to customer",
      "type": "task",
      "participant": "Logistics_Department",
      "lane": "Primary"
    }
  ],
  "events": [
    {
      "id": "Start",
      "name": "Start Event",
      "type": "startEvent",
      "participant": "N/A",
      "eventDefinition": "none"
    },
    {
      "id": "End",
      "name": "End Event",
      "type": "endEvent",
      "participant": "N/A",
      "eventDefinition": "none"
    }
  ],
  "gateways": [],
  "sequence_flows": [
    {
      "from": "Order_Placement",
      "to": "Stock_Availability_Check"
    },
    {
      "from": "Stock_Availability_Check",
      "to": "Stock_Check_Failed",
      "condition": "condition_Stock_Check_Failed"
    },
    {
      "from": "Stock_Check_Failed",
      "to": "Order_Rejection"
    },
    {
      "from": "Stock_Availability_Check",
      "to": "Stock_Check_Succeeded"
    },
    {
      "from": "Stock_Check_Succeeded",
      "to": "Order_Confirmation"
    },
    {
      "from": "Order_Confirmation",
      "to": "Invoice_Generation"
    },
    {
      "from": "Invoice_Generation",
      "to": "Goods_Preparation"
    },
    {
      "from": "Goods_Preparation",
      "to": "Shipment_Preparation"
    },
    {
      "from": "Shipment_Preparation",
      "to": "Goods_Shipped"
    },
    {
      "from": "Goods_Shipped",
      "to": "Invoice_Sent"
    },
    {
      "from": "Order_Placement",
      "to": "End"
    },
    {
      "from": "Stock_Check_Failed",
      "to": "End"
    },
    {
      "from": "Stock_Check_Succeeded",
      "to": "End"
    }
  ]
