    },
    {
      "id": "flow_2",
      "from": "introduction_interview",
      "to": "discuss_with_business_manager"
    },
    {
      "id": "flow_3",
      "from": "discuss_with_business_manager",
      "to": "throw_event_discuss"
    },
    {
      "id": "flow_4",
      "from": "throw_event_discuss",
      "to": "catch_event_discuss"
    },
    {
      "id": "flow_5",
