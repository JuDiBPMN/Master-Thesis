      "to": "second_assessment"
    },
    {
      "id": "flow_6",
      "from": "second_assessment",
      "to": "decision_gateway"
    },
    {
      "id": "flow_7",
      "from": "decision_gateway",
      "to": "prepare_contract",
      "condition": "successful"
    },
    {
      "id": "flow_8",
      "from": "decision_gateway",
      "to": "close_application",
      "condition": "not successful"
    },
    {
      "id": "flow_9",
      "from": "discuss_with_business_manager",
      "to": "throw_event_inform"
    },
    {
      "id": "flow_10",
      "from": "throw_event_inform",
      "to": "catch_event_inform"
    },
    {
      "id": "flow_11",
      "from": "catch_event_inform",
      "to": "second_assessment"
    },
    {
      "id": "flow_12",
      "from": "prepare_contract",
      "to": "end_event_success"
    },
    {
      "id": "flow_13",
      "from": "close_application",
      "to": "end_event_failure"
    }
  ],
  "message_flows": [
    {
      "id": "message_flow_discuss",
      "from": "throw_event_discuss",
      "to": "catch_event_discuss",
      "name": "Discuss with Business Manager"
    },
    {
      "id": "message_flow_inform",
      "from": "throw_event_inform",
      "to": "catch_event_inform",
      "name": "Inform Candidate"
    }
  ]
