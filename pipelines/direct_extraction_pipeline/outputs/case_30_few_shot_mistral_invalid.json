    },
    {
      "id": "sf13",
      "from": "conduct_structural_review",
      "to": "record_structural_verdict"
    },
    {
      "id": "sf14",
      "from": "record_structural_verdict",
      "to": "join_parallel"
    },
    {
      "id": "sf15",
      "from": "join_parallel",
      "to": "review_combined_outcomes"
    },
    {
      "id": "sf16",
      "from": "review_combined_outcomes",
