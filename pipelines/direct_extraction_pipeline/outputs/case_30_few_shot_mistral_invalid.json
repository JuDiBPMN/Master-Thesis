    {
      "id": "sf10",
      "from": "gateway_zoning_compliance",
      "to": "record_zoning_verdict",
      "condition": "Compliant"
    },
    {
      "id": "sf11",
      "from": "gateway_zoning_compliance",
      "to": "issue_rejection_notice",
      "condition": "Non-Compliant"
    },
    {
      "id": "sf12",
      "from": "gateway_structural_safety",
