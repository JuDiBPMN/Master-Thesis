      "type": "parallelGateway",
      "lane": "permits_officer",
      "gatewayDirection": "diverging"
    },
    {
      "id": "join_parallel",
      "name": "Join Application Forwarding",
      "type": "parallelGateway",
      "lane": "permits_officer",
      "gatewayDirection": "converging"
    },
    {
      "id": "gateway_zoning_compliance",
      "name": "Zoning Compliance Verdict?",
      "type": "exclusiveGateway",
      "lane": "permits_officer",
      "gatewayDirection": "diverging"
    },
    {
      "id": "gateway_structural_safety",
      "name": "Structural Safety Verdict?",
      "type": "exclusiveGateway",
      "lane": "permits_officer",
      "gatewayDirection": "diverging"
    }
