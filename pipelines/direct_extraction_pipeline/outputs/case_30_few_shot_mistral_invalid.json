      "to": "split_complete"
    },
    {
      "id": "sf5",
      "from": "split_complete",
      "to": "notify_missing_info",
      "condition": "Incomplete"
    },
    {
      "id": "sf6",
      "from": "split_complete",
      "to": "split_parallel"
    },
    {
      "id": "sf7",
      "from": "split_parallel",
      "to": "forward_application"
    },
    {
      "id": "sf8",
      "from": "forward_application",
      "to": "assess_zoning_compliance"
    },
    {
      "id": "sf9",
