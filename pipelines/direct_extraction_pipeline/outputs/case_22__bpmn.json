{
    "pools": [
      { "id": "student_pool",      "name": "Student" },
      { "id": "university_pool",   "name": "University Administration" }
    ],
    "lanes": [
      { "id": "student",           "name": "Student",             "pool": "student_pool" },
      { "id": "admin_office",      "name": "Administration Office","pool": "university_pool" },
      { "id": "exam_board",        "name": "Examination Board",   "pool": "university_pool" }
    ],
    "tasks": [
      { "id": "submit_thesis",         "name": "Submit Thesis",                    "type": "task", "lane": "student" },
      { "id": "check_completeness",    "name": "Check Submission Completeness",    "type": "task", "lane": "admin_office" },
      { "id": "notify_incomplete",     "name": "Notify Student of Missing Documents","type": "task","lane": "admin_office" },
      { "id": "forward_thesis",        "name": "Forward Thesis to Examination Board","type": "task","lane": "admin_office" },
      { "id": "evaluate_thesis",       "name": "Evaluate Thesis",                  "type": "task", "lane": "exam_board" },
      { "id": "issue_grade",           "name": "Issue Grade",                      "type": "task", "lane": "exam_board" },
      { "id": "notify_pass",           "name": "Notify Student of Pass",           "type": "task", "lane": "exam_board" },
      { "id": "send_rejection",        "name": "Send Rejection Notice to Student", "type": "task", "lane": "exam_board" }
    ],
    "events": [
      { "id": "start_student",         "name": "Start",                   "type": "startEvent", "lane": "student",      "eventDefinition": "none" },
      { "id": "end_student_incomplete","name": "Submission Rejected",     "type": "endEvent",   "lane": "student",      "eventDefinition": "none" },
      { "id": "end_student_pass",      "name": "Thesis Passed",           "type": "endEvent",   "lane": "student",      "eventDefinition": "none" },
      { "id": "end_student_fail",      "name": "Thesis Failed",           "type": "endEvent",   "lane": "student",      "eventDefinition": "none" },
      { "id": "start_admin",           "name": "Thesis Received",         "type": "startEvent", "lane": "admin_office", "eventDefinition": "message" },
      { "id": "end_admin",             "name": "Thesis Forwarded",        "type": "endEvent",   "lane": "admin_office", "eventDefinition": "none" },
      { "id": "start_exam",            "name": "Thesis Received",         "type": "startEvent", "lane": "exam_board",   "eventDefinition": "message" },
      { "id": "end_exam_pass",         "name": "Grade Issued",            "type": "endEvent",   "lane": "exam_board",   "eventDefinition": "none" },
      { "id": "end_exam_fail",         "name": "Rejection Sent",          "type": "endEvent",   "lane": "exam_board",   "eventDefinition": "none" }
    ],
    "gateways": [
      { "id": "split_complete",    "name": "Submission Complete?",  "type": "exclusiveGateway", "lane": "admin_office", "gatewayDirection": "diverging" },
      { "id": "split_outcome",     "name": "Thesis Outcome?",       "type": "exclusiveGateway", "lane": "exam_board",   "gatewayDirection": "diverging" }
    ],
    "sequence_flows": [
      { "id": "sf1",  "from": "start_student",       "to": "submit_thesis" },
      { "id": "sf2",  "from": "start_admin",          "to": "check_completeness" },
      { "id": "sf3",  "from": "check_completeness",   "to": "split_complete" },
      { "id": "sf4",  "from": "split_complete",       "to": "notify_incomplete",  "condition": "Incomplete" },
      { "id": "sf5",  "from": "split_complete",       "to": "forward_thesis",     "condition": "Complete" },
      { "id": "sf6",  "from": "notify_incomplete",    "to": "end_admin" },
      { "id": "sf7",  "from": "forward_thesis",       "to": "end_admin" },
      { "id": "sf8",  "from": "start_exam",           "to": "evaluate_thesis" },
      { "id": "sf9",  "from": "evaluate_thesis",      "to": "split_outcome" },
      { "id": "sf10", "from": "split_outcome",        "to": "issue_grade",        "condition": "Pass" },
      { "id": "sf11", "from": "split_outcome",        "to": "send_rejection",     "condition": "Fail" },
      { "id": "sf12", "from": "issue_grade",          "to": "notify_pass" },
      { "id": "sf13", "from": "notify_pass",          "to": "end_exam_pass" },
      { "id": "sf14", "from": "send_rejection",       "to": "end_exam_fail" }
    ],
    "message_flows": [
      { "id": "mf1", "from": "submit_thesis",   "to": "start_admin",   "name": "Thesis Submission" },
      { "id": "mf2", "from": "forward_thesis",  "to": "start_exam",    "name": "Thesis Package" },
      { "id": "mf3", "from": "notify_incomplete","to": "end_student_incomplete", "name": "Incomplete Notice" },
      { "id": "mf4", "from": "notify_pass",     "to": "end_student_pass",       "name": "Pass Notification" },
      { "id": "mf5", "from": "send_rejection",  "to": "end_student_fail",       "name": "Rejection Notice" }
    ],
    "data": [],
    "data_associations": []
  }