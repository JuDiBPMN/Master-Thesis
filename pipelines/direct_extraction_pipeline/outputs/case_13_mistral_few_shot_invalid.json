{
  "pools": [
    {
      "id": "approval_committee",
      "name": "Approval Committee"
    }
  ],
  "lanes": [
    {
      "id": "project_manager",
      "name": "Project Manager",
      "pool": "approval_committee"
    },
    {
      "id": "finance_department",
      "name": "Finance Department",
      "pool": "approval_committee"
    },
    {
      "id": "hr_department",
      "name": "HR Department",
      "pool": "approval_committee"
    }
  ],
  "tasks": [
    {
      "id": "submit_proposal",
      "name": "Submit Project Proposal",
      "type": "task",
      "lane": "project_manager"
    },
    {
      "id": "assess_budget",
      "name": "Assess Budget Viable",
      "type": "task",
      "lane": "finance_department"
    },
    {
      "id": "evaluate_resources",
      "name": "Evaluate Resource Availability",
      "type": "task",
      "lane": "hr_department"
    },
    {
      "id": "review_proposal",
      "name": "Review Proposal",
      "type": "task",
      "lane": "approval_committee"
    },
    {
      "id": "approve_project",
      "name": "Approve Project",
      "type": "task",
      "lane": "approval_committee"
    },
    {
      "id": "request_revision",
      "name": "Request Proposal Revision",
      "type": "task",
      "lane": "approval_committee"
    }
  ],
  "events": [
    {
      "id": "start_approval",
      "name": "Project Approval Process Started",
      "type": "startEvent",
      "lane": "project_manager",
      "eventDefinition": "none"
    },
    {
      "id": "end_approval",
      "name": "Project Approval Process Ended",
      "type": "endEvent",
      "lane": "approval_committee",
      "eventDefinition": "none"
    }
  ],
  "gateways": [
    {
      "id": "gateway_finance_split",
      "name": "Budget Assessment",
      "type": "exclusiveGateway",
      "lane": "approval_committee",
      "gatewayDirection": "diverging"
    },
    {
      "id": "gateway_hr_split",
      "name": "Resource Availability Assessment",
      "type": "exclusiveGateway",
      "lane": "approval_committee",
      "gatewayDirection": "diverging"
    },
    {
      "id": "gateway_approval_split",
      "name": "Approval Decision",
      "type": "exclusiveGateway",
      "lane": "approval_committee",
      "gatewayDirection": "diverging"
    },
    {
      "id": "gateway_parallel_join",
      "name": "Parallel Processes Converge",
      "type": "parallelGateway",
      "lane": "approval_committee",
      "gatewayDirection": "converging"
    }
  ],
  "sequence_flows": [
    {
      "id": "sf1",
      "from": "start_approval",
      "to": "submit_proposal"
    },
    {
      "id": "sf2",
      "from": "submit_proposal",
      "to": "gateway_finance_split"
    },
    {
      "id": "sf3",
      "from": "gateway_finance_split",
      "to": "approve_project",
      "condition": "Positive"
    },
    {
      "id": "sf4",
      "from": "gateway_finance_split",
      "to": "request_revision",
      "condition": "Negative"
    },
    {
      "id": "sf5",
      "from": "submit_proposal",
      "to": "gateway_hr_split"
    },
    {
      "id": "sf6",
      "from": "gateway_hr_split",
      "to": "gateway_approval_split"
    },
    {
      "id": "sf7",
      "from": "gateway_approval_split",
      "to": "approve_project",
      "condition": "Both Positive"
    },
    {
      "id": "sf8",
      "from": "gateway_approval_split",
      "to": "request_revision",
      "condition": "At least One Negative"
    },
    {
      "id": "sf9",
      "from": "gateway_parallel_join",
      "to": "end_approval"
    }
  ],
  "message_flows": [],
  "data": [
    {
      "id": "project_proposal",
      "name": "Project Proposal Document"
    }
  ],
  "data_associations": [
    {
      "from": "submit_proposal",
      "to": "project_proposal",
      "type": "output"
    }
  ]
}