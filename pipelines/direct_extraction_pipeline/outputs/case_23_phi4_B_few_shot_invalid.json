    }
  ],
  "sequence_flows": [
    {
      "id": "Flow_1",
      "from": "start_client",
      "to": "write_complaint_email"
    },
    {
      "id": "Flow_2",
      "from": "write_complaint_email",
      "to": "send_complaint"
    },
    {
      "id": "Flow_3",
      "from": "receive_complaint",
      "to": "lookup_billing_info"
    },
    {
      "id": "Flow_4",
      "from": "lookup_billing_info",
      "to": "review_invoice"
    },
    {
      "id": "Flow_5",
      "from": "review_invoice",
      "to": "split_mistake_found"
    },
    {
      "id": "Flow_6",
      "from": "split_mistake_found",
      "to": "write_explanation_email",
      "condition": "No mistake"
    },
    {
      "id": "Flow_7",
      "from": "write_explanation_email",
      "to": "send_explanation"
    },
    {
      "id": "Flow_8",
