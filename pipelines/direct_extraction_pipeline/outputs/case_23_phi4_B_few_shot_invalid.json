    },
    {
      "id": "Flow_14",
      "from": "generate_new_invoice",
      "to": "send_new_invoice"
    },
    {
      "id": "Flow_15",
      "from": "send_new_invoice",
      "to": "receive_new_invoice"
    },
    {
      "id": "Flow_16",
      "from": "receive_new_invoice",
      "to": "end_client_mistake_corrected"
    }
