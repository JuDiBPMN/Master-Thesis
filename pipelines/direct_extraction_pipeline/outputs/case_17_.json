{
    "pools": [
      { "id": "gp_pool",        "name": "General Practitioner" },
      { "id": "hospital_pool",  "name": "Hospital" },
      { "id": "specialist_pool","name": "Specialist" }
    ],
    "lanes": [
      { "id": "gp",               "name": "General Practitioner", "pool": "gp_pool" },
      { "id": "intake_coord",     "name": "Intake Coordinator",   "pool": "hospital_pool" },
      { "id": "specialist",       "name": "Specialist",           "pool": "specialist_pool" }
    ],
    "tasks": [
      { "id": "examine_patient",      "name": "Examine Patient",                    "type": "task", "lane": "gp" },
      { "id": "prescribe_treatment",  "name": "Prescribe Treatment Directly",       "type": "task", "lane": "gp" },
      { "id": "send_referral",        "name": "Send Referral Request",              "type": "task", "lane": "gp" },
      { "id": "review_referral",      "name": "Review Referral and Check Availability","type": "task", "lane": "intake_coord" },
      { "id": "notify_no_slot",       "name": "Notify GP of No Availability",       "type": "task", "lane": "intake_coord" },
      { "id": "book_appointment",     "name": "Book Appointment",                   "type": "task", "lane": "intake_coord" },
      { "id": "notify_gp_booked",     "name": "Notify GP of Appointment",           "type": "task", "lane": "intake_coord" },
      { "id": "examine_specialist",   "name": "Examine Patient",                    "type": "task", "lane": "specialist" },
      { "id": "record_diagnosis",     "name": "Record Diagnosis",                   "type": "task", "lane": "specialist" },
      { "id": "schedule_treatment",   "name": "Schedule Treatment Plan",            "type": "task", "lane": "specialist" },
      { "id": "discharge_patient",    "name": "Discharge Patient",                  "type": "task", "lane": "specialist" },
      { "id": "notify_gp_discharge",  "name": "Notify GP of Discharge",             "type": "task", "lane": "specialist" }
    ],
    "events": [
      { "id": "start_gp",            "name": "Start",                    "type": "startEvent", "lane": "gp",           "eventDefinition": "none" },
      { "id": "end_gp_no_referral",  "name": "Treatment Prescribed",     "type": "endEvent",   "lane": "gp",           "eventDefinition": "none" },
      { "id": "end_gp_no_slot",      "name": "No Slot Available",        "type": "endEvent",   "lane": "gp",           "eventDefinition": "none" },
      { "id": "end_gp_discharged",   "name": "Patient Discharged",       "type": "endEvent",   "lane": "gp",           "eventDefinition": "none" },
      { "id": "start_hospital",      "name": "Referral Received",        "type": "startEvent", "lane": "intake_coord", "eventDefinition": "message" },
      { "id": "end_hospital_no_slot","name": "GP Notified",              "type": "endEvent",   "lane": "intake_coord", "eventDefinition": "none" },
      { "id": "end_hospital_booked", "name": "Appointment Booked",       "type": "endEvent",   "lane": "intake_coord", "eventDefinition": "none" },
      { "id": "start_specialist",    "name": "Referral Received",        "type": "startEvent", "lane": "specialist",   "eventDefinition": "message" },
      { "id": "end_specialist_treat","name": "Treatment Plan Scheduled", "type": "endEvent",   "lane": "specialist",   "eventDefinition": "none" },
      { "id": "end_specialist_disc", "name": "Patient Discharged",       "type": "endEvent",   "lane": "specialist",   "eventDefinition": "none" }
    ],
    "gateways": [
      { "id": "split_referral",   "name": "Referral Needed?",         "type": "exclusiveGateway", "lane": "gp",           "gatewayDirection": "diverging" },
      { "id": "split_slot",       "name": "Slot Available?",          "type": "exclusiveGateway", "lane": "intake_coord", "gatewayDirection": "diverging" },
      { "id": "split_followup",   "name": "Follow-up Treatment Required?", "type": "exclusiveGateway", "lane": "specialist", "gatewayDirection": "diverging" }
    ],
    "sequence_flows": [
      { "id": "sf1",  "from": "start_gp",           "to": "examine_patient" },
      { "id": "sf2",  "from": "examine_patient",    "to": "split_referral" },
      { "id": "sf3",  "from": "split_referral",     "to": "prescribe_treatment",  "condition": "No referral needed" },
      { "id": "sf4",  "from": "split_referral",     "to": "send_referral",        "condition": "Referral needed" },
      { "id": "sf5",  "from": "prescribe_treatment","to": "end_gp_no_referral" },
      { "id": "sf6",  "from": "start_hospital",     "to": "review_referral" },
      { "id": "sf7",  "from": "review_referral",    "to": "split_slot" },
      { "id": "sf8",  "from": "split_slot",         "to": "notify_no_slot",       "condition": "No slot available" },
      { "id": "sf9",  "from": "split_slot",         "to": "book_appointment",     "condition": "Slot available" },
      { "id": "sf10", "from": "notify_no_slot",     "to": "end_hospital_no_slot" },
      { "id": "sf11", "from": "book_appointment",   "to": "notify_gp_booked" },
      { "id": "sf12", "from": "notify_gp_booked",   "to": "end_hospital_booked" },
      { "id": "sf13", "from": "start_specialist",   "to": "examine_specialist" },
      { "id": "sf14", "from": "examine_specialist", "to": "record_diagnosis" },
      { "id": "sf15", "from": "record_diagnosis",   "to": "split_followup" },
      { "id": "sf16", "from": "split_followup",     "to": "schedule_treatment",   "condition": "Follow-up required" },
      { "id": "sf17", "from": "split_followup",     "to": "discharge_patient",    "condition": "No further treatment" },
      { "id": "sf18", "from": "schedule_treatment", "to": "end_specialist_treat" },
      { "id": "sf19", "from": "discharge_patient",  "to": "notify_gp_discharge" },
      { "id": "sf20", "from": "notify_gp_discharge","to": "end_specialist_disc" }
    ],
    "message_flows": [
      { "id": "mf1", "from": "send_referral",      "to": "start_hospital",    "name": "Referral Request" },
      { "id": "mf2", "from": "notify_no_slot",     "to": "end_gp_no_slot",    "name": "No Availability Notice" },
      { "id": "mf3", "from": "notify_gp_booked",   "to": "start_specialist",  "name": "Referral Package" },
      { "id": "mf4", "from": "notify_gp_discharge","to": "end_gp_discharged", "name": "Discharge Notice" }
    ]
  }