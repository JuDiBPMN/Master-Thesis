{
  "participants": [
    {
      "id": "Logistics",
      "name": "Logistics department",
      "type": "pool"
    },
    {
      "id": "Sales",
      "name": "Sales department",
      "type": "pool"
    },
    {
      "id": "Customer",
      "name": "Customer",
      "type": "pool"
    }
  ],
  "tasks": [
    {
      "id": "check_stock",
      "name": "Check Stock",
      "actor": "Logistics"
    },
    {
      "id": "reject_order",
      "name": "Reject Order",
      "actor": "Sales"
    },
    {
      "id": "reimburse_customer",
      "name": "Reimburse Customer",
      "actor": "Sales"
    },
    {
      "id": "confirm_order",
      "name": "Confirm Order",
      "actor": "Sales"
    },
    {
      "id": "send_invoice",
      "name": "Send Invoice",
      "actor": "Sales"
    },
    {
      "id": "ship_goods",
      "name": "Ship Goods",
      "actor": "Logistics"
    }
  ],
  "sequence_flows": [
    {
      "from": "check_stock",
      "to": "reject_order"
    },
    {
      "from": "check_stock",
      "to": "confirm_order"
    },
    {
      "from": "confirm_order",
      "to": "send_invoice"
    },
    {
      "from": "confirm_order",
      "to": "ship_goods"
    },
    {
      "from": "reject_order",
      "to": "reimburse_customer"
    }
  ],
  "events": [
    {
      "id": "order_received",
      "name": "Order Received",
      "type": "startEvent",
      "participant": "Customer",
      "eventDefinition": "none"
    },
    {
      "id": "order_processed",
      "name": "Order Processed",
      "type": "intermediateThrowEvent",
      "participant": "Sales",
      "eventDefinition": "none"
    },
    {
      "id": "order_completed",
      "name": "Order Completed",
      "type": "endEvent",
      "participant": "Customer",
      "eventDefinition": "none"
    }
  ],
  "gateways": [
    {
      "id": "gateway_stock",
      "type": "exclusiveGateway",
      "participant": "Logistics",
      "from": [
        "check_stock"
      ],
      "to": [
        "reject_order",
        "confirm_order"
      ]
    }
  ],
  "data": [
    {
      "id": "order",
      "name": "Customer order"
    },
    {
      "id": "invoice",
      "name": "Invoice"
    },
    {
      "id": "goods",
      "name": "Shipped goods"
    }
  ],
  "data_associations": [
    {
      "from": "check_stock",
      "to": "order",
      "type": "input"
    },
    {
      "from": "confirm_order",
      "to": "order",
      "type": "output"
    },
    {
      "from": "send_invoice",
      "to": "invoice",
      "type": "output"
    },
    {
      "from": "ship_goods",
      "to": "goods",
      "type": "output"
    }
  ]
}