  "sequence_flows": [
    {
      "id": "SequenceFlow_1",
      "from": "StartEvent_Client",
      "to": "Task_Write_Complaint_Email"
    },
    {
      "id": "SequenceFlow_2",
      "from": "Task_Write_Complaint_Email",
