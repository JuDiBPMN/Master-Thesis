    },
    {
      "id": "MessageFlow_2",
      "from": "IntermediateThrowEvent_Send_Explanation",
      "to": "IntermediateCatchEvent_Receive_Explanation",
      "name": "Explanation Email"
    },
    {
      "id": "MessageFlow_3",
      "from": "IntermediateThrowEvent_Send_New_Invoice",
      "to": "IntermediateCatchEvent_Receive_New_Invoice",
      "name": "New Invoice Email"
    }
  ]
