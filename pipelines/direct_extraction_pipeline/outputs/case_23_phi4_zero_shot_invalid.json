    },
    {
      "id": "SequenceFlow_6",
      "from": "Task_Review_Invoice",
      "to": "ExclusiveGateway_Check_Mistake"
    },
    {
      "id": "SequenceFlow_7",
      "from": "ExclusiveGateway_Check_Mistake",
      "to": "Task_Write_Explanation_Email",
      "condition": "no mistake"
    },
    {
      "id": "SequenceFlow_8",
      "from": "Task_Write_Explanation_Email",
      "to": "IntermediateThrowEvent_Send_Explanation"
    },
    {
      "id": "SequenceFlow_9",
      "from": "IntermediateCatchEvent_Receive_Explanation",
      "to": "EndEvent_Client"
    },
    {
      "id": "SequenceFlow_10",
      "from": "ExclusiveGateway_Check_Mistake",
      "to": "Task_Create_Ticket",
      "condition": "mistake found"
    },
    {
      "id": "SequenceFlow_11",
      "from": "Task_Create_Ticket",
      "to": "Task_Assign_Ticket"
    },
    {
      "id": "SequenceFlow_12",
      "from": "Task_Assign_Ticket",
      "to": "Task_Investigate_Invoicing_Mistake"
    },
    {
      "id": "SequenceFlow_13",
      "from": "Task_Investigate_Invoicing_Mistake",
      "to": "Task_Make_Correction"
    },
    {
      "id": "SequenceFlow_14",
      "from": "Task_Make_Correction",
      "to": "Task_Generate_New_Invoice"
    },
    {
      "id": "SequenceFlow_15",
      "from": "Task_Generate_New_Invoice",
      "to": "IntermediateThrowEvent_Send_New_Invoice"
    },
    {
      "id": "SequenceFlow_16",
      "from": "IntermediateCatchEvent_Receive_New_Invoice",
      "to": "EndEvent_Client"
    }
  ],
  "message_flows": [
    {
      "id": "MessageFlow_1",
      "from": "IntermediateThrowEvent_Send_Complaint",
