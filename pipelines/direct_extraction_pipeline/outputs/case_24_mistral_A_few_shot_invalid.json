  "gateways": [
    {
      "id": "gateway_documentation_split",
      "name": "Documentation Completeness?",
      "type": "exclusiveGateway",
      "lane": "grants_administrator",
      "gatewayDirection": "diverging"
    },
    {
      "id": "gateway_documentation_join",
      "name": "Reviews Initiated",
      "type": "exclusiveGateway",
      "lane": "grants_administrator",
      "gatewayDirection": "converging"
    },
    {
      "id": "gateway_verdicts_split",
      "name": "Verdicts?",
      "type": "parallelGateway",
      "lane": "grants_administrator",
      "gatewayDirection": "diverging"
    },
    {
      "id": "gateway_verdicts_join",
      "name": "Approval/Rejection",
      "type": "parallelGateway",
      "lane": "grants_administrator",
      "gatewayDirection": "converging"
    }
  ],
  "sequence_flows": [
    {
      "id": "sf1",
      "from": "start_grants_office",
      "to": "submit_application"
    },
    {
      "id": "sf2",
      "from": "submit_application",
      "to": "register_application"
    },
    {
      "id": "sf3",
      "from": "register_application",
      "to": "check_documentation"
    },
    {
      "id": "sf4",
      "from": "check_documentation",
      "to": "gateway_documentation_split"
    },
    {
      "id": "sf5",
      "from": "gateway_documentation_split",
      "to": "notify_missing_documents",
      "condition": "documentation is incomplete"
    },
    {
      "id": "sf6",
      "from": "gateway_documentation_split",
      "to": "recheck_documentation",
      "condition": "documentation is complete"
    },
    {
      "id": "sf7",
      "from": "recheck_documentation",
      "to": "forward_application"
    },
    {
      "id": "sf8",
      "from": "forward_application",
      "to": "gateway_verdicts_split"
    },
    {
      "id": "sf9",
      "from": "gateway_verdicts_split",
      "to": "technical_review",
      "condition": "technical review panel"
    },
    {
      "id": "sf10",
      "from": "gateway_verdicts_split",
      "to": "budget_review",
      "condition": "finance department"
    },
    {
      "id": "sf11",
      "from": "technical_review",
      "to": "gateway_verdicts_join"
    },
    {
      "id": "sf12",
      "from": "budget_review",
      "to": "gateway_verdicts_join"
    },
    {
      "id": "sf13",
      "from": "gateway_verdicts_join",
      "to": "review_outcomes"
    },
    {
      "id": "sf14",
      "from": "review_outcomes",
      "to": "end_grants_administrator"
    },
    {
      "id": "sf15",
      "from": "review_outcomes",
      "to": "end_technical_review_panel"
    },
    {
      "id": "sf16",
      "from": "review_outcomes",
      "to": "end_finance_department"
    }
  ],
  "message_flows": [
    {
      "id": "mf1",
      "from": "gateway_documentation_join",
      "to": "gateway_verdicts_split",
      "name": "Application Details"
    }
  ]
}