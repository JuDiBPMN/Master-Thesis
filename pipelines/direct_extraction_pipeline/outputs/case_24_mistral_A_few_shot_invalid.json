  "events": [
    {
      "id": "start_grants_office",
      "name": "Start",
      "type": "startEvent",
      "lane": "grants_office",
      "eventDefinition": "none"
    },
    {
      "id": "end_grants_administrator",
      "name": "End",
      "type": "endEvent",
      "lane": "grants_administrator",
      "eventDefinition": "none"
    },
    {
      "id": "start_applicant",
      "name": "Start",
      "type": "startEvent",
      "lane": "applicant",
      "eventDefinition": "none"
    },
    {
      "id": "end_technical_review_panel",
      "name": "End",
      "type": "endEvent",
      "lane": "technical_review_panel",
