      "to": "Retrieve_Book"
    },
    {
      "id": "Retrieve_Book_to_EndEvent",
      "from": "Retrieve_Book",
      "to": "EndEvent"
    }
  ],
  "message_flows": [
    {
      "id": "Book_Not_Available_to_Catch_Book_Not_Available",
      "from": "Book_Not_Available",
      "to": "Catch_Book_Not_Available",
      "name": "Inform Requester of Unavailability"
