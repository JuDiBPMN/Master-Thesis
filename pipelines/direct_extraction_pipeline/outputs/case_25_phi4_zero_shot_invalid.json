      "from": "ExclusiveGateway",
      "to": "Start_Checkout"
    },
    {
      "id": "Start_Checkout_to_Log_Book",
      "from": "Start_Checkout",
      "to": "Log_Book"
    },
    {
      "id": "Log_Book_to_Retrieve_Book",
