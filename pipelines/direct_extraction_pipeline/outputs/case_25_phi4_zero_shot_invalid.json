      "type": "exclusiveGateway",
      "lane": "Library_Staff",
      "gatewayDirection": "diverging"
    }
  ],
  "sequence_flows": [
    {
      "id": "Start_to_Check_Catalog",
      "from": "StartEvent",
      "to": "Check_Catalog"
    },
    {
      "id": "Check_Catalog_to_ExclusiveGateway",
      "from": "Check_Catalog",
