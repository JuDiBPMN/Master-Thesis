      "name": "Check Documents",
      "type": "userTask",
      "lane": "GrantsAdmin"
    },
    {
      "id": "NotifyMissingDocs",
      "name": "Notify Missing Documents",
      "type": "userTask",
      "lane": "GrantsAdmin"
    },
    {
      "id": "CollectMissingDocs",
      "name": "Collect Missing Documents",
      "type": "userTask",
      "lane": "ApplicantDept"
    },
    {
      "id": "ResubmitDocs",
      "name": "Resubmit Documents",
      "type": "userTask",
      "lane": "ApplicantDept"
    },
    {
      "id": "CheckCompleteness",
      "name": "Check Completeness Again",
      "type": "userTask",
      "lane": "GrantsAdmin"
    },
    {
      "id": "AssessFeasibility",
      "name": "Assess Project Feasibility",
      "type": "userTask",
      "lane": "TechnicalReview"
    },
    {
      "id": "ReviewBudget",
      "name": "Review Proposed Budget",
      "type": "userTask",
      "lane": "FinanceDept"
    },
    {
      "id": "ReviewOutcomes",
      "name": "Review Combined Outcomes",
      "type": "userTask",
      "lane": "GrantsAdmin"
    },
    {
      "id": "SendRejection",
      "name": "Send Rejection Notice",
      "type": "userTask",
      "lane": "GrantsAdmin"
    },
    {
      "id": "IssueApproval",
      "name": "Issue Grant Approval Letter",
      "type": "userTask",
      "lane": "GrantsAdmin"
    }
