      "name": "Technical Review Panel",
      "pool": "GovernmentAgency"
    },
    {
      "id": "FinanceDept",
      "name": "Finance Department",
      "pool": "GovernmentAgency"
    },
    {
      "id": "ApplicantDept",
      "name": "Applicant Department",
