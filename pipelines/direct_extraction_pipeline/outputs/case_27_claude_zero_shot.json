{
  "pools": [
    { "id": "pool_bank", "name": "Bank" }
  ],
  "lanes": [
    { "id": "lane_bank", "name": "Mortgage Department", "pool": "pool_bank" }
  ],
  "tasks": [
    { "id": "task_create_file",           "name": "Create mortgage file",              "type": "userTask",    "lane": "lane_bank" },
    { "id": "task_evaluate_stability",    "name": "Evaluate financial stability",      "type": "userTask",    "lane": "lane_bank" },
    { "id": "task_gather_income",         "name": "Gather income statements",          "type": "userTask",    "lane": "lane_bank" },
    { "id": "task_check_credit",          "name": "Check other credit applications",   "type": "userTask",    "lane": "lane_bank" },
    { "id": "task_risk_analysis",         "name": "Perform in-depth risk analysis",    "type": "userTask",    "lane": "lane_bank" },
    { "id": "task_grant_credit",          "name": "Grant line of credit",              "type": "userTask",    "lane": "lane_bank" },
    { "id": "task_decline_application",   "name": "Decline mortgage application",      "type": "userTask",    "lane": "lane_bank" }
  ],
  "events": [
    { "id": "start_bank",                 "name": "Mortgage application received",     "type": "startEvent",  "lane": "lane_bank", "eventDefinition": "none" },
    { "id": "end_bank_approved",          "name": "End – credit granted",              "type": "endEvent",    "lane": "lane_bank", "eventDefinition": "none" },
    { "id": "end_bank_declined",          "name": "End – application declined",        "type": "endEvent",    "lane": "lane_bank", "eventDefinition": "none" }
  ],
  "gateways": [
    { "id": "gw_parallel_split",          "name": "Begin concurrent evaluations",      "type": "parallelGateway",  "lane": "lane_bank", "gatewayDirection": "diverging" },
    { "id": "gw_parallel_join",           "name": "All evaluations complete",          "type": "parallelGateway",  "lane": "lane_bank", "gatewayDirection": "converging" },
    { "id": "gw_assessment_split",        "name": "Assessment outcome?",               "type": "exclusiveGateway", "lane": "lane_bank", "gatewayDirection": "diverging" }
  ],
  "sequence_flows": [
    { "id": "sf01", "from": "start_bank",               "to": "task_create_file" },
    { "id": "sf02", "from": "task_create_file",         "to": "gw_parallel_split" },
    { "id": "sf03", "from": "gw_parallel_split",        "to": "task_evaluate_stability" },
    { "id": "sf04", "from": "gw_parallel_split",        "to": "task_gather_income" },
    { "id": "sf05", "from": "gw_parallel_split",        "to": "task_check_credit" },
    { "id": "sf06", "from": "task_evaluate_stability",  "to": "gw_parallel_join" },
    { "id": "sf07", "from": "task_gather_income",       "to": "gw_parallel_join" },
    { "id": "sf08", "from": "task_check_credit",        "to": "gw_parallel_join" },
    { "id": "sf09", "from": "gw_parallel_join",         "to": "task_risk_analysis" },
    { "id": "sf10", "from": "task_risk_analysis",       "to": "gw_assessment_split" },
    { "id": "sf11", "from": "gw_assessment_split",      "to": "task_grant_credit",        "condition": "Assessment positive" },
    { "id": "sf12", "from": "task_grant_credit",        "to": "end_bank_approved" },
    { "id": "sf13", "from": "gw_assessment_split",      "to": "task_decline_application", "condition": "Assessment negative" },
    { "id": "sf14", "from": "task_decline_application", "to": "end_bank_declined" }
  ],
  "message_flows": []
}