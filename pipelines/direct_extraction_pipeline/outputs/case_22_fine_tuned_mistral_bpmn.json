    },
    {
      "from": "gateway_documentation_split",
      "to": "gateway_parallel_split",
      "condition": "Documents complete"
    },
    {
      "from": "notify_missing_documents",
      "to": "gateway_documentation_split"
    },
    {
      "from": "collect_missing_documents",
      "to": "gateway_documentation_split"
    },
    {
      "from": "gateway_parallel_split",
