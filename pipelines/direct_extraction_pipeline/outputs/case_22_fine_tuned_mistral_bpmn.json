    },
    {
      "from": "gateway_parallel_split",
      "to": "prepare_workspace"
    },
    {
      "from": "set_up_system_access",
      "to": "record_system_access_completion"
    },
    {
      "from": "prepare_workspace",
      "to": "record_workspace_completion"
    },
    {
      "from": "record_system_access_completion",
