  "gateways": [
    {
      "id": "split_information",
      "name": "Information Complete?",
      "type": "exclusiveGateway",
      "lane": "customer_service",
      "gatewayDirection": "diverging"
    },
    {
      "id": "split_parallel",
      "name": "Forward for Review",
      "type": "parallelGateway",
      "lane": "customer_service",
      "gatewayDirection": "diverging"
    },
    {
      "id": "join_parallel",
      "name": "Both Verdicts Recorded",
      "type": "parallelGateway",
      "lane": "customer_service",
      "gatewayDirection": "converging"
    },
    {
      "id": "split_outcome",
      "name": "Both Verdicts Positive?",
      "type": "exclusiveGateway",
      "lane": "customer_service",
      "gatewayDirection": "diverging"
    }
  ],
  "sequence_flows": [
    {
      "id": "sf1",
      "from": "start_customer",
      "to": "submit_return_request"
    },
    {
      "id": "sf2",
      "from": "start_retailer",
      "to": "register_return_request"
    },
    {
      "id": "sf3",
      "from": "register_return_request",
      "to": "check_information"
    },
    {
      "id": "sf4",
      "from": "check_information",
      "to": "split_information"
    },
    {
      "id": "sf5",
      "from": "split_information",
      "to": "notify_incomplete",
      "condition": "Incomplete"
    },
    {
      "id": "sf6",
      "from": "split_information",
      "to": "split_parallel",
      "condition": "Complete"
    },
    {
      "id": "sf7",
      "from": "notify_incomplete",
      "to": "end_retailer_incomplete"
    },
    {
      "id": "sf8",
      "from": "split_parallel",
      "to": "inspect_product"
    },
    {
      "id": "sf9",
      "from": "split_parallel",
      "to": "check_payment_eligibility"
    },
    {
      "id": "sf10",
      "from": "inspect_product",
      "to": "record_warehouse_verdict"
    },
    {
      "id": "sf11",
      "from": "record_warehouse_verdict",
      "to": "join_parallel"
    },
    {
      "id": "sf12",
      "from": "check_payment_eligibility",
      "to": "record_finance_verdict"
    },
    {
      "id": "sf13",
      "from": "record_finance_verdict",
      "to": "join_parallel"
    },
    {
      "id": "sf14",
      "from": "join_parallel",
      "to": "review_outcomes"
    },
    {
      "id": "sf15",
      "from": "review_outcomes",
      "to": "split_outcome"
    },
    {
      "id": "sf16",
      "from": "split_outcome",
      "to": "send_rejection_notice",
      "condition": "One or more verdicts negative"
    },
    {
      "id": "sf17",
      "from": "split_outcome",
      "to": "approve_return",
      "condition": "Both verdicts positive"
    },
    {
      "id": "sf18",
      "from": "approve_return",
      "to": "process_refund"
    },
    {
      "id": "sf19",
      "from": "process_refund",
      "to": "send_refund_confirmation"
    },
    {
      "id": "sf20",
      "from": "send_rejection_notice",
      "to": "end_retailer_rejected"
    },
    {
      "id": "sf21",
      "from": "send_refund_confirmation",
      "to": "end_retailer_refunded"
    },
    {
      "id": "sf22",
      "from": "end_retailer_rejected",
      "to": "end_customer_rejected"
    },
    {
      "id": "sf23",
      "from": "end_retailer_refunded",
      "to": "end_customer_refunded"
    }
