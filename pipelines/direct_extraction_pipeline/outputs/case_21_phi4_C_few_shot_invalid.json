      "lane": "customer",
      "eventDefinition": "none"
    },
    {
      "id": "end_customer_incomplete",
      "name": "Incomplete Information",
      "type": "endEvent",
      "lane": "customer",
      "eventDefinition": "none"
    },
    {
      "id": "end_customer_rejected",
      "name": "Return Rejected",
      "type": "endEvent",
      "lane": "customer",
      "eventDefinition": "none"
    },
    {
      "id": "end_customer_refunded",
