{
  "pools": [
    {
      "id": "customer",
      "name": "Customer"
    },
    {
      "id": "retailer",
      "name": "Retailer"
    }
  ],
  "lanes": [
    {
      "id": "customer_service",
      "name": "Customer Service",
      "pool": "retailer"
    },
    {
      "id": "customer",
      "name": "Customer",
      "pool": "customer"
    }
  ],
  "tasks": [
    {
      "id": "submit_return_request",
      "name": "Submit Return Request",
      "type": "task",
      "lane": "customer"
    },
    {
      "id": "register_return_request",
      "name": "Register Return Request",
      "type": "task",
      "lane": "customer_service"
    },
    {
      "id": "check_completeness",
      "name": "Check Request Completeness",
      "type": "task",
      "lane": "customer_service"
    },
    {
      "id": "notify_customer",
      "name": "Notify Customer of Missing Info",
      "type": "task",
      "lane": "customer_service"
    },
    {
      "id": "review_outcomes",
      "name": "Review Combined Verdicts",
      "type": "task",
      "lane": "customer_service"
    },
    {
      "id": "send_rejection_notice",
      "name": "Send Return Rejection Notice",
      "type": "task",
      "lane": "customer_service"
    },
    {
      "id": "approve_return",
      "name": "Approve Return",
      "type": "task",
      "lane": "customer_service"
    },
    {
      "id": "process_refund",
      "name": "Process Refund",
      "type": "task",
      "lane": "customer_service"
    },
    {
      "id": "inspect_product",
      "name": "Inspect Product",
      "type": "task",
      "lane": "warehouse"
    },
    {
      "id": "record_verdict",
      "name": "Record Inspection Verdict",
      "type": "task",
      "lane": "warehouse"
    }
  ],
  "events": [
    {
      "id": "start_customer",
      "name": "Start",
      "type": "startEvent",
      "lane": "customer",
      "eventDefinition": "none"
    },
    {
      "id": "end_customer",
      "name": "End",
      "type": "endEvent",
      "lane": "customer",
      "eventDefinition": "none"
    },
    {
      "id": "start_retailer",
      "name": "Return Request Received",
      "type": "startEvent",
      "lane": "customer_service",
      "eventDefinition": "message"
    },
    {
      "id": "end_incomplete",
      "name": "Customer Notified",
      "type": "endEvent",
      "lane": "customer_service",
      "eventDefinition": "none"
    },
    {
      "id": "end_rejected",
      "name": "Return Rejected",
      "type": "endEvent",
      "lane": "customer",
      "eventDefinition": "none"
    },
    {
      "id": "end_approved",
      "name": "Return Approved",
      "type": "endEvent",
      "lane": "customer",
      "eventDefinition": "none"
    }
  ],
  "gateways": [
    {
      "id": "split_complete",
      "name": "Request Complete?",
      "type": "exclusiveGateway",
      "lane": "customer_service",
      "gatewayDirection": "diverging"
    },
    {
      "id": "split_parallel",
      "name": "Forward for Inspection and Check",
      "type": "parallelGateway",
      "lane": "customer_service",
      "gatewayDirection": "diverging"
    },
    {
      "id": "join_parallel",
      "name": "Both Verdicts Recorded",
      "type": "parallelGateway",
      "lane": "customer_service",
      "gatewayDirection": "converging"
    },
    {
      "id": "split_outcome",
      "name": "Both Verdicts Positive?",
      "type": "exclusiveGateway",
      "lane": "customer_service",
      "gatewayDirection": "diverging"
    }
  ],
  "sequence_flows": [
    {
      "id": "sf1",
      "from": "start_customer",
      "to": "submit_return_request"
    },
    {
      "id": "sf2",
      "from": "start_retailer",
      "to": "register_return_request"
    },
    {
      "id": "sf3",
      "from": "register_return_request",
      "to": "check_completeness"
    },
    {
      "id": "sf4",
      "from": "check_completeness",
      "to": "split_complete"
    },
    {
      "id": "sf5",
      "from": "split_complete",
      "to": "notify_customer",
      "condition": "Incomplete"
    },
    {
      "id": "sf6",
      "from": "split_complete",
      "to": "split_parallel",
      "condition": "Complete"
    },
    {
      "id": "sf7",
      "from": "notify_customer",
      "to": "end_incomplete"
    },
    {
      "id": "sf8",
      "from": "split_parallel",
      "to": "inspect_product"
    },
    {
      "id": "sf9",
      "from": "split_parallel",
      "to": "record_verdict"
    },
    {
      "id": "sf10",
      "from": "inspect_product",
      "to": "join_parallel"
    },
    {
      "id": "sf11",
      "from": "record_verdict",
      "to": "join_parallel"
    },
    {
      "id": "sf12",
      "from": "join_parallel",
      "to": "review_outcomes"
    },
    {
      "id": "sf13",
      "from": "review_outcomes",
      "to": "split_outcome"
    },
    {
      "id": "sf14",
      "from": "split_outcome",
      "to": "send_rejection_notice",
      "condition": "One or more verdicts negative"
    },
    {
      "id": "sf15",
      "from": "split_outcome",
      "to": "approve_return",
      "condition": "Both verdicts positive"
    },
    {
      "id": "sf16",
      "from": "approve_return",
      "to": "process_refund"
    },
    {
      "id": "sf17",
      "from": "process_refund",
      "to": "end_approved"
    },
    {
      "id": "sf18",
      "from": "send_rejection_notice",
      "to": "end_rejected"
    }
  ],
  "message_flows": [
    {
      "id": "mf1",
      "from": "submit_return_request",
      "to": "start_retailer",
      "name": "Return Request"
    },
    {
      "id": "mf2",
      "from": "review_outcomes",
      "to": "end_customer",
      "name": "Refund Confirmation"
    }
  ]
}